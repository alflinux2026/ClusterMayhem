   243	def _read_jsonl(path: str) -> list[dict]:
   244	    """Carga eventos de un archivo JSONL."""
   245	    if not os.path.exists(path):
   246	        return []
   247	    out: list[dict] = []
   248	    with open(path, "r", encoding="utf-8") as f:
   249	        for line in f:
   250	            line = line.strip()
   251	            if not line:
   252	                continue
   253	            try:
   254	                out.append(json.loads(line))
   255	            except Exception:
   256	                continue
   257	    return out
   258	
   259	
   260	def _summarize_events(events: list[dict]) -> dict:
   261	    """
   262	    Crea un resúmen de eventos con counts por status.
   263	
   264	    Args:
   265	        events: Lista de eventos (puede tener duplicados por event_id).
   266	
   267	    Returns:
   268	        dict: Resúmen con total_events, counts (created, executing, completed), last_event_id.
   269	    """
   270	    latest_by_event_id: dict[str, dict] = {}
   271	    last_event_id = None
   272	    for event in events:
   273	        event_id = event.get("event_id")
   274	        if not event_id:
   275	            continue
   276	        latest_by_event_id[event_id] = event
   277	        last_event_id = event_id
   278	    counts = Counter()
   279	    for event in latest_by_event_id.values():
   280	        status = str(event.get("status", "unknown")).lower()
   281	        counts[status] += 1
   282	    return {
   283	        "total_events": len(latest_by_event_id),
   284	        "counts": {
   285	            "created": counts.get("created", 0),
   286	            "executing": counts.get("executing", 0),
   287	            "completed": counts.get("completed", 0),
   288	            "unknown": counts.get("unknown", 0),
   289	        },
   290	        "last_event_id": last_event_id,
   291	    }
   292	
   293	
   294	def _next_rotation_index(base_dir, stem, suffix=".jsonl"):
   295	    """Encuentra el próximo índice disponible para rotación de archivos."""
   296	    base_dir = Path(base_dir)
   297	    idx = 1
   298	    while True:
   299	        candidate = base_dir / f"{stem}.{idx:03d}{suffix}"
   300	        if not candidate.exists():
   301	            return idx
   302	        idx += 1
   303	
   304	
   305	def rotate_segment_files(target_group: str, segment: str = "000", files=None, force: bool = False):
   306	    """Rota archivos de segmento (renombra .local.000.jsonl a .{target_group}.001.jsonl)."""
   307	    files = files or ["events", "event_log"]
   308	    base_dir = Path(get_local_log_path(None)).resolve().parent
   309	    result = {}
   310	
   311	    for kind in files:
   312	        src = base_dir / f"{kind}.local.{segment}.jsonl"
   313	        if not src.exists():
   314	            if force:
   315	                result[kind] = {"before": str(src), "after": None, "index": None, "forced": True}
   316	                continue
   317	            raise FileNotFoundError(str(src))
   318	
   319	        idx = _next_rotation_index(base_dir, f"{kind}.{target_group}")
   320	        dst = base_dir / f"{kind}.{target_group}.{idx:03d}.jsonl"
   321	        os.replace(str(src), str(dst))
   322	        result[kind] = {"before": str(src), "after": str(dst), "index": idx, "forced": False}
   323	
   324	    return result
   325	
   326	
   327	def cleanup_local_segment_files(target_group: str, segment: str = "000", files=None):
   328	    """Elimina archivos de segmento local después de rotar."""
   329	    files = files or ["events", "event_log"]
   330	    base_dir = Path(get_local_log_path(None)).resolve().parent
   331	    removed = []
   332	    already_gone = []
   333	
   334	    for kind in files:
   335	        p = base_dir / f"{kind}.local.{segment}.jsonl"
   336	        if p.exists():
   337	            p.unlink()
   338	            removed.append(str(p))
   339	        else:
   340	            already_gone.append(str(p))
   341	
   342	    return {"target_group": target_group, "segment": segment, "removed": removed, "already_gone": already_gone}
