   136	def _round_or_none(value: float | None, digits: int = 1) -> float | None:
   137	    """Redondea un valor o retorna None si es None/inválido."""
   138	    if value is None:
   139	        return None
   140	    try:
   141	        return round(float(value), digits)
   142	    except Exception:
   143	        return None
   144	
   145	
   146	def _watchdog_age_s(node: dict, now: float | None = None) -> float | None:
   147	    """Calcula cuántos segundos desde el último watchdog."""
   148	    now = now or time.time()
   149	    last_watchdog = node.get("last_watchdog")
   150	    if last_watchdog is None:
   151	        return None
   152	    try:
   153	        return max(0.0, now - float(last_watchdog))
   154	    except Exception:
   155	        return None
   156	
   157	
   158	def _state_age_s(node: dict, now: float | None = None) -> float | None:
   159	    """Calcula cuántos segundos desde que se entró al estado actual."""
   160	    now = now or time.time()
   161	    state_since = node.get("state_since")
   162	    if state_since is None:
   163	        return None
   164	    try:
   165	        return max(0.0, now - float(state_since))
   166	    except Exception:
   167	        return None
   168	
   169	
   170	def _seen_age_s(node: dict, now: float | None = None) -> float | None:
   171	    """Calcula cuántos segundos desde el último last_seen."""
   172	    now = now or time.time()
   173	    last_seen = node.get("last_seen")
   174	    if last_seen is None:
   175	        return None
   176	    try:
   177	        return max(0.0, now - float(last_seen))
   178	    except Exception:
   179	        return None
   180	
   181	
   182	def _presence_age_s(node: dict, now: float | None = None) -> float | None:
   183	    """Calcula cuántos segundos desde la última actividad (last_seen o last_watchdog)."""
   184	    now = now or time.time()
   185	    last_seen = node.get("last_seen")
   186	    last_watchdog = node.get("last_watchdog")
   187	    candidates = []
   188	    for value in (last_seen, last_watchdog):
   189	        if value is None:
   190	            continue
   191	        try:
   192	            candidates.append(float(value))
   193	        except Exception:
   194	            continue
   195	    if not candidates:
   196	        return None
   197	    return max(0.0, now - max(candidates))
   198	
   199	
   200	def _presence_health(node: dict, now: float | None = None, stale_after_s: float = 3.0) -> str:
   201	    """
   202	    Calcula la salud de presencia del nodo.
   203	
   204	    Returns:
   205	        str: "ok" si actividad reciente (< stale_after_s), "stale" si no.
   206	    """
   207	    age = _presence_age_s(node, now)
   208	    if age is None:
   209	        return "stale"
   210	    return "ok" if age < stale_after_s else "stale"
   211	
