   459	@app.post("/segment/rotate")
   460	def segment_rotate(req: SegmentRotateRequest):
   461	    """
   462	    Rota archivos de segmento.
   463	
   464	    Si el nodo está en ISOLATED, retorna error.
   465	    Si falla, retorna error con message.
   466	    """
   467	    if ctx.node.state == NodeState.ISOLATED:
   468	        return {
   469	            "request_id": req.request_id,
   470	            "node_id": ctx.node_id,
   471	            "source_node": req.source_node,
   472	            "target_group": req.target_group,
   473	            "segment": req.segment,
   474	            "rotated": False,
   475	            "files": {},
   476	            "error": "node isolated",
   477	            "ts": time.time(),
   478	        }
   479	    try:
   480	        result = rotate_segment_files(
   481	            target_group=req.target_group,
   482	            segment=req.segment,
   483	            files=req.files,
   484	            force=req.force,
   485	        )
   486	        return {
   487	            "request_id": req.request_id,
   488	            "node_id": ctx.node_id,
   489	            "source_node": req.source_node,
   490	            "target_group": req.target_group,
   491	            "segment": req.segment,
   492	            "rotated": True,
   493	            "files": result,
   494	            "error": None,
   495	            "ts": time.time(),
   496	        }
   497	    except Exception as e:
   498	        return {
   499	            "request_id": req.request_id,
   500	            "node_id": ctx.node_id,
   501	            "source_node": req.source_node,
   502	            "target_group": req.target_group,
   503	            "segment": req.segment,
   504	            "rotated": False,
   505	            "files": {},
   506	            "error": str(e),
   507	            "ts": time.time(),
   508	        }
