   649	
   650	@app.post("/watchdog")
   651	def watchdog(wd: Watchdog):
   652	    """
   653	    Recibe un watchdog de un peer.
   654	
   655	    Actualiza cluster_state con last_watchdog y watchdog_busy.
   656	    """
   657	    if ctx.node.state == NodeState.ISOLATED:
   658	        return {"error": "node isolated"}
   659	    existing = cluster_state.get(wd.node_id, {})
   660	    ts = wd.emitted_at if wd.emitted_at is not None else time.time()
   661	    cluster_state[wd.node_id] = {**existing, "last_watchdog": ts, "watchdog_busy": bool(wd.busy)}
   662	    return {"ok": True, "node_id": wd.node_id, "last_watchdog": ts, "watchdog_busy": bool(wd.busy)}
   663	
   664	
   665	@app.post("/heartbeat")
   666	def heartbeat(hb: Heartbeat):
   667	    """
   668	    Recibe un heartbeat de un peer.
   669	
   670	    Actualiza cluster_state con state, priority, last_seen, state_since, etc.
   671	    """
   672	    if ctx.node.state == NodeState.ISOLATED:
   673	        return {"error": "node isolated"}
   674	    existing = cluster_state.get(hb.node_id, {})
   675	    cluster_state[hb.node_id] = {
   676	        **existing,
   677	        "state": hb.state,
   678	        "priority": hb.priority,
   679	        "last_seen": time.time(),
   680	        "state_since": hb.state_since if hb.state_since is not None else existing.get("state_since"),
   681	        "prev_state": hb.prev_state if hb.prev_state is not None else existing.get("prev_state"),
   682	        "state_reason": hb.state_reason if hb.state_reason is not None else existing.get("state_reason"),
   683	        "log_meta": hb.log_meta or existing.get("log_meta", {}),
   684	        "cluster_integrity": hb.cluster_integrity or existing.get("cluster_integrity", {}),
   685	        "streams": hb.streams or existing.get("streams", {}),
   686	    }
   687	    return {"ok": True}
   688	
   689	
   690	@app.get("/dashboard/compact")
   691	def dashboard_compact():
   692	    """
   693	    Dashboard compacto del cluster.
   694	
   695	    Devuelve info completa de todos los nodos: state, ages, health, events counters,
   696	    progress, integrity, etc. Para monitoring y debugging.
   697	    """
   698	    now = time.time()
   699	    leader = compute_leader()
   700	    local_events = events_summary()
   701	    integrity = local_integrity_api()
   702	    local_node = cluster_state.get(ctx.node_id, {}) or {}
   703	
   704	    try:
   705	        from cluster.runtime.progress_watchdog import (
   706	            get_progress_age_s,
   707	            get_progress_duration_s,
   708	            get_progress_pct,
   709	            refresh_progress_stalled_flag,
   710	        )
   711	    except Exception:
   712	        get_progress_age_s = None
   713	        get_progress_duration_s = None
   714	        get_progress_pct = None
   715	        refresh_progress_stalled_flag = None
   716	
   717	    nodes = []
   718	    for node_id, node in sorted(cluster_state.items(), key=lambda kv: str(kv[0])):
   719	        log_meta = node.get("log_meta", {}) or {}
   720	        counts = (((node.get("streams") or {}).get("events_summary_local") or {}).get("counts") or {})
   721	        progress_age_s = None
   722	        progress_duration_s = None
   723	        progress_pct = None
   724	        progress_stalled = bool(node.get("progress_stalled", False))
   725	
   726	        if refresh_progress_stalled_flag is not None:
   727	            try:
   728	                progress_stalled = bool(refresh_progress_stalled_flag(node_id=node_id, now=now))
   729	                node = cluster_state.get(node_id, node) or node
   730	            except Exception:
   731	                progress_stalled = bool(node.get("progress_stalled", False))
   732	
   733	        if get_progress_age_s is not None:
   734	            try:
   735	                progress_age_s = get_progress_age_s(node=node, now=now)
   736	            except Exception:
   737	                progress_age_s = None
   738	
   739	        if get_progress_duration_s is not None:
   740	            try:
   741	                progress_duration_s = get_progress_duration_s(node=node, now=now)
   742	            except Exception:
   743	                progress_duration_s = None
   744	
   745	        if get_progress_pct is not None:
   746	            try:
   747	                progress_pct = get_progress_pct(node=node)
   748	            except Exception:
   749	                progress_pct = None
   750	        else:
   751	            try:
   752	                current = node.get("progress_current")
   753	                total = node.get("progress_total")
   754	                if current is not None and total not in (None, 0):
   755	                    progress_pct = round((float(current) / float(total)) * 100.0, 1)
   756	            except Exception:
   757	                progress_pct = None
   758	
   759	        item = {
   760	            "node_id": node_id,
   761	            "state": node.get("state"),
   762	            "state_since": node.get("state_since"),
   763	            "state_age_s": round(_state_age_s(node, now) or 0.0, 1),
   764	            "prev_state": node.get("prev_state"),
   765	            "state_reason": node.get("state_reason"),
   766	            "priority": node.get("priority"),
   767	            "last_seen": node.get("last_seen"),
   768	            "seen_age_s": round(_seen_age_s(node, now) or 0.0, 1),
   769	            "last_watchdog": node.get("last_watchdog"),
   770	            "watchdog_age_s": round(_watchdog_age_s(node, now) or 0.0, 1) if node.get("last_watchdog") is not None else None,
   771	            "watchdog_busy": node.get("watchdog_busy"),
   772	            "presence_age_s": round(_presence_age_s(node, now) or 0.0, 1),
   773	            "health": _presence_health(node, now, stale_after_s=3.0),
   774	            "local_size": log_meta.get("size", 0),
   775	            "local_events": ((node.get("streams") or {}).get("events_summary_local") or {}).get("total_events", 0),
   776	            "created": counts.get("created", 0),

