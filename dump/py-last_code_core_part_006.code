     9	#
    10	# Purpose:
    11	#   Registro centralizado de nodos del cluster.
    12	#   Mantiene un diccionario global con la información de todos los nodos
    13	#   (host, port, priority) para permitir el enrutado de eventos y la
    14	#   comunicación entre nodos.
    15	# Notes:
    16	#   - Este registro se inicializa durante el bootstrap con los nodos configurados
    17	#   - Se usa en event_router.py para enrutar eventos al líder
    18	#   - En un cluster dinámico, podría ampliarse con registro/descubrimiento automático
    19	#   - No hay limpieza de nodos caídos (se asume estático o gestionado externamente)
    20	#
    21	# FRV-ID: 534531c72532d0c5
    22	# Header_End
    23	
    24	# =============================================================================
    25	# Registro global de nodos del cluster
    26	# =============================================================================
    27	
    28	#: Diccionario global que mapea node_id -> información del nodo
    29	#: Cada entry contiene: host, port, priority
    30	#: Tipo: dict[str, dict[str, str | int]]
    31	CLUSTER_REGISTRY = {}
    32	
    33	
    34	def register_node(node_id: str, host: str, port: int, priority: int = 100):
    35	    """
    36	    Registra un nodo en el cluster.
    37	
    38	    Añade o actualiza un nodo en el registry con su información de conexión.
    39	
    40	    Args:
    41	        node_id: ID único del nodo (string).
    42	        host: Hostname o IP del nodo (ej: "100.100.1.200", "localhost").
    43	        port: Puerto del nodo (ej: 8000, 7000).
    44	        priority: Prioridad del nodo para leader election (menor = más prioridad).
    45	                  Por defecto: 100.
    46	
    47	    Returns:
    48	        dict: El entry del nodo recién registrado/actualizado.
    49	
    50	    Example:
    51	        >>> register_node("lnx203hp", "100.100.1.200", 8000, priority=10)
    52	        {'host': '100.100.1.200', 'port': 8000, 'priority': 10}
    53	
    54	        >>> register_node("lnx200nas", "100.100.1.201", 8000)
    55	        {'host': '100.100.1.201', 'port': 8000, 'priority': 100}
    56	
    57	    Note:
    58	        - Si el node_id ya existe, se sobrescribe la información
    59	        - El priority se usa en compute_leader() para seleccionar el líder
    60	    """
    61	    CLUSTER_REGISTRY[node_id] = {
    62	        "host": host,
    63	        "port": port,
    64	        "priority": priority,
    65	    }
    66	    return CLUSTER_REGISTRY[node_id]
    67	
    68	
    69	def get_node(node_id: str):
    70	    """
    71	    Obtiene la información de un nodo del registry.
    72	
    73	    Args:
    74	        node_id: ID del nodo a buscar.
    75	
    76	    Returns:
    77	        dict | None: El dict del nodo si existe, None si no está registrado.
    78	
    79	    Example:
    80	        >>> get_node("lnx203hp")
    81	        {'host': '100.100.1.200', 'port': 8000, 'priority': 10}
    82	
    83	        >>> get_node("nodonotexist")
    84	        None
    85	
    86	    Note:
    87	        - Se usa en event_router.py para obtener host/port del líder
    88	        - Retorna None si el nodo no está en el registry (no levanta exception)
    89	    """
    90	    return CLUSTER_REGISTRY.get(node_id)


