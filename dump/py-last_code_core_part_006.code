    16	
    17	from datetime import datetime
    18	
    19	modeGhost = False
    20	
    21	def log_state(color, typ, msg, decimals=0):
    22	
    23	    if modeGhost:
    24	        return
    25	
    26	    colors = {
    27	        "red": "\033[91m",
    28	        "green": "\033[92m",
    29	        "yellow": "\033[93m",
    30	        "blue": "\033[94m",
    31	        "magenta": "\033[95m",
    32	        "cyan": "\033[96m",
    33	        "white": "\033[97m",
    34	        "reset": "\033[0m",
    35	    }
    36	
    37	    c = colors.get(color.lower(), colors["white"])
    38	    reset = colors["reset"]
    39	
    40	    decimals = max(0, min(6, int(decimals)))
    41	
    42	    # -----------------------------------------
    43	    # fixed-width timestamp
    44	    # -----------------------------------------
    45	
    46	    now = datetime.now()
    47	
    48	    if decimals == 0:
    49	
    50	        # reserva espacio para ".000"
    51	        ts = now.strftime("%H:%M:%S") + "    "
    52	
    53	    else:
    54	
    55	        micros = f"{now.microsecond:06d}"[:decimals]
    56	        ts = f"{now.strftime('%H:%M:%S')}.{micros}"
    57	
    58	        # padding fijo hasta longitud 12
    59	        ts = f"{ts:<12}"
    60	
    61	    # -----------------------------------------
    62	    # aligned tag
    63	    # -----------------------------------------
    64	
    65	    tag = f"{typ:>14}"
    66	
    67	    # -----------------------------------------
    68	    # print
    69	    # -----------------------------------------
    70	
    71	    print(f"[{ts}] {c}{tag}{reset} {msg}")
    72	
    73	

