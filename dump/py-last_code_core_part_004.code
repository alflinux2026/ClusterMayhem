     9	#
    10	# Purpose:
    11	#   Leader election para el cluster.
    12	#   Implementa un algoritmo simple de leader election basado en priority:
    13	#   el nodo con menor priority (y node_id alfabético como tie-breaker) se convierte
    14	#   en líder. Los nodos deben estar "vivos" (heartbeat reciente) para ser considerados.
    15	#   El líder es el único que procesa eventos; los nodos standby reenvían eventos al líder.
    16	# Notes:
    17	#   - Algoritmo: menor priority gana, tie-breaker es node_id alfabético
    18	#   - Timeout por defecto: 1.5s (si no hay heartbeat en 1.5s, nodo se considera muerto)
    19	#   - Solo nodos ACTIVE, STANDBY, STAND-BY, DRAINING son candidatos
    20	#   - Se ejecuta en cada tick del worker (cada ~1s), así que la election es rápida
    21	#   - No hay split-brain protection (asume red confiable)
    22	#   - debug_node_id permite forzar un líder para testing
    23	#
    24	# FRV-ID: bc64b1dd697351a2
    25	# Header_End
    26	
    27	import time
    28	
    29	from cluster.runtime.cluster_store import cluster_state
    30	from cluster.runtime import context as ctx
    31	
    32	# =============================================================================
    33	# Configuración de leader election
    34	# =============================================================================
    35	
    36	#: Timeout en segundos para considerar un nodo como vivo
    37	#: Si no hay heartbeat en este tiempo, el nodo se excluye de election
    38	#: Tipo: float
    39	LEADER_ALIVE_TIMEOUT = 1.5
    40	
    41	
    42	def refresh_self_alive_entry(now=None):
    43	    """
    44	    Actualiza la entrada del nodo actual en cluster_state.
    45	
    46	    Sincroniza el estado del nodo local (state, priority, last_seen) con
    47	    cluster_state para que sea visible para la leader election.
    48	
    49	    Args:
    50	        now: Timestamp opcional. Si no se proporciona, usa time.time().
    51	
    52	    Note:
    53	        - Se llama en compute_alive() antes de election para asegurarse
    54	          de que el nodo local está visible
    55	        - Copia state, priority, last_seen, state_since, prev_state, state_reason
    56	        - Si no hay ctx.node, retorna sin hacer nada
    57	
    58	
    59	Example:
    60	        >>> refresh_self_alive_entry()
    61	        # cluster_state["lnx203hp"] = {..., "state": "ACTIVE", "priority": 10, "last_seen": 1779956226}
    62	    """
    63	    now = now or time.time()
    64	    if not getattr(ctx, "node", None):
    65	        return
    66	
    67	    existing = cluster_state.get(ctx.node_id, {})
    68	
    69	    cluster_state[ctx.node_id] = {
    70	        **existing,
    71	        "state": ctx.node.state.value,
    72	        "priority": ctx.node.priority,
    73	        "last_seen": now,
    74	        "state_since": getattr(ctx.node, "state_since", None),
    75	        "prev_state": getattr(ctx.node, "prev_state", None),
    76	        "state_reason": getattr(ctx.node, "state_reason", None),
    77	    }
    78	
    79	
    80	def last_presence_ts(data: dict) -> float:
    81	    """
    82	    Obtiene el último timestamp de presencia de un nodo.
    83	
    84	    Busca el máximo entre last_seen y last_watchdog para determinar
    85	    cuándo fue la última vez que el nodo mostró actividad.
    86	
    87	    Args:
    88	        data: Dict con info del nodo (debe tener last_seen y/o last_watchdog).
    89	
    90	    Returns:
    91	        float: Último timestamp de presencia, o 0.0 si no hay ninguno.
    92	
    93	    Example:
    94	        >>> last_presence_ts({"last_seen": 1779956226.0, "last_watchdog": 1779956220.0})
    95	        1779956226.0
    96	
    97	        >>> last_presence_ts({"last_seen": None})
    98	        0.0
    99	
   100	    Note:
   101	        - Ignora valores None o que no se puedan convertir a float
   102	        - Se usa en is_alive() para determinar si el nodo está vivo
   103	    """
   104	    candidates = []
   105	    for key in ("last_seen", "last_watchdog"):
   106	        value = data.get(key, 0)
   107	        if value is None:
   108	            continue
   109	        try:
   110	            candidates.append(float(value))
   111	        except Exception:
   112	            continue
   113	    return max(candidates) if candidates else 0.0
   114	
   115	
   116	def is_alive(data, timeout=LEADER_ALIVE_TIMEOUT, now=None):
   117	    """
   118	    Comprueba si un nodo está vivo (heartbeat reciente).
   119	
   120	    Args:
   121	        data: Dict con info del nodo (last_seen o last_watchdog).
   122	        timeout: Timeout en segundos para considerar vivo al nodo.
   123	        now: Timestamp opcional. Si no se proporciona, usa time.time().
   124	
   125	    Returns:
   126	        bool: True si el nodo ha tenido actividad en los últimos `timeout` segundos.
   127	
   128	    Example:
   129	        >>> is_alive({"last_seen": 1779956226.0}, timeout=1.5, now=1779956227.0)
   130	        True
   131	
   132	        >>> is_alive({"last_seen": 1779956220.0}, timeout=1.5, now=1779956227.0)
   133	        False
   134	
   135	    Note:
   136	        - Usa last_presence_ts() para obtener el último timestamp
   137	        - Retorna True si (now - last_presence) < timeout
   138	    """
   139	    now = now or time.time()
   140	    last_presence = last_presence_ts(data)
   141	    return (now - last_presence) < timeout
   142	
   143	
   144	def compute_alive(timeout=LEADER_ALIVE_TIMEOUT, include_self=True):
   145	    """
   146	    Calcula qué nodos están vivos y activos en el cluster.
   147	
   148	    Filtra cluster_state para devolver solo nodos que:
   149	        1. Son "vivos" (heartbeat en los últimos `timeout` segundos)
   150	        2. Están en estado ACTIVE, STANDBY, STAND-BY, o DRAINING
   151	
   152	    Args:
   153	        timeout: Timeout para considerar vivo al nodo.
   154	        include_self: Si True, actualiza la entrada del nodo local antes de calcular.
   155	
   156	    Returns:
   157	        dict[str, dict]: Nodos vivos mapeados por node_id con su info completa.
   158	
   159	    Example:
   160	        >>> compute_alive(timeout=1.5)
   161	        {
   162	            "lnx203hp": {"state": "ACTIVE", "priority": 10, "last_seen": 1779956226.0, ...},
   163	            "lnx200nas": {"state": "STANDBY", "priority": 100, "last_seen": 1779956225.5, ...}
   164	        }
   165	
   166	    Note:
   167	        - Llama a refresh_self_alive_entry() si include_self=True para asegurarse
   168	          de que el nodo local está visible
   169	        - Excluye nodos en BOOT, DISCOVERING, SEGMENTATION, ISOLATED, OFFLINE
   170	    """
   171	    now = time.time()
   172	    if include_self:
   173	        refresh_self_alive_entry(now)
   174	
   175	    active_nodes = {}
   176	    for node_id, data in cluster_state.items():
   177	        if not is_alive(data, timeout=timeout, now=now):
   178	            continue
   179	        if data.get("state") not in ("ACTIVE", "STANDBY", "STAND-BY", "DRAINING"):
   180	            continue
   181	        active_nodes[node_id] = data
   182	    return active_nodes
   183	
   184	
   185	def compute_leader(debug_node_id=None, timeout=LEADER_ALIVE_TIMEOUT):
   186	    """
   187	    Calcula cuál es el líder del cluster.
   188	
   189	    El líder es el nodo vivo con menor priority (tie-breaker: node_id alfabético).
   190	
   191	    Args:
   192	        debug_node_id: (Testing) Fuerza este node_id como líder.
   193	        timeout: Timeout para considerar vivo al nodo.
   194	
   195	    Returns:
   196	        str | None: node_id del líder, o None si no hay nodos vivos.
   197	
   198	    Example:
   199	        >>> compute_leader()
   200	        'lnx203hp'
   201	
   202	        >>> compute_leader()  # Si todos los nodos están muertos
   203	        None
   204	
   205	    Note:
   206	        - Algoritmo: min(priority, node_id) en nodos vivos
   207	        - priority menor = más prioritario (el que gana)
   208	        - Tie-breaker: node_id alfabético (lexicográfico)
   209	        - Se llama en cada tick del worker (~1s) para detectar cambios de líder
   210	        - Si no hay líder (todos muertos), dispatch_tick() no procesa eventos
   211	    """
   212	    active_nodes = compute_alive(timeout=timeout, include_self=True)
   213	    if not active_nodes:
   214	        return None
   215	    return min(
   216	        active_nodes.items(),
   217	        key=lambda x: (x[1].get("priority", 9999), x[0]),
   218	    )[0]


