   164	def local_integrity_api() -> dict:
   165	    """
   166	    Verifica la integridad local del cluster.
   167	
   168	    Compara la view del nodo local con la de todos los nodos vivos.
   169	
   170	    Returns:
   171	        dict: Resultado de la verificación:
   172	            - node_id (str): ID del nodo local
   173	            - alive_nodes (list[str]): Nodos vivos
   174	            - self_view (dict): View compacta del nodo local
   175	            - peer_status (dict[str, dict]): Status de cada peer
   176	            - integrity_canonical (dict): View canonicalizada
   177	            - integrity_hash (str): SHA256 de la view canonical
   178	            - integrity_ok (bool): True si todos los peers tienen la misma view
   179	
   180	    Example:
   181	        >>> local_integrity_api()
   182	        {
   183	            'node_id': 'lnx203hp',
   184	            'alive_nodes': ['lnx203hp', 'lnx200nas'],
   185	            'self_view': {'state': 'ACTIVE', 'priority': 10, ...},
   186	            'peer_status': {'lnx203hp': {'view_ok': True}, 'lnx200nas': {'view_ok': True}},
   187	            'integrity_hash': 'abc123...',
   188	            'integrity_ok': True
   189	        }
   190	    """
   191	    alive = compute_alive(include_self=True)
   192	
   193	    canonical = get_integrity_canonical()
   194	    integrity_hash = hashlib.sha256(
   195	        json.dumps(canonical, sort_keys=True).encode("utf-8")
   196	    ).hexdigest()
   197	
   198	    peer_status = {}
   199	    self_view = canonicalize(cluster_state.get(ctx.node_id, {}), IGNORED_NODE_KEYS)
   200	    self_meta = self_view.get("log_meta", {}) if isinstance(self_view, dict) else {}
   201	
   202	    for node_id, data in alive.items():
   203	        view = canonicalize(data, IGNORED_NODE_KEYS)
   204	        meta = view.get("log_meta", {}) if isinstance(view, dict) else {}
   205	        peer_status[node_id] = {
   206	            "view": _compact_view(view),
   207	            "view_ok": view == canonicalize(cluster_state.get(node_id, {}), IGNORED_NODE_KEYS),
   208	        }
   209	
   210	    return {
   211	        "node_id": ctx.node_id,
   212	        "alive_nodes": sorted(alive.keys()),
   213	        "self_view": _compact_view(self_view),
   214	        "peer_status": peer_status,
   215	        "integrity_canonical": canonical,
   216	        "integrity_hash": integrity_hash,
   217	        "integrity_ok": all(v["view_ok"] for v in peer_status.values()),
   218	    }
