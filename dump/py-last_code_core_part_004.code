     9	#
    10	# Purpose:
    11	#   Replicación de logs del cluster entre nodos.
    12	#   Replica el event log local a todos los peers vivos para mantener una copia
    13	#   redundante de los eventos. Se ejecuta en cada tick del worker y solo replica
    14	#   si el log está marcado como "dirty" (modificado). Cada peer recibe el log
    15	#   y lo guarda como replica para poder recover en caso de fallo.
    16	# Notes:
    17	#   - Dos tipos de replicación: event log (eventos activos) y completed log (eventos procesados)
    18	#   - Solo se replica si el nodo está en ACTIVE, STANDBY, o DRAINING
    19	#   - Dirty flag se pone al appendar un evento, se limpia al replicar exitosamente
    20	#   - PEERALIVETTLSEC=3.0s: peer se considera muerto si no hay last_seen en 3s
    21	#   - Se llama en cada tick del worker (~1s) vía replicate_eventlog() y replicate_events()
    22	#   - Falla silenciosamente si un peer no responde (no bloquea el tick)
    23	#
    24	# FRV-ID: 4e48ada454ba3669
    25	# Header_End
    26	
    27	import logging
    28	import time
    29	import requests
    30	
    31	from cluster.runtime import context as ctx
    32	from cluster.runtime.cluster_store import cluster_state
    33	from cluster.runtime.registry import CLUSTER_REGISTRY
    34	from cluster.runtime.event_log import (
    35	    read_local_log_text,
    36	    read_completed_log_text,
    37	    write_replica_log,
    38	    write_replica_events,
    39	    write_completed_log,
    40	    read_state,
    41	    clear_eventlog_dirty_state,
    42	    clear_events_dirty_state,
    43	
    44	)
    45	from cluster.runtime.state import NodeState
    46	from cluster.utils.log_print import log_state
    47	
    48	logging.getLogger("urllib3").setLevel(logging.ERROR)
    49	logging.getLogger("requests").setLevel(logging.ERROR)
    50	
    51	# =============================================================================
    52	# Configuración de replicación
    53	# =============================================================================
    54	
    55	#: TTL en segundos para considerar un peer como vivo
    56	#: Si no hay last_seen en este tiempo, el peer se excluye de replicación
    57	PEERALIVETTLSEC = 3.0
    58	
    59	#: Estados del nodo que permiten replicación
    60	#: Solo ACTIVE, STANDBY, y DRAINING replican (no BOOT, ISOLATED, SEGMENTATION, OFFLINE)
    61	REPLICATION_ALLOWED_STATES = {
    62	    NodeState.ACTIVE.value,
    63	    NodeState.STANDBY.value,
    64	    NodeState.DRAINING.value,
    65	}
    66	
    67	
    68	def canonical_replica_node_id() -> str:
    69	    """
    70	    Devuelve el node_id canonical del nodo local para usar como nombre de replica.
    71	
    72	    Returns:
    73	        str: node_id del nodo local.
    74	
    75	    Example:
    76	        >>> canonical_replica_node_id()
    77	        'lnx203hp'
    78	    """
    79	    return ctx.node_id
    80	
    81	
    82	def alive_peer_ids():
    83	    """
    84	    Devuelve la lista de peers que están vivos (heartbeat reciente).
    85	
    86	    Filtra cluster_state para incluir solo nodos que:
    87	        1. No son el nodo local
    88	        2. Han tenido actividad en los últimos PEERALIVETTLSEC segundos
    89	
    90	    Returns:
    91	        list[str]: node_ids de peers vivos, ordenados alfabéticamente.
    92	
    93	    Example:
    94	        >>> alive_peer_ids()
    95	        ['lnx200nas', 'lnx204hp']
    96	
    97	    Note:
    98	        - Usa last_seen de cluster_state para determinar si está vivo
    99	        - Si un peer no ha hecho heartbeat en 3s, se excluye
   100	    """
   101	    out = []
   102	    now = time.time()
   103	    for node_id, data in cluster_state.items():
   104	        if node_id == ctx.node_id:
   105	            continue
   106	        if now - data.get("last_seen", 0) > PEERALIVETTLSEC:
   107	            continue
   108	        out.append(node_id)
   109	    return sorted(set(out))
   110	
   111	
   112	def configured_peer_ids():
   113	    """
   114	    Devuelve la lista de peers configurados (de ctx.peers y CLUSTER_REGISTRY).
   115	
   116	    Combina:
   117	        1. Peers de ctx.peers (configuración de bootstrap)
   118	        2. Nodos de CLUSTER_REGISTRY (registros estáticos)
   119	
   120	    Returns:
   121	        list[str]: node_ids de peers configurados, ordenados alfabéticamente.
   122	
   123	    Example:
   124	        >>> configured_peer_ids()
   125	        ['lnx200nas', 'lnx204hp']
   126	
   127	    Note:
   128	        - Excluye el nodo local
   129	        - Deduplica con set()
   130	    """
   131	    out = []
   132	
   133	    for peer in getattr(ctx, "peers", []) or []:
   134	        peer_id = peer.get("node_id")
   135	        if peer_id and peer_id != ctx.node_id:
   136	            out.append(peer_id)
   137	
   138	    for node_id in CLUSTER_REGISTRY.keys():
   139	        if node_id != ctx.node_id:
   140	            out.append(node_id)
   141	
   142	    return sorted(set(out))
   143	
   144	
   145	def target_peer_ids():
   146	    """
   147	    Devuelve la lista de peers objetivo para replicación (vivos OR configurados).
   148	
   149	    Combina alive_peer_ids() y configured_peer_ids() con Unión.
   150	    Esto asegura que se intenta replicar incluso a peers que están down
   151	    (pueden recoverar más tarde).
   152	
   153	    Returns:
   154	        list[str]: node_ids de peers objetivo, ordenados alfabéticamente.
   155	
   156	    Example:
   157	        >>> target_peer_ids()
   158	        ['lnx200nas', 'lnx204hp']
   159	
   160	    Note:
   161	        - Unión de peers vivos + configurados
   162	        - Si un peer está configurado pero no está vivo, se iguala intentar replicar
   163	          (fallará pero se intenta)
   164	    """
   165	    alive = alive_peer_ids()
   166	    configured = configured_peer_ids()
   167	    return sorted(set(alive) | set(configured))
   168	
   169	
   170	def replicate_eventlog():
   171	    """
   172	    Replica el event log local a todos los peers.
   173	
   174	    Secuencia:
   175	        1. comprueba si el nodo está en un estado permitido (ACTIVE, STANDBY, DRAINING)
   176	        2. comprueba si el log está dirty (modificado)
   177	        3. lee el contenido del log local
   178	        4. escribe el log como replica local
   179	        5. envía POST /debug/log/replica/{node_id} a cada peer
   180	        6. si todos los peers responden OK, limpia el dirty flag
   181	
   182	    Note:
   183	        - Se llama en cada tick del worker (~1s)
   184	        - Falla silenciosamente si un peer no responde
   185	        - El dirty flag se mantiene hasta que TODOS los peers confirmen
   186	        - Solo replica si hay contenido (no replica logs vacíos)
   187	    """
   188	
   189	    node_id = canonical_replica_node_id()
   190	    node_state = getattr(getattr(ctx, "node", None), "state", None)
   191	    node_state_value = getattr(node_state, "value", None)
   192	
   193	    state = read_state()
   194	    dirty = bool(state.get("dirty", False))
   195	
   196	    #log_state("cyan", "REPL TICK", f"node={node_id} dirty={dirty} ", 3)
   197	
   198	    if node_state_value not in REPLICATION_ALLOWED_STATES:
   199	        return
   200	
   201	    #log_state("cyan", "REPL FLAG", f"dirty={dirty} state_exists={bool(state)}", 3)
   202	    if not dirty:
   203	        return
   204	
   205	    content = read_local_log_text()
   206	    completed_content = read_completed_log_text()
   207	
   208	    if not content.strip():
   209	        return
   210	
   211	    write_replica_log(node_id, content)
   212	    if completed_content.strip():
   213	        write_completed_log(completed_content)
   214	
   215	    peers = target_peer_ids()
   216	
   217	    success = True
   218	
   219	    for peer_id in peers:
   220	        node = CLUSTER_REGISTRY.get(peer_id)
   221	        if not node:
   222	            success = False
   223	            continue
   224	
   225	        url = f"http://{node['host']}:{node['port']}/debug/log/replica/{node_id}"
   226	
   227	        try:
   228	            resp = requests.post(
   229	                url,
   230	                data=content.encode("utf-8"),
   231	                headers={"Content-Type": "text/plain; charset=utf-8"},
   232	                timeout=2,
   233	            )
   234	
   235	            if resp.ok:
   236	                success = True
   237	            else:
   238	                success = False
   239	
   240	        except Exception as e:
   241	            success = False
   242	
   243	    if success:
   244	        clear_eventlog_dirty_state()
   245	
   246	
   247	def replicate_events():
   248	    """
   249	    Replica los eventos completed (procesados) a todos los peers.
   250	
   251	    Similar a replicate_eventlog() pero solo replica el completed log.
   252	    Se usa para mantener una copia de eventos ya procesados en todos los nodos.
   253	
   254	    Secuencia:
   255	        1. comprueba si el nodo está en un estado permitido
   256	        2. comprueba si el events log está dirty
   257	        3. lee el completed log local
   258	        4. escribe el events como replica local
   259	        5. envía POST /debug/events/replica/{node_id} a cada peer
   260	        6. si todos los peers responden OK, limpia el dirty flag
   261	
   262	    Note:
   263	        - Se llama en cada tick del worker (~1s)
   264	        - Solo replica completed_content (eventos procesados)
   265	        - Falla silenciosamente si un peer no responde
   266	    """
   267	
   268	    node_id = canonical_replica_node_id()
   269	    node_state = getattr(getattr(ctx, "node", None), "state", None)
   270	    node_state_value = getattr(node_state, "value", None)
   271	
   272	    if node_state_value not in REPLICATION_ALLOWED_STATES:
   273	        return
   274	
   275	    state = read_state()
   276	    dirty = bool(state.get("events_dirty", False))
   277	    if not dirty:
   278	        return
   279	
   280	    completed_content = read_completed_log_text()
   281	
   282	    write_replica_events(node_id, completed_content)
   283	    if completed_content.strip():
   284	        write_completed_log(completed_content)
   285	
   286	    peers = target_peer_ids()
   287	
   288	    success = True
   289	
   290	    for peer_id in peers:
   291	        node = CLUSTER_REGISTRY.get(peer_id)
   292	        if not node:
   293	            success = False
   294	            continue
   295	
   296	        url = f"http://{node['host']}:{node['port']}/debug/events/replica/{node_id}"
   297	
   298	        try:
   299	            resp = requests.post(
   300	                url,
   301	                data=completed_content.encode("utf-8"),
   302	                headers={"Content-Type": "text/plain; charset=utf-8"},
   303	                timeout=2,
   304	            )
   305	
   306	            if resp.ok:
   307	                success = True
   308	            else:
   309	                success = False
   310	
   311	        except Exception as e:
   312	            success = False
   313	
   314	    if success:
   315	        clear_events_dirty_state()


