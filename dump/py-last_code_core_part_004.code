    74	
    75	    Útil para comparar dicts independientemente del orden de las claves.
    76	
    77	    Args:
    78	        obj: Objeto a canonicalizar (dict, list, o escalar).
    79	        ignored_keys: Conjunto de claves a ignorar (no incluir en el resultado).
    80	
    81	    Returns:
    82	        Any: Objeto canonicalizado (dict con claves ordenadas, list procesada, o escalar).
    83	
    84	    Example:
    85	        >>> canonicalize({"b": 2, "a": 1})
    86	        {'a': 1, 'b': 2}
    87	
    88	        >>> canonicalize({"b": 2, "a": 1}, ignored_keys={"a"})
    89	        {'b': 2}
    90	
    91	        >>> canonicalize([{"b": 2, "a": 1}])
    92	        [{'a': 1, 'b': 2}]
    93	
    94	    Note:
    95	        - Se usa antes de comparar views para ignorar el orden de claves
    96	        - Ignora recursivamente las claves en ignored_keys
    97	    """
    98	    ignored_keys = ignored_keys or set()
    99	    if isinstance(obj, dict):
   100	        return {
   101	            k: canonicalize(v, ignored_keys)
   102	            for k, v in sorted(obj.items())
   103	            if k not in ignored_keys
   104	        }
   105	    if isinstance(obj, list):
   106	        return [canonicalize(v, ignored_keys) for v in obj]
   107	    return obj
   108	
   109	
   110	def compare_views(a: dict, b: dict) -> bool:
   111	    """
   112	    Compara dos views canonicalizando primero.
   113	
   114	    Args:
   115	        a: Primer dict a comparar.
   116	        b: Segundo dict a comparar.
   117	
   118	    Returns:
   119	        bool: True si las views son iguales después de canonicalizar.
   120	
   121	    Example:
   122	        >>> compare_views({"b": 2, "a": 1}, {"a": 1, "b": 2})
   123	        True
   124	
   125	        >>> compare_views({"b": 2, "a": 1}, {"a": 1, "b": 3})
   126	        False
   127	    """
   128	    return canonicalize(a, IGNORED_NODE_KEYS) == canonicalize(b, IGNORED_NODE_KEYS)
   129	
