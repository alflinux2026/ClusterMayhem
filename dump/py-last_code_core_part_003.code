   458	def get_latest_event(event_id: str) -> Optional[dict]:
   459	    """
   460	    Obtiene el último evento con un event_id específico.
   461	
   462	    Args:
   463	        event_id: ID del evento a buscar.
   464	
   465	    Returns:
   466	        dict | None: Último evento con ese event_id, o None si no existe.
   467	    """
   468	    events = load_events()
   469	    for e in reversed(events):
   470	        if e["event_id"] == event_id:
   471	            return _normalize_event(e)
   472	    return None
