   499	def append_event(event: ClusterEvent):
   500	    """
   501	    Añade un evento al log local.
   502	
   503	    Secuencia:
   504	        1. Asegura archivos iniciales (ensure_initial_files)
   505	        2. Crea record con campos del evento
   506	        3. Añade línea al log local (JSONL append)
   507	        4. Actualiza state con dirty=True y metadata del append
   508	        5. Si status=CREATED, también añade al completed log
   509	        6. Actualiza cache de counters en cluster_state
   510	
   511	    Args:
   512	        event: Evento a appendear.
   513	
   514	    Note:
   515	        - El dirty flag se pone para indicar que hay que replicar
   516	        - Se escribe manualmente con fsync para asegurar durabilidad
   517	        - Si falla write_state, imprime error pero no levanta exception
   518	    """
   519	    ensure_initial_files()
   520	
   521	    record = {
   522	        "event_id": event.event_id,
   523	        "event_type": event.event_type,
   524	        "schema_version": str(event.schema_version),
   525	        "created_at": event.created_at,
   526	        "updated_at": getattr(event, "updated_at", None),
   527	        "received_at": getattr(event, "received_at", None),
   528	        "trace_id": event.trace_id,
   529	        "target_node": event.target_node,
   530	        "source_node": getattr(event, "source_node", None),
   531	        "route_hops": list(getattr(event, "route_hops", []) or []),
   532	        "status": event.status.value if hasattr(event.status, "value") else event.status,
   533	        "attempt": event.attempt,
   534	        "execution_key": getattr(event, "execution_key", None),
   535	        "payload": event.payload,
   536	    }
   537	
   538	    line = json.dumps(record) + "\n"
   539	    with open(LOCAL_LOG_PATH, "a", encoding="utf-8") as f:
   540	        f.write(line)
   541	        f.flush()
   542	        os.fsync(f.fileno())
   543	
   544	    state = read_state()
   545	    state["dirty"] = True
   546	    state["last_append_event_id"] = event.event_id
   547	    state["last_append_created_at"] = event.created_at
   548	    state["last_append_updated_at"] = getattr(event, "updated_at", None)
   549	
   550	    if record["status"] == EventStatus.CREATED.value:
   551	        with open(COMPLETED_LOG_PATH, "a", encoding="utf-8") as f:
   552	            f.write(line)
   553	            f.flush()
   554	            os.fsync(f.fileno())
   555	
   556	        state["events_dirty"] = True
   557	        state["last_completed_event_id"] = event.event_id
   558	        state["last_completed_created_at"] = event.created_at
   559	        state["last_completed_updated_at"] = getattr(event, "updated_at", None)
   560	
   561	    try:
   562	        write_state(state)
   563	        _update_node_events_cache(event, record["status"])
   564	
   565	    except Exception as e:
   566	        print(f"[STATE WRITE FAIL] {event.event_id} -> {e}")
   567	
   568	
   569	def replay_events(handler, stream: str | None = None):
   570	    """
   571	    Reproduce todos los eventos del log llamando a handler para cada uno.
   572	
   573	    Args:
   574	        handler: Función a llamar para cada evento (event -> None).
   575	        stream: (Opcional) Stream a filtrar (no implementado aún).
   576	
   577	    Example:
   578	        >>> def handler(event):
   579	        ...     print(f"Replaying {event.event_id}")
   580	        >>> replay_events(handler)
   581	    """
   582	    events = load_events()
   583	    for raw in events:
   584	        event = ClusterEvent(**_normalize_event(raw))
   585	        handler(event)
   586	
   587	
   588	def ingest_event(event, node_id):
   589	    """
   590	    Ingerta un evento (marca como CREATED y lo appendea).
   591	
   592	    Args:
   593	        event: Evento a ingerir.
   594	        node_id: ID del nodo que ingiere (líder).
   595	
   596	    Returns:
   597	        dict: Resultado con event_id, status="accepted", leader, trace_id.
   598	
   599	    Note:
   600	        - Se llama desde POST /event en api_app.py
   601	        - Marca el evento como CREATED (si no lo está ya)
   602	        - Marca received_at (si no lo tiene ya)
   603	        - Logeia el evento con log_state
   604	    """
   605	    event.mark_status(EventStatus.CREATED)
   606	    event.mark_received()
   607	    append_event(event)
   608	
   609	    msg = event.payload.get("msg", "<no-msg>")
   610	
   611	    log_state("yellow", "(EVENT)", f"{msg:12} -> CREATED", 3)
   612	    log_state("cyan", "[EVENT OK]", f"{msg:12}", 3)
   613	
   614	    return {
   615	        "event_id": event.event_id,
   616	        "status": "accepted",
   617	        "leader": node_id,
   618	        "trace_id": event.trace_id
   619	    }


