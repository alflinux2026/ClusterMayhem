   448	def rebuild_event_state_index() -> Dict[str, dict]:
   449	    """
   450	    Reconstruye el index de eventos por event_id (último versión).
   451	
   452	    Returns:
   453	        dict[str, dict]: Mapa event_id -> último evento.
   454	    """
   455	    return _latest_map(load_events())
