   412	def _normalize_event(e: dict) -> dict:
   413	    """
   414	    Normaliza un evento asegurando campos defaults.
   415	
   416	    Args:
   417	        e: Dict de evento.
   418	
   419	    Returns:
   420	        dict: Evento normalizado con schema_version, received_at, attempt, route_hops, execution_key.
   421	    """
   422	    e = dict(e)
   423	    e["schema_version"] = str(e.get("schema_version", "0.1"))
   424	    e.setdefault("received_at", None)
   425	    e.setdefault("attempt", 0)
   426	    e.setdefault("route_hops", [])
   427	    e.setdefault("execution_key", None)
   428	    return e
   429	
   430	
   431	def _latest_map(events: List[dict]) -> Dict[str, dict]:
   432	    """
   433	    Crea un mapa event_id -> último evento (por orden en el log).
   434	
   435	    Args:
   436	        events: Lista de eventos (puede tener duplicados por event_id).
   437	
   438	    Returns:
   439	        dict[str, dict]: Mapa de event_id -> último evento.
   440	    """
   441	    latest: Dict[str, dict] = {}
   442	    for e in events:
   443	        e = _normalize_event(e)
   444	        latest[e["event_id"]] = e
   445	    return latest
   446	
