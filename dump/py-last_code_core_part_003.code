   274	def write_text_atomic(path: str, content: str):
   275	    """
   276	    Escribe texto en un archivo de forma atómica.
   277	
   278	    Args:
   279	        path: Ruta del archivo destino.
   280	        content: Contenido a escribir.
   281	    """
   282	    ensure_dir()
   283	    target_path = Path(path)
   284	    fd, tmp_name = tempfile.mkstemp(
   285	        prefix=f"{target_path.name}.",
   286	        suffix=".tmp",
   287	        dir=str(target_path.parent),
   288	        text=True,
   289	    )
   290	    try:
   291	        with os.fdopen(fd, "w", encoding="utf-8") as f:
   292	            f.write(content)
   293	            f.flush()
   294	            os.fsync(f.fileno())
   295	        os.replace(tmp_name, str(target_path))
   296	    except Exception:
   297	        try:
   298	            os.remove(tmp_name)
   299	        except FileNotFoundError:
   300	            pass
   301	        raise
