   406	def setup_colors():
   407	    """Inicializa pares de colores para curses."""
   408	    if not curses.has_colors():
   409	        return False
   410	
   411	    curses.start_color()
   412	    curses.use_default_colors()
   413	
   414	    curses.init_pair(1, curses.COLOR_GREEN, -1)   # ok/ACTIVE/completed
   415	    curses.init_pair(2, curses.COLOR_YELLOW, -1)  # stale/STANDBY/executing
   416	    curses.init_pair(3, curses.COLOR_RED, -1)     # error/ISOLATED/FAILED/stalled
   417	    curses.init_pair(4, curses.COLOR_CYAN, -1)    # headers/progress_stage
   418	    curses.init_pair(5, curses.COLOR_WHITE, -1)   # default
   419	    curses.init_pair(6, curses.COLOR_MAGENTA, -1) # busy/created/DRAINING
   420	    return True
   421	
   422	
   423	def color_for_health(value):
   424	    """Color para health value."""
   425	    v = str(value or "").lower()
   426	    if v == "ok":
   427	        return curses.color_pair(1) | curses.A_BOLD
   428	    if v == "stale":
   429	        return curses.color_pair(3) | curses.A_BOLD
   430	    return curses.color_pair(2) | curses.A_BOLD
   431	
   432	
   433	def color_for_state(state, stale=False):
   434	    """Color para state value."""
   435	    if stale:
   436	        return curses.color_pair(3) | curses.A_BOLD
   437	
   438	    s = str(state or "").upper()
   439	    if s == "ACTIVE":
   440	        return curses.color_pair(1) | curses.A_BOLD
   441	    if s in ("STAND-BY", "STANDBY"):
   442	        return curses.color_pair(2) | curses.A_BOLD
   443	    if s == "DRAINING":
   444	        return curses.color_pair(6) | curses.A_BOLD
   445	    if s in ("ISOLATED", "OFFLINE", "???"):
   446	        return curses.color_pair(3) | curses.A_BOLD
   447	    return curses.color_pair(5)
   448	
   449	
   450	def color_for_dirty(value):
   451	    """Color para dirty flag."""
   452	    if value is True or str(value).lower() == "true":
   453	        return curses.color_pair(3) | curses.A_BOLD
   454	    return curses.color_pair(1)
   455	
   456	
   457	def color_for_count(label, value):
   458	    """Color para counters (created, executing, completed)."""
   459	    try:
   460	        n = int(value)
   461	    except Exception:
   462	        n = 0
   463	
   464	    if label == "executing" and n > 0:
   465	        return curses.color_pair(2) | curses.A_BOLD
   466	    if label == "created" and n > 0:
   467	        return curses.color_pair(6) | curses.A_BOLD
   468	    if label == "completed" and n > 0:
   469	        return curses.color_pair(1)
   470	    return curses.color_pair(5)
   471	
   472	
   473	def color_for_age(value, warn_s=1.5, stale_s=3.0):
   474	    """Color para age (watchdog_age_s, presence_age_s, etc.)."""
   475	    if value is None:
   476	        return curses.color_pair(5)
   477	    try:
   478	        age = float(value)
   479	    except Exception:
   480	        return curses.color_pair(5)
   481	    if age >= stale_s:
   482	        return curses.color_pair(3) | curses.A_BOLD
   483	    if age >= warn_s:
   484	        return curses.color_pair(2) | curses.A_BOLD
   485	    return curses.color_pair(1)
   486	
   487	
   488	def color_for_busy(value):
   489	    """Color para watchdog_busy."""
   490	    if value is True:
   491	        return curses.color_pair(6) | curses.A_BOLD
   492	    if value is False:
   493	        return curses.color_pair(1)
   494	    return curses.color_pair(5)
   495	
   496	
   497	def color_for_progress_active(value):
   498	    """Color para progress_active."""
   499	    if value is True:
   500	        return curses.color_pair(6) | curses.A_BOLD
   501	    return curses.color_pair(5)
   502	
   503	
   504	def color_for_progress_stalled(value):
   505	    """Color para progress_stalled."""
   506	    if value is True:
   507	        return curses.color_pair(3) | curses.A_BOLD
   508	    return curses.color_pair(1)
   509	
   510	
   511	def color_for_progress_stage(stage):
   512	    """Color para progress_stage."""
   513	    if not stage:
   514	        return curses.color_pair(5)
   515	    return curses.color_pair(4)
   516	
   517	
   518	def render_top_summary_1(api_snapshots, groups):
   519	    """
   520	    Renderiza summary del cluster en markdown.
   521	
   522	    Args:
   523	        api_snapshots: Dict de snapshots de API.
   524	        groups: Dict de grupos de archivos.
   525	
   526	    Returns:
   527	        list[str]: Líneas de markdown.
   528	    """
   529	    source_order = ["lnx200nas", "lnx202pc", "lnx203hp"]
   530	    lines = []
   531	
   532	    NODE_W = 12
   533	    HEALTH_W = 8
   534	    STATE_W = 12
   535	    TSTATE_W = 8
   536	    PRES_W = 7
   537	    WDOG_W = 7
   538	    BUSY_W = 5
   539	    STAGE_W = 18
   540	    PROG_W = 12
   541	    PAGE_W = 7
   542	    STALL_W = 6
   543	    SIZE_W = 10
   544	    EVENTS_W = 12
   545	    COUNT_W = 9
   546	    DIRTY_W = 7
   547	
   548	    def cut(value, width):
   549	        s = "-" if value is None else str(value)
   550	        return s if len(s) <= width else s[: max(0, width - 1)] + "…"
   551	
   552	    def fmt_age(value):
   553	        if value is None:
   554	            return "-"
   555	        try:
   556	            value = float(value)
   557	        except Exception:
   558	            return "-"
   559	        if value < 60:
   560	            return f"{value:.0f}s"
   561	        if value < 3600:
   562	            return f"{value / 60:.1f}m"
   563	        return f"{value / 3600:.1f}h"
   564	
   565	    def fmt_busy(value):
   566	        if value is True:
   567	            return "Y"
   568	        if value is False:
   569	            return "N"
   570	        return "?"
   571	
   572	    def fmt_progress(current, total, pct):
   573	        if current is None and total is None:
   574	            return "-"
   575	        try:
   576	            if pct is not None and current is not None and total is not None:
   577	                return f"{int(current)}/{int(total)} {pct:.0f}%"
   578	            if current is not None and total is not None:
   579	                return f"{int(current)}/{int(total)}"
   580	            return str(current if current is not None else "-")
   581	        except Exception:
   582	            return "-"
   583	
   584	    lines.append("### resumen cluster")
   585	    lines.append("")
   586	    lines.append(
   587	        "- leader esperado: "
   588	        + ", ".join(
   589	            f"{node}: {api_snapshots.get(node, {}).get('dashboard', {}).get('cluster', {}).get('leader', '?')}"
   590	            for node in source_order
   591	        )
   592	    )
   593	    lines.append("")
   594	    lines.append(
   595	        f"- {'nodo':<{NODE_W}}  {'health':<{HEALTH_W}}  {'state':<{STATE_W}}  {'t_state':>{TSTATE_W}}  "
   596	        f"{'pres':>{PRES_W}}  {'wdog':>{WDOG_W}}  {'busy':<{BUSY_W}}  "
   597	        f"{'stage':<{STAGE_W}}  {'prog':>{PROG_W}}  {'p_age':>{PAGE_W}}  {'stall':<{STALL_W}}  "
   598	        f"{'local_size':>{SIZE_W}}  {'local_events':>{EVENTS_W}}  "
   599	        f"{'created':>{COUNT_W}}  {'executing':>{COUNT_W}}  {'completed':>{COUNT_W}}  "
   600	        f"{'dirty':<{DIRTY_W}}"
   601	    )
   602	
   603	    for node_name in source_order:
   604	        view = _node_runtime_view(api_snapshots, node_name)
   605	        lines.append(
   606	            f"- {node_name:<{NODE_W}}  "
   607	            f"{cut(view['health'], HEALTH_W):<{HEALTH_W}}  "
   608	            f"{cut(view['state'], STATE_W):<{STATE_W}}  "
   609	            f"{fmt_age(view['state_age_s']):>{TSTATE_W}}  "
   610	            f"{fmt_age(view['presence_age_s']):>{PRES_W}}  "
   611	            f"{fmt_age(view['watchdog_age_s']):>{WDOG_W}}  "
   612	            f"{fmt_busy(view['watchdog_busy']):<{BUSY_W}}  "
   613	            f"{cut(view['progress_stage'], STAGE_W):<{STAGE_W}}  "
   614	            f"{cut(fmt_progress(view['progress_current'], view['progress_total'], view['progress_pct']), PROG_W):>{PROG_W}}  "
   615	            f"{fmt_age(view['progress_age_s']):>{PAGE_W}}  "
   616	            f"{('Y' if view['progress_stalled'] else 'N'):<{STALL_W}}  "
   617	            f"{view['local_size']:>{SIZE_W}}  "
   618	            f"{view['local_events']:>{EVENTS_W}}  "
   619	            f"{view['created']:>{COUNT_W}}  "
   620	            f"{view['executing']:>{COUNT_W}}  "
   621	            f"{view['completed']:>{COUNT_W}}  "
   622	            f"{cut(view['dirty'], DIRTY_W):<{DIRTY_W}}"
   623	        )
   624	
   625	    lines.append("")
   626	    return lines
   627	
   628	
