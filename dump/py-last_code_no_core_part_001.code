    64	#: Regex para parsear output de ls -lb --full-time
    65	LINE_RE = re.compile(
    66	    r"^(?P<perm>\S+)\s+"
    67	    r"(?P<links>\d+)\s+"
    68	    r"(?P<owner>\S+)\s+"
    69	    r"(?P<group>\S+)\s+"
    70	    r"(?P<size>\d+)\s+"
    71	    r"(?P<date>\d{4}-\d{2}-\d{2})\s+"
    72	    r"(?P<time>\d{2}:\d{2}:\d{2}\.\d+)\s+"
    73	    r"(?P<tz>[+-]\d{4})\s+"
    74	    r"(?P<name>.+)$"
    75	)
    76	
    77	#: Sesión HTTP compartida
    78	HTTP = requests.Session()
    79	
