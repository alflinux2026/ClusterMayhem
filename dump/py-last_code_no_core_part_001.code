   276	def check_consistency(groups):
   277	    """
   278	    Verifica consistencia de archivos entre replicas.
   279	
   280	    Args:
   281	        groups: Dict de grupos por source.
   282	
   283	    Note:
   284	        - Verifica que size sea igual en todos los nodos
   285	        - Verifica que mtime difiera en <= 2 nodos
   286	    """
   287	    for source, entries in groups.items():
   288	        for file_name in set(e["file"] for e in entries):
   289	            entries_file = [e for e in entries if e["file"] == file_name]
   290	            sizes = {e["node"]: e["size"] for e in entries_file}
   291	            mtimes = {e["node"]: (e["mtime_date"], e["mtime_time"]) for e in entries_file}
   292	            size_ok = len(set(sizes.values())) == 1
   293	            mtime_ok = len(set(mtimes.values())) <= 2
   294	            print(
   295	                f"[INFO] {source}/{file_name}: size={'OK' if size_ok else 'MISMATCH'} "
   296	                f"mtime={'OK' if mtime_ok else 'MISMATCH'}"
   297	            )
   298	
