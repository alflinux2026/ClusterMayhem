   215	def fetch_json(url, timeout=4):
   216	    """
   217	    Fetch JSON de una URL.
   218	
   219	    Args:
   220	        url: URL a fetchear.
   221	        timeout: Timeout en segundos.
   222	
   223	    Returns:
   224	        dict: JSON parseado, o {"error": ..., "url": ...} si falla.
   225	    """
   226	    try:
   227	        resp = HTTP.get(url, timeout=timeout)
   228	        resp.raise_for_status()
   229	        return resp.json()
   230	    except Exception as e:
   231	        return {"error": str(e), "url": url}
