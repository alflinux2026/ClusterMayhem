   121	def parse_ls_output(node_name, text):
   122	    """
   123	    Parsea output de ls y extrae archivos event_log.*.jsonl.
   124	
   125	    Args:
   126	        node_name: Nombre del nodo.
   127	        text: Output de ls -lb --full-time.
   128	
   129	    Returns:
   130	        list[dict]: Filas con node, file, source, mtime_date, mtime_time, mtime_tz, size.
   131	
   132	    Note:
   133	        - Extrae event_log.{source}.000.jsonl
   134	        - event_log.local.000.jsonl tiene source=node_name
   135	    """
   136	    rows = []
   137	    for line in text.splitlines():
   138	        line = line.rstrip()
   139	        if not line or line.startswith("total "):
   140	            continue
   141	        m = LINE_RE.match(line)
   142	        if not m:
   143	            continue
   144	        d = m.groupdict()
   145	        file_name = d["name"]
   146	        m_source = re.match(r"^event_log\.(.+)\.000\.jsonl$", file_name)
   147	        if not m_source and file_name != "event_log.local.000.jsonl":
   148	            continue
   149	
   150	        source = m_source.group(1) if m_source else None
   151	        if file_name == "event_log.local.000.jsonl":
   152	            source = node_name
   153	
   154	        rows.append(
   155	            {
   156	                "node": node_name,
   157	                "file": file_name,
   158	                "source": source,
   159	                "mtime_date": d["date"],
   160	                "mtime_time": d["time"],
   161	                "mtime_tz": d["tz"],
   162	                "size": int(d["size"]),
   163	            }
   164	        )
   165	    return rows
   166	
