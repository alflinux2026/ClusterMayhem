   234	def fetch_api_snapshot(node):
   235	    """
   236	    Obtiene snapshot completo de la API de un nodo.
   237	
   238	    Args:
   239	        node: Dict del nodo.
   240	
   241	    Returns:
   242	        dict: Snapshot con health, dashboard, integrity, events_summary_local.
   243	    """
   244	    base = f"http://{node['host']}:{node['api_port']}"
   245	    dashboard = fetch_json(f"{base}/dashboard/compact")
   246	    health = fetch_json(f"{base}/health")
   247	    integrity = fetch_json(f"{base}/integrity")
   248	    events_summary_local = fetch_json(f"{base}/debug/events/summary")
   249	
   250	    return {
   251	        "node": node["name"],
   252	        "host": node["host"],
   253	        "health": health,
   254	        "dashboard": dashboard,
   255	        "integrity": integrity,
   256	        "events_summary_local": events_summary_local,
   257	    }
