   364	def classify_submit_response(status_code, payload):
   365	    """
   366	    Clasifica la respuesta de un submit de evento.
   367	
   368	    Args:
   369	        status_code: Código HTTP de la respuesta.
   370	        payload: Dict de respuesta.
   371	
   372	    Returns:
   373	        str: "submit_ok", "retryable_error", "hard_fail", o "http_not_ok".
   374	    """
   375	    if status_code != 200:
   376	        return "http_not_ok"
   377	    if not isinstance(payload, dict):
   378	        return "submit_ok"
   379	    if payload.get("error"):
   380	        return "retryable_error" if is_retryable_response(payload) else "hard_fail"
   381	    result = payload.get("result")
   382	    if isinstance(result, dict) and result.get("error"):
   383	        return "retryable_error" if is_retryable_response(result) else "hard_fail"
   384	    return "submit_ok"
