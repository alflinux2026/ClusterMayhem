   422	def compute_retry_backoff(retries_done):
   423	    """
   424	    Calcula el backoff para retry (exponencial).
   425	
   426	    Args:
   427	        retries_done: Número de retries ya hechos.
   428	
   429	    Returns:
   430	        float: Backoff en segundos (base * 2^(retries_done - 1), max RETRY_BACKOFF_MAX).
   431	    """
   432	    return min(RETRY_BACKOFF_BASE * (2 ** max(0, retries_done - 1)), RETRY_BACKOFF_MAX)
