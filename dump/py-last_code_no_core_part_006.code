   387	def next_enqueue_seq():
   388	    """Genera el siguiente número de secuencia de encolado (thread-safe)."""
   389	    global enqueue_seq
   390	    with enqueue_seq_lock:
   391	        enqueue_seq += 1
   392	        return enqueue_seq
