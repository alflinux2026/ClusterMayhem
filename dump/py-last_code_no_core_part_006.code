   338	def is_retryable_response(payload):
   339	    """
   340	    Comprueba si una respuesta es retryable.
   341	
   342	    Args:
   343	        payload: Dict de respuesta.
   344	
   345	    Returns:
   346	        bool: True si es retryable (no leader, isolated, timeout, connection, etc.).
   347	    """
   348	    if not isinstance(payload, dict):
   349	        return False
   350	    if payload.get("error") in {"no leader", "node isolated"}:
   351	        return True
   352	    return any(p in str(payload.get("error", "")).lower() for p in ["timeout", "connection", "refused", "temporarily unavailable", "isolated", "no leader"])
   353	
   354	
   355	def extract_leader(payload):
   356	    """Extrae el node_id del líder de una respuesta."""
   357	    if not isinstance(payload, dict):
   358	        return None
   359	    if "result" in payload and isinstance(payload["result"], dict):
   360	        return payload["result"].get("leader")
   361	    return payload.get("leader")
   362	
