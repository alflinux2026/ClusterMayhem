   157	
   158	def stat_inc(key, amount=1):
   159	    with stats_lock:
   160	        stats[key] += amount
   161	
   162	
   163	def stat_node_ok(node):
   164	    with stats_lock:
   165	        stats["per_node_ok"][node] += 1
   166	
   167	
   168	def stat_node_fail(node):
   169	    with stats_lock:
