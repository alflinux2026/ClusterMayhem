   395	def enqueue_pending(pending, delay_seconds=0.0):
   396	    """
   397	    Encola un evento pendiente para enviar.
   398	
   399	    Args:
   400	        pending: PendingEvent a encolar.
   401	        delay_seconds: Segundos de delay antes de intentar enviar.
   402	    """
   403	    run_at = time.time() + max(0.0, delay_seconds)
   404	    pending_queue.put((run_at, next_enqueue_seq(), pending))
   405	    with stats_lock:
   406	        stats["queue_max_depth"] = max(stats["queue_max_depth"], pending_queue.qsize())
