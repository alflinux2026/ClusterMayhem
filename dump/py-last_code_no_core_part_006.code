   320	    Args:
   321	        data: Lista de valores numéricos.
   322	        p: Percentil a calcular (0-100).
   323	
   324	    Returns:
   325	        float: Percentil p (interpolación lineal).
   326	    """
   327	    if not data:
   328	        return 0.0
   329	    values = sorted(data)
   330	    if len(values) == 1:
   331	        return float(values[0])
   332	    rank = (len(values) - 1) * (p / 100.0)
   333	    low = int(rank)
   334	    high = min(low + 1, len(values) - 1)
   335	    return float(values[low] + (values[high] - values[low]) * (rank - low))
