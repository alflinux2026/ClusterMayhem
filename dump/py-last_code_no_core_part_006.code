   468	def kill_node(node, seconds=None):
   469	    """
   470	    Mata un nodo (sleep).
   471	
   472	    Args:
   473	        node: URL del nodo.
   474	        seconds: Segundos que durará muerto (para logging).
   475	
   476	    Returns:
   477	        bool: True si se mató exitosamente, False si falló.
   478	    """
   479	    stat_inc("kill_attempts")
   480	    try:
   481	        resp = requests.post(f"{node}/sleep", timeout=2)
   482	        try:
   483	            payload = resp.json()
   484	        except Exception:
   485	            payload = {"raw_text": resp.text}
   486	        if resp.status_code == 200 and payload.get("ok") is True:
   487	            with dead_lock:
   488	                dead_nodes.add(node)
   489	            stat_inc("kills")
   490	            stat_kill_event(node=node, action="sleep", ok=True, payload=payload, seconds=seconds)
   491	            print(f"[CHAOS] SLEEP {node}")
   492	            return True
   493	        stat_inc("kill_failures")
   494	        stat_kill_event(node=node, action="sleep", ok=False, payload=payload, seconds=seconds)
   495	        print(f"[CHAOS FAIL SLEEP] {node} -> status={resp.status_code} payload={payload}")
   496	        return False
   497	    except Exception as e:
   498	        stat_inc("kill_failures")
   499	        stat_kill_event(node=node, action="sleep", ok=False, error=str(e), seconds=seconds)
   500	        print(f"[CHAOS FAIL SLEEP] {node} -> {e}")
   501	        return False
