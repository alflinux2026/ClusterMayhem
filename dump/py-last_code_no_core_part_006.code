   504	def revive_node(node):
   505	    """
   506	    Revive un nodo (revive).
   507	
   508	    Args:
   509	        node: URL del nodo.
   510	
   511	    Returns:
   512	        bool: True si se revivió exitosamente, False si falló.
   513	    """
   514	    try:
   515	        resp = requests.post(f"{node}/revive", timeout=2)
   516	        try:
   517	            payload = resp.json()
   518	        except Exception:
   519	            payload = {"raw_text": resp.text}
   520	        if resp.status_code == 200 and payload.get("ok") is True:
   521	            with dead_lock:
   522	                dead_nodes.discard(node)
   523	            stat_inc("revives")
