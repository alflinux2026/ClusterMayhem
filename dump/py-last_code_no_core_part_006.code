   728	def wait_queue_drain():
   729	    """
   730	    Espera a que la cola se vacíe (drain).
   731	
   732	    Returns:
   733	        bool: True si la cola se vació, False si timeout.
   734	    """
   735	    deadline = time.time() + DRAIN_TIMEOUT
   736	    while time.time() < deadline:
   737	        if pending_queue.empty():
   738	            time.sleep(0.5)
   739	            if pending_queue.empty():
   740	                return True
   741	        time.sleep(0.2)
   742	    return False
