   347	def kill_cycle(node, seconds):
   348	    try:
   349	        if kill_node(node, seconds=seconds):
   350	            print(f"[CHAOS] DEAD {node} for {seconds:.2f}s")
   351	            time.sleep(seconds)
   352	    finally:
