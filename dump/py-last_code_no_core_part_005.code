   285	def get_session(worker_id):
   286	    with worker_sessions_lock:
   287	        if worker_id not in worker_sessions:
   288	            s = requests.Session()
   289	            adapter = requests.adapters.HTTPAdapter(pool_connections=16, pool_maxsize=16, max_retries=0)
   290	            s.mount("http://", adapter)
   291	            s.mount("https://", adapter)
   292	            worker_sessions[worker_id] = s
   293	        return worker_sessions[worker_id]
