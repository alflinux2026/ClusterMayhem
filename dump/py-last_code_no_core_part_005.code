   110	def parse_args():
   111	    """
   112	    Parsea argumentos de línea de comando.
   113	
   114	    Returns:
   115	        argparse.Namespace: Argumentos parseados.
   116	
   117	    Example:
   118	        # Smoke test
   119	        $ python chaos_torture.py --mode smoke
   120	
   121	        # Benchmark
   122	        $ python chaos_torture.py --mode benchmark --events 10000
   123	
   124	        # Torture
   125	        $ python chaos_torture.py --mode torture --nodes http://10.0.0.1:7000 http://10.0.0.2:7000
   126	    """
   127	    p = argparse.ArgumentParser(description="Universal chaos torture runner final v2")
   128	    p.add_argument("--mode", choices=["smoke", "benchmark", "torture"], default="benchmark")
   129	    p.add_argument("--nodes", nargs="+", default=DEFAULT_NODES)
   130	    p.add_argument("--events", type=int, default=DEFAULT_EVENTS)
   131	    p.add_argument("--delay-min", type=float, default=DEFAULT_EVENT_DELAY_MIN)
   132	    p.add_argument("--delay-max", type=float, default=DEFAULT_EVENT_DELAY_MAX)
   133	    p.add_argument("--kill-prob", type=float, default=DEFAULT_KILL_PROBABILITY)
   134	    p.add_argument("--death-min", type=float, default=DEFAULT_DEATH_TIME_MIN)
   135	    p.add_argument("--death-max", type=float, default=DEFAULT_DEATH_TIME_MAX)
   136	    p.add_argument("--timeout", type=float, default=DEFAULT_REQUEST_TIMEOUT)
   137	    p.add_argument("--retries", type=int, default=DEFAULT_MAX_RETRIES)
   138	    p.add_argument("--sleep-only-node", default=DEFAULT_SLEEP_ONLY_NODE)
   139	    p.add_argument("--slow-ms", type=float, default=DEFAULT_SLOW_EVENT_THRESHOLD_MS)
   140	    p.add_argument("--seed", type=int, default=None)
   141	    p.add_argument("--output", default=None)
   142	    p.add_argument("--send-workers", type=int, default=DEFAULT_SEND_WORKERS)
   143	    p.add_argument("--retry-backoff-base", type=float, default=DEFAULT_RETRY_BACKOFF_BASE)
   144	    p.add_argument("--retry-backoff-max", type=float, default=DEFAULT_RETRY_BACKOFF_MAX)
   145	    p.add_argument("--drain-timeout", type=float, default=60.0)
   146	    p.add_argument("--tenant-id", default=DEFAULT_TENANT_ID)
   147	    p.add_argument("--app-id", default=DEFAULT_APP_ID)
   148	    p.add_argument("--data-type", default=DEFAULT_DATA_TYPE)
   149	    p.add_argument("--schema-version", default=DEFAULT_SCHEMA_VERSION)
   150	    return p.parse_args()
   151	
   152	
