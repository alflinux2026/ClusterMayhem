   223	def extract_leader(payload):
   224	    if not isinstance(payload, dict):
   225	        return None
   226	    if "result" in payload and isinstance(payload["result"], dict):
   227	        return payload["result"].get("leader")
   228	    return payload.get("leader")
   229	
