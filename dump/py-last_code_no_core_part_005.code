   296	def kill_node(node, seconds=None):
   297	    stat_inc("kill_attempts")
   298	    try:
   299	        resp = requests.post(f"{node}/sleep", timeout=2)
   300	        try:
   301	            payload = resp.json()
   302	        except Exception:
   303	            payload = {"raw_text": resp.text}
   304	        if resp.status_code == 200 and payload.get("ok") is True:
   305	            with dead_lock:
   306	                dead_nodes.add(node)
   307	            stat_inc("kills")
   308	            stat_kill_event(node=node, action="sleep", ok=True, payload=payload, seconds=seconds)
   309	            print(f"[CHAOS] SLEEP {node}")
   310	            return True
   311	        stat_inc("kill_failures")
   312	        stat_kill_event(node=node, action="sleep", ok=False, payload=payload, seconds=seconds)
   313	        print(f"[CHAOS FAIL SLEEP] {node} -> status={resp.status_code} payload={payload}")
   314	        return False
   315	    except Exception as e:
   316	        stat_inc("kill_failures")
   317	        stat_kill_event(node=node, action="sleep", ok=False, error=str(e), seconds=seconds)
   318	        print(f"[CHAOS FAIL SLEEP] {node} -> {e}")
   319	        return False
