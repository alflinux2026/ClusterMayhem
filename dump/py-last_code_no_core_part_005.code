   447	def sender_worker(worker_id):
   448	    while True:
   449	        try:
   450	            run_at, _, pending = pending_queue.get(timeout=0.5)
   451	        except queue.Empty:
   452	            if is_producer_done() and pending_queue.empty():
   453	                return
   454	            continue
   455	        now = time.time()
   456	        if run_at > now:
   457	            pending_queue.put((run_at, next_enqueue_seq(), pending))
   458	            pending_queue.task_done()
   459	            time.sleep(min(run_at - now, 0.2))
   460	            continue
   461	        try:
   462	            process_pending_event(pending, worker_id)
   463	        finally:
   464	            pending_queue.task_done()
