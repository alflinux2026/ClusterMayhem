   234	@dataclass
   235	class PendingEvent:
   236	    """
   237	    Evento pendiente de enviar (con retry).
   238	
   239	    Attributes:
   240	        event_index: Índice del evento (0, 1, 2, ...).
   241	        event (dict): Datos del evento.
   242	        retries_done (int): Número de retries ya hechos.
   243	        tried_nodes (set): Nodos ya intentados para este evento.
   244	        first_enqueued_at (float): Timestamp cuando se encoló por primera vez.
   245	    """
   246	    event_index: int
   247	    event: dict
   248	    retries_done: int = 0
   249	    tried_nodes: set = field(default_factory=set)
   250	    first_enqueued_at: float = field(default_factory=time.time)
   251	
   252	
   253	def build_event(i):
   254	    """
   255	    Construye un evento de chaos test.
   256	
   257	    Args:
   258	        i: Índice del evento.
   259	
   260	    Returns:
   261	        dict: Evento con event_id, trace_id, payload, stream, etc.
   262	    """
   263	    return {"event_id": str(uuid.uuid4()), "trace_id": str(uuid.uuid4()), "event_type": "chaos.test", "payload": {"msg": f"msg-203: {i}", "seq": i, "source": "chaos_203", "run_id": RUN_ID, "stream_id": STREAM_KEY.stream_id()}, "stream": {"tenant_id": STREAM_KEY.tenant_id, "app_id": STREAM_KEY.app_id, "data_type": STREAM_KEY.data_type, "schema_version": STREAM_KEY.schema_version, "stream_id": STREAM_KEY.stream_id()}, "stream_id": STREAM_KEY.stream_id(), "tenant_id": STREAM_KEY.tenant_id, "app_id": STREAM_KEY.app_id, "data_type": STREAM_KEY.data_type, "schema_version": STREAM_KEY.schema_version, "status": "created", "route_hops": [], "source_node": None, "target_node": None, "execution_key": None, "created_at": time.time(), "updated_at": time.time(), "received_at": None, "attempt": 0}
   264	
   265	
   266	def stat_inc(key, amount=1):
   267	    """Incrementa un contador de stats."""
   268	    with stats_lock:
   269	        stats[key] += amount
   270	
   271	
   272	def stat_node_ok(node):
   273	    """Contabiliza un evento OK para un nodo."""
   274	    with stats_lock:
   275	        stats["per_node_ok"][node] += 1
   276	
   277	
   278	def stat_node_fail(node):
   279	    """Contabiliza un evento FAIL para un nodo."""
   280	    with stats_lock:
   281	        stats["per_node_fail"][node] += 1
   282	
   283	
   284	def stat_leader(name):
   285	    """Contabiliza un líder visto."""
   286	    with stats_lock:
   287	        stats["leaders_seen"][name] += 1
   288	
   289	
   290	def stat_latency(ms):
   291	    """Registra una latencia."""
   292	    with stats_lock:
   293	        stats["latency"].append(ms)
   294	
   295	
   296	def stat_unexpected_failure(event_index, attempt, node, status_code=None, payload=None, reason=None):
   297	    """Registra un fallo inesperado."""
   298	    with stats_lock:
   299	        stats["events_unexpected_fail"] += 1
   300	        stats["unexpected_failures"].append({"event_index": event_index, "attempt": attempt, "node": node, "status_code": status_code, "payload": payload, "reason": reason, "timestamp": datetime.now().isoformat()})
   301	
   302	
   303	def stat_slow_event(event_index, attempt, node, latency_ms, leader=None, payload=None):
   304	    """Registra un evento lento."""
   305	    with stats_lock:
   306	        stats["events_slow"] += 1
   307	        stats["slow_events"].append({"event_index": event_index, "attempt": attempt, "node": node, "latency_ms": round(latency_ms, 3), "leader": leader, "payload": payload, "timestamp": datetime.now().isoformat()})
   308	
   309	
   310	def stat_kill_event(node, action, ok, payload=None, error=None, seconds=None):
   311	    """Registra un evento de kill/revive."""
   312	    with stats_lock:
   313	        stats["kill_events"].append({"action": action, "node": node, "ok": ok, "seconds": seconds, "payload": payload, "error": error, "timestamp": datetime.now().isoformat()})
