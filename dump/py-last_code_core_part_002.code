   192	
   193	
   194	def list_replica_log_paths() -> List[str]:
   195	    """
   196	    Lista todas las rutas de logs locales en DATA_DIR.
   197	
   198	    Returns:
   199	        list[str]: Rutas de archivos *.local.000.jsonl.
   200	    """
   201	    if not DATA_DIR.exists():
   202	        return []
   203	
   204	    out: List[str] = []
   205	    for name in sorted(os.listdir(DATA_DIR)):
   206	        if not name.endswith(".local.000.jsonl"):
   207	            continue
   208	        out.append(str(DATA_DIR / name))
   209	    return out
   210	
