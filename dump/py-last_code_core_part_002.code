     1	# File: ./cluster/runtime/bootstrap.py
     2	# Previous: none
     3	# Author: alftorres
     4	# Date: 2026-05-28T17:06:16+0200
     5	# Version: 0.0.0
     6	# Genealogy:
     7	#   ./cluster/runtime/bootstrap.py 0.0.0 2026-05-28T17:06:16+0200
     8	#   God
     9	#
    10	# Purpose:
    11	#   Bootstrap de configuración del nodo.
    12	#   Carga la configuración del cluster desde un archivo nodes.json, identifica
    13	#   cuál es el nodo local (por hostname, NODE_ID, NODE_HOST, o NODE_IP), Extrae
    14	#   la configuración del nodo local y de los peers, y la guarda en config/node.json
    15	#   para uso futuro. Si ya existe config/node.json con el mismo node_id, lo usa
    16	#   (con merge de configuración).
    17	# Notes:
    18	#   - nodes.json define TODOS los nodos del cluster (lista completa)
    19	#   - node.json es la configuración del NODO LOCAL (se genera automáticamente)
    20	#   - Identificación del nodo local por prioridad: NODE_ID > NODE_HOST > NODE_IP > hostname
    21	#   - Escritura atómica de node.json (tmp + rename) para evitar corrupción
    22	#   - Environment vars override: NODE_ID, NODE_HOST, NODE_IP, NODE_PORT, etc.
    23	#   - Si node.json existe y tiene el mismo node_id, se hace merge (no se sobrescribe todo)
    24	#
    25	# FRV-ID: 94320b527b1c5a2b
    26	# Header_End
    27	
    28	import json
    29	import os
    30	import socket
    31	from pathlib import Path
    32	
    33	
    34	def _write_json_atomic(path: str, data: dict) -> None:
    35	    """
    36	    Escribe un dict como JSON de forma atómica.
    37	
    38	    Usa el patrón write-to-temp + rename para evitar corrupción si falla
    39	    la escritura (power failure, crash, etc.).
    40	
    41	    Args:
    42	        path: Ruta del archivo destino.
    43	        data: Dict a escribir como JSON.
    44	
    45	    Note:
    46	        - Crea el directorio padre si no existe
    47	        - Escribe en archivo .tmp y luego hace os.replace()
    48	        - flush() + fsync() aseguran que los datos llegan al disco
    49	        - os.replace() es atómico en casi todos los filesystems
    50	
    51	    Example:
    52	        >>> _write_json_atomic("config/node.json", {"node_id": "lnx203hp"})
    53	        # Crea config/ si no existe, escribe config/node.json.tmp, luego renombra
    54	    """
    55	    p = Path(path)
    56	    p.parent.mkdir(parents=True, exist_ok=True)
    57	    tmp = p.with_suffix(p.suffix + ".tmp")
    58	    with open(tmp, "w", encoding="utf-8") as f:
    59	        json.dump(data, f, ensure_ascii=False, indent=2)
    60	        f.flush()
    61	        os.fsync(f.fileno())
    62	    os.replace(tmp, p)
    63	
    64	
    65	def _node_get(node: dict, *keys, default=None):
    66	    """
    67	    Obtiene el primer valor no-None de un dict buscando varias claves.
    68	
    69	    Útil para soportar nombres alternativos de claves (node_id vs nodeid, etc.).
    70	
    71	    Args:
    72	        node: Dict a buscar.
    73	        *keys: Claves a buscar en orden.
    74	        default: Valor por defecto si ninguna clave existe.
    75	
    76	    Returns:
    77	        El primer valor no-None encontrado, o default.
    78	
    79	    Example:
    80	        >>> node = {"hostname": "lnx203hp", "port": 8000}
    81	        >>> _node_get(node, "node_id", "nodeid", "hostname")
    82	        'lnx203hp'
    83	
    84	        >>> _node_get(node, "port", "bind_port", default=7000)
    85	        8000
    86	
    87	        >>> _node_get(node, "missing", default="fallback")
    88	        'fallback'
    89	    """
    90	    for key in keys:
    91	        if key in node and node[key] is not None:
    92	            return node[key]
    93	    return default
    94	
    95	
    96	def _find_self_node(nodes: list[dict]) -> dict:
    97	    """
    98	    Identifica cuál es el nodo local en la lista de nodos del cluster.
    99	
   100	    Busca por prioridad:
   101	        1. NODE_ID o NODEID env var coincide con node_id
   102	        2. NODE_HOST o NODEHOST env var coincide con host
   103	        3. NODE_IP o NODEIP env var coincide con host
   104	        4. node_id coincide con hostname del sistema
   105	        5. host coincide con hostname del sistema
   106	
   107	    Args:
   108	        nodes: Lista de dicts con info de nodos del cluster.
   109	
   110	    Returns:
   111	        dict: El dict del nodo local.
   112	
   113	    Raises:
   114	        RuntimeError: Si no se puede identificar el nodo local.
   115	
   116	    Example:
   117	        >>> nodes = [
   118	        ...     {"node_id": "lnx203hp", "host": "10.0.0.1", "port": 8000},
   119	        ...     {"node_id": "lnx200nas", "host": "10.0.0.2", "port": 8000}
   120	        ... ]
   121	        >>> _find_self_node(nodes)  # Si hostname es "lnx203hp"
   122	        {"node_id": "lnx203hp", "host": "10.0.0.1", "port": 8000}
   123	
   124	    Note:
   125	        - La identificación es importante para saber qué nodo soy en el cluster
   126	        - Soporta env vars para override en entornos container/Docker/K8s
   127	    """
   128	    hostname = socket.gethostname()
   129	
   130	    node_id_env = os.getenv("NODE_ID") or os.getenv("NODEID")
   131	    host_env = os.getenv("NODE_HOST") or os.getenv("NODEHOST")
   132	    ip_env = os.getenv("NODE_IP") or os.getenv("NODEIP")
   133	
   134	    for node in nodes:
   135	        node_id = _node_get(node, "node_id", "nodeid")
   136	        host = _node_get(node, "host", "hostname", "ip")
   137	
   138	        if node_id_env and node_id == node_id_env:
   139	            return node
   140	        if host_env and host == host_env:
   141	            return node
   142	        if ip_env and host == ip_env:
   143	            return node
   144	        if node_id == hostname:
   145	            return node
   146	        if host == hostname:
   147	            return node
   148	
   149	    raise RuntimeError(
   150	        f"Cannot identify node for hostname={hostname!r} "
   151	        f"env NODE_ID={node_id_env!r} NODE_HOST={host_env!r} NODE_IP={ip_env!r}"
   152	    )
   153	
   154	
   155	def load_or_bootstrap_config():
   156	    """
   157	    Carga o genera la configuración del nodo.
   158	
   159	    Secuencia:
   160	        1. Carga nodes.json (lista completa de nodos del cluster)
   161	        2. Identifica el nodo local (_find_self_node)
   162	        3. Extrae configuración del nodo local y peers
   163	        4. Si node.json existe y tiene el mismo node_id, hace merge y retorna
   164	        5. Si no, genera node.json con la configuración y la retorna
   165	
   166	    Returns:
   167	        dict: Configuración del nodo con:
   168	            - cluster_name (str): Nombre del cluster
   169	            - node_id (str): ID único del nodo
   170	            - priority (int): Prioridad para leader election
   171	            - port (int): Puerto del nodo
   172	            - host (str): Hostname/IP del nodo
   173	            - bind_host (str): Host para bind del servidor
   174	            - bind_port (int): Puerto para bind del servidor
   175	            - tenants_id, app_id, data_type, schema_version (str): Metadatos
   176	            - peers (list[dict]): Lista de peers con node_id, host, port, priority
   177	
   178	    Raises:
   179	        FileNotFoundError: Si nodes.json no existe.
   180	        ValueError: Si nodes.json tiene formato inválido o está vacío.
   181	        RuntimeError: Si no se puede identificar el nodo local.
   182	
   183	    Example:
   184	        >>> config = load_or_bootstrap_config()
   185	        >>> config["node_id"]
   186	        'lnx203hp'
   187	        >>> config["peers"]
   188	        [{'node_id': 'lnx200nas', 'host': '10.0.0.2', 'port': 8000, 'priority': 100}]
   189	
   190	    Note:
   191	        - nodes.json por defecto: cluster/config/nodes.json
   192	        - node.json por defecto: config/node.json
   193	        - Se puede override con env vars: CLUSTER_NODES, CLUSTER_CONFIG
   194	        - Env vars adicionales: NODE_ID, NODE_HOST, NODE_IP, NODE_PORT, TENANT_ID, APP_ID, etc.
   195	    """
   196	    nodes_path = Path(os.getenv("CLUSTER_NODES", "cluster/config/nodes.json"))
   197	    config_path = Path(os.getenv("CLUSTER_CONFIG", "config/node.json"))
   198	
   199	    if not nodes_path.exists():
   200	        raise FileNotFoundError(f"Missing cluster nodes file: {nodes_path}")
   201	
   202	    with open(nodes_path, "r", encoding="utf-8") as f:
   203	        cluster_cfg = json.load(f)
   204	
   205	    if not isinstance(cluster_cfg, dict):
   206	        raise ValueError(f"Invalid cluster nodes file: {nodes_path}")
   207	
   208	    nodes = cluster_cfg.get("nodes", [])
   209	    if not isinstance(nodes, list) or not nodes:
   210	        raise ValueError(f"Empty node list in: {nodes_path}")
   211	
   212	    self_node = _find_self_node(nodes)
   213	
   214	    self_node_id = _node_get(self_node, "node_id", "nodeid")
   215	    self_priority = int(_node_get(self_node, "priority", default=100))
   216	    self_host = _node_get(self_node, "host", "hostname", "ip", default=os.getenv("NODE_HOST", "0.0.0.0"))
   217	    self_port = int(_node_get(self_node, "port", default=os.getenv("NODE_PORT", "8000")))
   218	    self_bind_host = _node_get(self_node, "bind_host", default=self_host)
   219	    self_bind_port = int(_node_get(self_node, "bind_port", default=self_port))
   220	
   221	    peers = []
   222	    for n in nodes:
   223	        peer_node_id = _node_get(n, "node_id", "nodeid")
   224	        if peer_node_id == self_node_id:
   225	            continue
   226	        peers.append({
   227	            "node_id": peer_node_id,
   228	            "host": _node_get(n, "host", "hostname", "ip"),
   229	            "port": int(_node_get(n, "port")),
   230	            "priority": int(_node_get(n, "priority", default=100)),
   231	        })
   232	
   233	    cfg = {
   234	        "cluster_name": cluster_cfg.get("cluster_name", "mayhem-cluster"),
   235	        "node_id": self_node_id,
   236	        "priority": self_priority,
   237	        "port": self_port,
   238	        "host": self_host,
   239	        "bind_host": self_bind_host,
   240	        "bind_port": self_bind_port,
   241	        "tenant_id": os.getenv("TENANT_ID", "default"),
   242	        "app_id": os.getenv("APP_ID", "mayhem"),
   243	        "data_type": os.getenv("DATA_TYPE", "event"),
   244	        "schema_version": os.getenv("SCHEMA_VERSION", "0.1"),
   245	        "peers": peers,
   246	    }
   247	
   248	    if config_path.exists():
   249	        try:
   250	            with open(config_path, "r", encoding="utf-8") as f:
   251	                existing = json.load(f)
   252	            if isinstance(existing, dict) and existing.get("node_id") == cfg["node_id"]:
   253	                merged = {**existing, **cfg}
   254	                merged["peers"] = cfg["peers"]
   255	                return merged
   256	        except (json.JSONDecodeError, OSError):
   257	            pass
   258	
   259	    _write_json_atomic(str(config_path), cfg)
   260	    return cfg


