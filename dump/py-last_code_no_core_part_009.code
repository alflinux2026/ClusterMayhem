   254	def percentile(data, p):
   255	    if not data:
   256	        return 0.0
   257	    values = sorted(data)
   258	    if len(values) == 1:
   259	        return float(values[0])
   260	    rank = (len(values) - 1) * (p / 100.0)
   261	    low = int(rank)
   262	    high = min(low + 1, len(values) - 1)
   263	    fraction = rank - low
   264	    return float(values[low] + (values[high] - values[low]) * fraction)
