   267	def is_retryable_response(payload):
   268	    if not isinstance(payload, dict):
   269	        return False
   270	    if payload.get("error") in {"no leader", "node isolated"}:
   271	        return True
   272	    error = str(payload.get("error", "")).lower()
   273	    retry_patterns = ["timeout", "connection", "refused", "temporarily unavailable", "isolated", "no leader"]
   274	    return any(p in error for p in retry_patterns)
   275	
   276	
   277	def extract_leader(payload):
   278	    if not isinstance(payload, dict):
   279	        return None
   280	    if "result" in payload and isinstance(payload["result"], dict):
   281	        return payload["result"].get("leader")
   282	    return payload.get("leader")
   283	
   284	
   285	def classify_submit_response(status_code, payload):
   286	    if status_code != 200:
   287	        return "http_not_ok"
   288	    if not isinstance(payload, dict):
   289	        return "submit_ok"
   290	    if payload.get("error"):
   291	        if is_retryable_response(payload):
   292	            return "retryable_error"
   293	        return "hard_fail"
   294	    result = payload.get("result")
   295	    if isinstance(result, dict) and result.get("error"):
   296	        if is_retryable_response(result):
   297	            return "retryable_error"
   298	        return "hard_fail"
   299	    return "submit_ok"
