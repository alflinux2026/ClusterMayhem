===== ./cluster/workers/cluster_worker.py =====
     1	import time
     2	
     3	from cluster.transport.server import register_local_node
     4	
     5	class ClusterWorker:
     6	
     7	    def __init__(self, node, peers, interval=1.0):
     8	
     9	        self.node = node
    10	        self.peers = peers
    11	        self.interval = interval
    12	        self.running = False
    13	
    14	    # -----------------------------------------
    15	
    16	    def start(self):
    17	
    18	        self.running = True
    19	
    20	        print(f"[{self.node.node_id}] CLUSTER WORKER STARTED")
    21	
    22	        while self.running:
    23	
    24	            self.tick()
    25	
    26	            time.sleep(self.interval)
    27	
    28	    # -----------------------------------------
    29	
    30	    def stop(self):
    31	
    32	        self.running = False
    33	
    34	    # -----------------------------------------
    35	
    36	    def tick(self):
    37	
    38	        print(f"[{self.node.node_id}] REGISTERING SELF")
    39	
    40	        # 👇 registrar self localmente
    41	        register_local_node(
    42	            node_id=self.node.node_id,
    43	            state=self.node.state.value,
    44	            priority=self.node.priority,
    45	        )
    46	
    47	        # 👇 enviar a peers
    48	        self.node.emit_heartbeat(self.peers)


===== ./cluster/workers/heartbeat_worker.py =====
     1	import time
     2	from cluster.runtime.state import NodeState
     3	
     4	
     5	class HeartbeatWorker:
     6	
     7	    def __init__(self, nodes, lease_manager, interval=1.0):
     8	
     9	        self.nodes = nodes
    10	        self.lease_manager = lease_manager
    11	        self.interval = interval
    12	
    13	    # -----------------------------------------------------
    14	
    15	    def start(self, ticks=5):
    16	
    17	        print("\n=== HEARTBEAT START ===\n")
    18	
    19	        for i in range(ticks):
    20	
    21	            print(f"\n--- tick {i} ---\n")
    22	
    23	            self.tick()
    24	
    25	            time.sleep(self.interval)
    26	
    27	    # -----------------------------------------------------
    28	
    29	    def tick(self):
    30	
    31	        self.send_heartbeats()
    32	        self.expire_leases()
    33	        self.update_nodes()
    34	
    35	    # -----------------------------------------------------
    36	
    37	    def send_heartbeats(self):
    38	
    39	        for node in self.nodes:
    40	
    41	            if node.state == NodeState.ACTIVE:
    42	
    43	                self.lease_manager.grant(
    44	                    node.node_id,
    45	                    ttl=2.5
    46	                )
    47	
    48	                print(f"HEARTBEAT from {node.node_id}")
    49	
    50	    # -----------------------------------------------------
    51	
    52	    def expire_leases(self):
    53	
    54	        expired = self.lease_manager.expire()
    55	
    56	        for node_id in expired:
    57	
    58	            print(f"LEASE EXPIRED: {node_id}")
    59	
    60	    # -----------------------------------------------------
    61	
    62	    def update_nodes(self):
    63	
    64	        for node in self.nodes:
    65	
    66	            node.tick()
    67	
    68	            lease_valid = self.lease_manager.is_valid(
    69	                node.node_id
    70	            )
    71	
    72	            # ACTIVE sin lease → degradación lógica
    73	            if node.state == NodeState.ACTIVE and not lease_valid:
    74	
    75	                print(
    76	                    f"ACTIVE LOST LEASE: {node.node_id}"
    77	                )
    78	
    79	                node.transition(NodeState.DEGRADED)


