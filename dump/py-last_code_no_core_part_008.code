   651	def sender_worker(worker_id):
   652	    while True:
   653	        try:
   654	            run_at, _, pending = pending_queue.get(timeout=0.5)
   655	        except queue.Empty:
   656	            if is_producer_done() and pending_queue.empty():
   657	                return
   658	            continue
   659	
   660	        now = time.time()
   661	        if run_at > now:
   662	            pending_queue.put((run_at, next_enqueue_seq(), pending))
   663	            pending_queue.task_done()
   664	            time.sleep(min(run_at - now, 0.2))
   665	            continue
   666	
   667	        try:
   668	            process_pending_event(pending)
   669	        finally:
   670	            pending_queue.task_done()
