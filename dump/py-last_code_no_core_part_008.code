   337	def enqueue_pending(pending, delay_seconds=0.0):
   338	    run_at = time.time() + max(0.0, delay_seconds)
   339	    pending_queue.put((run_at, next_enqueue_seq(), pending))
   340	    with stats_lock:
   341	        depth = pending_queue.qsize()
   342	        if depth > stats["queue_max_depth"]:
   343	            stats["queue_max_depth"] = depth
   344	
