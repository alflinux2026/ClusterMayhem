   875	                "ended_at_iso": datetime.fromtimestamp(ended_at).isoformat(),
   876	                "duration_seconds": round(ended_at - TEST_STARTED_AT, 3),
   877	            },
   878	            "stats": {
   879	                **stats,
   880	                "success_rate": round(success_rate, 2),
   881	                "latency_avg": round(avg_latency, 3),
   882	                "latency_min": round(min_latency, 3),
   883	                "latency_p50": round(p50_latency, 3),
   884	                "latency_p95": round(p95_latency, 3),
   885	                "latency_p99": round(p99_latency, 3),
   886	                "latency_max": round(max_latency, 3),
