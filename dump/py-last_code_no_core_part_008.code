   862	            if len(stats["unexpected_failures"]) > 20:
   863	                print(f"  ... and {len(stats['unexpected_failures']) - 20} more")
   864	        else:
   865	            print("  none")
   866	
   867	        print("=" * 56)
   868	
   869	        report = {
   870	            "test_config": TEST_CONFIG,
   871	            "run_meta": {
