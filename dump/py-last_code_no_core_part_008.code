   888	                "per_node_fail": dict(stats["per_node_fail"]),
   889	                "leaders_seen": dict(stats["leaders_seen"]),
   890	            }
   891	        }
   892	
   893	        with open(STATS_FILE, "w") as f:
   894	            json.dump(report, f, indent=2)
   895	
   896	        print(f"\n[MAIN] stats saved to {STATS_FILE}\n")
   897	
