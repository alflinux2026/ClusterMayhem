   278	def is_retryable_response(payload):
   279	    if not isinstance(payload, dict):
   280	        return False
   281	
   282	    if payload.get("error") in {"no leader", "node isolated"}:
   283	        return True
   284	
   285	    error = str(payload.get("error", "")).lower()
   286	
   287	    retry_patterns = [
   288	        "timeout",
   289	        "connection",
   290	        "refused",
   291	        "temporarily unavailable",
   292	        "isolated",
   293	        "no leader",
   294	    ]
   295	
   296	    return any(p in error for p in retry_patterns)
   297	
   298	
   299	def extract_leader(payload):
   300	    if not isinstance(payload, dict):
   301	        return None
   302	
   303	    if "result" in payload and isinstance(payload["result"], dict):
   304	        return payload["result"].get("leader")
   305	
   306	    return payload.get("leader")
   307	
