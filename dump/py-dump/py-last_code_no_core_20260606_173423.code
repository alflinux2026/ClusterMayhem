     1	# File: ./cluster/runtime/node_boot.py
     2	# Previous: none
     3	# Author: alftorres
     4	# Date: 2026-05-28T17:10:49+0200
     5	# Version: 0.0.0
     6	# Genealogy:
     7	#   ./cluster/runtime/node_boot.py 0.0.0 2026-05-28T17:10:49+0200
     8	#   God
     9	#
    10	# Purpose:
    11	#   Entry point del nodo del cluster.
    12	#   Arranca el nodo: carga configuración, inicializa contexto global, crea NodeRuntime,
    13	#   registra el nodo y peers en el registry, arranca el worker en background,
    14	#   y sirve la API HTTP con uvicorn.
    15	# Notes:
    16	#   - Este es el archivo que se ejecuta con `python -m cluster.runtime.node_boot`
    17	#   - La configuración viene de bootstrap.py (config.json o env vars)
    18	#   - El worker se ejecuta en un hilo separado (daemon thread)
    19	#   - uvicorn es el servidor HTTP que sirve api_app.py (FastAPI)
    20	#   - El bloque __main__ permite ejecutar el script directamente o como módulo
    21	#
    22	# FRV-ID: 05bb09170fc30a8f
    23	# Header_End
    24	
    25	import uvicorn
    26	
    27	from cluster.runtime.node_worker import NodeWorker
    28	from cluster.runtime.node_runtime import NodeRuntime
    29	from cluster.runtime.bootstrap import load_or_bootstrap_config
    30	from cluster.runtime.registry import register_node
    31	from cluster.runtime.event_log import ensure_initial_files
    32	from cluster.runtime import context as ctx
    33	from cluster.runtime.api_app import app
    34	from cluster.utils.log_print import log_state
    35	
    36	
    37	def run_node(config):
    38	    """
    39	    Arranca un nodo del cluster.
    40	
    41	    Secuencia de inicialización:
    42	        1. Crea archivos iniciales de event log (si no existen)
    43	        2. Inicializa contexto global (ctx.node_id, ctx.node, ctx.peers, ...)
    44	        3. Crea NodeRuntime (nodo local, estado BOOT)
    45	        4. Registra nodo local y peers en CLUSTER_REGISTRY
    46	        5. Arranca NodeWorker en hilo background
    47	        6. Arranca uvicorn (servidor HTTP)
    48	
    49	    Args:
    50	        config (dict): Configuración del nodo con:
    51	            - node_id (str): ID único del nodo
    52	            - priority (int): Prioridad para leader election
    53	            - host (str): Hostname/IP del nodo
    54	            - port (int): Puerto del nodo
    55	            - bind_host (str): Host para bind del servidor HTTP (default: 0.0.0.0)
    56	            - bind_port (int): Puerto para bind del servidor HTTP (default: 7000)
    57	            - peers (list[dict]): Lista de peers con node_id, host, port, priority
    58	
    59	    Example:
    60	        >>> config = {
    61	        ...     "node_id": "lnx203hp",
    62	        ...     "priority": 10,
    63	        ...     "host": "100.100.1.200",
    64	        ...     "port": 8000,
    65	        ...     "bind_host": "0.0.0.0",
    66	        ...     "bind_port": 7000,
    67	        ...     "peers": [
    68	        ...         {"node_id": "lnx200nas", "host": "100.100.1.201", "port": 8000, "priority": 100}
    69	        ...     ]
    70	        ... }
    71	        >>> run_node(config)
    72	        # Arranca el nodo lnx203hp con peer lnx200nas
    73	    """
    74	    ensure_initial_files()
    75	
    76	    ctx.node_id = config["node_id"]
    77	    ctx.nodeid = config["node_id"]
    78	    ctx.priority = config["priority"]
    79	    ctx.peers = config.get("peers", [])
    80	
    81	    node = NodeRuntime(
    82	        node_id=config["node_id"],
    83	        priority=config["priority"],
    84	    )
    85	    ctx.node = node
    86	
    87	    register_node(
    88	        node_id=config["node_id"],
    89	        host=config["host"],
    90	        port=config["port"],
    91	        priority=config["priority"],
    92	    )
    93	
    94	    for peer in config.get("peers", []):
    95	        register_node(
    96	            node_id=peer["node_id"],
    97	            host=peer["host"],
    98	            port=peer["port"],
    99	            priority=peer["priority"],
   100	        )
   101	
   102	    log_state(
   103	        "cyan",
   104	        "[BOOT]",
   105	        (
   106	            f"node={config['node_id']} "
   107	            f"priority={config['priority']} "
   108	            f"bind={config.get('bind_host', '0.0.0.0')}:{config.get('bind_port', 7000)} "
   109	            f"peers={len(config.get('peers', []))} "
   110	            f"state={node.state.value} "
   111	            f"state_since={getattr(node, 'state_since', None)} "
   112	            f"reason={getattr(node, 'state_reason', None)}"
   113	        ),
   114	        3,
   115	    )
   116	
   117	    worker = NodeWorker(
   118	        node=node,
   119	        peers=config["peers"],
   120	        interval=1.0,
   121	    )
   122	    worker.start()
   123	
   124	    log_state("green", "[WORKER]", f"background loop started for {config['node_id']}", 3)
   125	    log_state(
   126	        "green",
   127	        "[HTTP]",
   128	        f"serving app on {config.get('bind_host', '0.0.0.0')}:{config.get('bind_port', 7000)}",
   129	        3,
   130	    )
   131	
   132	    uvicorn.run(
   133	        app,
   134	        host=config.get("bind_host", "0.0.0.0"),
   135	        port=config.get("bind_port", 7000),
   136	        log_level="warning",
   137	        access_log=False,
   138	    )
   139	
   140	
   141	if __name__ == "__main__":
   142	    """
   143	    Entry point cuando se ejecuta el script directamente.
   144	
   145	    Carga la configuración (de config.json o env vars) y arranca el nodo.
   146	
   147	    Example:
   148	        # Ejecutar como script
   149	        $ python cluster/runtime/node_boot.py
   150	
   151	        # Ejecutar como módulo
   152	        $ python -m cluster.runtime.node_boot
   153	    """
   154	    config = load_or_bootstrap_config()
   155	    run_node(config)


