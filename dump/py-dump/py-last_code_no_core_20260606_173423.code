   355	
   356	def process_pending_event(pending: PendingEvent, worker_id: int):
   357	    i = pending.event_index
   358	    event = pending.event
   359	    attempt_number = pending.retries_done + 1
   360	    available = [n for n in NODES if n not in pending.tried_nodes]
   361	    if not available:
   362	        pending.tried_nodes.clear()
   363	        available = list(NODES)
   364	    node = random.choice(available)
   365	    pending.tried_nodes.add(node)
   366	    start = time.time()
   367	    session = get_session(worker_id)
   368	    try:
   369	        r = session.post(f"{node}/event", json=event, timeout=REQUEST_TIMEOUT)
   370	        elapsed_ms = (time.time() - start) * 1000
   371	        stat_latency(elapsed_ms)
   372	        try:
   373	            payload = r.json()
   374	        except Exception:
   375	            payload = {"raw_text": r.text}
   376	        leader = extract_leader(payload)
   377	        if leader:
   378	            stat_leader(leader)
   379	        if elapsed_ms >= SLOW_EVENT_THRESHOLD_MS:
   380	            stat_slow_event(i, attempt_number, node, elapsed_ms, leader, payload)
   381	        if r.status_code == 200:
   382	            stat_inc("submit_http_200")
   383	        result = classify_submit_response(r.status_code, payload)
   384	        row = {"event_index": i, "attempt": attempt_number, "node": node, "status_code": r.status_code, "elapsed_ms": round(elapsed_ms, 3), "leader": leader, "result": result, "final": None}
   385	        if result == "submit_ok":
   386	            stat_inc("events_ok")
   387	            stat_inc("submit_semantic_ok")
   388	            stat_node_ok(node)
   389	            row["final"] = "ok"
   390	            with results_lock:
   391	                results.append(row)
   392	            print(f"[TORTURE] {i:03} OK attempt={attempt_number} node={node} leader={leader} latency={elapsed_ms:.1f}ms")
   393	            return True
   394	        if result == "retryable_error" or r.status_code >= 500:
   395	            stat_inc("events_retried")
   396	            if isinstance(payload, dict) and payload.get("error") == "no leader":
   397	                stat_inc("events_no_leader")
   398	            result_payload = payload.get("result") if isinstance(payload.get("result"), dict) else None
   399	            if isinstance(result_payload, dict) and result_payload.get("error") == "no leader":
   400	                stat_inc("events_no_leader")
   401	            row["final"] = "retry"
   402	            with results_lock:
   403	                results.append(row)
   404	            print(f"[RETRY] {i:03} attempt={attempt_number} node={node} status={r.status_code} payload={payload}")
   405	            if pending.retries_done + 1 >= MAX_RETRIES:
   406	                stat_inc("events_failed")
   407	                stat_unexpected_failure(i, attempt_number, node, r.status_code, payload, "dropped_after_retries_retryable_response")
   408	                print(f"[DROP] {i:03} event dropped after retries")
   409	                return False
   410	            pending.retries_done += 1
   411	            stat_inc("queue_requeues")
   412	            enqueue_pending(pending, compute_retry_backoff(pending.retries_done))
   413	            return False
   414	        stat_inc("events_failed")
   415	        stat_inc("submit_hard_fail")
   416	        stat_node_fail(node)
   417	        stat_unexpected_failure(i, attempt_number, node, r.status_code, payload, "hard_fail_non_retryable_response")
   418	        row["final"] = "hard_fail"
   419	        with results_lock:
   420	            results.append(row)
   421	        print(f"[FAIL] {i:03} attempt={attempt_number} node={node} status={r.status_code} payload={payload}")
   422	        return False
   423	    except requests.Timeout as e:
   424	        stat_inc("events_timeout")
   425	        stat_inc("events_retried")
   426	        print(f"[TIMEOUT] {i:03} attempt={attempt_number} {node} -> {e}")
   427	    except requests.ConnectionError as e:
   428	        stat_inc("events_connection_error")
   429	        stat_inc("events_retried")
   430	        print(f"[CONNECTION] {i:03} attempt={attempt_number} {node} -> {e}")
   431	    except Exception as e:
   432	        stat_inc("events_forward_error")
   433	        stat_inc("events_retried")
   434	        stat_unexpected_failure(i, attempt_number, node, reason=f"exception:{type(e).__name__}", payload={"exception": str(e)})
   435	        print(f"[ERROR] {i:03} attempt={attempt_number} {node} -> {e}")
   436	    if pending.retries_done + 1 >= MAX_RETRIES:
   437	        stat_inc("events_failed")
   438	        stat_unexpected_failure(i, attempt_number, node, reason="dropped_after_retries_exception", payload={"tried_nodes": list(pending.tried_nodes)})
   439	        print(f"[DROP] {i:03} event dropped after retries")
   440	        return False
   441	    pending.retries_done += 1
   442	    stat_inc("queue_requeues")
   443	    enqueue_pending(pending, compute_retry_backoff(pending.retries_done))
   444	    return False
   445	
   446	
   447	def sender_worker(worker_id):
   448	    while True:
   449	        try:
   450	            run_at, _, pending = pending_queue.get(timeout=0.5)
   451	        except queue.Empty:
   452	            if is_producer_done() and pending_queue.empty():
   453	                return
   454	            continue
   455	        now = time.time()
   456	        if run_at > now:
   457	            pending_queue.put((run_at, next_enqueue_seq(), pending))
   458	            pending_queue.task_done()
   459	            time.sleep(min(run_at - now, 0.2))
   460	            continue
   461	        try:
   462	            process_pending_event(pending, worker_id)
   463	        finally:
   464	            pending_queue.task_done()
   465	
   466	
   467	def chaos_loop():
   468	    for i in range(EVENTS):
   469	        if random.random() < KILL_PROBABILITY:
   470	            node = SLEEP_ONLY_NODE if SLEEP_ONLY_NODE else random.choice(NODES)
   471	            seconds = random.uniform(*DEATH_TIME_RANGE)
   472	            t = threading.Thread(target=kill_cycle, args=(node, seconds), daemon=True)
   473	            t.start()
   474	            kill_threads.append(t)
   475	        stat_inc("events_total")
   476	        enqueue_pending(PendingEvent(event_index=i, event=build_event(i)), delay_seconds=0.0)
   477	        time.sleep(random.uniform(*EVENT_DELAY_RANGE))
   478	    mark_producer_done()
   479	
   480	
   481	def revive_everything():
   482	    print("\\n[MAIN] REVIVING ALL NODES\\n")
   483	    for node in sorted(set(NODES)):
   484	        try:
   485	            requests.post(f"{node}/revive", timeout=2)
   486	            print(f"[FORCE REVIVE] {node}")
   487	        except Exception as e:
   488	            print(f"[FORCE REVIVE FAIL] {node} -> {e}")
   489	
   490	
   491	def wait_kills():
   492	    print("\\n[MAIN] waiting active kill cycles...\\n")
   493	    for t in kill_threads:
   494	        t.join(timeout=30)
   495	
   496	
   497	def wait_queue_drain():
   498	    deadline = time.time() + DRAIN_TIMEOUT
   499	    while time.time() < deadline:
   500	        if pending_queue.empty():
   501	            time.sleep(0.5)
   502	            if pending_queue.empty():
   503	                return True
   504	        time.sleep(0.2)
   505	    return False
   506	
   507	
   508	def write_csv_and_json():
   509	    with results_lock:
   510	        rows = list(results)
   511	    with open(EVENTS_CSV, "w", newline="", encoding="utf-8") as f:
   512	        writer = csv.DictWriter(f, fieldnames=["event_index", "attempt", "node", "status_code", "elapsed_ms", "leader", "result", "final"])
   513	        writer.writeheader()
   514	        writer.writerows(rows)
   515	    with stats_lock:
   516	        total = stats["events_total"]
   517	        ok = stats["events_ok"]
   518	        failed = stats["events_failed"]
   519	        success_rate = ((ok / total) * 100) if total else 0
   520	        avg_latency = (sum(stats["latency"]) / len(stats["latency"])) if stats["latency"] else 0
   521	        max_latency = max(stats["latency"]) if stats["latency"] else 0
   522	        min_latency = min(stats["latency"]) if stats["latency"] else 0
   523	        p50_latency = percentile(stats["latency"], 50)
   524	        p95_latency = percentile(stats["latency"], 95)
   525	        p99_latency = percentile(stats["latency"], 99)
   526	        report = {"test_config": TEST_CONFIG, "run_meta": {"started_at_epoch": TEST_STARTED_AT, "ended_at_epoch": time.time(), "started_at_iso": datetime.fromtimestamp(TEST_STARTED_AT).isoformat(), "ended_at_iso": datetime.now().isoformat(), "duration_seconds": round(time.time() - TEST_STARTED_AT, 3)}, "stats": {**stats, "success_rate": round(success_rate, 2), "latency_avg": round(avg_latency, 3), "latency_min": round(min_latency, 3), "latency_p50": round(p50_latency, 3), "latency_p95": round(p95_latency, 3), "latency_p99": round(p99_latency, 3), "latency_max": round(max_latency, 3), "per_node_ok": dict(stats["per_node_ok"]), "per_node_fail": dict(stats["per_node_fail"]), "leaders_seen": dict(stats["leaders_seen"]), "results_csv": str(EVENTS_CSV)}}
   527	    with open(STATS_FILE, "w", encoding="utf-8") as f:
   528	        json.dump(report, f, indent=2, ensure_ascii=False)
   529	
   530	
   531	def print_stats():
   532	    with stats_lock:
   533	        total = stats["events_total"]
   534	        ok = stats["events_ok"]
   535	        failed = stats["events_failed"]
   536	        success_rate = ((ok / total) * 100) if total else 0
   537	        avg_latency = (sum(stats["latency"]) / len(stats["latency"])) if stats["latency"] else 0
   538	        max_latency = max(stats["latency"]) if stats["latency"] else 0
   539	        min_latency = min(stats["latency"]) if stats["latency"] else 0
   540	        p50_latency = percentile(stats["latency"], 50)
   541	        p95_latency = percentile(stats["latency"], 95)
   542	        p99_latency = percentile(stats["latency"], 99)
   543	    print("\\n" + "=" * 56)
   544	    print("FINAL CHAOS STATS")
   545	    print("=" * 56)
   546	    print(f"events_total........: {total}")
   547	    print(f"events_ok...........: {ok}")
   548	    print(f"events_failed.......: {failed}")
   549	    print(f"success_rate........: {success_rate:.2f}%")
   550	    print(f"latency_avg.........: {avg_latency:.1f} ms")
   551	    print(f"latency_min.........: {min_latency:.1f} ms")
   552	    print(f"latency_p50.........: {p50_latency:.1f} ms")
   553	    print(f"latency_p95.........: {p95_latency:.1f} ms")
   554	    print(f"latency_p99.........: {p99_latency:.1f} ms")
   555	    print(f"latency_max.........: {max_latency:.1f} ms")
   556	    print(f"stats_file..........: {STATS_FILE}")
   557	    print(f"events_csv..........: {EVENTS_CSV}")
   558	    print("=" * 56)
   559	
   560	
   561	def main():
   562	    print(f"[MAIN] starting UNIVERSAL chaos torture final v2 ({ARGS.mode})")
   563	    print_test_config()
   564	    workers = []
   565	    for idx in range(SEND_WORKERS):
   566	        t = threading.Thread(target=sender_worker, args=(idx,), daemon=True)
   567	        t.start()
   568	        workers.append(t)
   569	    drained = False
   570	    try:
   571	        chaos_loop()
   572	        drained = wait_queue_drain()
   573	        pending_queue.join()
   574	        for t in workers:
   575	            t.join(timeout=5)
   576	    finally:
   577	        wait_kills()
   578	        revive_everything()
   579	        if not drained:
   580	            print(f"\\n[MAIN WARN] queue drain timeout reached after {DRAIN_TIMEOUT:.1f}s\\n")
   581	        write_csv_and_json()
   582	        print_stats()
   583	        print("\\n[MAIN] cluster restored\\n")
   584	
   585	
   586	if __name__ == "__main__":
   587	    main()


