   464	# =====================================================
   465	# EVENT PROCESSING
   466	# =====================================================
   467	
   468	def process_pending_event(pending: PendingEvent):
   469	    i = pending.event_index
   470	    event = pending.event
   471	    attempt_number = pending.retries_done + 1
   472	
   473	    available = [n for n in NODES if n not in pending.tried_nodes]
   474	
   475	    if not available:
   476	        pending.tried_nodes.clear()
   477	        available = list(NODES)
   478	
   479	    node = random.choice(available)
   480	    pending.tried_nodes.add(node)
   481	    start = time.time()
   482	
   483	    try:
   484	        r = requests.post(
   485	            f"{node}/event",
   486	            json=event,
   487	            timeout=REQUEST_TIMEOUT
   488	        )
   489	
   490	        elapsed_ms = (time.time() - start) * 1000
   491	        stat_latency(elapsed_ms)
   492	
   493	        payload = {}
   494	        try:
   495	            payload = r.json()
   496	        except Exception:
   497	            payload = {"raw_text": r.text}
   498	
   499	        leader = extract_leader(payload)
   500	        if leader:
   501	            stat_leader(leader)
   502	
   503	        if elapsed_ms >= SLOW_EVENT_THRESHOLD_MS:
   504	            stat_slow_event(
   505	                event_index=i,
   506	                attempt=attempt_number,
   507	                node=node,
   508	                latency_ms=elapsed_ms,
   509	                leader=leader,
   510	                payload=payload,
   511	            )
   512	
   513	        if r.status_code == 200:
   514	            stat_inc("submit_http_200")
   515	
   516	        result = classify_submit_response(r.status_code, payload)
   517	
   518	        if result == "submit_ok":
   519	            stat_inc("events_ok")
   520	            stat_inc("submit_semantic_ok")
   521	            stat_node_ok(node)
   522	
   523	            print(
   524	                f"[TORTURE] "
   525	                f"{i:03} "
   526	                f"OK "
   527	                f"attempt={attempt_number} "
   528	                f"node={node} "
   529	                f"leader={leader} "
   530	                f"latency={elapsed_ms:.1f}ms"
   531	            )
   532	            return True
   533	
   534	        if result == "retryable_error" or r.status_code >= 500:
   535	            stat_inc("events_retried")
   536	
   537	            if isinstance(payload, dict) and payload.get("error") == "no leader":
   538	                stat_inc("events_no_leader")
   539	
   540	            result_payload = payload.get("result") if isinstance(payload.get("result"), dict) else None
   541	            if isinstance(result_payload, dict) and result_payload.get("error") == "no leader":
   542	                stat_inc("events_no_leader")
   543	
   544	            print(
   545	                f"[RETRY] "
   546	                f"{i:03} "
   547	                f"attempt={attempt_number} "
   548	                f"node={node} "
   549	                f"status={r.status_code} "
   550	                f"payload={payload}"
   551	            )
   552	
   553	            if pending.retries_done + 1 >= MAX_RETRIES:
   554	                stat_inc("events_failed")
   555	                stat_unexpected_failure(
   556	                    event_index=i,
   557	                    attempt=attempt_number,
   558	                    node=node,
   559	                    status_code=r.status_code,
   560	                    payload=payload,
   561	                    reason="dropped_after_retries_retryable_response",
   562	                )
   563	                print(f"[DROP] {i:03} event dropped after retries")
   564	                return False
   565	
   566	            pending.retries_done += 1
   567	            stat_inc("queue_requeues")
   568	            enqueue_pending(pending, compute_retry_backoff(pending.retries_done))
   569	            return False
   570	
   571	        stat_inc("events_failed")
   572	        stat_inc("submit_hard_fail")
   573	        stat_node_fail(node)
   574	        stat_unexpected_failure(
   575	            event_index=i,
   576	            attempt=attempt_number,
   577	            node=node,
   578	            status_code=r.status_code,
   579	            payload=payload,
   580	            reason="hard_fail_non_retryable_response",
   581	        )
   582	
   583	        print(
   584	            f"[FAIL] "
   585	            f"{i:03} "
   586	            f"attempt={attempt_number} "
   587	            f"node={node} "
   588	            f"status={r.status_code} "
   589	            f"payload={payload}"
   590	        )
   591	        return False
   592	
   593	    except requests.Timeout as e:
   594	        stat_inc("events_timeout")
   595	        stat_inc("events_retried")
   596	
   597	        print(
   598	            f"[TIMEOUT] "
   599	            f"{i:03} "
   600	            f"attempt={attempt_number} "
   601	            f"{node} -> {e}"
   602	        )
   603	
   604	    except requests.ConnectionError as e:
   605	        stat_inc("events_connection_error")
   606	        stat_inc("events_retried")
   607	
   608	        print(
   609	            f"[CONNECTION] "
   610	            f"{i:03} "
   611	            f"attempt={attempt_number} "
   612	            f"{node} -> {e}"
   613	        )
   614	
   615	    except Exception as e:
   616	        stat_inc("events_forward_error")
   617	        stat_inc("events_retried")
   618	        stat_unexpected_failure(
   619	            event_index=i,
   620	            attempt=attempt_number,
   621	            node=node,
   622	            reason=f"exception:{type(e).__name__}",
   623	            payload={"exception": str(e)},
   624	        )
   625	
   626	        print(
   627	            f"[ERROR] "
   628	            f"{i:03} "
   629	            f"attempt={attempt_number} "
   630	            f"{node} -> {e}"
   631	        )
   632	
   633	    if pending.retries_done + 1 >= MAX_RETRIES:
   634	        stat_inc("events_failed")
   635	        stat_unexpected_failure(
   636	            event_index=i,
   637	            attempt=attempt_number,
   638	            node=node,
   639	            reason="dropped_after_retries_exception",
   640	            payload={"tried_nodes": list(pending.tried_nodes)},
   641	        )
   642	        print(f"[DROP] {i:03} event dropped after retries")
   643	        return False
   644	
   645	    pending.retries_done += 1
   646	    stat_inc("queue_requeues")
   647	    enqueue_pending(pending, compute_retry_backoff(pending.retries_done))
   648	    return False
   649	
   650	
   651	def sender_worker(worker_id):
   652	    while True:
   653	        try:
   654	            run_at, _, pending = pending_queue.get(timeout=0.5)
   655	        except queue.Empty:
   656	            if is_producer_done() and pending_queue.empty():
   657	                return
   658	            continue
   659	
   660	        now = time.time()
   661	        if run_at > now:
   662	            pending_queue.put((run_at, next_enqueue_seq(), pending))
   663	            pending_queue.task_done()
   664	            time.sleep(min(run_at - now, 0.2))
   665	            continue
   666	
   667	        try:
   668	            process_pending_event(pending)
   669	        finally:
   670	            pending_queue.task_done()
   671	
