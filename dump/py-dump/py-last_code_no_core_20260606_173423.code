     1	# File: ./cluster/runtime/event_log.py
     2	# Previous: none
     3	# Author: alftorres
     4	# Date: 2026-05-28T17:08:01+0200
     5	# Version: 0.0.0
     6	# Genealogy:
     7	#   ./cluster/runtime/event_log.py 0.0.0 2026-05-28T17:08:01+0200
     8	#   God
     9	#
    10	# Purpose:
    11	#   Almacenamiento y gestión del event log del cluster.
    12	#   Guarda eventos en archivos JSONL (one event per line), proporciona funciones
    13	#   para cargar, filtrar, y appendear eventos. Mantiene dos logs:
    14	#     - event_log.local.000.jsonl: eventos activos (CREATED, EXECUTING)
    15	#     - events.local.000.jsonl: eventos completados (COMPLETED)
    16	#   También gestiona el estado (dirty flags, last_append metadata) y la
    17	#   replicación de logs a peers.
    18	# Notes:
    19	#   - JSONL format: cada línea es un JSON independiente (fácil append y tail)
    20	#   - Escritura atómica de state (tmp + rename) para evitar corrupción
    21	#   - Dirty flag se pone al append, se limpia al replicar exitosamente
    22	#   - _update_node_events_cache() actualiza counters en cluster_state para dashboard
    23	#   - get_created_events() y get_completed_event_ids() filtran por status
    24	#   - Se usa en dispatcher.py, ingest.py, reconciler.py, api_app.py
    25	#
    26	# FRV-ID: da709be2675a0a9a
    27	# Header_End
    28	
    29	import json
    30	import os
    31	import tempfile
    32	import threading
    33	from pathlib import Path
    34	from typing import Dict, List, Optional, Any
    35	
    36	from cluster.runtime.events.cluster_event import ClusterEvent
    37	from cluster.runtime.events.event_state import EventStatus
    38	from cluster.utils.log_print import log_state
    39	from cluster.runtime.cluster_store import cluster_state
    40	
    41	# =============================================================================
    42	# Rutas de archivos de event log
    43	# =============================================================================
    44	
    45	#: Directorio de datos del cluster (../data relativo al archivo)
    46	DATA_DIR = Path(__file__).resolve().parents[1] / "data"
    47	
    48	#: Ruta del log local de eventos (JSONL)
    49	LOCAL_LOG_PATH = DATA_DIR / "event_log.local.000.jsonl"
    50	
    51	#: Ruta del log de eventos completados (JSONL)
    52	COMPLETED_LOG_PATH = DATA_DIR / "events.local.000.jsonl"
    53	
    54	#: Ruta del archivo de estado (last append metadata, dirty flags)
    55	STATE_PATH = DATA_DIR / "last_append.state.json"
    56	
    57	#: Lock para escrituras concurrentes de state (thread-safe)
    58	_STATE_LOCK = threading.Lock()
    59	
    60	
    61	def _update_node_events_cache(event: ClusterEvent, status: str):
    62	    """
    63	    Actualiza el cache de counters de eventos en cluster_state.
    64	
    65	    Actualiza events_summary_local con total_events y counts por status.
    66	
    67	    Args:
    68	        event: Evento recién appended.
    69	        status: Status del evento (CREATED, EXECUTING, COMPLETED, FAILED).
    70	
    71	    Note:
    72	        - Se llama en append_event() después de escribir el log
    73	        - Actualiza cluster_state para que el dashboard muestre counters actualizados
    74	        - Usa source_node o target_node para identificar el nodo
    75	    """
    76	    node_id = getattr(event, "source_node", None) or getattr(event, "target_node", None)
    77	    if not node_id:
    78	        return
    79	
    80	    node = cluster_state.get(node_id, {}) or {}
    81	    streams = dict(node.get("streams", {}) or {})
    82	
    83	    local_summary = streams.get("events_summary_local", {}) or {}
    84	    local_summary["last_event_id"] = event.event_id
    85	    local_summary["counts"] = dict(local_summary.get("counts", {}) or {})
    86	    local_summary["total_events"] = int(local_summary.get("total_events", 0)) + 1
    87	    local_summary["counts"][status] = int(local_summary["counts"].get(status, 0)) + 1
    88	
    89	    streams["events_summary_local"] = local_summary
    90	    node["streams"] = streams
    91	    cluster_state[node_id] = node
    92	
    93	
    94	def get_integrity_canonical() -> dict:
    95	    """
    96	    Devuelve la vista canonical del log para verificar integridad.
    97	
    98	    Returns:
    99	        dict: Vista canonical con log_size, file_size, last_append_event_id, last_append_created_at.
   100	
   101	    Note:
   102	        - Se usa en integrity.py para comparar views entre nodos
   103	        - SHA256 de este dict es el integrity_hash
   104	    """
   105	    state = read_state()
   106	    return {
   107	        "log_size": os.path.getsize(LOCAL_LOG_PATH) if LOCAL_LOG_PATH.exists() else 0,
   108	        "file_size": os.path.getsize(LOCAL_LOG_PATH) if LOCAL_LOG_PATH.exists() else 0,
   109	        "last_append_event_id": state.get("last_append_event_id"),
   110	        "last_append_created_at": state.get("last_append_created_at"),
   111	    }
   112	
   113	
   114	def ensure_dir():
   115	    """Crea DATA_DIR si no existe (incluye directorios padres)."""
   116	    DATA_DIR.mkdir(parents=True, exist_ok=True)
   117	
   118	
   119	def ensure_initial_files():
   120	    """
   121	    Crea los archivos iniciales si no existen.
   122	
   123	    Crea:
   124	        - last_append.state.json: estado con dirty flags y metadata
   125	        - event_log.local.000.jsonl: log local de eventos (vacío)
   126	        - events.local.000.jsonl: log de eventos completados (vacío)
   127	
   128	    Note:
   129	        - Se llama en append_event() antes de escribir
   130	        - El state inicial tiene dirty=True para forzar replicación inicial
   131	    """
   132	    ensure_dir()
   133	
   134	    if not STATE_PATH.exists():
   135	        write_state({
   136	            "dirty": True,
   137	            "events_dirty": True,
   138	            "last_append_event_id": None,
   139	            "last_append_created_at": None,
   140	            "last_append_updated_at": None,
   141	            "last_completed_event_id": None,
   142	            "last_completed_created_at": None,
   143	            "last_completed_updated_at": None,
   144	        })
   145	
   146	    if not LOCAL_LOG_PATH.exists():
   147	        LOCAL_LOG_PATH.touch()
   148	
   149	    if not COMPLETED_LOG_PATH.exists():
   150	        COMPLETED_LOG_PATH.touch()
   151	
   152	
   153	def get_local_log_path(stream: str | None = None) -> str:
   154	    """Devuelve la ruta del log local."""
   155	    return str(LOCAL_LOG_PATH)
   156	
   157	
   158	def get_completed_log_path(stream: str | None = None) -> str:
   159	    """Devuelve la ruta del log de eventos completados."""
   160	    return str(COMPLETED_LOG_PATH)
   161	
   162	
   163	def get_state_path() -> str:
   164	    """Devuelve la ruta del archivo de estado."""
