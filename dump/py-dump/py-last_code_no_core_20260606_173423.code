   260	def build_groups_ev(rows):
   261	    """Agrupa eventos por source."""
   262	    groups_ev = {}
   263	    for row in rows:
   264	        groups_ev.setdefault(row["source"], []).append(row)
   265	    return groups_ev
   266	
   267	
   268	def build_groups(rows):
   269	    """Agrupa archivos por source."""
   270	    groups = {}
   271	    for row in rows:
   272	        groups.setdefault(row["source"], []).append(row)
   273	    return groups
