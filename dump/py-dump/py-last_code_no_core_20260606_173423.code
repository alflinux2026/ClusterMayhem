   448	def get_session(worker_id):
   449	    """
   450	    Obtiene o crea una sesión requests para un worker.
   451	
   452	    Args:
   453	        worker_id: ID del worker.
   454	
   455	    Returns:
   456	        requests.Session: Sesión con connection pooling.
   457	    """
   458	    with worker_sessions_lock:
   459	        if worker_id not in worker_sessions:
   460	            s = requests.Session()
   461	            adapter = requests.adapters.HTTPAdapter(pool_connections=16, pool_maxsize=16, max_retries=0)
   462	            s.mount("http://", adapter)
   463	            s.mount("https://", adapter)
   464	            worker_sessions[worker_id] = s
   465	        return worker_sessions[worker_id]
   466	
