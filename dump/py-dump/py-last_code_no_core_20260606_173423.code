   227	def stat_slow_event(event_index, attempt, node, latency_ms, leader=None, payload=None):
   228	    with stats_lock:
   229	        stats["events_slow"] += 1
   230	        stats["slow_events"].append({
   231	            "event_index": event_index,
   232	            "attempt": attempt,
   233	            "node": node,
   234	            "latency_ms": round(latency_ms, 3),
   235	            "leader": leader,
   236	            "payload": payload,
