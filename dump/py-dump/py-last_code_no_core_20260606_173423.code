   253	
   254	def percentile(data, p):
   255	    if not data:
   256	        return 0.0
   257	    values = sorted(data)
   258	    if len(values) == 1:
   259	        return float(values[0])
   260	    rank = (len(values) - 1) * (p / 100.0)
   261	    low = int(rank)
   262	    high = min(low + 1, len(values) - 1)
   263	    fraction = rank - low
   264	    return float(values[low] + (values[high] - values[low]) * fraction)
   265	
   266	
   267	def is_retryable_response(payload):
   268	    if not isinstance(payload, dict):
   269	        return False
   270	    if payload.get("error") in {"no leader", "node isolated"}:
   271	        return True
   272	    error = str(payload.get("error", "")).lower()
   273	    retry_patterns = ["timeout", "connection", "refused", "temporarily unavailable", "isolated", "no leader"]
   274	    return any(p in error for p in retry_patterns)
   275	
   276	
   277	def extract_leader(payload):
   278	    if not isinstance(payload, dict):
   279	        return None
   280	    if "result" in payload and isinstance(payload["result"], dict):
   281	        return payload["result"].get("leader")
   282	    return payload.get("leader")
   283	
   284	
   285	def classify_submit_response(status_code, payload):
   286	    if status_code != 200:
   287	        return "http_not_ok"
   288	    if not isinstance(payload, dict):
   289	        return "submit_ok"
   290	    if payload.get("error"):
   291	        if is_retryable_response(payload):
   292	            return "retryable_error"
   293	        return "hard_fail"
   294	    result = payload.get("result")
   295	    if isinstance(result, dict) and result.get("error"):
   296	        if is_retryable_response(result):
   297	            return "retryable_error"
   298	        return "hard_fail"
   299	    return "submit_ok"
   300	
   301	
   302	def next_enqueue_seq():
   303	    global enqueue_seq
   304	    with enqueue_seq_lock:
   305	        enqueue_seq += 1
   306	        return enqueue_seq
   307	
   308	
   309	def enqueue_pending(pending, delay_seconds=0.0):
   310	    run_at = time.time() + max(0.0, delay_seconds)
   311	    pending_queue.put((run_at, next_enqueue_seq(), pending))
   312	    with stats_lock:
   313	        depth = pending_queue.qsize()
   314	        if depth > stats["queue_max_depth"]:
   315	            stats["queue_max_depth"] = depth
   316	
   317	
   318	def mark_producer_done():
   319	    global producer_done
   320	    with producer_done_lock:
   321	        producer_done = True
   322	
   323	
   324	def is_producer_done():
   325	    with producer_done_lock:
   326	        return producer_done
   327	
   328	
   329	def compute_retry_backoff(retries_done):
   330	    backoff = RETRY_BACKOFF_BASE * (2 ** max(0, retries_done - 1))
   331	    return min(backoff, RETRY_BACKOFF_MAX)
   332	
