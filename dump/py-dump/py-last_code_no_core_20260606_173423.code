   660	                "ended_at_iso": datetime.fromtimestamp(ended_at).isoformat(),
   661	                "duration_seconds": round(ended_at - TEST_STARTED_AT, 3),
   662	            },
   663	            "stats": {
   664	                **stats,
   665	                "success_rate": round(success_rate, 2),
   666	                "latency_avg": round(avg_latency, 3),
   667	                "latency_min": round(min_latency, 3),
   668	                "latency_p50": round(p50_latency, 3),
   669	                "latency_p95": round(p95_latency, 3),
   670	                "latency_p99": round(p99_latency, 3),
   671	                "latency_max": round(max_latency, 3),
   672	                "per_node_ok": dict(stats["per_node_ok"]),
   673	                "per_node_fail": dict(stats["per_node_fail"]),
   674	                "leaders_seen": dict(stats["leaders_seen"]),
   675	            }
   676	        }
   677	        with open(STATS_FILE, "w") as f:
   678	            json.dump(report, f, indent=2)
   679	        print(f"
   680	[MAIN] stats saved to {STATS_FILE}
   681	")
   682	
   683	
   684	def main():
   685	    print("[MAIN] starting UNIVERSAL chaos torture v4")
   686	    print_test_config()
   687	    workers = []
   688	    for idx in range(SEND_WORKERS):
   689	        t = threading.Thread(target=sender_worker, args=(idx,), daemon=True)
   690	        t.start()
   691	        workers.append(t)
   692	    drained = False
   693	    try:
   694	        chaos_loop()
   695	        drained = wait_queue_drain()
   696	        pending_queue.join()
   697	        for t in workers:
   698	            t.join(timeout=5)
   699	    finally:
   700	        wait_kills()
   701	        revive_everything()
   702	        if not drained:
   703	            print(f"
   704	[MAIN WARN] queue drain timeout reached after {DRAIN_TIMEOUT:.1f}s
   705	")
   706	        print_test_config()
   707	        print_stats()
   708	        print("
   709	[MAIN] cluster restored
   710	")
   711	
   712	
   713	if __name__ == "__main__":
   714	    main()


