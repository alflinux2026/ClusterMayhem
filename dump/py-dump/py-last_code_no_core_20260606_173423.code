   689	
   690	@app.get("/dashboard/compact")
   691	def dashboard_compact():
   692	    """
   693	    Dashboard compacto del cluster.
   694	
   695	    Devuelve info completa de todos los nodos: state, ages, health, events counters,
   696	    progress, integrity, etc. Para monitoring y debugging.
   697	    """
   698	    now = time.time()
   699	    leader = compute_leader()
   700	    local_events = events_summary()
   701	    integrity = local_integrity_api()
   702	    local_node = cluster_state.get(ctx.node_id, {}) or {}
   703	
   704	    try:
   705	        from cluster.runtime.progress_watchdog import (
   706	            get_progress_age_s,
   707	            get_progress_duration_s,
   708	            get_progress_pct,
   709	            refresh_progress_stalled_flag,
   710	        )
   711	    except Exception:
   712	        get_progress_age_s = None
   713	        get_progress_duration_s = None
   714	        get_progress_pct = None
   715	        refresh_progress_stalled_flag = None
   716	
   717	    nodes = []
   718	    for node_id, node in sorted(cluster_state.items(), key=lambda kv: str(kv[0])):
   719	        log_meta = node.get("log_meta", {}) or {}
   720	        counts = (((node.get("streams") or {}).get("events_summary_local") or {}).get("counts") or {})
   721	        progress_age_s = None
   722	        progress_duration_s = None
   723	        progress_pct = None
   724	        progress_stalled = bool(node.get("progress_stalled", False))
   725	
   726	        if refresh_progress_stalled_flag is not None:
   727	            try:
   728	                progress_stalled = bool(refresh_progress_stalled_flag(node_id=node_id, now=now))
   729	                node = cluster_state.get(node_id, node) or node
   730	            except Exception:
   731	                progress_stalled = bool(node.get("progress_stalled", False))
   732	
   733	        if get_progress_age_s is not None:
   734	            try:
   735	                progress_age_s = get_progress_age_s(node=node, now=now)
   736	            except Exception:
   737	                progress_age_s = None
   738	
   739	        if get_progress_duration_s is not None:
   740	            try:
   741	                progress_duration_s = get_progress_duration_s(node=node, now=now)
   742	            except Exception:
   743	                progress_duration_s = None
   744	
   745	        if get_progress_pct is not None:
   746	            try:
   747	                progress_pct = get_progress_pct(node=node)
   748	            except Exception:
   749	                progress_pct = None
   750	        else:
   751	            try:
   752	                current = node.get("progress_current")
   753	                total = node.get("progress_total")
   754	                if current is not None and total not in (None, 0):
   755	                    progress_pct = round((float(current) / float(total)) * 100.0, 1)
   756	            except Exception:
   757	                progress_pct = None
   758	
   759	        item = {
   760	            "node_id": node_id,
   761	            "state": node.get("state"),
   762	            "state_since": node.get("state_since"),
   763	            "state_age_s": round(_state_age_s(node, now) or 0.0, 1),
   764	            "prev_state": node.get("prev_state"),
   765	            "state_reason": node.get("state_reason"),
   766	            "priority": node.get("priority"),
   767	            "last_seen": node.get("last_seen"),
   768	            "seen_age_s": round(_seen_age_s(node, now) or 0.0, 1),
   769	            "last_watchdog": node.get("last_watchdog"),
   770	            "watchdog_age_s": round(_watchdog_age_s(node, now) or 0.0, 1) if node.get("last_watchdog") is not None else None,
   771	            "watchdog_busy": node.get("watchdog_busy"),
   772	            "presence_age_s": round(_presence_age_s(node, now) or 0.0, 1),
   773	            "health": _presence_health(node, now, stale_after_s=3.0),
   774	            "local_size": log_meta.get("size", 0),
   775	            "local_events": ((node.get("streams") or {}).get("events_summary_local") or {}).get("total_events", 0),
   776	            "created": counts.get("created", 0),
   777	            "executing": counts.get("executing", 0),
   778	            "completed": counts.get("completed", 0),
   779	            "dirty": ((node.get("cluster_integrity") or {}).get("last_append_meta") or {}).get("dirty"),
   780	            "progress_active": bool(node.get("progress_active", False)),
   781	            "progress_stage": node.get("progress_stage"),
   782	            "progress_started_at": node.get("progress_started_at"),
   783	            "progress_touched_at": node.get("progress_touched_at"),
   784	            "progress_age_s": round(progress_age_s, 1) if progress_age_s is not None else None,
   785	            "progress_duration_s": round(progress_duration_s, 1) if progress_duration_s is not None else None,
   786	            "progress_current": node.get("progress_current"),
   787	            "progress_total": node.get("progress_total"),
   788	            "progress_pct": progress_pct,
   789	            "progress_stalled": progress_stalled,
   790	            "progress_meta": node.get("progress_meta") or {},
   791	        }
   792	        nodes.append(item)
   793	
   794	    local_progress = {
   795	        "progress_active": bool(local_node.get("progress_active", False)),
   796	        "progress_stage": local_node.get("progress_stage"),
   797	        "progress_started_at": local_node.get("progress_started_at"),
   798	        "progress_touched_at": local_node.get("progress_touched_at"),
   799	        "progress_age_s": None,
   800	        "progress_duration_s": None,
   801	        "progress_current": local_node.get("progress_current"),
   802	        "progress_total": local_node.get("progress_total"),
   803	        "progress_pct": None,
   804	        "progress_stalled": bool(local_node.get("progress_stalled", False)),
   805	        "progress_meta": local_node.get("progress_meta") or {},
   806	    }
   807	
   808	    return {
   809	        "cluster": {
   810	            "node_id": ctx.node_id,
   811	            "leader": leader,
   812	            "generated_at": now,
   813	            "integrity_ok": bool(integrity.get("integrity_ok", True)),
   814	            "local_state": ctx.node.state.value,
   815	            "local_state_since": getattr(ctx.node, "state_since", None),
   816	            "local_state_age_s": round(_state_age_s({"state_since": getattr(ctx.node, "state_since", None)}, now) or 0.0, 1),
   817	        },
   818	        "local": {
   819	            "events_summary": local_events,
   820	            "integrity": integrity,
   821	            "progress": local_progress,
   822	        },
   823	        "nodes": nodes,
   824	    }
   825	
   826	
   827	@app.get("/integrity")
   828	def integrity():
   829	    """Devuelve el reporte de integridad local."""
   830	    return local_integrity_api()
   831	
   832	
   833	@app.get("/integrity/cluster")
   834	def integrity_cluster():
   835	    """Devuelve el reporte de integridad del cluster."""
   836	    return cluster_integrity_report()


===== ./cluster/runtime/bootstrap.py =====
     1	# File: ./cluster/runtime/bootstrap.py
     2	# Previous: none
     3	# Author: alftorres
     4	# Date: 2026-05-28T17:06:16+0200
     5	# Version: 0.0.0
     6	# Genealogy:
     7	#   ./cluster/runtime/bootstrap.py 0.0.0 2026-05-28T17:06:16+0200
     8	#   God
     9	#
    10	# Purpose:
    11	#   Bootstrap de configuración del nodo.
    12	#   Carga la configuración del cluster desde un archivo nodes.json, identifica
    13	#   cuál es el nodo local (por hostname, NODE_ID, NODE_HOST, o NODE_IP), Extrae
    14	#   la configuración del nodo local y de los peers, y la guarda en config/node.json
    15	#   para uso futuro. Si ya existe config/node.json con el mismo node_id, lo usa
    16	#   (con merge de configuración).
    17	# Notes:
    18	#   - nodes.json define TODOS los nodos del cluster (lista completa)
    19	#   - node.json es la configuración del NODO LOCAL (se genera automáticamente)
    20	#   - Identificación del nodo local por prioridad: NODE_ID > NODE_HOST > NODE_IP > hostname
    21	#   - Escritura atómica de node.json (tmp + rename) para evitar corrupción
    22	#   - Environment vars override: NODE_ID, NODE_HOST, NODE_IP, NODE_PORT, etc.
    23	#   - Si node.json existe y tiene el mismo node_id, se hace merge (no se sobrescribe todo)
    24	#
    25	# FRV-ID: 94320b527b1c5a2b
    26	# Header_End
    27	
    28	import json
    29	import os
    30	import socket
    31	from pathlib import Path
    32	
    33	
    34	def _write_json_atomic(path: str, data: dict) -> None:
    35	    """
    36	    Escribe un dict como JSON de forma atómica.
    37	
    38	    Usa el patrón write-to-temp + rename para evitar corrupción si falla
    39	    la escritura (power failure, crash, etc.).
    40	
    41	    Args:
    42	        path: Ruta del archivo destino.
    43	        data: Dict a escribir como JSON.
    44	
    45	    Note:
    46	        - Crea el directorio padre si no existe
    47	        - Escribe en archivo .tmp y luego hace os.replace()
    48	        - flush() + fsync() aseguran que los datos llegan al disco
    49	        - os.replace() es atómico en casi todos los filesystems
    50	
    51	    Example:
    52	        >>> _write_json_atomic("config/node.json", {"node_id": "lnx203hp"})
    53	        # Crea config/ si no existe, escribe config/node.json.tmp, luego renombra
    54	    """
    55	    p = Path(path)
    56	    p.parent.mkdir(parents=True, exist_ok=True)
    57	    tmp = p.with_suffix(p.suffix + ".tmp")
    58	    with open(tmp, "w", encoding="utf-8") as f:
    59	        json.dump(data, f, ensure_ascii=False, indent=2)
    60	        f.flush()
    61	        os.fsync(f.fileno())
    62	    os.replace(tmp, p)
    63	
    64	
    65	def _node_get(node: dict, *keys, default=None):
    66	    """
    67	    Obtiene el primer valor no-None de un dict buscando varias claves.
    68	
    69	    Útil para soportar nombres alternativos de claves (node_id vs nodeid, etc.).
    70	
    71	    Args:
    72	        node: Dict a buscar.
    73	        *keys: Claves a buscar en orden.
    74	        default: Valor por defecto si ninguna clave existe.
    75	
    76	    Returns:
    77	        El primer valor no-None encontrado, o default.
    78	
    79	    Example:
    80	        >>> node = {"hostname": "lnx203hp", "port": 8000}
    81	        >>> _node_get(node, "node_id", "nodeid", "hostname")
    82	        'lnx203hp'
    83	
    84	        >>> _node_get(node, "port", "bind_port", default=7000)
    85	        8000
    86	
    87	        >>> _node_get(node, "missing", default="fallback")
    88	        'fallback'
    89	    """
    90	    for key in keys:
    91	        if key in node and node[key] is not None:
    92	            return node[key]
    93	    return default
    94	
    95	
    96	def _find_self_node(nodes: list[dict]) -> dict:
    97	    """
    98	    Identifica cuál es el nodo local en la lista de nodos del cluster.
    99	
   100	    Busca por prioridad:
   101	        1. NODE_ID o NODEID env var coincide con node_id
   102	        2. NODE_HOST o NODEHOST env var coincide con host
   103	        3. NODE_IP o NODEIP env var coincide con host
   104	        4. node_id coincide con hostname del sistema
   105	        5. host coincide con hostname del sistema
   106	
   107	    Args:
   108	        nodes: Lista de dicts con info de nodos del cluster.
   109	
   110	    Returns:
   111	        dict: El dict del nodo local.
   112	
   113	    Raises:
   114	        RuntimeError: Si no se puede identificar el nodo local.
   115	
   116	    Example:
   117	        >>> nodes = [
   118	        ...     {"node_id": "lnx203hp", "host": "10.0.0.1", "port": 8000},
   119	        ...     {"node_id": "lnx200nas", "host": "10.0.0.2", "port": 8000}
   120	        ... ]
   121	        >>> _find_self_node(nodes)  # Si hostname es "lnx203hp"
   122	        {"node_id": "lnx203hp", "host": "10.0.0.1", "port": 8000}
   123	
   124	    Note:
   125	        - La identificación es importante para saber qué nodo soy en el cluster
   126	        - Soporta env vars para override en entornos container/Docker/K8s
   127	    """
   128	    hostname = socket.gethostname()
   129	
   130	    node_id_env = os.getenv("NODE_ID") or os.getenv("NODEID")
   131	    host_env = os.getenv("NODE_HOST") or os.getenv("NODEHOST")
   132	    ip_env = os.getenv("NODE_IP") or os.getenv("NODEIP")
   133	
   134	    for node in nodes:
   135	        node_id = _node_get(node, "node_id", "nodeid")
   136	        host = _node_get(node, "host", "hostname", "ip")
   137	
   138	        if node_id_env and node_id == node_id_env:
   139	            return node
   140	        if host_env and host == host_env:
   141	            return node
   142	        if ip_env and host == ip_env:
   143	            return node
   144	        if node_id == hostname:
   145	            return node
   146	        if host == hostname:
   147	            return node
   148	
   149	    raise RuntimeError(
   150	        f"Cannot identify node for hostname={hostname!r} "
   151	        f"env NODE_ID={node_id_env!r} NODE_HOST={host_env!r} NODE_IP={ip_env!r}"
   152	    )
   153	
   154	
   155	def load_or_bootstrap_config():
   156	    """
   157	    Carga o genera la configuración del nodo.
   158	
   159	    Secuencia:
   160	        1. Carga nodes.json (lista completa de nodos del cluster)
   161	        2. Identifica el nodo local (_find_self_node)
   162	        3. Extrae configuración del nodo local y peers
   163	        4. Si node.json existe y tiene el mismo node_id, hace merge y retorna
   164	        5. Si no, genera node.json con la configuración y la retorna
   165	
   166	    Returns:
   167	        dict: Configuración del nodo con:
   168	            - cluster_name (str): Nombre del cluster
   169	            - node_id (str): ID único del nodo
   170	            - priority (int): Prioridad para leader election
   171	            - port (int): Puerto del nodo
   172	            - host (str): Hostname/IP del nodo
   173	            - bind_host (str): Host para bind del servidor
   174	            - bind_port (int): Puerto para bind del servidor
   175	            - tenants_id, app_id, data_type, schema_version (str): Metadatos
   176	            - peers (list[dict]): Lista de peers con node_id, host, port, priority
   177	
   178	    Raises:
   179	        FileNotFoundError: Si nodes.json no existe.
   180	        ValueError: Si nodes.json tiene formato inválido o está vacío.
   181	        RuntimeError: Si no se puede identificar el nodo local.
   182	
   183	    Example:
   184	        >>> config = load_or_bootstrap_config()
   185	        >>> config["node_id"]
   186	        'lnx203hp'
   187	        >>> config["peers"]
   188	        [{'node_id': 'lnx200nas', 'host': '10.0.0.2', 'port': 8000, 'priority': 100}]
   189	
   190	    Note:
   191	        - nodes.json por defecto: cluster/config/nodes.json
   192	        - node.json por defecto: config/node.json
   193	        - Se puede override con env vars: CLUSTER_NODES, CLUSTER_CONFIG
   194	        - Env vars adicionales: NODE_ID, NODE_HOST, NODE_IP, NODE_PORT, TENANT_ID, APP_ID, etc.
   195	    """
   196	    nodes_path = Path(os.getenv("CLUSTER_NODES", "cluster/config/nodes.json"))
   197	    config_path = Path(os.getenv("CLUSTER_CONFIG", "config/node.json"))
   198	
   199	    if not nodes_path.exists():
   200	        raise FileNotFoundError(f"Missing cluster nodes file: {nodes_path}")
   201	
   202	    with open(nodes_path, "r", encoding="utf-8") as f:
   203	        cluster_cfg = json.load(f)
   204	
   205	    if not isinstance(cluster_cfg, dict):
   206	        raise ValueError(f"Invalid cluster nodes file: {nodes_path}")
   207	
   208	    nodes = cluster_cfg.get("nodes", [])
   209	    if not isinstance(nodes, list) or not nodes:
   210	        raise ValueError(f"Empty node list in: {nodes_path}")
   211	
   212	    self_node = _find_self_node(nodes)
   213	
   214	    self_node_id = _node_get(self_node, "node_id", "nodeid")
   215	    self_priority = int(_node_get(self_node, "priority", default=100))
   216	    self_host = _node_get(self_node, "host", "hostname", "ip", default=os.getenv("NODE_HOST", "0.0.0.0"))
   217	    self_port = int(_node_get(self_node, "port", default=os.getenv("NODE_PORT", "8000")))
   218	    self_bind_host = _node_get(self_node, "bind_host", default=self_host)
   219	    self_bind_port = int(_node_get(self_node, "bind_port", default=self_port))
   220	
   221	    peers = []
   222	    for n in nodes:
   223	        peer_node_id = _node_get(n, "node_id", "nodeid")
   224	        if peer_node_id == self_node_id:
   225	            continue
   226	        peers.append({
   227	            "node_id": peer_node_id,
   228	            "host": _node_get(n, "host", "hostname", "ip"),
   229	            "port": int(_node_get(n, "port")),
   230	            "priority": int(_node_get(n, "priority", default=100)),
   231	        })
   232	
   233	    cfg = {
   234	        "cluster_name": cluster_cfg.get("cluster_name", "mayhem-cluster"),
   235	        "node_id": self_node_id,
   236	        "priority": self_priority,
   237	        "port": self_port,
   238	        "host": self_host,
   239	        "bind_host": self_bind_host,
   240	        "bind_port": self_bind_port,
   241	        "tenant_id": os.getenv("TENANT_ID", "default"),
   242	        "app_id": os.getenv("APP_ID", "mayhem"),
   243	        "data_type": os.getenv("DATA_TYPE", "event"),
   244	        "schema_version": os.getenv("SCHEMA_VERSION", "0.1"),
   245	        "peers": peers,
   246	    }
   247	
   248	    if config_path.exists():
   249	        try:
   250	            with open(config_path, "r", encoding="utf-8") as f:
   251	                existing = json.load(f)
   252	            if isinstance(existing, dict) and existing.get("node_id") == cfg["node_id"]:
   253	                merged = {**existing, **cfg}
   254	                merged["peers"] = cfg["peers"]
   255	                return merged
   256	        except (json.JSONDecodeError, OSError):
   257	            pass
   258	
   259	    _write_json_atomic(str(config_path), cfg)
   260	    return cfg


===== ./cluster/runtime/cluster_store.py =====
     1	# File: ./cluster/runtime/cluster_store.py
     2	# Previous: none
     3	# Author: alftorres
     4	# Date: 2026-05-28T17:07:24+0200
     5	# Version: 0.0.0
     6	# Genealogy:
     7	#   ./cluster/runtime/cluster_store.py 0.0.0 2026-05-28T17:07:24+0200
     8	#   God
     9	#
    10	# Purpose:
    11	#   Almacenamiento en memoria del estado del cluster.
    12	#   Mantiene un diccionario global con el estado de todos los nodos del cluster,
    13	#   actualizado mediante heartbeats. Se usa para leader election, watchdog,
    14	#   y para consultar el estado de otros nodos.
    15	# Notes:
    16	#   - Este es un estado en memoria (no persiste, se reinicia al arrancar)
    17	#   - Se llena con heartbeats de los nodos (ver heartbeat() en api_app.py)
    18	#   - cluster_state vs CLUSTER_REGISTRY:
    19	#       * CLUSTER_REGISTRY: nodos configurados estáticamente (host, port, priority)
    20	#       * cluster_state: estado dinámico de nodos activos (state, last_seen, etc.)
    21	#   - En un futuro podría amplificarse con persistencia o replicación
    22	#
    23	# FRV-ID: ed651d710eb25af1
    24	# Header_End
    25	
    26	import time
    27	
    28	# =============================================================================
    29	# Estado global del cluster (en memoria)
    30	# =============================================================================
    31	
    32	#: Diccionario global con el estado de todos los nodos del cluster
    33	#: Clave: node_id (str)
    34	#: Valor: dict con state, priority, last_seen, last_watchdog, watchdog_busy,
    35	#:        state_since, prev_state, state_reason, log_meta, cluster_integrity, streams
    36	#: Tipo: dict[str, dict[str, Any]]
    37	cluster_state = {}
    38	
    39	
    40	def get_active_cluster():
    41	    """
    42	    Devuelve el estado completo del cluster.
    43	
    44	    Returns:
    45	        dict[str, dict]: Copia de referencia de cluster_state con todos los nodos.
    46	
    47	    Note:
    48	        - Retorna la referencia directa (no una copia), así que cuidado con modificarlo
    49	        - Se usa principalmente para debugging/monitoring
    50	
    51	    Example:
    52	        >>> cluster = get_active_cluster()
    53	        >>> for node_id, info in cluster.items():
    54	        ...     print(f"{node_id}: {info.get('state')}")
    55	    """
    56	    return cluster_state
    57	
    58	
    59	def upsert_node(node_id: str, payload: dict, now: float | None = None) -> dict:
    60	    """
    61	    Inserta o actualiza un nodo en el cluster_state.
    62	
    63	    Fusiona el payload con el estado existente del nodo, actualizando
    64	    automáticamente `last_seen` al timestamp actual.
    65	
    66	    Args:
    67	        node_id: ID único del nodo.
    68	        payload: Dict con los campos a actualizar (state, priority, last_watchdog, etc.).
    69	        now: Timestamp opcional. Si no se proporciona, usa time.time().
    70	
    71	    Returns:
    72	        dict: El estado actualizado del nodo (después de la actualización).
    73	
    74	    Example:
    75	        >>> upsert_node("lnx203hp", {"state": "ACTIVE", "priority": 10})
    76	        {'state': 'ACTIVE', 'priority': 10, 'last_seen': 1779956226.123}
    77	
    78	    Note:
    79	        - fusiona payload con el estado existente (no lo sobrescribe completamente)
    80	        - last_seen siempre se actualiza al timestamp actual (a menos que payload lo fije)
    81	    """
    82	    now = now or time.time()
    83	    current = cluster_state.get(node_id, {})
    84	
    85	    cluster_state[node_id] = {
    86	        **current,
    87	        **payload,
    88	        "last_seen": payload.get("last_seen", now),
    89	    }
    90	    return cluster_state[node_id]
    91	
    92	
    93	def refresh_node_seen(node_id: str, now: float | None = None) -> dict:
    94	    """
    95	    Actualiza solo el last_seen de un nodo (heartbeat).
    96	
    97	    Útil para refreshar el timestamp de actividad sin cambiar otros campos.
    98	
    99	    Args:
   100	        node_id: ID del nodo a refreshar.
   101	        now: Timestamp opcional. Si no se proporciona, usa time.time().
   102	
   103	    Returns:
   104	        dict: El estado del nodo con last_seen actualizado.
   105	
   106	    Example:
   107	        >>> refresh_node_seen("lnx203hp")
   108	        {'state': 'ACTIVE', 'priority': 10, 'last_seen': 1779956226.456}
   109	
   110	    Note:
   111	        - Solo actualiza last_seen, no cambia state/priority/otros campos
   112	        - Se usa en heartbeats para marcar que el nodo sigue vivo
   113	        - Si el nodo no existe, se crea con solo last_seen
   114	    """
   115	    now = now or time.time()
   116	    current = cluster_state.get(node_id, {})
   117	
   118	    cluster_state[node_id] = {
   119	        **current,
   120	        "last_seen": now,
   121	    }
   122	    return cluster_state[node_id]
   123	
   124	
   125	def get_node(node_id: str) -> dict:
   126	    """
   127	    Obtiene el estado de un nodo del cluster.
   128	
   129	    Args:
   130	        node_id: ID del nodo a consultar.
   131	
   132	    Returns:
   133	        dict: El estado del nodo si existe, dict vacío {} si no existe.
   134	
   135	    Example:
   136	        >>> get_node("lnx203hp")
   137	        {'state': 'ACTIVE', 'priority': 10, 'last_seen': 1779956226.123}
   138	
   139	        >>> get_node("nodonotexist")
   140	        {}
   141	
   142	    Note:
   143	        - Retorna dict vacío en lugar de None para evitar checks de None
   144	        - Se usa en compute_leader(), compute_alive(), dashboard_compact(), etc.
   145	    """
   146	    return cluster_state.get(node_id, {})


