   593	def print_stats():
   594	    with stats_lock:
   595	        total = stats["events_total"]
   596	        ok = stats["events_ok"]
   597	        failed = stats["events_failed"]
   598	        success_rate = ((ok / total) * 100) if total else 0
   599	        avg_latency = (sum(stats["latency"]) / len(stats["latency"])) if stats["latency"] else 0
   600	        max_latency = max(stats["latency"]) if stats["latency"] else 0
   601	        min_latency = min(stats["latency"]) if stats["latency"] else 0
   602	        p50_latency = percentile(stats["latency"], 50)
   603	        p95_latency = percentile(stats["latency"], 95)
   604	        p99_latency = percentile(stats["latency"], 99)
   605	    print("
   606	" + "=" * 56)
   607	    print("FINAL CHAOS STATS")
   608	    print("=" * 56)
   609	    print(f"events_total........: {total}")
   610	    print(f"events_ok...........: {ok}")
   611	    print(f"events_failed.......: {failed}")
   612	    print(f"success_rate........: {success_rate:.2f}%")
   613	    print(f"latency_avg.........: {avg_latency:.1f} ms")
   614	    print(f"latency_min.........: {min_latency:.1f} ms")
   615	    print(f"latency_p50.........: {p50_latency:.1f} ms")
   616	    print(f"latency_p95.........: {p95_latency:.1f} ms")
   617	    print(f"latency_p99.........: {p99_latency:.1f} ms")
   618	    print(f"latency_max.........: {max_latency:.1f} ms")
   619	    print(f"stats_file..........: {STATS_FILE}")
   620	    print(f"events_csv..........: {EVENTS_CSV}")
   621	    print("=" * 56)
