   213	def stat_unexpected_failure(event_index, attempt, node, status_code=None, payload=None, reason=None):
   214	    with stats_lock:
   215	        stats["events_unexpected_fail"] += 1
   216	        stats["unexpected_failures"].append({
   217	            "event_index": event_index,
   218	            "attempt": attempt,
   219	            "node": node,
   220	            "status_code": status_code,
   221	            "payload": payload,
   222	            "reason": reason,
   223	            "timestamp": datetime.now().isoformat(),
   224	        })
