     1	# File: ./cluster/runtime/events/cluster_event.py
     2	# Previous: none
     3	# Author: alftorres
     4	# Date: 2026-05-28T17:09:05+0200
     5	# Version: 0.0.0
     6	# Genealogy:
     7	#   ./cluster/runtime/events/cluster_event.py 0.0.0 2026-05-28T17:09:05+0200
     8	#   God
     9	#
    10	# Purpose:
    11	#   Modelo de dato de evento del cluster.
    12	#   ClusterEvent es el objeto que representa un evento en el sistema,
    13	#   con todos los metadatos necesarios para routing, tracking, y state management.
    14	#   Hereda de Pydantic BaseModel para validación automática y serialization.
    15	# Notes:
    16	#   - event_id y trace_id se generan automáticamente con uuid4()
    17	#   - status es un EventStatus (CREATED, EXECUTING, COMPLETED, FAILED)
    18	#   - route_hops trackea el path del evento a través del cluster (para debugging)
    19	#   - target_node y source_node para routing entre nodos
    20	#   - created_at, updated_at, received_at para tracking temporal
    21	#   - attempt y execution_key para retries y deduplication
    22	#   - add_hop(), mark_status(), mark_received() actualizan updated_at automáticamente
    23	#
    24	# FRV-ID: 317a6125cc88cfcb
    25	# Header_End
    26	
    27	from pydantic import BaseModel, Field
    28	from typing import Optional
    29	from uuid import uuid4
    30	import time
    31	
    32	from cluster.runtime.events.event_state import EventStatus
    33	
    34	
    35	class ClusterEvent(BaseModel):
    36	    """
    37	    Evento del cluster.
    38	
    39	    Objeto de dato que representa un evento en el sistema distribuido.
    40	    Incluye metadatos para routing, tracking, state management, y debugging.
    41	
    42	    Attributes:
    43	        event_id (str): ID único del evento (UUID v4, auto-generado).
    44	        trace_id (str): ID de traza para correlación (UUID v4, auto-generado).
    45	        schema_version (str): Versión del schema del evento (default: "0.1").
    46	        event_type (str): Tipo del evento (ej: "user_command", "timer", "webhook").
    47	        payload (dict): Datos del evento (business payload).
    48	        status (EventStatus): Estado actual (CREATED, EXECUTING, COMPLETED, FAILED).
    49	        route_hops (list[str]): Lista de nodos por donde pasó el evento.
    50	        target_node (str | None): Nodo destino del evento.
    51	        source_node (str | None): Nodo origen del evento.
    52	        created_at (float): Timestamp cuando se creó el evento.
    53	        updated_at (float): Timestamp de la última actualización.
    54	        received_at (float | None): Timestamp cuando se recibió el evento.
    55	        attempt (int): Número de intentos de ejecución (para retries).
    56	        execution_key (str | None): Key para deduplication de ejecución.
    57	
    58	    Example:
    59	        >>> event = ClusterEvent(
    60	        ...     event_type="user_command",
    61	        ...     payload={"msg": "hola", "data": {"foo": "bar"}}
    62	        ... )
    63	        >>> event.event_id
    64	        'a1b2c3d4-...'
    65	        >>> event.status
    66	        <EventStatus.CREATED: 'created'>
    67	
    68	        >>> event.mark_status(EventStatus.EXECUTING)
    69	        >>> event.status
    70	        <EventStatus.EXECUTING: 'executing'>
    71	
    72	        >>> event.add_hop("lnx203hp")
    73	        >>> event.route_hops
    74	        ['lnx203hp']
    75	
    76	    Note:
    77	        - Hereda de Pydantic BaseModel: validación automática, .model_dump(), .model_json()
    78	        - event_id y trace_id se generan con default_factory=lambda: str(uuid4())
    79	        - payload es un dict vacío por defecto (default_factory=dict)
    80	        - route_hops es una lista vacía por defecto (default_factory=list)
    81	    """
    82	    event_id: str = Field(default_factory=lambda: str(uuid4()))
    83	    trace_id: str = Field(default_factory=lambda: str(uuid4()))
    84	
    85	    schema_version: str = "0.1"
    86	    event_type: str
    87	
    88	    payload: dict = Field(default_factory=dict)
    89	
    90	    status: EventStatus = EventStatus.CREATED
    91	
    92	    route_hops: list[str] = Field(default_factory=list)
    93	
    94	    target_node: Optional[str] = None
    95	    source_node: Optional[str] = None
    96	
    97	    created_at: float = Field(default_factory=time.time)
    98	    updated_at: float = Field(default_factory=time.time)
    99	
   100	    received_at: Optional[float] = None
   101	
   102	    attempt: int = 0
   103	    execution_key: Optional[str] = None
   104	
   105	    def add_hop(self, hop: str):
   106	        """
   107	        Añade un hop al route_hops (tracking de routing).
   108	
   109	        Args:
   110	            hop: node_id del nodo por donde pasó el evento.
   111	
   112	        Example:
   113	            >>> event = ClusterEvent(event_type="test")
   114	            >>> event.route_hops
   115	            []
   116	            >>> event.add_hop("lnx203hp")
   117	            >>> event.route_hops
   118	            ['lnx203hp']
   119	            >>> event.add_hop("lnx200nas")
   120	            >>> event.route_hops
   121	            ['lnx203hp', 'lnx200nas']
   122	
   123	        Note:
   124	            - Actualiza updated_at al añadir el hop
   125	            - Se usa para debugging de routing en cluster
   126	        """
   127	        self.route_hops.append(hop)
   128	        self.updated_at = time.time()
   129	
   130	    def mark_status(self, status: EventStatus):
   131	        """
   132	        Marca el estado del evento.
   133	
   134	        Args:
   135	            status: Nuevo estado (EventStatus enum).
   136	
   137	        Example:
   138	            >>> event = ClusterEvent(event_type="test")
   139	            >>> event.status
   140	            <EventStatus.CREATED: 'created'>
   141	            >>> event.mark_status(EventStatus.EXECUTING)
   142	            >>> event.status
   143	            <EventStatus.EXECUTING: 'executing'>
   144	            >>> event.mark_status(EventStatus.COMPLETED)
   145	            >>> event.status
   146	            <EventStatus.COMPLETED: 'completed'>
   147	
   148	        Note:
   149	            - Actualiza updated_at al cambiar el estado
   150	            - No valida la transición (usa validate_transition() si hace falta)
   151	        """
   152	        self.status = status
   153	        self.updated_at = time.time()
   154	
   155	    def mark_received(self):
   156	        """
   157	        Marca el timestamp cuando se recibió el evento.
   158	
   159	        Sets received_at = time.time() y updated_at = received_at.
   160	
   161	        Example:
   162	            >>> event = ClusterEvent(event_type="test")
   163	            >>> event.received_at
   164	            None
   165	            >>> event.mark_received()
   166	            >>> event.received_at
   167	            1779956226.123
   168	        Note:
   169	            - Se llama en ingest_event() cuando se ingiere el evento
   170	        """
   171	        self.received_at = time.time()
   172	        self.updated_at = self.received_at


===== ./cluster/runtime/events/event_state.py =====
     1	# File: ./cluster/runtime/events/event_state.py
     2	# Previous: none
     3	# Author: alftorres
     4	# Date: 2026-05-28T17:09:28+0200
     5	# Version: 0.0.0
     6	# Genealogy:
     7	#   ./cluster/runtime/events/event_state.py 0.0.0 2026-05-28T17:09:28+0200
     8	#   God
     9	#
    10	# Purpose:
    11	#   Definición de estados de eventos y transiciones válidas.
    12	#   Define la máquina de estados finitos (FSM) para el ciclo de vida de un evento:
    13	#     CREATED -> EXECUTING -> COMPLETED o FAILED
    14	#   También valida que las transiciones entre estados sean válidas.
    15	# Notes:
    16	#   - CREATED: evento recién creado, esperando ser ejecutado
    17	#   - EXECUTING: evento en ejecución (business logic se está ejecutando)
    18	#   - COMPLETED: evento ejecutado exitosamente
    19	#   - FAILED: evento fallido (no se reintentará automáticamente)
    20	#   - VALID_TRANSITIONS define qué transiciones son permitidas
    21	#   - validate_transition() levanta ValueError si la transición es inválida
    22	#   - Transiciones idempotentes (old == new) son sempre válidas (NO-OP)
    23	#
    24	# FRV-ID: 0aa52064e4460767
    25	# Header_End
    26	
    27	from enum import Enum
    28	
    29	
    30	class EventStatus(str, Enum):
    31	    """
    32	    Estados de un evento en el cluster.
    33	
    34	    Ciclo de vida típico:
    35	        CREATED -> EXECUTING -> COMPLETED
    36	
    37	    O en caso de error:
    38	        CREATED -> EXECUTING -> FAILED
    39	
    40	    Attributes:
    41	        CREATED: Evento recién creado, esperando ser ejecutado.
    42	        EXECUTING: Evento en ejecución (business logic se está ejecutando).
    43	        COMPLETED: Evento ejecutado exitosamente.
    44	        FAILED: Evento fallido (no se reintentó o falló el retry).
    45	
    46	    Example:
    47	        >>> EventStatus.CREATED
    48	        <EventStatus.CREATED: 'created'>
    49	
    50	        >>> EventStatus.CREATED.value
    51	        'created'
    52	
    53	        >>> str(EventStatus.COMPLETED)
    54	        'completed'
    55	
    56	    Note:
    57	        - Hereda de str para poder comparar directamente con strings
    58	        - value es el nombre del estado en minúsculas
    59	    """
    60	    CREATED = "created"
    61	    EXECUTING = "executing"
    62	    COMPLETED = "completed"
    63	    FAILED = "failed"
    64	
    65	
    66	    """
    67	    Máquina de estados de evento.
    68	
    69	    Defines qué transiciones entre estados son permitidas:
    70	        - CREATED -> EXECUTING: iniciar ejecución
    71	        - EXECUTING -> COMPLETED: ejecución exitosa
    72	        - EXECUTING -> FAILED: ejecución fallida
    73	        - EXECUTING -> CREATED: retry (volver a empezar)
    74	        - COMPLETED -> cualquiera: NO (evento ya completado, inmutable)
    75	        - FAILED -> cualquiera: NO (evento fallido, inmutable)
    76	
    77	    Example:
    78	        >>> VALID_TRANSITIONS[EventStatus.CREATED]
    79	        [<EventStatus.EXECUTING: 'executing'>]
    80	
    81	        >>> VALID_TRANSITIONS[EventStatus.EXECUTING]
    82	        [<EventStatus.COMPLETED: 'completed'>, <EventStatus.FAILED: 'failed'>, <EventStatus.CREATED: 'created'>]
    83	    """
    84	
    85	    # Transiciones válidas entre estados de evento
    86	
    87	VALID_TRANSITIONS = {
    88	    EventStatus.CREATED: [
    89	        EventStatus.EXECUTING,
    90	    ],
    91	
    92	    EventStatus.EXECUTING: [
    93	        EventStatus.COMPLETED,
    94	        EventStatus.FAILED,
    95	        EventStatus.CREATED,  # retry
    96	    ],
    97	
    98	    EventStatus.COMPLETED: [],
    99	
   100	    EventStatus.FAILED: [],
   101	}
   102	
   103	
   104	def validate_transition(old_status, new_status):
   105	    """
   106	    Valida que una transición entre estados sea válida.
   107	
   108	    Args:
   109	        old_status: Estado actual (EventStatus enum).
   110	        new_status: Nuevo estado (EventStatus enum).
   111	
   112	    Raises:
   113	        ValueError: Si la transición no está permitida.
   114	
   115	    Example:
   116	        >>> validate_transition(EventStatus.CREATED, EventStatus.EXECUTING)
   117	        # OK (no levanta exception)
   118	
   119	        >>> validate_transition(EventStatus.CREATED, EventStatus.COMPLETED)
   120	        ValueError: Invalid transition: created -> completed
   121	
   122	        >>> validate_transition(EventStatus.COMPLETED, EventStatus.COMPLETED)
   123	        # OK (idempotent NO-OP)
   124	
   125	    Note:
   126	        - Transiciones idempotentes (old == new) siempre son válidas (NO-OP)
   127	        - Si old_status no está en VALID_TRANSITIONS, retorna allowed=[] (ninguna transición válida)
   128	    """
   129	    if old_status == new_status:
   130	        return  # IDEMPOTENTE NO-OP
   131	
   132	    allowed = VALID_TRANSITIONS.get(old_status, [])
   133	
   134	    if new_status not in allowed:
   135	        raise ValueError(
   136	            f"Invalid transition: {old_status} -> {new_status}"
   137	        )


