    83	
    84	def ssh_ls(node):
    85	    """
    86	    Ejecuta ls -lb --full-time en el nodo remoto por SSH.
    87	
    88	    Args:
    89	        node: Dict del nodo (name, host, user, password, port).
    90	
    91	    Returns:
    92	        str: Output de ls.
    93	
    94	    Raises:
    95	        RuntimeError: Si hay error en SSH y no hay output.
    96	    """
    97	    remote_dir = REMOTE_DIRS[node["name"]]
    98	    client = paramiko.SSHClient()
    99	    client.set_missing_host_key_policy(paramiko.AutoAddPolicy())
   100	    client.connect(
   101	        hostname=node["host"],
   102	        port=node["port"],
   103	        username=node["user"],
   104	        password=node["password"],
   105	        timeout=5,
   106	        look_for_keys=False,
   107	        allow_agent=False,
   108	    )
   109	    cmd = f'ls -lb --full-time "{remote_dir}"'
   110	    stdin, stdout, stderr = client.exec_command(cmd)
   111	    out = stdout.read().decode("utf-8", errors="replace")
   112	    err = stderr.read().decode("utf-8", errors="replace")
   113	    client.close()
   114	
   115	    if err.strip() and not out.strip():
   116	        raise RuntimeError(f"{node['name']}: {err.strip()}")
   117	
   118	    return out
   119	
