   468	def kill_node(node, seconds=None):
   469	    """
   470	    Mata un nodo (sleep).
   471	
   472	    Args:
   473	        node: URL del nodo.
   474	        seconds: Segundos que durará muerto (para logging).
   475	
   476	    Returns:
   477	        bool: True si se mató exitosamente, False si falló.
   478	    """
   479	    stat_inc("kill_attempts")
   480	    try:
   481	        resp = requests.post(f"{node}/sleep", timeout=2)
   482	        try:
   483	            payload = resp.json()
   484	        except Exception:
   485	            payload = {"raw_text": resp.text}
   486	        if resp.status_code == 200 and payload.get("ok") is True:
   487	            with dead_lock:
   488	                dead_nodes.add(node)
   489	            stat_inc("kills")
   490	            stat_kill_event(node=node, action="sleep", ok=True, payload=payload, seconds=seconds)
   491	            print(f"[CHAOS] SLEEP {node}")
   492	            return True
   493	        stat_inc("kill_failures")
   494	        stat_kill_event(node=node, action="sleep", ok=False, payload=payload, seconds=seconds)
   495	        print(f"[CHAOS FAIL SLEEP] {node} -> status={resp.status_code} payload={payload}")
   496	        return False
   497	    except Exception as e:
   498	        stat_inc("kill_failures")
   499	        stat_kill_event(node=node, action="sleep", ok=False, error=str(e), seconds=seconds)
   500	        print(f"[CHAOS FAIL SLEEP] {node} -> {e}")
   501	        return False
   502	
   503	
   504	def revive_node(node):
   505	    """
   506	    Revive un nodo (revive).
   507	
   508	    Args:
   509	        node: URL del nodo.
   510	
   511	    Returns:
   512	        bool: True si se revivió exitosamente, False si falló.
   513	    """
   514	    try:
   515	        resp = requests.post(f"{node}/revive", timeout=2)
   516	        try:
   517	            payload = resp.json()
   518	        except Exception:
   519	            payload = {"raw_text": resp.text}
   520	        if resp.status_code == 200 and payload.get("ok") is True:
   521	            with dead_lock:
   522	                dead_nodes.discard(node)
   523	            stat_inc("revives")
   524	            stat_kill_event(node=node, action="revive", ok=True, payload=payload)
   525	            print(f"[CHAOS] REVIVE {node}")
   526	            return True
   527	        stat_inc("revive_failures")
   528	        stat_kill_event(node=node, action="revive", ok=False, payload=payload)
   529	        print(f"[CHAOS FAIL REVIVE] {node} -> status={resp.status_code} payload={payload}")
   530	        return False
   531	    except Exception as e:
   532	        stat_inc("revive_failures")
   533	        stat_kill_event(node=node, action="revive", ok=False, error=str(e))
   534	        print(f"[CHAOS FAIL REVIVE] {node} -> {e}")
   535	        return False
   536	
   537	
   538	def kill_cycle(node, seconds):
   539	    """
   540	    Ciclo de kill: mata el nodo, espera seconds, y lo revive.
   541	
   542	    Args:
   543	        node: URL del nodo.
   544	        seconds: Segundos que durará muerto.
   545	    """
   546	    try:
   547	        if kill_node(node, seconds=seconds):
   548	            print(f"[CHAOS] DEAD {node} for {seconds:.2f}s")
   549	            time.sleep(seconds)
   550	    finally:
   551	        revive_node(node)
   552	
   553	
   554	def process_pending_event(pending: PendingEvent, worker_id: int):
   555	    """
   556	    Procesa un evento pendiente (envía, retry si falla).
   557	
   558	    Args:
   559	        pending: Evento pendiente.
   560	        worker_id: ID del worker.
   561	
   562	    Returns:
   563	        bool: True si el evento se envió exitosamente, False si falló definitivamente.
   564	    """
   565	    i = pending.event_index
   566	    event = pending.event
   567	    attempt_number = pending.retries_done + 1
   568	    available = [n for n in NODES if n not in pending.tried_nodes]
   569	    if not available:
   570	        pending.tried_nodes.clear()
   571	        available = list(NODES)
   572	    node = random.choice(available)
   573	    pending.tried_nodes.add(node)
   574	    start = time.time()
   575	    session = get_session(worker_id)
   576	    try:
   577	        r = session.post(f"{node}/event", json=event, timeout=REQUEST_TIMEOUT)
   578	        elapsed_ms = (time.time() - start) * 1000
   579	        stat_latency(elapsed_ms)
   580	        try:
   581	            payload = r.json()
   582	        except Exception:
   583	            payload = {"raw_text": r.text}
   584	        leader = extract_leader(payload)
   585	        if leader:
   586	            stat_leader(leader)
   587	        if elapsed_ms >= SLOW_EVENT_THRESHOLD_MS:
   588	            stat_slow_event(i, attempt_number, node, elapsed_ms, leader, payload)
   589	        if r.status_code == 200:
   590	            stat_inc("submit_http_200")
   591	        result = classify_submit_response(r.status_code, payload)
   592	        row = {"event_index": i, "attempt": attempt_number, "node": node, "status_code": r.status_code, "elapsed_ms": round(elapsed_ms, 3), "leader": leader, "result": result, "final": None}
   593	        if result == "submit_ok":
   594	            stat_inc("events_ok")
   595	            stat_inc("submit_semantic_ok")
   596	            stat_node_ok(node)
   597	            row["final"] = "ok"
   598	            with results_lock:
   599	                results.append(row)
   600	            print(f"[TORTURE] {i:03} OK attempt={attempt_number} node={node} leader={leader} latency={elapsed_ms:.1f}ms")
   601	            return True
   602	        if result == "retryable_error" or r.status_code >= 500:
   603	            stat_inc("events_retried")
   604	            if isinstance(payload, dict) and payload.get("error") == "no leader":
   605	                stat_inc("events_no_leader")
   606	            result_payload = payload.get("result") if isinstance(payload.get("result"), dict) else None
   607	            if isinstance(result_payload, dict) and result_payload.get("error") == "no leader":
   608	                stat_inc("events_no_leader")
   609	            row["final"] = "retry"
   610	            with results_lock:
   611	                results.append(row)
   612	            print(f"[RETRY] {i:03} attempt={attempt_number} node={node} status={r.status_code} payload={payload}")
   613	            if pending.retries_done + 1 >= MAX_RETRIES:
   614	                stat_inc("events_failed")
   615	                stat_unexpected_failure(i, attempt_number, node, r.status_code, payload, "dropped_after_retries_retryable_response")
   616	                print(f"[DROP] {i:03} event dropped after retries")
   617	                return False
   618	            pending.retries_done += 1
   619	            stat_inc("queue_requeues")
   620	            enqueue_pending(pending, compute_retry_backoff(pending.retries_done))
   621	            return False
   622	        stat_inc("events_failed")
   623	        stat_inc("submit_hard_fail")
   624	        stat_node_fail(node)
   625	        stat_unexpected_failure(i, attempt_number, node, r.status_code, payload, "hard_fail_non_retryable_response")
   626	        row["final"] = "hard_fail"
   627	        with results_lock:
   628	            results.append(row)
   629	        print(f"[FAIL] {i:03} attempt={attempt_number} node={node} status={r.status_code} payload={payload}")
   630	        return False
   631	    except requests.Timeout as e:
   632	        stat_inc("events_timeout")
   633	        stat_inc("events_retried")
   634	        print(f"[TIMEOUT] {i:03} attempt={attempt_number} {node} -> {e}")
   635	    except requests.ConnectionError as e:
   636	        stat_inc("events_connection_error")
   637	        stat_inc("events_retried")
   638	        print(f"[CONNECTION] {i:03} attempt={attempt_number} {node} -> {e}")
   639	    except Exception as e:
   640	        stat_inc("events_forward_error")
   641	        stat_inc("events_retried")
   642	        stat_unexpected_failure(i, attempt_number, node, reason=f"exception:{type(e).__name__}", payload={"exception": str(e)})
   643	        print(f"[ERROR] {i:03} attempt={attempt_number} {node} -> {e}")
   644	    if pending.retries_done + 1 >= MAX_RETRIES:
   645	        stat_inc("events_failed")
   646	        stat_unexpected_failure(i, attempt_number, node, reason="dropped_after_retries_exception", payload={"tried_nodes": list(pending.tried_nodes)})
   647	        print(f"[DROP] {i:03} event dropped after retries")
   648	        return False
   649	    pending.retries_done += 1
   650	    stat_inc("queue_requeues")
   651	    enqueue_pending(pending, compute_retry_backoff(pending.retries_done))
   652	    return False
   653	
   654	
   655	def sender_worker(worker_id):
   656	    """
   657	    Worker que envía eventos desde la cola.
   658	
   659	    Args:
   660	        worker_id: ID del worker.
   661	
   662	    Note:
   663	        - Se ejecuta en un hilo daemon
   664	        - Saca eventos de pending_queue y los procesa
   665	        - Termina cuando producer_done=True y la cola está vacía
   666	    """
   667	    while True:
   668	        try:
   669	            run_at, _, pending = pending_queue.get(timeout=0.5)
   670	        except queue.Empty:
   671	            if is_producer_done() and pending_queue.empty():
   672	                return
   673	            continue
   674	        now = time.time()
   675	        if run_at > now:
   676	            pending_queue.put((run_at, next_enqueue_seq(), pending))
   677	            pending_queue.task_done()
   678	            time.sleep(min(run_at - now, 0.2))
   679	            continue
   680	        try:
   681	            process_pending_event(pending, worker_id)
   682	        finally:
   683	            pending_queue.task_done()
   684	
   685	
   686	def chaos_loop():
   687	    """
   688	    Loop principal del chaos test.
   689	
   690	    Genera EVENTS eventos, y con probabilidad KILL_PROBABILITY
   691	    mata un nodo aleatorio por seconds aleatorios.
   692	    """
   693	    for i in range(EVENTS):
   694	        if random.random() < KILL_PROBABILITY:
   695	            node = SLEEP_ONLY_NODE if SLEEP_ONLY_NODE else random.choice(NODES)
   696	            seconds = random.uniform(*DEATH_TIME_RANGE)
   697	            t = threading.Thread(target=kill_cycle, args=(node, seconds), daemon=True)
   698	            t.start()
   699	            kill_threads.append(t)
   700	        stat_inc("events_total")
   701	        enqueue_pending(PendingEvent(event_index=i, event=build_event(i)), delay_seconds=0.0)
   702	        time.sleep(random.uniform(*EVENT_DELAY_RANGE))
   703	    mark_producer_done()
   704	
   705	
   706	def revive_everything():
   707	    """
   708	    Revive TODOS los nodos (force revive).
   709	
   710	    Se llama al final del test para restaurar el cluster.
   711	    """
   712	    print("\\n[MAIN] REVIVING ALL NODES\\n")
   713	    for node in sorted(set(NODES)):
   714	        try:
   715	            requests.post(f"{node}/revive", timeout=2)
   716	            print(f"[FORCE REVIVE] {node}")
   717	        except Exception as e:
   718	            print(f"[FORCE REVIVE FAIL] {node} -> {e}")
   719	
   720	
   721	def wait_kills():
   722	    """Espera a que terminen todos los kill threads."""
   723	    print("\\n[MAIN] waiting active kill cycles...\\n")
   724	    for t in kill_threads:
   725	        t.join(timeout=30)
   726	
   727	
   728	def wait_queue_drain():
   729	    """
   730	    Espera a que la cola se vacíe (drain).
   731	
   732	    Returns:
   733	        bool: True si la cola se vació, False si timeout.
   734	    """
   735	    deadline = time.time() + DRAIN_TIMEOUT
   736	    while time.time() < deadline:
   737	        if pending_queue.empty():
   738	            time.sleep(0.5)
   739	            if pending_queue.empty():
   740	                return True
   741	        time.sleep(0.2)
   742	    return False
   743	
   744	
   745	def write_csv_and_json():
   746	    """
   747	    Escribe stats.json y events.csv.
   748	
   749	    Calcula success_rate, latencia (avg, min, p50, p95, p99, max),
   750	    y guarda todo el report.
   751	    """
   752	    with results_lock:
   753	        rows = list(results)
   754	    with open(EVENTS_CSV, "w", newline="", encoding="utf-8") as f:
   755	        writer = csv.DictWriter(f, fieldnames=["event_index", "attempt", "node", "status_code", "elapsed_ms", "leader", "result", "final"])
   756	        writer.writeheader()
   757	        writer.writerows(rows)
   758	    with stats_lock:
   759	        total = stats["events_total"]
   760	        ok = stats["events_ok"]
   761	        failed = stats["events_failed"]
   762	        success_rate = ((ok / total) * 100) if total else 0
   763	        avg_latency = (sum(stats["latency"]) / len(stats["latency"])) if stats["latency"] else 0
   764	        max_latency = max(stats["latency"]) if stats["latency"] else 0
   765	        min_latency = min(stats["latency"]) if stats["latency"] else 0
   766	        p50_latency = percentile(stats["latency"], 50)
   767	        p95_latency = percentile(stats["latency"], 95)
   768	        p99_latency = percentile(stats["latency"], 99)
   769	        report = {"test_config": TEST_CONFIG, "run_meta": {"started_at_epoch": TEST_STARTED_AT, "ended_at_epoch": time.time(), "started_at_iso": datetime.fromtimestamp(TEST_STARTED_AT).isoformat(), "ended_at_iso": datetime.now().isoformat(), "duration_seconds": round(time.time() - TEST_STARTED_AT, 3)}, "stats": {**stats, "success_rate": round(success_rate, 2), "latency_avg": round(avg_latency, 3), "latency_min": round(min_latency, 3), "latency_p50": round(p50_latency, 3), "latency_p95": round(p95_latency, 3), "latency_p99": round(p99_latency, 3), "latency_max": round(max_latency, 3), "per_node_ok": dict(stats["per_node_ok"]), "per_node_fail": dict(stats["per_node_fail"]), "leaders_seen": dict(stats["leaders_seen"]), "results_csv": str(EVENTS_CSV)}}
   770	    with open(STATS_FILE, "w", encoding="utf-8") as f:
   771	        json.dump(report, f, indent=2, ensure_ascii=False)
   772	
   773	
   774	def print_stats():
   775	    """Imprime stats finales del test."""
   776	    with stats_lock:
   777	        total = stats["events_total"]
   778	        ok = stats["events_ok"]
   779	        failed = stats["events_failed"]
   780	        success_rate = ((ok / total) * 100) if total else 0
   781	        avg_latency = (sum(stats["latency"]) / len(stats["latency"])) if stats["latency"] else 0
   782	        max_latency = max(stats["latency"]) if stats["latency"] else 0
   783	        min_latency = min(stats["latency"]) if stats["latency"] else 0
   784	        p50_latency = percentile(stats["latency"], 50)
   785	        p95_latency = percentile(stats["latency"], 95)
   786	        p99_latency = percentile(stats["latency"], 99)
   787	    print("\\n" + "=" * 56)
   788	    print("FINAL CHAOS STATS v5")
   789	    print("=" * 56)
   790	    print(f"events_total........: {total}")
   791	    print(f"events_ok...........: {ok}")
   792	    print(f"events_failed.......: {failed}")
   793	    print(f"success_rate........: {success_rate:.2f}%")
   794	    print(f"latency_avg.........: {avg_latency:.1f} ms")
   795	    print(f"latency_min.........: {min_latency:.1f} ms")
   796	    print(f"latency_p50.........: {p50_latency:.1f} ms")
   797	    print(f"latency_p95.........: {p95_latency:.1f} ms")
   798	    print(f"latency_p99.........: {p99_latency:.1f} ms")
   799	    print(f"latency_max.........: {max_latency:.1f} ms")
   800	    print(f"stats_file..........: {STATS_FILE}")
   801	    print(f"events_csv..........: {EVENTS_CSV}")
   802	    print("=" * 56)
   803	
   804	
   805	def main():
   806	    """
   807	    Entry point del chaos test.
   808	
   809	    Secuencia:
   810	        1. Arranca SEND_WORKERS workers
   811	        2. Ejecuta chaos_loop() (genera eventos + mata nodos)
   812	        3. Espera queue drain
   813	        4. Espera kill threads
   814	        5. Revive todos los nodos
   815	        6. Escribe stats y imprime resumen
   816	    """
   817	    print(f"[MAIN] starting UNIVERSAL chaos torture final v5 ({ARGS.mode})")
   818	    print_test_config()
   819	    workers = []
   820	    for idx in range(SEND_WORKERS):
   821	        t = threading.Thread(target=sender_worker, args=(idx,), daemon=True)
   822	        t.start()
   823	        workers.append(t)
   824	    drained = False
   825	    try:
   826	        chaos_loop()
   827	        drained = wait_queue_drain()
   828	        pending_queue.join()
   829	        for t in workers:
   830	            t.join(timeout=5)
   831	    finally:
   832	        wait_kills()
   833	        revive_everything()
   834	        if not drained:
   835	            print(f"\\n[MAIN WARN] queue drain timeout reached after {DRAIN_TIMEOUT:.1f}s\\n")
   836	        write_csv_and_json()
   837	        print_stats()
   838	        print("\\n[MAIN] cluster restored\\n")
   839	
   840	
   841	if __name__ == "__main__":
   842	    main()


