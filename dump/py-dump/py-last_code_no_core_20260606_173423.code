   337	def get_session(worker_id):
   338	    with worker_sessions_lock:
   339	        if worker_id not in worker_sessions:
   340	            s = requests.Session()
   341	            adapter = requests.adapters.HTTPAdapter(pool_connections=16, pool_maxsize=16, max_retries=0)
   342	            s.mount("http://", adapter)
   343	            s.mount("https://", adapter)
   344	            worker_sessions[worker_id] = s
   345	        return worker_sessions[worker_id]
   346	
   347	
   348	def kill_node(node, seconds=None):
   349	    stat_inc("kill_attempts")
   350	    try:
   351	        resp = requests.post(f"{node}/sleep", timeout=2)
   352	        try:
   353	            payload = resp.json()
   354	        except Exception:
   355	            payload = {"raw_text": resp.text}
   356	        if resp.status_code == 200 and payload.get("ok") is True:
   357	            with dead_lock:
   358	                dead_nodes.add(node)
   359	            stat_inc("kills")
   360	            stat_kill_event(node=node, action="sleep", ok=True, payload=payload, seconds=seconds)
   361	            print(f"[CHAOS] SLEEP {node}")
   362	            return True
   363	        stat_inc("kill_failures")
   364	        stat_kill_event(node=node, action="sleep", ok=False, payload=payload, seconds=seconds)
   365	        print(f"[CHAOS FAIL SLEEP] {node} -> status={resp.status_code} payload={payload}")
   366	        return False
   367	    except Exception as e:
   368	        stat_inc("kill_failures")
   369	        stat_kill_event(node=node, action="sleep", ok=False, error=str(e), seconds=seconds)
   370	        print(f"[CHAOS FAIL SLEEP] {node} -> {e}")
   371	        return False
   372	
   373	
   374	def revive_node(node):
   375	    try:
   376	        resp = requests.post(f"{node}/revive", timeout=2)
   377	        try:
   378	            payload = resp.json()
   379	        except Exception:
   380	            payload = {"raw_text": resp.text}
   381	        if resp.status_code == 200 and payload.get("ok") is True:
   382	            with dead_lock:
   383	                dead_nodes.discard(node)
   384	            stat_inc("revives")
   385	            stat_kill_event(node=node, action="revive", ok=True, payload=payload)
   386	            print(f"[CHAOS] REVIVE {node}")
   387	            return True
   388	        stat_inc("revive_failures")
   389	        stat_kill_event(node=node, action="revive", ok=False, payload=payload)
   390	        print(f"[CHAOS FAIL REVIVE] {node} -> status={resp.status_code} payload={payload}")
   391	        return False
   392	    except Exception as e:
   393	        stat_inc("revive_failures")
   394	        stat_kill_event(node=node, action="revive", ok=False, error=str(e))
   395	        print(f"[CHAOS FAIL REVIVE] {node} -> {e}")
   396	        return False
   397	
   398	
   399	def kill_cycle(node, seconds):
   400	    try:
   401	        ok = kill_node(node, seconds=seconds)
   402	        if ok:
   403	            print(f"[CHAOS] DEAD {node} for {seconds:.2f}s")
   404	            time.sleep(seconds)
   405	    finally:
   406	        revive_node(node)
   407	
   408	
   409	def process_pending_event(pending: PendingEvent, worker_id: int):
   410	    i = pending.event_index
   411	    event = pending.event
   412	    attempt_number = pending.retries_done + 1
   413	    available = [n for n in NODES if n not in pending.tried_nodes]
   414	    if not available:
   415	        pending.tried_nodes.clear()
   416	        available = list(NODES)
   417	    node = random.choice(available)
   418	    pending.tried_nodes.add(node)
   419	    start = time.time()
   420	    session = get_session(worker_id)
   421	    try:
   422	        r = session.post(f"{node}/event", json=event, timeout=REQUEST_TIMEOUT)
   423	        elapsed_ms = (time.time() - start) * 1000
   424	        stat_latency(elapsed_ms)
   425	        try:
   426	            payload = r.json()
   427	        except Exception:
   428	            payload = {"raw_text": r.text}
   429	        leader = extract_leader(payload)
   430	        if leader:
   431	            stat_leader(leader)
   432	        if elapsed_ms >= SLOW_EVENT_THRESHOLD_MS:
   433	            stat_slow_event(i, attempt_number, node, elapsed_ms, leader, payload)
   434	        if r.status_code == 200:
   435	            stat_inc("submit_http_200")
   436	        result = classify_submit_response(r.status_code, payload)
   437	        outcome = {"event_index": i, "attempt": attempt_number, "node": node, "status_code": r.status_code, "elapsed_ms": round(elapsed_ms, 3), "leader": leader, "result": result}
   438	        if result == "submit_ok":
   439	            stat_inc("events_ok")
   440	            stat_inc("submit_semantic_ok")
   441	            stat_node_ok(node)
   442	            outcome["final"] = "ok"
   443	            with results_lock:
   444	                results.append(outcome)
   445	            print(f"[TORTURE] {i:03} OK attempt={attempt_number} node={node} leader={leader} latency={elapsed_ms:.1f}ms")
   446	            return True
   447	        if result == "retryable_error" or r.status_code >= 500:
   448	            stat_inc("events_retried")
   449	            if isinstance(payload, dict) and payload.get("error") == "no leader":
   450	                stat_inc("events_no_leader")
   451	            result_payload = payload.get("result") if isinstance(payload.get("result"), dict) else None
   452	            if isinstance(result_payload, dict) and result_payload.get("error") == "no leader":
   453	                stat_inc("events_no_leader")
   454	            outcome["final"] = "retry"
   455	            with results_lock:
   456	                results.append(outcome)
   457	            print(f"[RETRY] {i:03} attempt={attempt_number} node={node} status={r.status_code} payload={payload}")
   458	            if pending.retries_done + 1 >= MAX_RETRIES:
   459	                stat_inc("events_failed")
   460	                stat_unexpected_failure(i, attempt_number, node, r.status_code, payload, "dropped_after_retries_retryable_response")
   461	                print(f"[DROP] {i:03} event dropped after retries")
   462	                return False
   463	            pending.retries_done += 1
   464	            stat_inc("queue_requeues")
   465	            enqueue_pending(pending, compute_retry_backoff(pending.retries_done))
   466	            return False
   467	        stat_inc("events_failed")
   468	        stat_inc("submit_hard_fail")
   469	        stat_node_fail(node)
   470	        stat_unexpected_failure(i, attempt_number, node, r.status_code, payload, "hard_fail_non_retryable_response")
   471	        outcome["final"] = "hard_fail"
   472	        with results_lock:
   473	            results.append(outcome)
   474	        print(f"[FAIL] {i:03} attempt={attempt_number} node={node} status={r.status_code} payload={payload}")
   475	        return False
   476	    except requests.Timeout as e:
   477	        stat_inc("events_timeout")
   478	        stat_inc("events_retried")
   479	        print(f"[TIMEOUT] {i:03} attempt={attempt_number} {node} -> {e}")
   480	    except requests.ConnectionError as e:
   481	        stat_inc("events_connection_error")
   482	        stat_inc("events_retried")
   483	        print(f"[CONNECTION] {i:03} attempt={attempt_number} {node} -> {e}")
   484	    except Exception as e:
   485	        stat_inc("events_forward_error")
   486	        stat_inc("events_retried")
   487	        stat_unexpected_failure(i, attempt_number, node, reason=f"exception:{type(e).__name__}", payload={"exception": str(e)})
   488	        print(f"[ERROR] {i:03} attempt={attempt_number} {node} -> {e}")
   489	    if pending.retries_done + 1 >= MAX_RETRIES:
   490	        stat_inc("events_failed")
   491	        stat_unexpected_failure(i, attempt_number, node, reason="dropped_after_retries_exception", payload={"tried_nodes": list(pending.tried_nodes)})
   492	        print(f"[DROP] {i:03} event dropped after retries")
   493	        return False
   494	    pending.retries_done += 1
   495	    stat_inc("queue_requeues")
   496	    enqueue_pending(pending, compute_retry_backoff(pending.retries_done))
   497	    return False
   498	
   499	
   500	def sender_worker(worker_id):
   501	    while True:
   502	        try:
   503	            run_at, _, pending = pending_queue.get(timeout=0.5)
   504	        except queue.Empty:
   505	            if is_producer_done() and pending_queue.empty():
   506	                return
   507	            continue
   508	        now = time.time()
   509	        if run_at > now:
   510	            pending_queue.put((run_at, next_enqueue_seq(), pending))
   511	            pending_queue.task_done()
   512	            time.sleep(min(run_at - now, 0.2))
   513	            continue
   514	        try:
   515	            process_pending_event(pending, worker_id)
   516	        finally:
   517	            pending_queue.task_done()
   518	
   519	
   520	def chaos_loop():
   521	    for i in range(EVENTS):
   522	        if random.random() < KILL_PROBABILITY:
   523	            node = SLEEP_ONLY_NODE if SLEEP_ONLY_NODE else random.choice(NODES)
   524	            seconds = random.uniform(*DEATH_TIME_RANGE)
   525	            t = threading.Thread(target=kill_cycle, args=(node, seconds), daemon=True)
   526	            t.start()
   527	            kill_threads.append(t)
   528	        stat_inc("events_total")
   529	        enqueue_pending(PendingEvent(event_index=i, event=build_event(i)), delay_seconds=0.0)
   530	        time.sleep(random.uniform(*EVENT_DELAY_RANGE))
   531	    mark_producer_done()
   532	
   533	
   534	def revive_everything():
   535	    print("
   536	[MAIN] REVIVING ALL NODES
   537	")
   538	    for node in sorted(set(NODES)):
   539	        try:
   540	            requests.post(f"{node}/revive", timeout=2)
   541	            print(f"[FORCE REVIVE] {node}")
   542	        except Exception as e:
   543	            print(f"[FORCE REVIVE FAIL] {node} -> {e}")
   544	
   545	
   546	def wait_kills():
   547	    print("
   548	[MAIN] waiting active kill cycles...
   549	")
   550	    for t in kill_threads:
   551	        t.join(timeout=30)
   552	
   553	
   554	def wait_queue_drain():
   555	    deadline = time.time() + DRAIN_TIMEOUT
   556	    while time.time() < deadline:
   557	        if pending_queue.empty():
   558	            time.sleep(0.5)
   559	            if pending_queue.empty():
   560	                return True
   561	        time.sleep(0.2)
   562	    return False
   563	
   564	
   565	def write_csv_and_json():
   566	    with results_lock:
   567	        rows = list(results)
   568	    with open(EVENTS_CSV, "w", newline="", encoding="utf-8") as f:
   569	        writer = csv.DictWriter(f, fieldnames=["event_index", "attempt", "node", "status_code", "elapsed_ms", "leader", "result", "final"])
   570	        writer.writeheader()
   571	        for r in rows:
   572	            writer.writerow(r)
   573	    with stats_lock:
   574	        total = stats["events_total"]
   575	        ok = stats["events_ok"]
   576	        failed = stats["events_failed"]
   577	        success_rate = ((ok / total) * 100) if total else 0
   578	        avg_latency = (sum(stats["latency"]) / len(stats["latency"])) if stats["latency"] else 0
   579	        max_latency = max(stats["latency"]) if stats["latency"] else 0
   580	        min_latency = min(stats["latency"]) if stats["latency"] else 0
   581	        p50_latency = percentile(stats["latency"], 50)
   582	        p95_latency = percentile(stats["latency"], 95)
   583	        p99_latency = percentile(stats["latency"], 99)
   584	        report = {
   585	            "test_config": TEST_CONFIG,
