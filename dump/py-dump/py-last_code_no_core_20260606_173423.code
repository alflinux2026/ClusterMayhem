   673	# =====================================================
   674	# MAIN LOOP
   675	# =====================================================
   676	
   677	def chaos_loop():
   678	    for i in range(EVENTS):
   679	        if random.random() < KILL_PROBABILITY:
   680	            if SLEEP_ONLY_NODE:
   681	                node = SLEEP_ONLY_NODE
   682	            else:
   683	                node = random.choice(NODES)
   684	
   685	            seconds = random.uniform(*DEATH_TIME_RANGE)
   686	
   687	            t = threading.Thread(
   688	                target=kill_cycle,
   689	                args=(node, seconds),
   690	                daemon=True
   691	            )
   692	            t.start()
   693	            kill_threads.append(t)
   694	
   695	        stat_inc("events_total")
   696	        pending = PendingEvent(
   697	            event_index=i,
   698	            event=build_event(i),
   699	        )
   700	        enqueue_pending(pending, delay_seconds=0.0)
   701	
   702	        time.sleep(random.uniform(*EVENT_DELAY_RANGE))
   703	
   704	    mark_producer_done()
   705	
