    30	from cluster.runtime import context as ctx
    31	from cluster.runtime.cluster_store import cluster_state
    32	
    33	import json
    34	from cluster.runtime.event_log import get_integrity_canonical
    35	
    36	from cluster.runtime.leader import compute_alive
    37	
    38	# =============================================================================
    39	# Configuración de integridad
    40	# =============================================================================
    41	
    42	#: Claves a ignorar al comparar views (cambian constantemente)
    43	IGNORED_NODE_KEYS = {"last_seen"}
    44	
    45	# descomentado si hace falta validar log_meta
    46	#INTEGRITY_KEYS = (
