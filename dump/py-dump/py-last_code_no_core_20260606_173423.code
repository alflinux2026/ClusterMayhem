    72	class Heartbeat(BaseModel):
    73	    """
    74	    Modelo de heartbeat enviado por los nodos.
    75	
    76	    Attributes:
    77	        node_id: ID del nodo.
    78	        state: Estado actual (BOOT, STANDBY, ACTIVE, etc.).
    79	        priority: Prioridad para leader election.
    80	        state_since: Timestamp cuando se entró al estado.
    81	        prev_state: Estado anterior.
    82	        state_reason: Razón de la última transición.
    83	        log_meta: Metadatos del log (dirty, last_append_event_id, etc.).
    84	        cluster_integrity: Reporte de integridad.
    85	        streams: Stats de eventos (counts, totals).
    86	    """
    87	    node_id: str
    88	    state: str
    89	    priority: int
    90	    state_since: float | None = None
    91	    prev_state: str | None = None
    92	    state_reason: str | None = None
    93	    log_meta: dict | None = None
    94	    cluster_integrity: dict | None = None
    95	    streams: dict | None = None
    96	
    97	
    98	class Watchdog(BaseModel):
    99	    """
   100	    Modelo de watchdog enviado por los nodos.
   101	
   102	    Attributes:
   103	        node_id: ID del nodo.
