   316	def percentile(data, p):
   317	    """
   318	    Calcula el percentil p de una lista de datos.
   319	
   320	    Args:
   321	        data: Lista de valores numéricos.
   322	        p: Percentil a calcular (0-100).
   323	
   324	    Returns:
   325	        float: Percentil p (interpolación lineal).
   326	    """
   327	    if not data:
   328	        return 0.0
   329	    values = sorted(data)
   330	    if len(values) == 1:
   331	        return float(values[0])
   332	    rank = (len(values) - 1) * (p / 100.0)
   333	    low = int(rank)
   334	    high = min(low + 1, len(values) - 1)
   335	    return float(values[low] + (values[high] - values[low]) * (rank - low))
   336	
   337	
   338	def is_retryable_response(payload):
   339	    """
   340	    Comprueba si una respuesta es retryable.
   341	
   342	    Args:
   343	        payload: Dict de respuesta.
   344	
   345	    Returns:
   346	        bool: True si es retryable (no leader, isolated, timeout, connection, etc.).
   347	    """
   348	    if not isinstance(payload, dict):
   349	        return False
   350	    if payload.get("error") in {"no leader", "node isolated"}:
   351	        return True
   352	    return any(p in str(payload.get("error", "")).lower() for p in ["timeout", "connection", "refused", "temporarily unavailable", "isolated", "no leader"])
   353	
   354	
   355	def extract_leader(payload):
   356	    """Extrae el node_id del líder de una respuesta."""
   357	    if not isinstance(payload, dict):
   358	        return None
   359	    if "result" in payload and isinstance(payload["result"], dict):
   360	        return payload["result"].get("leader")
   361	    return payload.get("leader")
   362	
   363	
   364	def classify_submit_response(status_code, payload):
   365	    """
   366	    Clasifica la respuesta de un submit de evento.
   367	
   368	    Args:
   369	        status_code: Código HTTP de la respuesta.
   370	        payload: Dict de respuesta.
   371	
   372	    Returns:
   373	        str: "submit_ok", "retryable_error", "hard_fail", o "http_not_ok".
   374	    """
   375	    if status_code != 200:
   376	        return "http_not_ok"
   377	    if not isinstance(payload, dict):
   378	        return "submit_ok"
   379	    if payload.get("error"):
   380	        return "retryable_error" if is_retryable_response(payload) else "hard_fail"
   381	    result = payload.get("result")
   382	    if isinstance(result, dict) and result.get("error"):
   383	        return "retryable_error" if is_retryable_response(result) else "hard_fail"
   384	    return "submit_ok"
   385	
   386	
   387	def next_enqueue_seq():
   388	    """Genera el siguiente número de secuencia de encolado (thread-safe)."""
   389	    global enqueue_seq
   390	    with enqueue_seq_lock:
   391	        enqueue_seq += 1
   392	        return enqueue_seq
   393	
   394	
   395	def enqueue_pending(pending, delay_seconds=0.0):
   396	    """
   397	    Encola un evento pendiente para enviar.
   398	
   399	    Args:
   400	        pending: PendingEvent a encolar.
   401	        delay_seconds: Segundos de delay antes de intentar enviar.
   402	    """
   403	    run_at = time.time() + max(0.0, delay_seconds)
   404	    pending_queue.put((run_at, next_enqueue_seq(), pending))
   405	    with stats_lock:
   406	        stats["queue_max_depth"] = max(stats["queue_max_depth"], pending_queue.qsize())
   407	
   408	
   409	def mark_producer_done():
   410	    """Marca que el producer ha terminado de generar eventos."""
   411	    global producer_done
   412	    with producer_done_lock:
   413	        producer_done = True
   414	
   415	
   416	def is_producer_done():
   417	    """Comprueba si el producer ha terminado."""
   418	    with producer_done_lock:
   419	        return producer_done
   420	
   421	
   422	def compute_retry_backoff(retries_done):
   423	    """
   424	    Calcula el backoff para retry (exponencial).
   425	
   426	    Args:
   427	        retries_done: Número de retries ya hechos.
   428	
   429	    Returns:
   430	        float: Backoff en segundos (base * 2^(retries_done - 1), max RETRY_BACKOFF_MAX).
   431	    """
   432	    return min(RETRY_BACKOFF_BASE * (2 ** max(0, retries_done - 1)), RETRY_BACKOFF_MAX)
   433	
