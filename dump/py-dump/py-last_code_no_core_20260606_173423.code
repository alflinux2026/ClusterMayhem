    41	def parse_args():
    42	    parser = argparse.ArgumentParser(description="Universal chaos torture runner final")
    43	    parser.add_argument("--nodes", nargs="+", default=DEFAULT_NODES)
    44	    parser.add_argument("--events", type=int, default=DEFAULT_EVENTS)
    45	    parser.add_argument("--delay-min", type=float, default=DEFAULT_EVENT_DELAY_MIN)
    46	    parser.add_argument("--delay-max", type=float, default=DEFAULT_EVENT_DELAY_MAX)
    47	    parser.add_argument("--kill-prob", type=float, default=DEFAULT_KILL_PROBABILITY)
    48	    parser.add_argument("--death-min", type=float, default=DEFAULT_DEATH_TIME_MIN)
    49	    parser.add_argument("--death-max", type=float, default=DEFAULT_DEATH_TIME_MAX)
    50	    parser.add_argument("--timeout", type=float, default=DEFAULT_REQUEST_TIMEOUT)
    51	    parser.add_argument("--retries", type=int, default=DEFAULT_MAX_RETRIES)
    52	    parser.add_argument("--sleep-only-node", default=DEFAULT_SLEEP_ONLY_NODE)
    53	    parser.add_argument("--slow-ms", type=float, default=DEFAULT_SLOW_EVENT_THRESHOLD_MS)
    54	    parser.add_argument("--seed", type=int, default=None)
    55	    parser.add_argument("--output", default=None)
    56	    parser.add_argument("--send-workers", type=int, default=DEFAULT_SEND_WORKERS)
    57	    parser.add_argument("--retry-backoff-base", type=float, default=DEFAULT_RETRY_BACKOFF_BASE)
    58	    parser.add_argument("--retry-backoff-max", type=float, default=DEFAULT_RETRY_BACKOFF_MAX)
    59	    parser.add_argument("--drain-timeout", type=float, default=60.0)
    60	    parser.add_argument("--tenant-id", default=DEFAULT_TENANT_ID)
