     6	from cluster.runtime.events.cluster_event import ClusterEvent
     7	
     8	def transition_event(event_id: str, new_status):
     9	
    10	    events = load_events()
    11	
    12	    latest_raw = None
    13	
    14	    for e in reversed(events):
    15	        if e["event_id"] == event_id:
    16	            latest_raw = e
    17	            break
    18	
    19	    if not latest_raw:
    20	        return
    21	
    22	    latest = ClusterEvent(**latest_raw)  # 🔥 NORMALIZACIÓN AQUÍ
    23	
    24	    old_status = latest.status
    25	
    26	    validate_transition(old_status, new_status)
    27	
    28	    latest.status = new_status
    29	
    30	    append_event(latest)  # ✔ ahora sí correcto


===== ./cluster/runtime/watchdog.py =====
     1	# File: ./cluster/runtime/watchdog.py
     2	# Previous: none
     3	# Author: alftorres
     4	# Date: 2026-05-28T17:12:10+0200
     5	# Version: 0.0.0
     6	# Genealogy:
     7	#   ./cluster/runtime/watchdog.py 0.0.0 2026-05-28T17:12:10+0200
     8	#   God
     9	#
    10	# Purpose:
    11	#   Mecanismo de watchdog para detectar nodos bloqueados.
    12	#   Envía señales periódicas (watchdog) a todos los peers indicando si el nodo
    13	#   está ocupado (busy) o libre. Si un nodo no envía watchdog en WATCHDOG_TIMEOUTSEC,
    14	#   se considera bloqueado y los otros nodos pueden tomar acción.
    15	# Notes:
    16	#   - Se ejecuta en cada tick del worker (~1s) vía emit_watchdog_if_due()
    17	#   - Throttle automático: no más de un watchdog cada WATCHDOG_PERIODSEC (0.5s por defecto)
    18	#   - busy=True cuando el nodo está procesando eventos, busy=False cuando está libre
    19	#   - Si un nodo está busy > timeout, se considera stuck y puede ser ignorado en election
    20	#   - WATCHDOG_DEBUG=(1|true|yes|on) habilita logs detallados
    21	#
    22	# FRV-ID: 4aa43744dbd78882
    23	# Header_End
    24	
    25	
    26	import os
    27	import time
    28	import logging
    29	import requests
    30	
    31	from cluster.runtime import context as ctx
    32	from cluster.runtime.cluster_store import cluster_state
    33	from cluster.utils.log_print import log_state
    34	
    35	logging.getLogger("urllib3").setLevel(logging.ERROR)
    36	logging.getLogger("requests").setLevel(logging.ERROR)
    37	
    38	# =============================================================================
    39	# Configuración de watchdog (mediante env vars)
    40	# =============================================================================
    41	
    42	#: Frecuencia mínima entre watchdogs en segundos (default: 0.5s)
    43	#: Evita enviar watchdogs demasiado seguido
    44	WATCHDOG_PERIODSEC = float(os.getenv("WATCHDOG_PERIODSEC", 0.5))
    45	
    46	#: Timeout para considerar un nodo como stuck en segundos (default: 1.0s)
    47	#: Si un nodo no envía watchdog en este tiempo, se considera bloqueado
    48	WATCHDOG_TIMEOUTSEC = float(os.getenv("WATCHDOG_TIMEOUTSEC", 1.0))
    49	
    50	#: Habilita logs detallados de watchdog (default: False)
    51	#: Activar con WATCHDOG_DEBUG=1 o WATCHDOG_DEBUG=true
    52	WATCHDOG_DEBUG = str(os.getenv("WATCHDOG_DEBUG", "0")).strip().lower() in ("1", "true", "yes", "on")
    53	
    54	#: Sesión HTTP reutilizable para requests (connection pooling)
    55	HTTP = requests.Session()
    56	
    57	#: Timestamp del último watchdog emitido (para throttle)
    58	_last_watchdog_emit_ts = 0.0
    59	
    60	
    61	def _iter_targets(peers):
    62	    """
    63	    Itera sobre los peers,YIELD node_id y dict del nodo.
    64	
    65	    Soporta tanto dict (node_id -> node) como list (lista de nodes).
    66	
    67	    Args:
    68	        peers: Dict o list con info de peers.
    69	
    70	    Yields:
    71	        tuple[str, dict]: (node_id, node_dict) para cada peer.
    72	
    73	    Example:
    74	        >>> peers = {"lnx203hp": {"host": "10.0.0.1", "port": 8000}}
    75	        >>> list(_iter_targets(peers))
    76	        [("lnx203hp", {"host": "10.0.0.1", "port": 8000})]
    77	
    78	        >>> peers = [{"node_id": "lnx203hp", "host": "10.0.0.1", "port": 8000}]
    79	        >>> list(_iter_targets(peers))
    80	        [("lnx203hp", {"node_id": "lnx203hp", "host": "10.0.0.1", "port": 8000})]
    81	    """
    82	    if isinstance(peers, dict):
    83	        for peer_id, node in peers.items():
    84	            if isinstance(node, dict):
    85	                yield peer_id, node
    86	        return
    87	
    88	    if isinstance(peers, list):
    89	        for node in peers:
    90	            if not isinstance(node, dict):
    91	                continue
    92	            peer_id = node.get("node_id") or node.get("name") or node.get("host")
    93	            if peer_id:
    94	                yield peer_id, node
    95	        return
    96	
    97	
    98	def _mark_local_watchdog(emitted_at: float, busy: bool):
    99	    """
   100	    Actualiza el watchdog del nodo local en cluster_state.
   101	
   102	    Marca el nodo local como busy/free y actualiza last_watchdog y last_seen.
   103	
   104	    Args:
   105	        emitted_at: Timestamp cuando se emitió el watchdog.
   106	        busy: True si el nodo está ocupado, False si está libre.
   107	
   108	    Note:
   109	        - Actualiza tanto cluster_state como ctx.node (si existe)
   110	        - Se llama antes de enviar watchdogs a peers
   111	    """
   112	    node_id = getattr(ctx, "node_id", None)
   113	    if not node_id:
   114	        return
   115	
   116	    current = cluster_state.get(node_id, {})
   117	    cluster_state[node_id] = {
   118	        **current,
   119	        "last_watchdog": emitted_at,
   120	        "last_seen": emitted_at,
   121	        "watchdog_busy": bool(busy),
   122	    }
   123	
   124	    try:
   125	        ctx.node.last_watchdog = emitted_at
   126	        ctx.node.watchdog_busy = bool(busy)
   127	    except Exception:
   128	        pass
   129	
   130	
   131	def emit_watchdog(peers, force=False, busy=True):
   132	    """
   133	    Emite un watchdog a todos los peers.
   134	
   135	    Envía POST /watchdog a cada peer indicando si el nodo está busy.
   136	    Tiene throttle automático para no enviar demasiado seguido.
   137	
   138	    Args:
   139	        peers: Lista o dict de peers con host y port.
   140	        force: Si True, ignora el throttle y envía siempre.
   141	        busy: True si el nodo está ocupado procesando, False si está libre.
   142	
   143	    Returns:
   144	        bool: True si se emitió el watchdog, False si se throttleó.
   145	
   146	    Example:
   147	        >>> peers = [{"host": "10.0.0.1", "port": 8000}]
   148	        >>> emit_watchdog(peers, busy=True)
   149	        True
   150	
   151	        >>> emit_watchdog(peers, busy=False)  # 0.1s después del anterior
   152	        False  # Throttleado (menos de WATCHDOG_PERIODSEC)
   153	
   154	    Note:
   155	        - Throttle: no más de un watchdog cada WATCHDOG_PERIODSEC (0.5s por defecto)
   156	        - force=True ignora el throttle (útil para eventos críticos)
   157	        - busy=True cuando se está procesando eventos, busy=False cuando está idle
   158	        - Actualiza cluster_state local antes de enviar
   159	        - Logea detalles si WATCHDOG_DEBUG=True
   160	    """
   161	    global _last_watchdog_emit_ts
   162	
   163	    if not getattr(ctx, "node_id", None):
   164	        return False
   165	
   166	    now = time.time()
   167	    if not force and (now - _last_watchdog_emit_ts) < WATCHDOG_PERIODSEC:
   168	        return False
   169	
   170	    emitted_at = now
   171	    _mark_local_watchdog(emitted_at, busy)
   172	
   173	    payload = {
   174	        "node_id": ctx.node_id,
   175	        "busy": bool(busy),
   176	        "emitted_at": emitted_at,
   177	    }
   178	
   179	    sent = 0
   180	    attempted = 0
   181	
   182	    for peer_id, node in _iter_targets(peers):
   183	        host = node.get("host")
   184	        port = node.get("port")
   185	        if not host or not port:
   186	            continue
   187	
   188	        attempted += 1
   189	        url = f"http://{host}:{port}/watchdog"
   190	        try:
   191	            resp = requests.post(url, json=payload, timeout=WATCHDOG_TIMEOUTSEC)
   192	            if resp.ok:
   193	                sent += 1
   194	            elif WATCHDOG_DEBUG:
   195	                log_state("yellow", "WATCHDOG", f"peer={peer_id} status={resp.status_code}", 3)
   196	        except Exception as e:
   197	            if WATCHDOG_DEBUG:
   198	                log_state("red", "WATCHDOG", f"peer={peer_id} err={e}", 3)
   199	
   200	    _last_watchdog_emit_ts = emitted_at
   201	
   202	    if WATCHDOG_DEBUG:
   203	        log_state(
   204	            "cyan",
   205	            "WATCHDOG",
   206	            f"node={ctx.node_id} sent={sent}/{attempted} busy={bool(busy)} ts={emitted_at:.3f}",
   207	            3,
   208	        )
   209	
   210	    return True
   211	
   212	
   213	def emit_watchdog_if_due(peers, busy=True):
   214	    """
   215	    Emite watchdog si ha pasado suficiente tiempo (throttle respetado).
   216	
   217	    Wrapper de emit_watchdog() con force=False.
   218	
   219	    Args:
   220	        peers: Lista o dict de peers.
   221	        busy: True si el nodo está ocupado, False si está libre.
   222	
   223	    Returns:
   224	        bool: True si se emitió, False si se throttleó.
   225	
   226	    Example:
   227	        >>> emit_watchdog_if_due(peers, busy=True)
   228	        # Se llama en cada tick del worker (~1s)
   229	    """
   230	    return emit_watchdog(peers=peers, force=False, busy=busy)
   231	
   232	
   233	def emit_watchdog_now(peers, busy=True):
   234	    """
   235	    Emite watchdog inmediatamente, ignorando el throttle.
   236	
   237	    Wrapper de emit_watchdog() con force=True.
   238	
   239	    Args:
   240	        peers: Lista o dict de peers.
   241	        busy: True si el nodo está ocupado, False si está libre.
   242	
   243	    Returns:
   244	        bool: Siempre True (si hay node_id).
   245	
   246	    Example:
   247	        >>> emit_watchdog_now(peers, busy=True)
   248	        # Se envía inmediatamente, sin esperar WATCHDOG_PERIODSEC
   249	    """
   250	    return emit_watchdog(peers=peers, force=True, busy=busy)


