     9	#
    10	# Purpose:
    11	#   Módulo de contexto global para el cluster.
    12	#   Almacena variables de estado compartidas que se inicializan durante el bootstrap
    13	#   y se acceden desde múltiples módulos sin pasarlas explícitamente como parámetros.
    14	# Notes:
    15	#   - Este patrón (global state) es común en sistemas single-threaded con event loop
    16	#   - En un futuro considerar inyección de dependencias explícita para testabilidad
    17	#   - Las variables se inicializan en None/empty y se llenan en bootstrap.py
    18	#
    19	# FRV-ID: fae1f65db3f7af4a
    20	# Header_End
    21	
    22	from typing import Any
    23	
    24	# =============================================================================
    25	# Variables globales de contexto del nodo
    26	# =============================================================================
    27	
    28	#: Objeto NodeRuntime completo del nodo actual (se inicializa en bootstrap)
    29	#: Tipo: NodeRuntime | None
    30	node = None
    31	
    32	#: ID único del nodo actual dentro del cluster (string)
    33	#: Se usa para identificar el nodo en heartbeats, leader election, etc.
    34	#: Tipo: str | None
    35	node_id = None
    36	
    37	#: Alias de node_id para compatibilidad con código legacy
    38	#: TODO: Deprecar y usar solo node_id
    39	#: Tipo: str | None
    40	nodeid = None
    41	
    42	#: Lista de nodos peer en el cluster (lista de dicts con info de nodos)
    43	#: Cada entry típicamente tiene: node_id, host, port, priority, state, etc.
    44	#: Se actualiza en cluster_state durante bootstrap y heartbeats
    45	#: Tipo: list[dict[str, Any]]
    46	peers = []
    47	
    48	#: Stream actual del nodo (para multiplexación de eventos por stream)
    49	#: Si es None, se usa el stream por defecto o node_stream
    50	#: Tipo: str | None
    51	stream = None
    52	
    53	#: Stream asociado al nodo (alternativa a stream)
    54	#: Se prioriza stream sobre node_stream en get_stream()
    55	#: Tipo: str | None
    56	node_stream = None
    57	
    58	
    59	def get_stream():
    60	    """
    61	    Devuelve el stream activo del nodo.
    62	
    63	    Prioridad:
    64	        1. `stream` (si está definido)
    65	        2. `node_stream` (fallback)
    66	        3. None (si ninguno está definido)
    67	
    68	    Returns:
    69	        str | None: El stream activo o None si no hay ninguno configurado.
    70	
    71	    Example:
    72	        >>> stream = get_stream()
    73	        >>> if stream:
    74	        ...     process_events(stream)
    75	    """
    76	    return stream or node_stream


