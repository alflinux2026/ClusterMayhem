   394	@app.post("/debug/log/replica/{node_id}")
   395	async def log_replica_write(node_id: str, request: Request):
   396	    """
   397	    Recibe y escribe el log replica de un peer.
   398	
   399	    Parte del mecanismo de replicación: el peer envía su log local
   400	    y este endpoint lo guarda como replica.
   401	    """
   402	    try:
   403	        content = await request.body()
   404	    except Exception as e:
   405	        return {"ok": False, "node_id": node_id, "error": str(e)}
   406	    text = content.decode("utf-8") if content else ""
   407	    write_replica_log(node_id, text)
   408	    return {"ok": True, "node_id": node_id, "path": get_replica_log_path(node_id), "bytes": len(content)}
   409	
