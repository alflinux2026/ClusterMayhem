   264	
   265	def percentile(data, p):
   266	    if not data:
   267	        return 0.0
   268	    values = sorted(data)
   269	    if len(values) == 1:
   270	        return float(values[0])
   271	    rank = (len(values) - 1) * (p / 100.0)
   272	    low = int(rank)
   273	    high = min(low + 1, len(values) - 1)
   274	    fraction = rank - low
   275	    return float(values[low] + (values[high] - values[low]) * fraction)
   276	
   277	
   278	def is_retryable_response(payload):
   279	    if not isinstance(payload, dict):
   280	        return False
   281	
   282	    if payload.get("error") in {"no leader", "node isolated"}:
   283	        return True
   284	
   285	    error = str(payload.get("error", "")).lower()
   286	
   287	    retry_patterns = [
   288	        "timeout",
   289	        "connection",
   290	        "refused",
   291	        "temporarily unavailable",
   292	        "isolated",
   293	        "no leader",
   294	    ]
   295	
   296	    return any(p in error for p in retry_patterns)
   297	
   298	
   299	def extract_leader(payload):
   300	    if not isinstance(payload, dict):
   301	        return None
   302	
   303	    if "result" in payload and isinstance(payload["result"], dict):
   304	        return payload["result"].get("leader")
   305	
   306	    return payload.get("leader")
   307	
   308	
   309	def classify_submit_response(status_code, payload):
   310	    if status_code != 200:
   311	        return "http_not_ok"
   312	
   313	    if not isinstance(payload, dict):
   314	        return "submit_ok"
   315	
   316	    if payload.get("error"):
   317	        if is_retryable_response(payload):
   318	            return "retryable_error"
   319	        return "hard_fail"
   320	
   321	    result = payload.get("result")
   322	    if isinstance(result, dict) and result.get("error"):
   323	        if is_retryable_response(result):
   324	            return "retryable_error"
   325	        return "hard_fail"
   326	
   327	    return "submit_ok"
   328	
   329	
   330	def next_enqueue_seq():
   331	    global enqueue_seq
   332	    with enqueue_seq_lock:
   333	        enqueue_seq += 1
   334	        return enqueue_seq
   335	
   336	
   337	def enqueue_pending(pending, delay_seconds=0.0):
   338	    run_at = time.time() + max(0.0, delay_seconds)
   339	    pending_queue.put((run_at, next_enqueue_seq(), pending))
   340	    with stats_lock:
   341	        depth = pending_queue.qsize()
   342	        if depth > stats["queue_max_depth"]:
   343	            stats["queue_max_depth"] = depth
   344	
   345	
   346	def mark_producer_done():
   347	    global producer_done
   348	    with producer_done_lock:
   349	        producer_done = True
   350	
   351	
   352	def is_producer_done():
   353	    with producer_done_lock:
   354	        return producer_done
   355	
   356	
   357	def compute_retry_backoff(retries_done):
   358	    backoff = RETRY_BACKOFF_BASE * (2 ** max(0, retries_done - 1))
   359	    return min(backoff, RETRY_BACKOFF_MAX)
   360	
