   531	@app.post("/event")
   532	def handle_event(event: ClusterEvent):
   533	    """
   534	    Recibe un evento y lo ingiere o reenvía al líder.
   535	
   536	    Flow:
   537	        1. Checkea si el nodo está en SEGMENTATION/DRAINING/ISOLATED -> error
   538	        2. Checkea si hay líder -> si no, error
   539	        3. Si soy STANDBY, reenvío al líder con requests.post()
   540	        4. Si soy líder, ingierto el evento con ingest_event()
   541	
   542	    Args:
   543	        event: Evento a ingerir.
   544	
   545	    Returns:
   546	        dict: {"status": "ok", "event_id": ..., "result": ...} si es líder
   547	              o resp.json() del líder si soy standby
   548	    """
   549	    if ctx.node.state == NodeState.SEGMENTATION:
   550	        return {"error": "node SEGMENTATION"}
   551	    if ctx.node.state == NodeState.DRAINING:
   552	        return {"error": "node DRAINING"}
   553	    if ctx.node.state == NodeState.ISOLATED:
   554	        return {"error": "node ISOLATED"}
   555	    leader = compute_leader()
   556	    if not leader:
   557	        log_state("red", "(NO LEADER)", event.event_id, 3)
   558	        return {"error": "no leader"}
   559	
   560	    if ctx.node.state == NodeState.STANDBY:
   561	        msg = event.payload.get("msg", "<no-msg>")
   562	        log_state("cyan", "[EVENT FWD]", f"{msg:12} -> {leader}", 3)
   563	        node = CLUSTER_REGISTRY[leader]
   564	        url = f"http://{node['host']}:{node['port']}/event"
   565	        try:
   566	            resp = requests.post(url, json=event.model_dump(), timeout=2)
   567	            return resp.json()
   568	        except Exception as e:
   569	            return {"error": str(e)}
   570	
   571	    result = ingest_event(event, ctx.node_id)
   572	    return {"status": "ok", "event_id": event.event_id, "result": result}
   573	
