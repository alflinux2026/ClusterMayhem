     9	from cluster.runtime.events.cluster_event import ClusterEvent
    10	from cluster.runtime.event_log import (
    11	    append_event,
    12	    get_completed_event_ids,
    13	)
    14	
    15	from cluster.runtime.events.event_state import EventStatus
    16	
    17	
    18	
    19	# =========================
    20	# FORWARD TO LEADER
    21	# =========================
    22	def forward_to_leader(event: ClusterEvent):
    23	
    24	    leader = compute_leader()
    25	
    26	    if not leader:
    27	        log_state("red", "(NO LEADER)", event.event_id, 3)
    28	        return {"error": "no leader"}
    29	
    30	    node = CLUSTER_REGISTRY[leader]
    31	    url = f"http://{node['host']}:{node['port']}/route"
    32	
    33	    event.add_hop("leader_routed")
    34	
    35	    resp = requests.post(
    36	        url,
    37	        json=event.model_dump(),
    38	        timeout=2
    39	    )
    40	
    41	    try:
    42	        return resp.json()
    43	    except:
    44	        return {"status": "forwarded", "raw": resp.text}
    45	
    46	# =========================
    47	# FORWARD TO WORKER (TRANSPORT ONLY)
    48	# =========================
    49	
    50	import requests
    51	
    52	from cluster.runtime.registry import CLUSTER_REGISTRY
    53	from cluster.runtime.leader import compute_leader
    54	from cluster.utils.log_print import log_state
    55	from cluster.runtime.events.cluster_event import ClusterEvent
    56	
    57	
    58	def forward_event(node_id: str, event: ClusterEvent):
    59	
    60	    node = CLUSTER_REGISTRY[node_id]
    61	    url = f"http://{node['host']}:{node['port']}/execute"
    62	
    63	    event.add_hop(f"worker:{node_id}")
    64	
    65	    msg = event.payload.get("msg", "<no-msg>")
    66	
    67	    log_state(
    68	        "magenta",
    69	        "[WORKER SEND]",
    70	        f"{msg:12} -> {node_id}",
    71	        3
    72	    )
    73	
    74	    # -------------------------
    75	    # SEND TO WORKER
    76	    # -------------------------
    77	    try:
    78	
    79	        #log_state("red", "[BEFORE POST]", url, 3)
    80	        resp = requests.post(
    81	            url,
    82	            json=event.model_dump(),
    83	            timeout=2
    84	        )
    85	        #log_state("red", "[AFTER POST]", str(resp.status_code), 3)
    86	
    87	
    88	        worker_result = resp.json()
    89	
    90	    except Exception as e:
    91	        log_state(
    92	            "red",
    93	            "[WORKER SEND FAIL]",
    94	            f"{msg:12} -> {node_id} | {e}",
    95	            3
    96	        )
    97	        return {"error": "worker_send_failed"}
    98	
    99	    # -------------------------
   100	    # LEADER DECIDES FINAL STATE (Opción B real)
   101	    # -------------------------
   102	    if worker_result.get("status") == "completed":
   103	
   104	        from cluster.runtime.state_machine import transition_event
   105	        from cluster.runtime.events.event_state import EventStatus
   106	
   107	        transition_event(
   108	            event.event_id,
   109	            EventStatus.COMPLETED
   110	        )
   111	
   112	
   113	        log_state(
   114	            "yellow",
   115	            "(EVENT)",
   116	            f"{msg:12} -> COMPLETED",
   117	            3
   118	        )
   119	
   120	    return {
   121	        "status": "forwarded",
   122	        "event_id": event.event_id,
   123	        "target": node_id
   124	    }


