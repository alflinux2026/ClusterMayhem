   204	            "latency_ms": round(latency_ms, 3),
   205	            "leader": leader,
   206	            "payload": payload,
   207	            "timestamp": datetime.now().isoformat(),
   208	        })
   209	
   210	
   211	def stat_kill_event(node, action, ok, payload=None, error=None, seconds=None):
   212	    with stats_lock:
   213	        stats["kill_events"].append({
   214	            "action": action,
   215	            "node": node,
   216	            "ok": ok,
