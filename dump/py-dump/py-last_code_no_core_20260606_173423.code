   110	
   111	
   112	class SegmentRotateRequest(BaseModel):
   113	    """
   114	    Modelo para rotación de segmentos.
   115	
   116	    Attributes:
   117	        request_id: ID único de la request.
   118	        source_node: Nodo origen.
   119	        target_group: Grupo destino.
   120	        segment: Segmento a rotar (default: "000").
   121	        files: Lista de tipos de archivos (default: ["events", "event_log"]).
   122	        action: Acción a realizar (default: "rotate").
   123	        force: Si True, crea entry incluso si el archivo no existe.
   124	        ts: Timestamp opcional.
   125	    """
   126	    request_id: str
   127	    source_node: str
   128	    target_group: str
   129	    segment: str
   130	    files: list[str] = ["events", "event_log"]
   131	    action: str = "rotate"
   132	    force: bool = False
   133	    ts: float | None = None
   134	
   135	
   136	def _round_or_none(value: float | None, digits: int = 1) -> float | None:
   137	    """Redondea un valor o retorna None si es None/inválido."""
   138	    if value is None:
   139	        return None
   140	    try:
   141	        return round(float(value), digits)
   142	    except Exception:
   143	        return None
   144	
   145	
   146	def _watchdog_age_s(node: dict, now: float | None = None) -> float | None:
   147	    """Calcula cuántos segundos desde el último watchdog."""
   148	    now = now or time.time()
   149	    last_watchdog = node.get("last_watchdog")
   150	    if last_watchdog is None:
   151	        return None
   152	    try:
   153	        return max(0.0, now - float(last_watchdog))
   154	    except Exception:
   155	        return None
   156	
   157	
   158	def _state_age_s(node: dict, now: float | None = None) -> float | None:
   159	    """Calcula cuántos segundos desde que se entró al estado actual."""
   160	    now = now or time.time()
   161	    state_since = node.get("state_since")
   162	    if state_since is None:
   163	        return None
   164	    try:
   165	        return max(0.0, now - float(state_since))
   166	    except Exception:
   167	        return None
   168	
   169	
   170	def _seen_age_s(node: dict, now: float | None = None) -> float | None:
   171	    """Calcula cuántos segundos desde el último last_seen."""
   172	    now = now or time.time()
   173	    last_seen = node.get("last_seen")
   174	    if last_seen is None:
   175	        return None
   176	    try:
   177	        return max(0.0, now - float(last_seen))
   178	    except Exception:
   179	        return None
   180	
   181	
   182	def _presence_age_s(node: dict, now: float | None = None) -> float | None:
   183	    """Calcula cuántos segundos desde la última actividad (last_seen o last_watchdog)."""
   184	    now = now or time.time()
   185	    last_seen = node.get("last_seen")
   186	    last_watchdog = node.get("last_watchdog")
   187	    candidates = []
   188	    for value in (last_seen, last_watchdog):
   189	        if value is None:
   190	            continue
   191	        try:
   192	            candidates.append(float(value))
   193	        except Exception:
   194	            continue
   195	    if not candidates:
   196	        return None
   197	    return max(0.0, now - max(candidates))
   198	
   199	
   200	def _presence_health(node: dict, now: float | None = None, stale_after_s: float = 3.0) -> str:
   201	    """
   202	    Calcula la salud de presencia del nodo.
   203	
   204	    Returns:
   205	        str: "ok" si actividad reciente (< stale_after_s), "stale" si no.
   206	    """
   207	    age = _presence_age_s(node, now)
   208	    if age is None:
   209	        return "stale"
   210	    return "ok" if age < stale_after_s else "stale"
   211	
   212	
   213	def _compact_node(node: dict) -> dict:
   214	    """
   215	    Compacta un nodo a un resúmen para el dashboard.
   216	
   217	    Args:
   218	        node: Dict completo del nodo.
   219	
   220	    Returns:
   221	        dict: Node compactado con state, priority, ages, health, etc.
   222	    """
   223	    now = time.time()
   224	    return {
   225	        "state": node.get("state"),
   226	        "priority": node.get("priority"),
   227	        "last_seen": node.get("last_seen"),
   228	        "seen_age_s": _round_or_none(_seen_age_s(node, now), 3),
   229	        "last_watchdog": node.get("last_watchdog"),
   230	        "watchdog_age_s": _round_or_none(_watchdog_age_s(node, now), 3),
   231	        "watchdog_busy": node.get("watchdog_busy"),
   232	        "presence_age_s": _round_or_none(_presence_age_s(node, now), 3),
   233	        "presence_health": _presence_health(node, now),
   234	        "state_since": node.get("state_since"),
   235	        "state_age_s": _round_or_none(_state_age_s(node, now), 3),
   236	        "prev_state": node.get("prev_state"),
   237	        "state_reason": node.get("state_reason"),
   238	        "log_meta": node.get("log_meta", {}),
   239	        "streams": node.get("streams", {}),
   240	    }
   241	
   242	
   243	def _read_jsonl(path: str) -> list[dict]:
   244	    """Carga eventos de un archivo JSONL."""
   245	    if not os.path.exists(path):
   246	        return []
   247	    out: list[dict] = []
   248	    with open(path, "r", encoding="utf-8") as f:
   249	        for line in f:
   250	            line = line.strip()
   251	            if not line:
   252	                continue
   253	            try:
   254	                out.append(json.loads(line))
   255	            except Exception:
   256	                continue
   257	    return out
   258	
   259	
   260	def _summarize_events(events: list[dict]) -> dict:
   261	    """
   262	    Crea un resúmen de eventos con counts por status.
   263	
   264	    Args:
   265	        events: Lista de eventos (puede tener duplicados por event_id).
   266	
   267	    Returns:
   268	        dict: Resúmen con total_events, counts (created, executing, completed), last_event_id.
   269	    """
   270	    latest_by_event_id: dict[str, dict] = {}
   271	    last_event_id = None
   272	    for event in events:
   273	        event_id = event.get("event_id")
   274	        if not event_id:
   275	            continue
   276	        latest_by_event_id[event_id] = event
   277	        last_event_id = event_id
   278	    counts = Counter()
   279	    for event in latest_by_event_id.values():
   280	        status = str(event.get("status", "unknown")).lower()
   281	        counts[status] += 1
   282	    return {
   283	        "total_events": len(latest_by_event_id),
   284	        "counts": {
   285	            "created": counts.get("created", 0),
   286	            "executing": counts.get("executing", 0),
   287	            "completed": counts.get("completed", 0),
   288	            "unknown": counts.get("unknown", 0),
   289	        },
   290	        "last_event_id": last_event_id,
   291	    }
   292	
   293	
   294	def _next_rotation_index(base_dir, stem, suffix=".jsonl"):
   295	    """Encuentra el próximo índice disponible para rotación de archivos."""
   296	    base_dir = Path(base_dir)
   297	    idx = 1
   298	    while True:
   299	        candidate = base_dir / f"{stem}.{idx:03d}{suffix}"
   300	        if not candidate.exists():
   301	            return idx
   302	        idx += 1
   303	
   304	
   305	def rotate_segment_files(target_group: str, segment: str = "000", files=None, force: bool = False):
   306	    """Rota archivos de segmento (renombra .local.000.jsonl a .{target_group}.001.jsonl)."""
   307	    files = files or ["events", "event_log"]
   308	    base_dir = Path(get_local_log_path(None)).resolve().parent
   309	    result = {}
   310	
   311	    for kind in files:
   312	        src = base_dir / f"{kind}.local.{segment}.jsonl"
   313	        if not src.exists():
   314	            if force:
   315	                result[kind] = {"before": str(src), "after": None, "index": None, "forced": True}
   316	                continue
   317	            raise FileNotFoundError(str(src))
   318	
   319	        idx = _next_rotation_index(base_dir, f"{kind}.{target_group}")
   320	        dst = base_dir / f"{kind}.{target_group}.{idx:03d}.jsonl"
   321	        os.replace(str(src), str(dst))
   322	        result[kind] = {"before": str(src), "after": str(dst), "index": idx, "forced": False}
   323	
   324	    return result
   325	
   326	
   327	def cleanup_local_segment_files(target_group: str, segment: str = "000", files=None):
   328	    """Elimina archivos de segmento local después de rotar."""
   329	    files = files or ["events", "event_log"]
   330	    base_dir = Path(get_local_log_path(None)).resolve().parent
   331	    removed = []
   332	    already_gone = []
   333	
   334	    for kind in files:
   335	        p = base_dir / f"{kind}.local.{segment}.jsonl"
   336	        if p.exists():
   337	            p.unlink()
   338	            removed.append(str(p))
   339	        else:
   340	            already_gone.append(str(p))
   341	
   342	    return {"target_group": target_group, "segment": segment, "removed": removed, "already_gone": already_gone}
   343	
