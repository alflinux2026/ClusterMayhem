    42	@dataclass(slots=True)
    43	class EventEnvelope:
    44	    stream: StreamKey
    45	    event_type: str
    46	    payload: dict[str, Any] = field(default_factory=dict)
    47	    event_id: str = field(default_factory=lambda: str(uuid4()))
    48	    trace_id: str = field(default_factory=lambda: str(uuid4()))
    49	    status: EventStatus = EventStatus.CREATED
    50	    route_hops: list[str] = field(default_factory=list)
    51	    source_node: Optional[str] = None
    52	    target_node: Optional[str] = None
