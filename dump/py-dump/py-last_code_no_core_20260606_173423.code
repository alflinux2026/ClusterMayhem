   386	# =====================================================
   387	# KILL / REVIVE
   388	# =====================================================
   389	
   390	def kill_node(node, seconds=None):
   391	    stat_inc("kill_attempts")
   392	
   393	    try:
   394	        resp = requests.post(f"{node}/sleep", timeout=2)
   395	        payload = {}
   396	
   397	        try:
   398	            payload = resp.json()
   399	        except Exception:
   400	            payload = {"raw_text": resp.text}
   401	
   402	        if resp.status_code == 200 and payload.get("ok") is True:
   403	            with dead_lock:
   404	                dead_nodes.add(node)
   405	
   406	            stat_inc("kills")
   407	            stat_kill_event(node=node, action="sleep", ok=True, payload=payload, seconds=seconds)
   408	            print(f"[CHAOS] SLEEP {node}")
   409	            return True
   410	
   411	        stat_inc("kill_failures")
   412	        stat_kill_event(node=node, action="sleep", ok=False, payload=payload, seconds=seconds)
   413	        print(f"[CHAOS FAIL SLEEP] {node} -> status={resp.status_code} payload={payload}")
   414	        return False
   415	
   416	    except Exception as e:
   417	        stat_inc("kill_failures")
   418	        stat_kill_event(node=node, action="sleep", ok=False, error=str(e), seconds=seconds)
   419	        print(f"[CHAOS FAIL SLEEP] {node} -> {e}")
   420	        return False
   421	
   422	
   423	def revive_node(node):
   424	    try:
   425	        resp = requests.post(f"{node}/revive", timeout=2)
   426	        payload = {}
   427	
   428	        try:
   429	            payload = resp.json()
   430	        except Exception:
   431	            payload = {"raw_text": resp.text}
   432	
   433	        if resp.status_code == 200 and payload.get("ok") is True:
   434	            with dead_lock:
   435	                dead_nodes.discard(node)
   436	
   437	            stat_inc("revives")
   438	            stat_kill_event(node=node, action="revive", ok=True, payload=payload)
   439	            print(f"[CHAOS] REVIVE {node}")
   440	            return True
   441	
   442	        stat_inc("revive_failures")
   443	        stat_kill_event(node=node, action="revive", ok=False, payload=payload)
   444	        print(f"[CHAOS FAIL REVIVE] {node} -> status={resp.status_code} payload={payload}")
   445	        return False
   446	
   447	    except Exception as e:
   448	        stat_inc("revive_failures")
   449	        stat_kill_event(node=node, action="revive", ok=False, error=str(e))
   450	        print(f"[CHAOS FAIL REVIVE] {node} -> {e}")
   451	        return False
   452	
   453	
   454	def kill_cycle(node, seconds):
   455	    try:
   456	        ok = kill_node(node, seconds=seconds)
   457	        if ok:
   458	            print(f"[CHAOS] DEAD {node} for {seconds:.2f}s")
   459	            time.sleep(seconds)
   460	    finally:
   461	        revive_node(node)
   462	
