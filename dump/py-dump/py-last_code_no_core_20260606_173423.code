     9	#
    10	# Purpose:
    11	#   Definición de estados del nodo y transiciones de estado.
    12	#   Define la máquina de estados finitos (FSM) que controla el ciclo de vida
    13	#   de un nodo en el cluster: BOOT -> DISCOVERING -> STANDBY -> ACTIVE, etc.
    14	#   También proporciona funciones para transicionar entre estados y calcular
    15	#   la antigüedad del estado actual.
    16	# Notes:
    17	#   - Estados principales: BOOT -> DISCOVERING -> STANDBY -> ACTIVE
    18	#   - Estados especiales: SEGMENTATION (rotación de logs), DRAINING (preparando segmentación),
    19	#                        ISOLATED (sleep/pausa), OFFLINE (desconectado)
    20	#   - Cada estado tiene: state_since (timestamp), prev_state, state_reason
    21	#   - Se usa en node_runtime.py y node_worker.py para controlar el ciclo de vida
    22	#   - No hay validación estricta de transiciones válidas (se permite cualquier transición)
    23	#
    24	# FRV-ID: 606b01b5d3a56e66
    25	# Header_End
    26	
    27	# state.py
    28	import time
    29	from enum import Enum
    30	
    31	
    32	class NodeState(str, Enum):
    33	    """
    34	    Estados del nodo en el cluster.
    35	
    36	    Ciclo de vida típico:
    37	        BOOT -> DISCOVERING -> STANDBY -> ACTIVE
    38	
    39	    Estados especiales:
    40	        - SEGMENTATION: rotando archivos de log (segmentación)
    41	        - DRAINING: esperando a que no haya eventos pendientes antes de segmentar
    42	        - ISOLATED: nodo pausado/sleep (no procesa eventos)
    43	        - OFFLINE: nodo desconectado (no responde)
    44	
    45	    Example:
    46	        >>> NodeState.ACTIVE
    47	        <NodeState.ACTIVE: 'ACTIVE'>
    48	
    49	        >>> NodeState.ACTIVE.value
    50	        'ACTIVE'
    51	
    52	        >>> str(NodeState.STANDBY)
    53	        'STAND-BY'
    54	
    55	    Note:
    56	        - Hereda de str para poder comparar directamente con strings
    57	        - value es el nombre del estado en mayúsculas (excepto STANDBY -> "STAND-BY")
    58	    """
    59	    BOOT = "BOOT"
    60	    DISCOVERING = "DISCOVERING"
    61	    STANDBY = "STAND-BY"
    62	    ACTIVE = "ACTIVE"
    63	    SEGMENTATION = "SEGMENTATION"
    64	    DRAINING = "DRAINING"
    65	    ISOLATED = "ISOLATED"
    66	    OFFLINE = "OFFLINE"
    67	
    68	
    69	def _state_value(value):
    70	    """
    71	    Extrae el valor string de un estado.
    72	
    73	    Convierte un NodeState (enum) a su valor string, o deja el string tal cual
    74	    si ya es string.
    75	
    76	    Args:
    77	        value: NodeState enum o string.
    78	
    79	    Returns:
    80	        str: El valor string del estado.
    81	
    82	    Example:
    83	        >>> _state_value(NodeState.ACTIVE)
    84	        'ACTIVE'
    85	
    86	        >>> _state_value("ACTIVE")
    87	        'ACTIVE'
    88	    """
    89	    return value.value if isinstance(value, Enum) else str(value)
    90	
    91	
    92	def ensure_state_meta(node, now=None):
    93	    """
    94	    Asegura que el nodo tiene los metadatos de estado iniciales.
    95	
    96	    Añade los atributos si no existen:
    97	        - state_since: timestamp cuando se entró al estado actual
    98	        - prev_state: estado anterior (None si es el primero)
    99	        - state_reason: razón de la última transición
   100	
   101	    Args:
   102	        node: Objeto nodo (tiene atributo state).
   103	        now: Timestamp opcional. Si no se proporciona, usa time.time().
   104	
   105	    Returns:
   106	        Node: El mismo nodo con los metadatos asegurados.
   107	
   108	    Example:
   109	        >>> class Node:
   110	        ...     state = NodeState.ACTIVE
   111	        >>> node = Node()
   112	        >>> ensure_state_meta(node)
   113	        >>> node.state_since
   114	        1779956226.123
   115	        >>> node.prev_state
   116	        None
   117	        >>> node.state_reason
   118	        None
   119	
   120	    Note:
   121	        - Solo añade los atributos si no existen (no sobrescribe)
   122	        - Se llama antes de calcular state_age o transicionar
   123	    """
   124	    now = now or time.time()
   125	
   126	    if not hasattr(node, "state_since") or node.state_since is None:
   127	        node.state_since = now
   128	
   129	    if not hasattr(node, "prev_state"):
   130	        node.prev_state = None
   131	
   132	    if not hasattr(node, "state_reason"):
   133	        node.state_reason = None
   134	
   135	    return node
   136	
   137	
   138	def transition_node_state(node, new_state, reason=None, now=None):
   139	    """
   140	    Transiciona un nodo a un nuevo estado.
   141	
   142	    Actualiza los metadatos de estado (prev_state, state_since, state_reason)
   143	    solo si el estado cambia. Si el estado es el mismo pero hay reason,
   144	    actualiza solo el reason.
   145	
   146	    Args:
   147	        node: Objeto nodo con atributo state.
   148	        new_state: Nuevo estado (NodeState enum o string).
   149	        reason: Razón de la transición (ej: "leader_selected", "sleep_command").
   150	        now: Timestamp opcional. Si no se proporciona, usa time.time().
   151	
   152	    Returns:
   153	        dict: Información sobre la transición:
   154	            - changed: bool, si el estado cambió
   155	            - old_state: str, estado anterior
   156	            - new_state: str, nuevo estado
   157	            - state_since: float, timestamp del estado
   158	            - state_reason: str | None, razón de la transición
   159	
   160	    Example:
   161	        >>> class Node:
   162	        ...     state = NodeState.STANDBY
   163	        >>> node = Node()
   164	        >>> transition_node_state(node, NodeState.ACTIVE, reason="leader_selected")
   165	        {'changed': True, 'old_state': 'STAND-BY', 'new_state': 'ACTIVE',
   166	         'state_since': 1779956226.123, 'state_reason': 'leader_selected'}
   167	
   168	        >>> transition_node_state(node, NodeState.ACTIVE, reason="still_leader")
   169	        {'changed': False, 'old_state': 'ACTIVE', 'new_state': 'ACTIVE',
   170	         'state_since': 1779956226.123, 'state_reason': 'still_leader'}
   171	
   172	    Note:
   173	        - Si el estado no cambia pero hay reason, se actualiza solo el reason
   174	        - Si el nodo no tiene state_since, se inicializa al primer call
   175	        - Se usa en NodeRuntime.transition() y NodeWorker.tick_*()
   176	    """
   177	    now = now or time.time()
   178	    ensure_state_meta(node, now=now)
   179	
   180	    old_state = _state_value(node.state)
   181	    new_state_value = _state_value(new_state)
   182	
   183	    changed = old_state != new_state_value
   184	
   185	    if changed:
   186	        node.prev_state = old_state
   187	        node.state = new_state if isinstance(new_state, Enum) else NodeState(new_state_value)
   188	        node.state_since = now
   189	        node.state_reason = reason
   190	    else:
   191	        if reason is not None:
   192	            node.state_reason = reason
   193	
   194	    return {
   195	        "changed": changed,
   196	        "old_state": old_state,
   197	        "new_state": _state_value(node.state),
   198	        "state_since": node.state_since,
   199	        "state_reason": node.state_reason,
   200	    }
   201	
   202	
   203	def get_state_age_s(node, now=None):
   204	    """
   205	    Calcula la antigüedad del estado actual del nodo en segundos.
   206	
   207	    Args:
   208	        node: Objeto nodo con atributo state_since.
   209	        now: Timestamp opcional. Si no se proporciona, usa time.time().
   210	
   211	    Returns:
   212	        float: Segundos desde que se entró al estado actual (mínimo 0.0).
   213	
   214	    Example:
   215	        >>> class Node:
   216	        ...     state_since = 1779956226.0
   217	        >>> node = Node()
   218	        >>> get_state_age_s(node, now=1779956256.0)
   219	        30.0
   220	
   221	        >>> get_state_age_s(node, now=1779956226.0)
   222	        0.0
   223	
   224	    Note:
   225	        - Asegura metadatos antes de calcular (llama a ensure_state_meta)
   226	        - Retorna máximo 0.0 (nunca negativo)
   227	        - Se usa en logs para mostrar "age=35.9s" del estado
   228	    """
   229	    now = now or time.time()
   230	    ensure_state_meta(node, now=now)
   231	    return max(0.0, now - float(node.state_since))


