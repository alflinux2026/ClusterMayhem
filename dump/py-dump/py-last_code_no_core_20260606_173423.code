   650	@app.post("/watchdog")
   651	def watchdog(wd: Watchdog):
   652	    """
   653	    Recibe un watchdog de un peer.
   654	
   655	    Actualiza cluster_state con last_watchdog y watchdog_busy.
   656	    """
   657	    if ctx.node.state == NodeState.ISOLATED:
   658	        return {"error": "node isolated"}
   659	    existing = cluster_state.get(wd.node_id, {})
   660	    ts = wd.emitted_at if wd.emitted_at is not None else time.time()
   661	    cluster_state[wd.node_id] = {**existing, "last_watchdog": ts, "watchdog_busy": bool(wd.busy)}
   662	    return {"ok": True, "node_id": wd.node_id, "last_watchdog": ts, "watchdog_busy": bool(wd.busy)}
   663	
   664	
   665	@app.post("/heartbeat")
   666	def heartbeat(hb: Heartbeat):
   667	    """
   668	    Recibe un heartbeat de un peer.
   669	
   670	    Actualiza cluster_state con state, priority, last_seen, state_since, etc.
   671	    """
   672	    if ctx.node.state == NodeState.ISOLATED:
   673	        return {"error": "node isolated"}
   674	    existing = cluster_state.get(hb.node_id, {})
   675	    cluster_state[hb.node_id] = {
   676	        **existing,
   677	        "state": hb.state,
   678	        "priority": hb.priority,
   679	        "last_seen": time.time(),
   680	        "state_since": hb.state_since if hb.state_since is not None else existing.get("state_since"),
   681	        "prev_state": hb.prev_state if hb.prev_state is not None else existing.get("prev_state"),
   682	        "state_reason": hb.state_reason if hb.state_reason is not None else existing.get("state_reason"),
   683	        "log_meta": hb.log_meta or existing.get("log_meta", {}),
   684	        "cluster_integrity": hb.cluster_integrity or existing.get("cluster_integrity", {}),
   685	        "streams": hb.streams or existing.get("streams", {}),
   686	    }
   687	    return {"ok": True}
