   272	def stat_node_ok(node):
   273	    """Contabiliza un evento OK para un nodo."""
   274	    with stats_lock:
   275	        stats["per_node_ok"][node] += 1
   276	
   277	
   278	def stat_node_fail(node):
   279	    """Contabiliza un evento FAIL para un nodo."""
   280	    with stats_lock:
   281	        stats["per_node_fail"][node] += 1
   282	
   283	
   284	def stat_leader(name):
   285	    """Contabiliza un líder visto."""
   286	    with stats_lock:
   287	        stats["leaders_seen"][name] += 1
