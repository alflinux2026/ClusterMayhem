   166	
   167	
   168	def get_replica_log_path(node_id: str) -> str:
   169	    """
   170	    Devuelve la ruta para el log replica de un peer.
   171	
   172	    Args:
   173	        node_id: ID del peer.
   174	
   175	    Returns:
   176	        str: Ruta del archivo replica (ej: data/event_log.lnx200nas.000.jsonl).
   177	    """
   178	    return str(DATA_DIR / f"event_log.{node_id}.000.jsonl")
   179	
   180	
   181	def get_replica_events_path(node_id: str) -> str:
   182	    """
   183	    Devuelve la ruta para el events replica de un peer.
   184	
   185	    Args:
   186	        node_id: ID del peer.
   187	
   188	    Returns:
   189	        str: Ruta del archivo replica de events.
   190	    """
   191	    return str(DATA_DIR / f"events.{node_id}.000.jsonl")
   192	
   193	
   194	def list_replica_log_paths() -> List[str]:
   195	    """
   196	    Lista todas las rutas de logs locales en DATA_DIR.
   197	
   198	    Returns:
   199	        list[str]: Rutas de archivos *.local.000.jsonl.
   200	    """
   201	    if not DATA_DIR.exists():
   202	        return []
   203	
   204	    out: List[str] = []
   205	    for name in sorted(os.listdir(DATA_DIR)):
   206	        if not name.endswith(".local.000.jsonl"):
   207	            continue
   208	        out.append(str(DATA_DIR / name))
   209	    return out
   210	
   211	
   212	def load_events_from_path(path: str) -> List[dict]:
   213	    """
   214	    Carga eventos de un archivo JSONL.
   215	
   216	    Args:
   217	        path: Ruta del archivo JSONL.
   218	
   219	    Returns:
   220	        list[dict]: Lista de eventos (dicts). Ignora líneas inválidas.
   221	    """
   222	    if not os.path.exists(path):
   223	        return []
   224	
   225	    events = []
   226	    with open(path, "r", encoding="utf-8") as f:
   227	        for line in f:
   228	            line = line.strip()
   229	            if not line:
   230	                continue
   231	            try:
   232	                events.append(json.loads(line))
   233	            except json.JSONDecodeError:
   234	                continue
   235	    return events
   236	
   237	
   238	def _write_json_atomic(target_path: Path, payload: dict):
   239	    """
   240	    Escribe un dict como JSON de forma atómica (thread-safe).
   241	
   242	    Usa tempfile.mkstemp + fsync + os.replace para escritura atómica.
   243	
   244	    Args:
   245	        target_path: Ruta del archivo destino.
   246	        payload: Dict a escribir.
   247	
   248	    Note:
   249	        - Usa _STATE_LOCK para evitar escrituras concurrentes
   250	        - tempfile.mkstemp en el mismo directorio para os.replace atómico
   251	    """
   252	    ensure_dir()
   253	    with _STATE_LOCK:
   254	        fd, tmp_name = tempfile.mkstemp(
   255	            prefix=f"{target_path.name}.",
   256	            suffix=".tmp",
   257	            dir=str(target_path.parent),
   258	            text=True,
   259	        )
   260	        try:
   261	            with os.fdopen(fd, "w", encoding="utf-8") as f:
   262	                json.dump(payload, f, ensure_ascii=False)
   263	                f.flush()
   264	                os.fsync(f.fileno())
   265	            os.replace(tmp_name, str(target_path))
   266	        except Exception:
   267	            try:
   268	                os.remove(tmp_name)
   269	            except FileNotFoundError:
   270	                pass
   271	            raise
   272	
   273	
   274	def write_text_atomic(path: str, content: str):
   275	    """
   276	    Escribe texto en un archivo de forma atómica.
   277	
   278	    Args:
   279	        path: Ruta del archivo destino.
   280	        content: Contenido a escribir.
   281	    """
   282	    ensure_dir()
   283	    target_path = Path(path)
   284	    fd, tmp_name = tempfile.mkstemp(
   285	        prefix=f"{target_path.name}.",
   286	        suffix=".tmp",
   287	        dir=str(target_path.parent),
   288	        text=True,
   289	    )
   290	    try:
   291	        with os.fdopen(fd, "w", encoding="utf-8") as f:
   292	            f.write(content)
   293	            f.flush()
   294	            os.fsync(f.fileno())
   295	        os.replace(tmp_name, str(target_path))
   296	    except Exception:
   297	        try:
   298	            os.remove(tmp_name)
   299	        except FileNotFoundError:
   300	            pass
   301	        raise
   302	
   303	
   304	def read_local_log_text() -> str:
   305	    """Lee todo el contenido del log local."""
   306	    if not LOCAL_LOG_PATH.exists():
   307	        return ""
   308	    return LOCAL_LOG_PATH.read_text(encoding="utf-8")
   309	
   310	
   311	def read_completed_log_text() -> str:
   312	    """Lee todo el contenido del log de eventos completados."""
   313	    if not COMPLETED_LOG_PATH.exists():
   314	        return ""
   315	    return COMPLETED_LOG_PATH.read_text(encoding="utf-8")
   316	
   317	
   318	def write_replica_log(node_id: str, content: str):
   319	    """Escribe el log como replica para un peer."""
   320	    ensure_dir()
   321	    write_text_atomic(get_replica_log_path(node_id), content)
   322	
   323	
   324	def write_replica_events(node_id: str, content: str):
   325	    """Escribe los events como replica para un peer."""
   326	    ensure_dir()
   327	    write_text_atomic(get_replica_events_path(node_id), content)
   328	
   329	
   330	def write_completed_log(content: str):
   331	    """Escribe el log de eventos completados."""
   332	    ensure_dir()
   333	    write_text_atomic(str(COMPLETED_LOG_PATH), content)
   334	
   335	
   336	def read_state() -> dict:
   337	    """
   338	    Lee el estado del archivo state.
   339	
   340	    Returns:
   341	        dict: Estado con dirty flags y metadata, o {} si no existe.
   342	    """
   343	    if not STATE_PATH.exists():
   344	        return {}
   345	
   346	    try:
   347	        with open(STATE_PATH, "r", encoding="utf-8") as f:
   348	            data = json.load(f)
   349	            return data if isinstance(data, dict) else {}
   350	    except (OSError, json.JSONDecodeError):
   351	        return {}
   352	
   353	
   354	def get_last_append_meta() -> dict:
   355	    """Devuelve metadata del último append."""
   356	    state = read_state()
   357	    return state if isinstance(state, dict) else {}
   358	
   359	
   360	def write_state(state: dict):
   361	    """Escribe el estado de forma atómica."""
   362	    _write_json_atomic(STATE_PATH, state)
   363	
   364	
   365	def clear_eventlog_dirty_state():
   366	    """Limpia el dirty flag del event log (replicación exitosa)."""
   367	    state = read_state()
   368	    state["dirty"] = False
   369	    write_state(state)
   370	
   371	
   372	def clear_events_dirty_state():
