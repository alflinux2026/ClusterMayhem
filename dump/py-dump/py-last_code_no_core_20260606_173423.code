   188	def stat_inc(key, amount=1):
   189	    with stats_lock:
   190	        stats[key] += amount
   191	
   192	
   193	def stat_node_ok(node):
   194	    with stats_lock:
   195	        stats["per_node_ok"][node] += 1
   196	
   197	
   198	def stat_node_fail(node):
   199	    with stats_lock:
