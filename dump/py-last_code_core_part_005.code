    26	import time
    27	import requests
    28	
    29	from cluster.runtime.state import NodeState, ensure_state_meta, transition_node_state
    30	from cluster.runtime.leader import compute_leader
    31	from cluster.utils.log_print import log_state
    32	
    33	
    34	class NodeRuntime:
    35	    """
    36	    Representa un nodo en el cluster.
    37	
    38	    Gestiona el estado del nodo, la detección automática de líder, y la
    39	    emisión de heartbeats a otros nodos.
    40	
    41	    Ciclo de vida típico:
    42	        1. BOOT (inicialización)
    43	        2. DISCOVERING (opcional, descubriendo peers)
    44	        3. STANDBY (esperando a ser líder)
    45	        4. ACTIVE (es el líder, procesa eventos)
    46	
    47	    Si pierde el líder, vuelve a STANDBY. Si el nodo se vuelve líder,
    48	    pasa a ACTIVE.
    49	
    50	    Attributes:
    51	        node_id (str): ID único del nodo.
    52	        priority (int): Prioridad para leader election (menor = más prioritario).
    53	        state (NodeState): Estado actual del nodo.
    54	        last_heartbeat (float): Timestamp del último heartbeat enviado.
    55	        state_since (float): Timestamp cuando se entró al estado actual.
    56	        prev_state (str | None): Estado anterior.
    57	        state_reason (str | None): Razón de la última transición.
    58	
    59	    Example:
    60	        >>> node = NodeRuntime("lnx203hp", priority=10)
    61	        >>> node.node_id
    62	        'lnx203hp'
    63	        >>> node.priority
    64	        10
    65	        >>> node.state
    66	        <NodeState.BOOT: 'BOOT'>
    67	
    68	        >>> node.transition(NodeState.STANDBY, reason="boot_complete")
    69	        {'changed': True, 'old_state': 'BOOT', 'new_state': 'STANDBY', ...}
    70	    """
    71	
    72	    def __init__(self, node_id, priority):
    73	        """
    74	        Inicializa un nodo del cluster.
    75	
    76	        Args:
    77	            node_id: ID único del nodo (string).
    78	            priority: Prioridad para leader election (menor = más prioritario).
    79	
    80	        Example:
    81	            >>> node = NodeRuntime("lnx203hp", priority=10)
    82	            >>> node = NodeRuntime("lnx200nas", priority=100)
    83	        """
    84	        self.node_id = node_id
    85	        self.priority = priority
    86	        self.state = NodeState.BOOT
    87	        self.last_heartbeat = time.time()
    88	
    89	        ensure_state_meta(self)
    90	        self.state_reason = "node_init"
    91	
    92	    def transition(self, new_state, reason=None):
    93	        """
    94	        Transiciona el nodo a un nuevo estado.
    95	
    96	        Delega en transition_node_state() y muestra un log si el estado cambia.
    97	
    98	        Args:
    99	            new_state: Nuevo estado (NodeState enum o string).
   100	            reason: Razón de la transición (ej: "leader_selected", "boot_complete").
   101	
   102	        Returns:
   103	            dict: Resultado de la transición (changed, old_state, new_state, ...).
   104	
   105	        Example:
   106	            >>> node.transition(NodeState.STANDBY, reason="boot_complete")
   107	            [lnx203hp] BOOT -> STAND-BY (reason=boot_complete)
   108	            {'changed': True, 'old_state': 'BOOT', 'new_state': 'STANDBY', ...}
   109	
   110	            >>> node.transition(NodeState.ACTIVE, reason="leader_selected")
   111	            [lnx203hp] STAND-BY -> ACTIVE (reason=leader_selected)
   112	            {'changed': True, 'old_state': 'STANDBY', 'new_state': 'ACTIVE', ...}
   113	        """
   114	        result = transition_node_state(self, new_state, reason=reason)
   115	
   116	        if result["changed"]:
   117	            print(
   118	                f"[{self.node_id}] "
   119	                f"{result['old_state']} -> {result['new_state']} "
   120	                f"(reason={result['state_reason']})"
   121	            )
   122	
   123	        return result
   124	
   125	    def tick(self):
   126	        """
   127	        Ejecuta la lógica de cada tick del nodo (~1s).
   128	
   129	        Comprueba quién es el líder y transiciona automáticamente:
   130	            - Si soy el líder y estoy en STANDBY -> paso a ACTIVE
   131	            - Si no soy el líder y estoy en ACTIVE -> paso a STANDBY
   132	
   133	        Note:
   134	            - Se llama en cada iteration del worker loop (~1s)
   135	            - La transición es automática, no requiere comando externo
   136	            - Si no hay líder (None), el nodo se queda en su estado actual
   137	
   138	        Example:
   139	            >>> node.state = NodeState.STANDBY
   140	            >>> node.tick()  # Si soy líder
   141	            [CLUSTER] [lnx203hp] becoming ACTIVE
   142	            >>> node.state
   143	            <NodeState.ACTIVE: 'ACTIVE'>
   144	        """
   145	        #        if self.state == NodeState.BOOT:
   146	        #            self.transition(NodeState.STANDBY, reason="boot_complete")
   147	        #            return
   148	
   149	        #log_state("yellow", "[NodeRunTime tick]", f"[{self.node_id}] ticking ...", 3)
   150	
   151	        leader = compute_leader()
   152	
   153	        if leader == self.node_id:
   154	            if self.state == NodeState.STANDBY:
   155	                log_state("yellow", "[CLUSTER]", f"[{self.node_id}] becoming ACTIVE", 3)
   156	                self.transition(NodeState.ACTIVE, reason="leader_selected")
   157	        else:
   158	            if self.state == NodeState.ACTIVE:
   159	                log_state("yellow", "[CLUSTER]", f"[{self.node_id}] becoming STANDBY", 3)
   160	                self.transition(NodeState.STANDBY, reason="leader_lost")
   161	
   162	    def emit_heartbeat(self, peers):
   163	        """
   164	        Emite un heartbeat a todos los peers del cluster.
   165	
   166	        Envía el estado actual del nodo (state, priority, state_since, ...)
   167	        a todos los peers para que actualicen cluster_state.
   168	
   169	        Args:
   170	            peers: Lista de dicts con info de peers (cada uno tiene 'host' y 'port').
   171	
   172	        Note:
   173	            - Se usa POST /heartbeat en cada peer (api_app.py)
   174	            - Timeout: 2s por peer
   175	            - Falla silenciosamente si un peer no responde (no levanta exception)
   176	            - Se llama en cada tick del worker (~1s)
   177	
   178	        Example:
   179	            >>> peers = [
   180	            ...     {"host": "100.100.1.200", "port": 8000},
   181	            ...     {"host": "100.100.1.201", "port": 8000}
   182	            ... ]
   183	            >>> node.emit_heartbeat(peers)
   184	            # Envía POST http://100.100.1.200:8000/heartbeat y POST http://100.100.1.201:8000/heartbeat
   185	        """
   186	        hb = {
   187	            "node_id": self.node_id,
   188	            "state": self.state.value,
   189	            "priority": self.priority,
   190	            "state_since": getattr(self, "state_since", None),
   191	            "prev_state": getattr(self, "prev_state", None),
   192	            "state_reason": getattr(self, "state_reason", None),
   193	        }
   194	
   195	        for peer in peers:
   196	            url = f"http://{peer['host']}:{peer['port']}/heartbeat"
   197	            try:
   198	                requests.post(url, json=hb, timeout=2)
   199	            except requests.exceptions.RequestException:
   200	                pass


