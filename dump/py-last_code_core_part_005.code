    65	def _node_cache(node):
    66	    """
    67	    Obtiene el cache del nodo de cluster_state.
    68	
    69	    Args:
    70	        node: NodeRuntime o dict del nodo.
    71	
    72	    Returns:
    73	        dict: Cache del nodo (streams, counters, etc.), o {} si no existe.
    74	    """
    75	    node_id = _node_id(node)
    76	    if not node_id:
    77	        return {}
    78	    data = cluster_state.get(node_id, {}) or {}
    79	    return data if isinstance(data, dict) else {}
    80	
    81	
    82	def _node_id(node):
    83	    """
    84	    Extrae el node_id de un nodo (dict o NodeRuntime).
    85	
    86	    Args:
    87	        node: NodeRuntime o dict.
    88	
    89	    Returns:
    90	        str: node_id del nodo, o "?" si no se puede extraer.
    91	    """
    92	    if isinstance(node, dict):
    93	        return node.get("node_id", "?")
    94	    return getattr(node, "node_id", "?")
    95	
    96	
    97	def rebuild_node_event_cache(node_id: str):
    98	    """
    99	    Reconstruye el cache de eventos de un nodo en cluster_state.
   100	
   101	    Carga eventos locales y completados, cuenta por status, y actualiza
   102	    streams con resúmenes (events_summary_local, events_summary_created, etc.).
   103	
   104	    Args:
   105	        node_id: ID del nodo.
   106	
   107	    Note:
   108	        - Se llama en cada tick para actualizar counters
   109	        - Actualiza cluster_state para que el dashboard muestre counters actualizados
   110	    """
   111	    if not isinstance(node_id, str):
   112	        node_id = getattr(node_id, "node_id", None)
   113	
   114	    if not node_id:
   115	        log_state("red", "CACHE_BOOTSTRAP", "invalid node_id for event cache bootstrap", 3)
   116	        return
   117	
   118	    node = cluster_state.get(node_id, {}) or {}
   119	    if not isinstance(node, dict):
   120	        node = {}
   121	
   122	    streams = dict(node.get("streams", {}) or {})
   123	
   124	    local_events = load_events() or []
   125	    completed_events = []
   126	    try:
   127	        completed_events = load_completed_events() or []
   128	    except Exception as e:
   129	        log_state("red", "CACHE_BOOTSTRAP", f"{node_id} completed_load_failed={e}", 3)
   130	
   131	    created_events = [e for e in local_events if e.get("status") == EventStatus.CREATED.value]
   132	    executing_events = [e for e in local_events if e.get("status") == EventStatus.EXECUTING.value]
   133	
   134	    streams["events_summary_local"] = _summarize_events(local_events)
   135	    streams["events_summary_created"] = _summarize_events(created_events)
   136	    streams["events_summary_executing"] = _summarize_events(executing_events)
   137	    streams["events_summary_completed"] = _summarize_events(completed_events)
   138	
   139	    node["node_id"] = node_id
   140	    node["streams"] = streams
   141	    cluster_state[node_id] = node
   142	
   143	    log_state("blue", "NODE STATE a", f"{_node_id(node)} local={len(local_events)} created={len(created_events)} executing={len(executing_events)} completed={len(completed_events)}", 3)
   144	
   145	
   146	def _node_streams(node):
   147	    """Obtiene streams del nodo (dict o NodeRuntime)."""
   148	    if isinstance(node, dict):
   149	        return node.get("streams", {}) or {}
   150	    return getattr(node, "streams", {}) or {}
   151	
   152	
   153	def _node_event_counters(node) -> tuple[int, int, int, int]:
   154	    """
   155	    Cuenta eventos por status del nodo.
   156	
   157	    Returns:
   158	        tuple[int, int, int, int]: (created, executing, completed, total)
   159	    """
   160	    cache = _node_cache(node)
   161	    streams = cache.get("streams", {}) or {}
   162	    summary = streams.get("events_summary_local", {}) or {}
   163	    counts = summary.get("counts", {}) or {}
   164	    created = int(counts.get("created", 0))
   165	    executing = int(counts.get("executing", 0))
   166	    completed = int(counts.get("completed", 0))
   167	    total = int(summary.get("total_events", created + executing + completed))
   168	    return created, executing, completed, total
   169	
   170	
   171	def _can_segment(node) -> bool:
   172	    """
   173	    Comprueba si el nodo puede segmentar (rotar logs).
   174	
   175	    Solo se puede segmentar si:
   176	        - created > 0 (hay eventos sin procesar)
   177	        - executing == 0 (no hay eventos en ejecución)
   178	        - dirty == False (no hay replicación pendiente)
   179	
   180	    Args:
   181	        node: NodeRuntime del nodo.
   182	
   183	    Returns:
   184	        bool: True si se puede segmentar.
   185	    """
   186	    created, executing, completed, total = _node_event_counters(node)
   187	    cache = _node_cache(node)
   188	    dirty = bool(cache.get("dirty", False))
   189	    return created > 0 and executing == 0 and not dirty
   190	
   191	
   192	def _should_enter_DRAINING(node) -> bool:
   193	    """
   194	    Comprueba si el nodo debe entrar en DRAINING.
   195	
   196	    Entra en DRAINING si total_events > MAX_SEGMENT_COUNT.
   197	
   198	    Args:
   199	        node: NodeRuntime del nodo.
   200	
   201	    Returns:
   202	        bool: True si debe entrar en DRAINING.
   203	    """
   204	    created, executing, completed, total = _node_event_counters(node)
   205	    return total > MAX_SEGMENT_COUNT
   206	
   207	
   208	def _should_enter_segmentation(node) -> bool:
   209	    """
   210	    Comprueba si el nodo debe entrar en SEGMENTATION.
   211	
   212	    Entra en SEGMENTATION si _can_segment() es True.
   213	
   214	    Args:
   215	        node: NodeRuntime del nodo.
   216	
   217	    Returns:
   218	        bool: True si debe entrar en SEGMENTATION.
   219	    """
   220	    return _can_segment(node)
   221	
   222	
   223	def leader_event_state_check_tick():
   224	    """
   225	    Check periódico del estado de eventos (cada EVENTSTATECHECKPERIODSEC).
   226	
   227	    Carga eventos raw y del state_index, cuenta por status, y logea
   228	    diferencias (si hay).
   229	
   230	    Note:
   231	        - Throttleado a EVENTSTATECHECKPERIODSEC=10s
   232	        - Actualmente no hace nada con los conteos (solo cuenta)
   233	    """
   234	    global lasteventstatecheckts
   235	    now = time.time()
   236	    if now - lasteventstatecheckts < EVENTSTATECHECKPERIODSEC:
   237	        return
   238	    lasteventstatecheckts = now
   239	
   240	    raw_events = load_events() or []
   241	    state_index = rebuild_event_state_index()
   242	
   243	    raw_created = raw_executing = raw_completed = 0
   244	    for e in raw_events:
   245	        status = e.get("status")
   246	        if hasattr(status, "value"):
   247	            status = status.value
   248	        status = str(status).strip().lower()
   249	        if status == EventStatus.CREATED.value:
   250	            raw_created += 1
   251	        elif status == EventStatus.EXECUTING.value:
   252	            raw_executing += 1
   253	        elif status == EventStatus.COMPLETED.value:
   254	            raw_completed += 1
   255	
   256	    created = executing = completed = 0
   257	    for event in state_index.values():
   258	        status = event.get("status") if isinstance(event, dict) else getattr(event, "status", None)
   259	        if hasattr(status, "value"):
   260	            status = status.value
   261	        status = str(status).strip().lower()
   262	        if status == EventStatus.CREATED.value:
   263	            created += 1
   264	        elif status == EventStatus.EXECUTING.value:
   265	            executing += 1
   266	        elif status == EventStatus.COMPLETED.value:
   267	            completed += 1
   268	
   269	
   270	def cleanup_local_segment_files(node_id: str, segment: str = "000", files=None):
   271	    """
   272	    Elimina archivos de segmento local después de rotar.
   273	
   274	    Args:
   275	        node_id: ID del nodo.
   276	        segment: Segmento a limpiar (default: "000").
   277	        files: Lista de tipos de archivos (default: ["events", "event_log"]).
   278	
   279	    Returns:
   280	        dict: Resumen de archivos eliminados y faltantes.
   281	    """
   282	    files = files or ["events", "event_log"]
   283	    base_dir = Path(get_local_log_path(None)).resolve().parent
   284	    removed = []
   285	    missing = []
   286	
   287	    for kind in files:
   288	        p = base_dir / f"{kind}.local.{segment}.jsonl"
   289	        if p.exists():
   290	            p.unlink()
   291	            removed.append(str(p))
   292	        else:
   293	            missing.append(str(p))
   294	
   295	    return {
   296	        "node_id": node_id,
   297	        "segment": segment,
   298	        "removed": removed,
   299	        "missing": missing,
   300	    }
   301	
   302	
   303	def log_state_runtime_debug(node):
   304	    """
   305	    Log de debug de estado del nodo (cada STATEDEBUGPERIODSEC).
   306	
   307	    Args:
   308	        node: NodeRuntime del nodo.
   309	
   310	    Note:
   311	        - Throttleado a STATEDEBUGPERIODSEC=30s
   312	        - Reconstruye cache de eventos antes de logear
   313	    """
   314	    global laststatedebugts
   315	    now = time.time()
   316	    if now - laststatedebugts < STATEDEBUGPERIODSEC:
   317	        return
   318	    laststatedebugts = now
   319	
   320	    age_s = get_state_age_s(node, now=now)
   321	    rebuild_node_event_cache(node.node_id)
   322	
   323	    log_state("blue", "NODE STATE b", f"{_node_id(node)} state={node.state.value} age={age_s:.1f}s prev={getattr(node, 'prev_state', None)} reason={getattr(node, 'state_reason', None)}", 3)
   324	
   325	
   326	def rotate_segment_files(target_group: str, segment: str = "000", files=None, force: bool = False):
   327	    """
   328	    Rota archivos de segmento (renombra .local.000.jsonl a .{node_id}.001.jsonl).
   329	
   330	    Args:
   331	        target_group: Grupo destino (no usado, se usa node_id local).
   332	        segment: Segmento a rotar (default: "000").
   333	        files: Lista de tipos de archivos (default: ["events", "event_log"]).
   334	        force: Si True, crea entry incluso si el archivo no existe.
   335	
   336	    Returns:
   337	        dict: Resultado con before/after paths e índices.
   338	
   339	    Raises:
   340	        RuntimeError: Si no hay node_id local.
   341	        FileNotFoundError: Si el archivo no existe y force=False.
   342	    """
   343	    files = files or ["events", "event_log"]
   344	    base_dir = Path(get_local_log_path(None)).resolve().parent
   345	    local_node_id = getattr(ctx, "node_id", None) or getattr(getattr(ctx, "node", None), "node_id", None)
   346	
   347	    if not local_node_id:
   348	        raise RuntimeError("missing local node_id for segment rotation")
   349	
   350	    result = {}
   351	
   352	    for kind in files:
   353	        src = base_dir / f"{kind}.local.{segment}.jsonl"
   354	        if not src.exists():
   355	            if force:
   356	                result[kind] = {"before": str(src), "after": None, "index": None, "forced": True}
   357	                continue
   358	            raise FileNotFoundError(str(src))
   359	
   360	        idx = _next_rotation_index(base_dir, f"{kind}.{local_node_id}")
   361	        dst = base_dir / f"{kind}.{local_node_id}.{idx:03d}.jsonl"
   362	        os.replace(str(src), str(dst))
   363	        result[kind] = {"before": str(src), "after": str(dst), "index": idx, "forced": False}
   364	
   365	    return result
   366	
   367	
   368	def _next_rotation_index(base_dir, stem, suffix=".jsonl"):
   369	    """
   370	    Encuentra el próximo índice disponible para rotación.
   371	
   372	    Args:
   373	        base_dir: Directorio base.
   374	        stem: Prefix del archivo (ej: "event_log.lnx203hp").
   375	        suffix: Suffix del archivo (default: ".jsonl").
   376	
   377	    Returns:
   378	        int: Próximo índice disponible (001, 002, ...).
   379	    """
   380	    base_dir = Path(base_dir)
   381	    idx = 1
   382	    while True:
   383	        candidate = base_dir / f"{stem}.{idx:03d}{suffix}"
   384	        if not candidate.exists():
   385	            return idx
   386	        idx += 1
   387	
   388	
   389	class NodeWorker:
   390	    """
   391	    Worker en background que ejecuta el tick del nodo cada ~1s.
   392	
   393	    Attributes:
   394	        node (NodeRuntime): Nodo del cluster.
   395	        peers (list[dict]): Lista de peers con host, port, node_id.
   396	        interval (float): Intervalo entre ticks en segundos (default: 1.0).
   397	        running (bool): Flag para controlar el loop.
   398	
   399	    Example:
   400	        >>> worker = NodeWorker(node, peers, interval=1.0)
   401	        >>> worker.start()
   402	        # Worker empieza a ejecutar tick cada 1s en hilo background
   403	        >>> worker.stop()
   404	        # Worker para el loop
   405	    """
   406	
   407	    def __init__(self, node, peers, interval=1.0):
   408	        """
   409	        Inicializa el worker.
   410	
   411	        Args:
   412	            node: NodeRuntime del nodo.
   413	            peers: Lista de peers.
   414	            interval: Intervalo entre ticks en segundos.
   415	        """
   416	        self.node = node
   417	        self.peers = peers
   418	        self.interval = interval
   419	        self.running = False
   420	
   421	    def start(self):
   422	        """
   423	        Arranca el worker en un hilo daemon.
   424	
   425	        El hilo ejecuta loop() hasta que running=False.
   426	        """
   427	        self.running = True
   428	        t = threading.Thread(target=self.loop, daemon=True)
   429	        t.start()
   430	
   431	    def stop(self):
   432	        """Detiene el worker (setting running=False)."""
   433	        self.running = False
   434	
   435	    def tick_boot(self):
   436	        """
   437	        Tick del estado BOOT.
   438	
   439	        - Emite watchdog busy=True
   440	        - Reconstruye cache de eventos
   441	        - Transiciona a STANDBY
   442	        """
   443	        emit_watchdog_if_due(self.peers, busy=True)
   444	        rebuild_node_event_cache(self.node.node_id)
   445	        self.node.event_cache_ready = True
   446	        self.node.transition(NodeState.STANDBY, reason="boot_complete")
   447	
   448	    def tick_discovering(self):
   449	        """Tick del estado DISCOVERING (actualmente no hace nada)."""
   450	        pass
   451	
   452	    def tick_standby(self):
   453	        """
   454	        Tick del estado STANDBY.
   455	
   456	        - Emite heartbeat a peers
   457	        - Emite watchdog busy=True
   458	        - Replica event log y events
   459	        - Check de estado de eventos

