app = FastAPI()


# -------------------------
# ACK (FINAL STATE ONLY)
# -------------------------
@app.post("/ack")
def ack(event: ClusterEvent):

    log_state("green", "[ACK]", f"{event.event_id} completed", 3)

    event.mark_status(EventStatus.COMPLETED)
    append_event(event)

    return {"ok": True}


# -------------------------
# REPLAY
