===== ./runtime/bootstrap.py =====
   1: import socket
   2: import json
   3: import os
   4: import requests
   5: import hashlib
   6: 
   7: 
   8: # -------------------------------------------------
   9: # PRIORITY DETERMINISTIC (FIXA POR NODO)
  10: # -------------------------------------------------
  11: def deterministic_priority(node_id: str):
  12:     return int(hashlib.md5(node_id.encode()).hexdigest(), 16) % 1000
  13: 
  14: 
  15: # -------------------------------------------------
  16: # BASIC UTILS
  17: # -------------------------------------------------
  18: def get_hostname():
  19:     return socket.gethostname()
  20: 
  21: 
  22: def load_config(path="config/node.local.json"):
  23:     with open(path, "r") as f:
  24:         return json.load(f)
  25: 
  26: 
  27: # -------------------------------------------------
  28: # DISCOVERY (MERGED VIEW SAFE)
  29: # -------------------------------------------------
  30: def discover_seed(peers):
  31:     clusters = []
  32: 
  33:     for p in peers:
  34:         try:
  35:             r = requests.get(
  36:                 f"http://{p['host']}:{p['port']}/cluster",
  37:                 timeout=1
  38:             )
  39:             if r.status_code == 200:
  40:                 clusters.append(r.json())
  41:         except:
  42:             continue
  43: 
  44:     merged = {}
  45: 
  46:     for cluster in clusters:
  47:         for node_id, data in cluster.items():
  48: 
  49:             if node_id not in merged:
  50:                 merged[node_id] = data
  51:                 continue
  52: 
  53:             # keep most recent info
  54:             if data.get("last_seen", 0) > merged[node_id].get("last_seen", 0):
  55:                 merged[node_id] = data
  56: 
  57:     return merged
  58: 
  59: 
  60: # -------------------------------------------------
  61: # CONFIG GENERATION
  62: # -------------------------------------------------
  63: def generate_local_config(peers):
  64:     hostname = get_hostname()
  65: 
  66:     priority = deterministic_priority(hostname)
  67: 
  68:     # resolve collisions deterministically (NO LOOP DRIFT)
  69:     while priority in used_priorities:
  70:         priority += 1000  # salt step to avoid clustering collisions
  71: 
  72:     config = {
  73:         "node_id": hostname,
  74:         "priority": priority,
  75:         "bind_host": "0.0.0.0",
  76:         "bind_port": 7000,
  77:         "peers": peers
  78:     }
  79: 
  80:     os.makedirs("config", exist_ok=True)
  81: 
  82:     with open("config/node.local.json", "w") as f:
  83:         json.dump(config, f, indent=2)
  84: 
  85:     return config
  86: 
  87: 
  88: # -------------------------------------------------
  89: # BOOTSTRAP OR LOAD
  90: # -------------------------------------------------
  91: def load_or_bootstrap_config():
  92:     try:
  93:         return load_config()
  94:     except FileNotFoundError:
  95: 
  96:         peers = [
  97:             {"host": "100.100.1.200", "port": 7000},
  98:             {"host": "100.100.1.202", "port": 7000},
  99:             {"host": "100.100.1.203", "port": 7000},
 100:         ]
 101: 
 102:         return generate_local_config(peers)



===== ./runtime/cluster_store.py =====
   1: import time
   2: 
   3: cluster_state = {}
   4: 
   5: NODE_TTL = 5.0  # segundos
   6: 
   7: 
   8: def cleanup_cluster():
   9:     now = time.time()
  10: 
  11:     for node_id, data in list(cluster_state.items()):
  12: 
  13:         age = now - data.get("last_seen", 0)
  14:         alive = age <= NODE_TTL
  15: 
  16:         # 🔥 NUEVO: reconciliación de estado
  17:         if not alive and data.get("state") == "ACTIVE":
  18:             data["state"] = "STAND-BY"
  19: 
  20:     # eliminación real
  21:     to_delete = [
  22:         node_id
  23:         for node_id, data in list(cluster_state.items())
  24:         if (now - data.get("last_seen", 0)) > NODE_TTL
  25:     ]
  26: 
  27:     for node_id in to_delete:
  28:         print(f"[GC] removing {node_id}")
  29:         del cluster_state[node_id]
  30: 
  31: 
  32: def get_active_cluster():
  33:     cleanup_cluster()
  34:     return cluster_state



