  10: # Purpose:
  11: #   Verificación de integridad del cluster.
  12: #   Comprueba que todos los nodos tienen una vista consistente del cluster_state.
  13: #   Каноникализирует los datos (ordena claves, ignora last_seen) y compara hash SHA256
  14: #   para detectar divergencias. Se usa para debugging y para detectar split-brain.
  15: # Notes:
  16: #   - canonicalize() ordena claves recursivamente para comparar dicts independientemente del orden
  17: #   - IGNORED_NODE_KEYS = {"last_seen"} se ignora porque cambia constantemente
  18: #   - integrity_ok = True si todos los nodos tienen la misma vista
  19: #   - Se llama desde /integrity y /integrity/cluster en api_app.py
  20: #   - compute_views() compacta la vista para reducir ruido en logs
  21: #
  22: # FRV-ID: bb416140aa771527
  23: # Header_End
