  69: 
  70: 
  71: def canonicalize(obj: Any, ignored_keys: set[str] | None = None) -> Any:
  72:     """
  73:     Canonicaiza un objeto recursivamente (ordena claves, ignora ciertas keys).
  74: 
  75:     Útil para comparar dicts independientemente del orden de las claves.
  76: 
  77:     Args:
  78:         obj: Objeto a canonicalizar (dict, list, o escalar).
  79:         ignored_keys: Conjunto de claves a ignorar (no incluir en el resultado).
  80: 
  81:     Returns:
  82:         Any: Objeto canonicalizado (dict con claves ordenadas, list procesada, o escalar).
  83: 
  84:     Example:
  85:         >>> canonicalize({"b": 2, "a": 1})
  86:         {'a': 1, 'b': 2}
  87: 
  88:         >>> canonicalize({"b": 2, "a": 1}, ignored_keys={"a"})
  89:         {'b': 2}
  90: 
  91:         >>> canonicalize([{"b": 2, "a": 1}])
  92:         [{'a': 1, 'b': 2}]
  93: 
  94:     Note:
  95:         - Se usa antes de comparar views para ignorar el orden de claves
  96:         - Ignora recursivamente las claves en ignored_keys
  97:     """
  98:     ignored_keys = ignored_keys or set()
  99:     if isinstance(obj, dict):
 100:         return {
 101:             k: canonicalize(v, ignored_keys)
 102:             for k, v in sorted(obj.items())
 103:             if k not in ignored_keys
 104:         }
 105:     if isinstance(obj, list):
 106:         return [canonicalize(v, ignored_keys) for v in obj]
 107:     return obj
 108: 
 109: 
 110: def compare_views(a: dict, b: dict) -> bool:
 111:     """
 112:     Compara dos views canonicalizando primero.
 113: 
 114:     Args:
 115:         a: Primer dict a comparar.
 116:         b: Segundo dict a comparar.
 117: 
 118:     Returns:
 119:         bool: True si las views son iguales después de canonicalizar.
 120: 
 121:     Example:
 122:         >>> compare_views({"b": 2, "a": 1}, {"a": 1, "b": 2})
 123:         True
 124: 
 125:         >>> compare_views({"b": 2, "a": 1}, {"a": 1, "b": 3})
 126:         False
 127:     """
 128:     return canonicalize(a, IGNORED_NODE_KEYS) == canonicalize(b, IGNORED_NODE_KEYS)
 129: 
 130: 
 131: #def log_meta_ok(local_meta: dict, peer_meta: dict) -> bool:
 132: #    """Compara log_meta entre nodos."""
 133: #    return all(local_meta.get(k) == peer_meta.get(k) for k in INTEGRITY_KEYS)
 134: 
 135: 
 136: def _compact_view(view: dict) -> dict:
 137:     """
 138:     Compacta una view a solo los campos relevantes para debugging.
 139: 
 140:     Args:
 141:         view: Dict completo de un nodo.
 142: 
 143:     Returns:
 144:         dict: View compacta con state, state_since, prev_state, state_reason, priority, log_meta, streams.
 145: 
 146:     Example:
 147:         >>> view = {"state": "ACTIVE", "state_since": 123, "extra": "ruido", "priority": 10}
 148:         >>> _compact_view(view)
 149:         {'state': 'ACTIVE', 'state_since': 123, 'prev_state': None, 'state_reason': None, 'priority': 10, 'log_meta': {}, 'streams': {}}
 150:     """
 151:     if not isinstance(view, dict):
 152:         return {}
 153:     return {
 154:         "state": view.get("state"),
 155:         "state_since": view.get("state_since"),
 156:         "prev_state": view.get("prev_state"),
 157:         "state_reason": view.get("state_reason"),
 158:         "priority": view.get("priority"),
 159:         "log_meta": view.get("log_meta", {}),
 160:         "streams": view.get("streams", {}),
 161:     }
 162: 
 163: 
 164: def local_integrity_api() -> dict:
 165:     """
 166:     Verifica la integridad local del cluster.
 167: 
 168:     Compara la view del nodo local con la de todos los nodos vivos.
 169: 
 170:     Returns:
 171:         dict: Resultado de la verificación:
 172:             - node_id (str): ID del nodo local
 173:             - alive_nodes (list[str]): Nodos vivos
 174:             - self_view (dict): View compacta del nodo local
 175:             - peer_status (dict[str, dict]): Status de cada peer
 176:             - integrity_canonical (dict): View canonicalizada
 177:             - integrity_hash (str): SHA256 de la view canonical
 178:             - integrity_ok (bool): True si todos los peers tienen la misma view
 179: 
 180:     Example:
 181:         >>> local_integrity_api()
 182:         {
 183:             'node_id': 'lnx203hp',
 184:             'alive_nodes': ['lnx203hp', 'lnx200nas'],
 185:             'self_view': {'state': 'ACTIVE', 'priority': 10, ...},
 186:             'peer_status': {'lnx203hp': {'view_ok': True}, 'lnx200nas': {'view_ok': True}},
 187:             'integrity_hash': 'abc123...',
 188:             'integrity_ok': True
 189:         }
 190:     """
 191:     alive = compute_alive(include_self=True)
 192: 
 193:     canonical = get_integrity_canonical()
 194:     integrity_hash = hashlib.sha256(
 195:         json.dumps(canonical, sort_keys=True).encode("utf-8")
 196:     ).hexdigest()
 197: 
 198:     peer_status = {}
 199:     self_view = canonicalize(cluster_state.get(ctx.node_id, {}), IGNORED_NODE_KEYS)
 200:     self_meta = self_view.get("log_meta", {}) if isinstance(self_view, dict) else {}
 201: 
 202:     for node_id, data in alive.items():
 203:         view = canonicalize(data, IGNORED_NODE_KEYS)
 204:         meta = view.get("log_meta", {}) if isinstance(view, dict) else {}
 205:         peer_status[node_id] = {
 206:             "view": _compact_view(view),
 207:             "view_ok": view == canonicalize(cluster_state.get(node_id, {}), IGNORED_NODE_KEYS),
 208:         }
 209: 
 210:     return {
 211:         "node_id": ctx.node_id,
 212:         "alive_nodes": sorted(alive.keys()),
 213:         "self_view": _compact_view(self_view),
 214:         "peer_status": peer_status,
 215:         "integrity_canonical": canonical,
 216:         "integrity_hash": integrity_hash,
 217:         "integrity_ok": all(v["view_ok"] for v in peer_status.values()),
 218:     }
 219: 
 220: 
 221: def cluster_integrity_report() -> dict:
 222:     """
 223:     Genera un reporte de integridad completo del cluster.
 224: 
 225:     Compara cada nodo con una referencia (cluster_state completo).
 226: 
 227:     Returns:
 228:         dict: Reporte de integridad:
 229:             - node_id (str): ID del nodo local
 230:             - alive_nodes (list[str]): Nodos vivos
 231:             - reference (dict[str, dict]): View canonicalizada de cada nodo
 232:             - per_peer (dict[str, dict]): Detalle por peer
 233:             - integrity_ok (bool): True si todos coinciden con la referencia
 234: 
 235:     Example:
 236:         >>> cluster_integrity_report()
 237:         {
 238:             'node_id': 'lnx203hp',
 239:             'alive_nodes': ['lnx203hp', 'lnx200nas'],
 240:             'reference': {'lnx203hp': {...}, 'lnx200nas': {...}},
 241:             'per_peer': {
 242:                 'lnx203hp': {'matches_reference': True, 'matches_log_meta': True, 'state': 'ACTIVE', ...},
 243:                 'lnx200nas': {'matches_reference': True, 'matches_log_meta': True, 'state': 'STANDBY', ...}
 244:             },
 245:             'integrity_ok': True
 246:         }
 247:     """
 248:     alive = compute_alive(include_self=True)
 249:     reference = canonicalize(cluster_state, IGNORED_NODE_KEYS)
 250:     per_peer = {}
 251: 
 252:     for node_id, data in alive.items():
 253:         view = canonicalize(data, IGNORED_NODE_KEYS)
 254:         meta = view.get("log_meta", {}) if isinstance(view, dict) else {}
 255:         ref_view = reference.get(node_id, {})
 256:         ref_meta = ref_view.get("log_meta", {}) if isinstance(ref_view, dict) else {}
 257: 
 258:         per_peer[node_id] = {
 259:             "matches_reference": view == ref_view,
 260:             "matches_log_meta": meta == ref_meta,
 261:             "state": view.get("state"),
 262:             "state_since": view.get("state_since"),
 263:             "prev_state": view.get("prev_state"),
 264:             "state_reason": view.get("state_reason"),
 265:             "priority": view.get("priority"),
 266:             "streams": view.get("streams", {}),
 267:         }
 268: 
 269:     return {
 270:         "node_id": ctx.node_id,
 271:         "alive_nodes": sorted(alive.keys()),
 272:         "reference": {k: _compact_view(v) for k, v in reference.items()} if isinstance(reference, dict) else {},
 273:         "per_peer": per_peer,
 274:         "integrity_ok": all(v["matches_reference"] and v["matches_log_meta"] for v in per_peer.values()),
 275:     }



===== ./runtime/leader.py =====
   1: # File: ./cluster/runtime/leader.py
   2: # Previous: none
   3: # Author: alftorres
   4: # Date: 2026-05-28T17:10:07+0200
   5: # Version: 0.0.0
   6: # Genealogy:
   7: #   ./cluster/runtime/leader.py 0.0.0 2026-05-28T17:10:07+0200
   8: #   God
   9: #
  10: # Purpose:
  11: #   Leader election para el cluster.
  12: #   Implementa un algoritmo simple de leader election basado en priority:
  13: #   el nodo con menor priority (y node_id alfabético como tie-breaker) se convierte
  14: #   en líder. Los nodos deben estar "vivos" (heartbeat reciente) para ser considerados.
  15: #   El líder es el único que procesa eventos; los nodos standby reenvían eventos al líder.
  16: # Notes:
  17: #   - Algoritmo: menor priority gana, tie-breaker es node_id alfabético
  18: #   - Timeout por defecto: 1.5s (si no hay heartbeat en 1.5s, nodo se considera muerto)
  19: #   - Solo nodos ACTIVE, STANDBY, STAND-BY, DRAINING son candidatos
  20: #   - Se ejecuta en cada tick del worker (cada ~1s), así que la election es rápida
  21: #   - No hay split-brain protection (asume red confiable)
  22: #   - debug_node_id permite forzar un líder para testing
  23: #
  24: # FRV-ID: bc64b1dd697351a2
  25: # Header_End
  26: 
  27: import time
  28: 
  29: from cluster.runtime.cluster_store import cluster_state
  30: from cluster.runtime import context as ctx
  31: 
  32: # =============================================================================
  33: # Configuración de leader election
  34: # =============================================================================
  35: 
  36: #: Timeout en segundos para considerar un nodo como vivo
  37: #: Si no hay heartbeat en este tiempo, el nodo se excluye de election
  38: #: Tipo: float
  39: LEADER_ALIVE_TIMEOUT = 1.5
  40: 
  41: 
  42: def refresh_self_alive_entry(now=None):
  43:     """
  44:     Actualiza la entrada del nodo actual en cluster_state.
  45: 
  46:     Sincroniza el estado del nodo local (state, priority, last_seen) con
  47:     cluster_state para que sea visible para la leader election.
  48: 
  49:     Args:
  50:         now: Timestamp opcional. Si no se proporciona, usa time.time().
  51: 
  52:     Note:
  53:         - Se llama en compute_alive() antes de election para asegurarse
  54:           de que el nodo local está visible
  55:         - Copia state, priority, last_seen, state_since, prev_state, state_reason
  56:         - Si no hay ctx.node, retorna sin hacer nada
  57: 
  58: 
  59: Example:
  60:         >>> refresh_self_alive_entry()
  61:         # cluster_state["lnx203hp"] = {..., "state": "ACTIVE", "priority": 10, "last_seen": 1779956226}
  62:     """
  63:     now = now or time.time()
  64:     if not getattr(ctx, "node", None):
  65:         return
  66: 
  67:     existing = cluster_state.get(ctx.node_id, {})
  68: 
  69:     cluster_state[ctx.node_id] = {
  70:         **existing,
  71:         "state": ctx.node.state.value,
  72:         "priority": ctx.node.priority,
  73:         "last_seen": now,
  74:         "state_since": getattr(ctx.node, "state_since", None),
  75:         "prev_state": getattr(ctx.node, "prev_state", None),
  76:         "state_reason": getattr(ctx.node, "state_reason", None),
  77:     }
  78: 
  79: 
  80: def last_presence_ts(data: dict) -> float:
  81:     """
  82:     Obtiene el último timestamp de presencia de un nodo.
  83: 
  84:     Busca el máximo entre last_seen y last_watchdog para determinar
  85:     cuándo fue la última vez que el nodo mostró actividad.
  86: 
  87:     Args:
  88:         data: Dict con info del nodo (debe tener last_seen y/o last_watchdog).
  89: 
  90:     Returns:
  91:         float: Último timestamp de presencia, o 0.0 si no hay ninguno.
  92: 
  93:     Example:
  94:         >>> last_presence_ts({"last_seen": 1779956226.0, "last_watchdog": 1779956220.0})
  95:         1779956226.0
  96: 
  97:         >>> last_presence_ts({"last_seen": None})
  98:         0.0
  99: 
 100:     Note:
 101:         - Ignora valores None o que no se puedan convertir a float
 102:         - Se usa en is_alive() para determinar si el nodo está vivo
 103:     """
 104:     candidates = []
 105:     for key in ("last_seen", "last_watchdog"):
 106:         value = data.get(key, 0)
 107:         if value is None:
 108:             continue
 109:         try:
 110:             candidates.append(float(value))
 111:         except Exception:
 112:             continue
 113:     return max(candidates) if candidates else 0.0
 114: 
 115: 
 116: def is_alive(data, timeout=LEADER_ALIVE_TIMEOUT, now=None):
 117:     """
 118:     Comprueba si un nodo está vivo (heartbeat reciente).
 119: 
 120:     Args:
 121:         data: Dict con info del nodo (last_seen o last_watchdog).
 122:         timeout: Timeout en segundos para considerar vivo al nodo.
 123:         now: Timestamp opcional. Si no se proporciona, usa time.time().
 124: 
 125:     Returns:
 126:         bool: True si el nodo ha tenido actividad en los últimos `timeout` segundos.
 127: 
 128:     Example:
 129:         >>> is_alive({"last_seen": 1779956226.0}, timeout=1.5, now=1779956227.0)
 130:         True
 131: 
 132:         >>> is_alive({"last_seen": 1779956220.0}, timeout=1.5, now=1779956227.0)
 133:         False
 134: 
 135:     Note:
 136:         - Usa last_presence_ts() para obtener el último timestamp
 137:         - Retorna True si (now - last_presence) < timeout
 138:     """
 139:     now = now or time.time()
 140:     last_presence = last_presence_ts(data)
 141:     return (now - last_presence) < timeout
 142: 
 143: 
 144: def compute_alive(timeout=LEADER_ALIVE_TIMEOUT, include_self=True):
 145:     """
 146:     Calcula qué nodos están vivos y activos en el cluster.
 147: 
 148:     Filtra cluster_state para devolver solo nodos que:
 149:         1. Son "vivos" (heartbeat en los últimos `timeout` segundos)
 150:         2. Están en estado ACTIVE, STANDBY, STAND-BY, o DRAINING
 151: 
 152:     Args:
 153:         timeout: Timeout para considerar vivo al nodo.
 154:         include_self: Si True, actualiza la entrada del nodo local antes de calcular.
 155: 
 156:     Returns:
 157:         dict[str, dict]: Nodos vivos mapeados por node_id con su info completa.
 158: 
 159:     Example:
 160:         >>> compute_alive(timeout=1.5)
 161:         {
 162:             "lnx203hp": {"state": "ACTIVE", "priority": 10, "last_seen": 1779956226.0, ...},
 163:             "lnx200nas": {"state": "STANDBY", "priority": 100, "last_seen": 1779956225.5, ...}
 164:         }
 165: 
 166:     Note:
 167:         - Llama a refresh_self_alive_entry() si include_self=True para asegurarse
 168:           de que el nodo local está visible
 169:         - Excluye nodos en BOOT, DISCOVERING, SEGMENTATION, ISOLATED, OFFLINE
 170:     """
 171:     now = time.time()
 172:     if include_self:
 173:         refresh_self_alive_entry(now)
 174: 
 175:     active_nodes = {}
 176:     for node_id, data in cluster_state.items():
 177:         if not is_alive(data, timeout=timeout, now=now):
 178:             continue
 179:         if data.get("state") not in ("ACTIVE", "STANDBY", "STAND-BY", "DRAINING"):
 180:             continue
 181:         active_nodes[node_id] = data
 182:     return active_nodes
 183: 
 184: 
 185: def compute_leader(debug_node_id=None, timeout=LEADER_ALIVE_TIMEOUT):
 186:     """
 187:     Calcula cuál es el líder del cluster.
 188: 
 189:     El líder es el nodo vivo con menor priority (tie-breaker: node_id alfabético).
 190: 
 191:     Args:
 192:         debug_node_id: (Testing) Fuerza este node_id como líder.
 193:         timeout: Timeout para considerar vivo al nodo.
 194: 
 195:     Returns:
 196:         str | None: node_id del líder, o None si no hay nodos vivos.
 197: 
 198:     Example:
 199:         >>> compute_leader()
 200:         'lnx203hp'
 201: 
 202:         >>> compute_leader()  # Si todos los nodos están muertos
 203:         None
 204: 
 205:     Note:
 206:         - Algoritmo: min(priority, node_id) en nodos vivos
 207:         - priority menor = más prioritario (el que gana)
 208:         - Tie-breaker: node_id alfabético (lexicográfico)
 209:         - Se llama en cada tick del worker (~1s) para detectar cambios de líder
 210:         - Si no hay líder (todos muertos), dispatch_tick() no procesa eventos
 211:     """
 212:     active_nodes = compute_alive(timeout=timeout, include_self=True)
 213:     if not active_nodes:
 214:         return None
 215:     return min(
 216:         active_nodes.items(),
 217:         key=lambda x: (x[1].get("priority", 9999), x[0]),
 218:     )[0]



===== ./runtime/log_replication.py =====
   1: # File: ./cluster/runtime/log_replication.py
   2: # Previous: none
   3: # Author: alftorres
   4: # Date: 2026-05-28T17:10:30+0200
   5: # Version: 0.0.0
   6: # Genealogy:
   7: #   ./cluster/runtime/log_replication.py 0.0.0 2026-05-28T17:10:30+0200
   8: #   God
   9: #
  10: # Purpose:
  11: #   Replicación de logs del cluster entre nodos.
  12: #   Replica el event log local a todos los peers vivos para mantener una copia
  13: #   redundante de los eventos. Se ejecuta en cada tick del worker y solo replica
  14: #   si el log está marcado como "dirty" (modificado). Cada peer recibe el log
  15: #   y lo guarda como replica para poder recover en caso de fallo.
  16: # Notes:
  17: #   - Dos tipos de replicación: event log (eventos activos) y completed log (eventos procesados)
  18: #   - Solo se replica si el nodo está en ACTIVE, STANDBY, o DRAINING
  19: #   - Dirty flag se pone al appendar un evento, se limpia al replicar exitosamente
  20: #   - PEERALIVETTLSEC=3.0s: peer se considera muerto si no hay last_seen en 3s
  21: #   - Se llama en cada tick del worker (~1s) vía replicate_eventlog() y replicate_events()
  22: #   - Falla silenciosamente si un peer no responde (no bloquea el tick)
  23: #
  24: # FRV-ID: 4e48ada454ba3669
  25: # Header_End
  26: 
  27: import logging
  28: import time
  29: import requests
  30: 
  31: from cluster.runtime import context as ctx
  32: from cluster.runtime.cluster_store import cluster_state
  33: from cluster.runtime.registry import CLUSTER_REGISTRY
  34: from cluster.runtime.event_log import (
  35:     read_local_log_text,
  36:     read_completed_log_text,
  37:     write_replica_log,
  38:     write_replica_events,
  39:     write_completed_log,
  40:     read_state,
  41:     clear_eventlog_dirty_state,
  42:     clear_events_dirty_state,
  43: 
  44: )
  45: from cluster.runtime.state import NodeState
  46: from cluster.utils.log_print import log_state
  47: 
  48: logging.getLogger("urllib3").setLevel(logging.ERROR)
  49: logging.getLogger("requests").setLevel(logging.ERROR)
  50: 
  51: # =============================================================================
  52: # Configuración de replicación
  53: # =============================================================================
  54: 
  55: #: TTL en segundos para considerar un peer como vivo
  56: #: Si no hay last_seen en este tiempo, el peer se excluye de replicación
  57: PEERALIVETTLSEC = 3.0
  58: 
  59: #: Estados del nodo que permiten replicación
  60: #: Solo ACTIVE, STANDBY, y DRAINING replican (no BOOT, ISOLATED, SEGMENTATION, OFFLINE)
  61: REPLICATION_ALLOWED_STATES = {
  62:     NodeState.ACTIVE.value,
  63:     NodeState.STANDBY.value,
  64:     NodeState.DRAINING.value,
  65: }
  66: 
  67: 
  68: def canonical_replica_node_id() -> str:
  69:     """
  70:     Devuelve el node_id canonical del nodo local para usar como nombre de replica.
  71: 
  72:     Returns:
  73:         str: node_id del nodo local.
  74: 
  75:     Example:
  76:         >>> canonical_replica_node_id()
  77:         'lnx203hp'
  78:     """
  79:     return ctx.node_id
  80: 
  81: 
  82: def alive_peer_ids():
  83:     """
  84:     Devuelve la lista de peers que están vivos (heartbeat reciente).
  85: 
  86:     Filtra cluster_state para incluir solo nodos que:
  87:         1. No son el nodo local
  88:         2. Han tenido actividad en los últimos PEERALIVETTLSEC segundos
  89: 
  90:     Returns:
  91:         list[str]: node_ids de peers vivos, ordenados alfabéticamente.
  92: 
  93:     Example:
  94:         >>> alive_peer_ids()
  95:         ['lnx200nas', 'lnx204hp']
  96: 
  97:     Note:
  98:         - Usa last_seen de cluster_state para determinar si está vivo
  99:         - Si un peer no ha hecho heartbeat en 3s, se excluye
 100:     """
 101:     out = []
 102:     now = time.time()
 103:     for node_id, data in cluster_state.items():
 104:         if node_id == ctx.node_id:
 105:             continue
 106:         if now - data.get("last_seen", 0) > PEERALIVETTLSEC:
 107:             continue
 108:         out.append(node_id)
 109:     return sorted(set(out))
 110: 
 111: 
 112: def configured_peer_ids():
 113:     """
 114:     Devuelve la lista de peers configurados (de ctx.peers y CLUSTER_REGISTRY).
 115: 
 116:     Combina:
 117:         1. Peers de ctx.peers (configuración de bootstrap)
 118:         2. Nodos de CLUSTER_REGISTRY (registros estáticos)
 119: 
 120:     Returns:
 121:         list[str]: node_ids de peers configurados, ordenados alfabéticamente.
 122: 
 123:     Example:
 124:         >>> configured_peer_ids()
 125:         ['lnx200nas', 'lnx204hp']
 126: 
 127:     Note:
 128:         - Excluye el nodo local
 129:         - Deduplica con set()
 130:     """
 131:     out = []
 132: 
 133:     for peer in getattr(ctx, "peers", []) or []:
 134:         peer_id = peer.get("node_id")
 135:         if peer_id and peer_id != ctx.node_id:
 136:             out.append(peer_id)
 137: 
 138:     for node_id in CLUSTER_REGISTRY.keys():
 139:         if node_id != ctx.node_id:
 140:             out.append(node_id)
 141: 
 142:     return sorted(set(out))
 143: 
 144: 
 145: def target_peer_ids():
 146:     """
 147:     Devuelve la lista de peers objetivo para replicación (vivos OR configurados).
 148: 
 149:     Combina alive_peer_ids() y configured_peer_ids() con Unión.
 150:     Esto asegura que se intenta replicar incluso a peers que están down
 151:     (pueden recoverar más tarde).
 152: 
 153:     Returns:
 154:         list[str]: node_ids de peers objetivo, ordenados alfabéticamente.
 155: 
 156:     Example:
 157:         >>> target_peer_ids()
 158:         ['lnx200nas', 'lnx204hp']
 159: 
 160:     Note:
 161:         - Unión de peers vivos + configurados
 162:         - Si un peer está configurado pero no está vivo, se iguala intentar replicar
 163:           (fallará pero se intenta)
 164:     """
 165:     alive = alive_peer_ids()
 166:     configured = configured_peer_ids()
 167:     return sorted(set(alive) | set(configured))
 168: 
 169: 
 170: def replicate_eventlog():
 171:     """
 172:     Replica el event log local a todos los peers.
 173: 
 174:     Secuencia:
 175:         1. comprueba si el nodo está en un estado permitido (ACTIVE, STANDBY, DRAINING)
 176:         2. comprueba si el log está dirty (modificado)
 177:         3. lee el contenido del log local
 178:         4. escribe el log como replica local
 179:         5. envía POST /debug/log/replica/{node_id} a cada peer
 180:         6. si todos los peers responden OK, limpia el dirty flag
 181: 
 182:     Note:
 183:         - Se llama en cada tick del worker (~1s)
 184:         - Falla silenciosamente si un peer no responde
 185:         - El dirty flag se mantiene hasta que TODOS los peers confirmen
 186:         - Solo replica si hay contenido (no replica logs vacíos)
 187:     """
 188: 
 189:     node_id = canonical_replica_node_id()
 190:     node_state = getattr(getattr(ctx, "node", None), "state", None)
 191:     node_state_value = getattr(node_state, "value", None)
 192: 
 193:     state = read_state()
 194:     dirty = bool(state.get("dirty", False))
 195: 
 196:     #log_state("cyan", "REPL TICK", f"node={node_id} dirty={dirty} ", 3)
 197: 
 198:     if node_state_value not in REPLICATION_ALLOWED_STATES:
 199:         return
 200: 
 201:     #log_state("cyan", "REPL FLAG", f"dirty={dirty} state_exists={bool(state)}", 3)
 202:     if not dirty:
 203:         return
 204: 
 205:     content = read_local_log_text()
 206:     completed_content = read_completed_log_text()
 207: 
 208:     if not content.strip():
 209:         return
 210: 
 211:     write_replica_log(node_id, content)
 212:     if completed_content.strip():
 213:         write_completed_log(completed_content)
 214: 
 215:     peers = target_peer_ids()
 216: 
 217:     success = True
 218: 
 219:     for peer_id in peers:
 220:         node = CLUSTER_REGISTRY.get(peer_id)
 221:         if not node:
 222:             success = False
 223:             continue
 224: 
 225:         url = f"http://{node['host']}:{node['port']}/debug/log/replica/{node_id}"
 226: 
 227:         try:
 228:             resp = requests.post(
 229:                 url,
 230:                 data=content.encode("utf-8"),
 231:                 headers={"Content-Type": "text/plain; charset=utf-8"},
 232:                 timeout=2,
 233:             )
 234: 
 235:             if resp.ok:
 236:                 success = True
 237:             else:
 238:                 success = False
 239: 
 240:         except Exception as e:
 241:             success = False
 242: 
 243:     if success:
 244:         clear_eventlog_dirty_state()
 245: 
 246: 
 247: def replicate_events():
 248:     """
 249:     Replica los eventos completed (procesados) a todos los peers.
 250: 
 251:     Similar a replicate_eventlog() pero solo replica el completed log.
 252:     Se usa para mantener una copia de eventos ya procesados en todos los nodos.
 253: 
 254:     Secuencia:
 255:         1. comprueba si el nodo está en un estado permitido
 256:         2. comprueba si el events log está dirty
 257:         3. lee el completed log local
 258:         4. escribe el events como replica local
 259:         5. envía POST /debug/events/replica/{node_id} a cada peer
 260:         6. si todos los peers responden OK, limpia el dirty flag
 261: 
 262:     Note:
 263:         - Se llama en cada tick del worker (~1s)
 264:         - Solo replica completed_content (eventos procesados)
 265:         - Falla silenciosamente si un peer no responde
 266:     """
 267: 
 268:     node_id = canonical_replica_node_id()
 269:     node_state = getattr(getattr(ctx, "node", None), "state", None)
 270:     node_state_value = getattr(node_state, "value", None)
 271: 
 272:     if node_state_value not in REPLICATION_ALLOWED_STATES:
 273:         return
 274: 
 275:     state = read_state()
 276:     dirty = bool(state.get("events_dirty", False))
 277:     if not dirty:
 278:         return
 279: 
 280:     completed_content = read_completed_log_text()
 281: 
 282:     write_replica_events(node_id, completed_content)
 283:     if completed_content.strip():
 284:         write_completed_log(completed_content)
 285: 
 286:     peers = target_peer_ids()
 287: 
 288:     success = True
 289: 
 290:     for peer_id in peers:
 291:         node = CLUSTER_REGISTRY.get(peer_id)
 292:         if not node:
 293:             success = False
 294:             continue
 295: 
 296:         url = f"http://{node['host']}:{node['port']}/debug/events/replica/{node_id}"
 297: 
 298:         try:
 299:             resp = requests.post(
 300:                 url,
 301:                 data=completed_content.encode("utf-8"),
 302:                 headers={"Content-Type": "text/plain; charset=utf-8"},
 303:                 timeout=2,
 304:             )
 305: 
 306:             if resp.ok:
 307:                 success = True
 308:             else:
 309:                 success = False
 310: 
 311:         except Exception as e:
 312:             success = False
 313: 
 314:     if success:
 315:         clear_events_dirty_state()



===== ./runtime/node_boot.py =====
   1: # File: ./cluster/runtime/node_boot.py
   2: # Previous: none
   3: # Author: alftorres
   4: # Date: 2026-05-28T17:10:49+0200
   5: # Version: 0.0.0
   6: # Genealogy:
   7: #   ./cluster/runtime/node_boot.py 0.0.0 2026-05-28T17:10:49+0200
   8: #   God
   9: #
  10: # Purpose:
  11: #   Entry point del nodo del cluster.
  12: #   Arranca el nodo: carga configuración, inicializa contexto global, crea NodeRuntime,
  13: #   registra el nodo y peers en el registry, arranca el worker en background,
  14: #   y sirve la API HTTP con uvicorn.
  15: # Notes:
  16: #   - Este es el archivo que se ejecuta con `python -m cluster.runtime.node_boot`
  17: #   - La configuración viene de bootstrap.py (config.json o env vars)
  18: #   - El worker se ejecuta en un hilo separado (daemon thread)
  19: #   - uvicorn es el servidor HTTP que sirve api_app.py (FastAPI)
  20: #   - El bloque __main__ permite ejecutar el script directamente o como módulo
  21: #
  22: # FRV-ID: 05bb09170fc30a8f
  23: # Header_End
  24: 
  25: import uvicorn
  26: 
  27: from cluster.runtime.node_worker import NodeWorker
  28: from cluster.runtime.node_runtime import NodeRuntime
  29: from cluster.runtime.bootstrap import load_or_bootstrap_config
  30: from cluster.runtime.registry import register_node
  31: from cluster.runtime.event_log import ensure_initial_files
  32: from cluster.runtime import context as ctx
  33: from cluster.runtime.api_app import app
  34: from cluster.utils.log_print import log_state
  35: 
  36: 
  37: def run_node(config):
  38:     """
  39:     Arranca un nodo del cluster.
  40: 
  41:     Secuencia de inicialización:
  42:         1. Crea archivos iniciales de event log (si no existen)
  43:         2. Inicializa contexto global (ctx.node_id, ctx.node, ctx.peers, ...)
  44:         3. Crea NodeRuntime (nodo local, estado BOOT)
  45:         4. Registra nodo local y peers en CLUSTER_REGISTRY
  46:         5. Arranca NodeWorker en hilo background
  47:         6. Arranca uvicorn (servidor HTTP)
  48: 
  49:     Args:
  50:         config (dict): Configuración del nodo con:
  51:             - node_id (str): ID único del nodo
  52:             - priority (int): Prioridad para leader election
  53:             - host (str): Hostname/IP del nodo
  54:             - port (int): Puerto del nodo
  55:             - bind_host (str): Host para bind del servidor HTTP (default: 0.0.0.0)
  56:             - bind_port (int): Puerto para bind del servidor HTTP (default: 7000)
  57:             - peers (list[dict]): Lista de peers con node_id, host, port, priority
  58: 
  59:     Example:
  60:         >>> config = {
  61:         ...     "node_id": "lnx203hp",
  62:         ...     "priority": 10,
  63:         ...     "host": "100.100.1.200",
  64:         ...     "port": 8000,
  65:         ...     "bind_host": "0.0.0.0",
  66:         ...     "bind_port": 7000,
  67:         ...     "peers": [
  68:         ...         {"node_id": "lnx200nas", "host": "100.100.1.201", "port": 8000, "priority": 100}
  69:         ...     ]
  70:         ... }
  71:         >>> run_node(config)
  72:         # Arranca el nodo lnx203hp con peer lnx200nas
  73:     """
  74:     ensure_initial_files()
  75: 
  76:     ctx.node_id = config["node_id"]
  77:     ctx.nodeid = config["node_id"]
  78:     ctx.priority = config["priority"]
  79:     ctx.peers = config.get("peers", [])
  80: 
  81:     node = NodeRuntime(
  82:         node_id=config["node_id"],
  83:         priority=config["priority"],
  84:     )
  85:     ctx.node = node
  86: 
  87:     register_node(
  88:         node_id=config["node_id"],
  89:         host=config["host"],
  90:         port=config["port"],
  91:         priority=config["priority"],
  92:     )
  93: 
  94:     for peer in config.get("peers", []):
  95:         register_node(
  96:             node_id=peer["node_id"],
  97:             host=peer["host"],
  98:             port=peer["port"],
  99:             priority=peer["priority"],
 100:         )
 101: 
 102:     log_state(
 103:         "cyan",
 104:         "[BOOT]",
 105:         (
 106:             f"node={config['node_id']} "
 107:             f"priority={config['priority']} "
 108:             f"bind={config.get('bind_host', '0.0.0.0')}:{config.get('bind_port', 7000)} "
 109:             f"peers={len(config.get('peers', []))} "
 110:             f"state={node.state.value} "
 111:             f"state_since={getattr(node, 'state_since', None)} "
 112:             f"reason={getattr(node, 'state_reason', None)}"
 113:         ),
 114:         3,
 115:     )
 116: 
 117:     worker = NodeWorker(
 118:         node=node,
 119:         peers=config["peers"],
 120:         interval=1.0,
 121:     )
 122:     worker.start()
 123: 
 124:     log_state("green", "[WORKER]", f"background loop started for {config['node_id']}", 3)
 125:     log_state(
 126:         "green",
 127:         "[HTTP]",
 128:         f"serving app on {config.get('bind_host', '0.0.0.0')}:{config.get('bind_port', 7000)}",
 129:         3,
 130:     )
 131: 
 132:     uvicorn.run(
 133:         app,
 134:         host=config.get("bind_host", "0.0.0.0"),
 135:         port=config.get("bind_port", 7000),
 136:         log_level="warning",
 137:         access_log=False,
 138:     )
 139: 
 140: 
 141: if __name__ == "__main__":
 142:     """
 143:     Entry point cuando se ejecuta el script directamente.
 144: 
 145:     Carga la configuración (de config.json o env vars) y arranca el nodo.
 146: 
 147:     Example:
 148:         # Ejecutar como script
 149:         $ python cluster/runtime/node_boot.py
 150: 
 151:         # Ejecutar como módulo
 152:         $ python -m cluster.runtime.node_boot
 153:     """
 154:     config = load_or_bootstrap_config()
 155:     run_node(config)



===== ./runtime/node_runtime.py =====
   1: # File: ./cluster/runtime/node_runtime.py
   2: # Previous: none
   3: # Author: alftorres
   4: # Date: 2026-05-28T17:11:02+0200
   5: # Version: 0.0.0
   6: # Genealogy:
   7: #   ./cluster/runtime/node_runtime.py 0.0.0 2026-05-28T17:11:02+0200
   8: #   God
   9: #
  10: # Purpose:
  11: #   Objeto principal que representa un nodo en el cluster.
  12: #   NodeRuntime encapsula el estado, la identidad (node_id, priority) y el
  13: #   comportamiento de un nodo: transiciones de estado, detección de líder,
  14: #   y emisión de heartbeats a peers.
  15: # Notes:
  16: #   - Se instancia una vez por proceso (el nodo local)
  17: #   - El estado se sincroniza con cluster_state mediante heartbeats
  18: #   - ticker.tick() se llama en cada tick del worker (~1s) para detectar cambios de líder
  19: #   - La transición STANDBY <-> ACTIVE es automática según quién sea el líder
  20: #   - No hay persistencia de estado (se reinicia al arrancar)
  21: #
  22: # FRV-ID: 380b2fdaa1d41be7
  23: # Header_End
  24: 
  25: 
  26: import time
  27: import requests
  28: 
  29: from cluster.runtime.state import NodeState, ensure_state_meta, transition_node_state
  30: from cluster.runtime.leader import compute_leader
  31: from cluster.utils.log_print import log_state
  32: 
  33: 
  34: class NodeRuntime:
  35:     """
  36:     Representa un nodo en el cluster.
  37: 
  38:     Gestiona el estado del nodo, la detección automática de líder, y la
  39:     emisión de heartbeats a otros nodos.
  40: 
  41:     Ciclo de vida típico:
  42:         1. BOOT (inicialización)
  43:         2. DISCOVERING (opcional, descubriendo peers)
  44:         3. STANDBY (esperando a ser líder)
  45:         4. ACTIVE (es el líder, procesa eventos)
  46: 
  47:     Si pierde el líder, vuelve a STANDBY. Si el nodo se vuelve líder,
  48:     pasa a ACTIVE.
  49: 
  50:     Attributes:
  51:         node_id (str): ID único del nodo.
  52:         priority (int): Prioridad para leader election (menor = más prioritario).
  53:         state (NodeState): Estado actual del nodo.
  54:         last_heartbeat (float): Timestamp del último heartbeat enviado.
  55:         state_since (float): Timestamp cuando se entró al estado actual.
  56:         prev_state (str | None): Estado anterior.
  57:         state_reason (str | None): Razón de la última transición.
  58: 
  59:     Example:
  60:         >>> node = NodeRuntime("lnx203hp", priority=10)
  61:         >>> node.node_id
  62:         'lnx203hp'
  63:         >>> node.priority
  64:         10
  65:         >>> node.state
  66:         <NodeState.BOOT: 'BOOT'>
  67: 
  68:         >>> node.transition(NodeState.STANDBY, reason="boot_complete")
  69:         {'changed': True, 'old_state': 'BOOT', 'new_state': 'STANDBY', ...}
  70:     """
  71: 
  72:     def __init__(self, node_id, priority):
  73:         """
  74:         Inicializa un nodo del cluster.
  75: 
  76:         Args:
  77:             node_id: ID único del nodo (string).
  78:             priority: Prioridad para leader election (menor = más prioritario).
  79: 
  80:         Example:
  81:             >>> node = NodeRuntime("lnx203hp", priority=10)
  82:             >>> node = NodeRuntime("lnx200nas", priority=100)
  83:         """
  84:         self.node_id = node_id
  85:         self.priority = priority
  86:         self.state = NodeState.BOOT
  87:         self.last_heartbeat = time.time()
  88: 
  89:         ensure_state_meta(self)
  90:         self.state_reason = "node_init"
  91: 
  92:     def transition(self, new_state, reason=None):
  93:         """
  94:         Transiciona el nodo a un nuevo estado.
  95: 
  96:         Delega en transition_node_state() y muestra un log si el estado cambia.
  97: 
  98:         Args:
  99:             new_state: Nuevo estado (NodeState enum o string).
 100:             reason: Razón de la transición (ej: "leader_selected", "boot_complete").
 101: 
 102:         Returns:
 103:             dict: Resultado de la transición (changed, old_state, new_state, ...).
 104: 
 105:         Example:
 106:             >>> node.transition(NodeState.STANDBY, reason="boot_complete")
 107:             [lnx203hp] BOOT -> STAND-BY (reason=boot_complete)
 108:             {'changed': True, 'old_state': 'BOOT', 'new_state': 'STANDBY', ...}
 109: 
 110:             >>> node.transition(NodeState.ACTIVE, reason="leader_selected")
 111:             [lnx203hp] STAND-BY -> ACTIVE (reason=leader_selected)
 112:             {'changed': True, 'old_state': 'STANDBY', 'new_state': 'ACTIVE', ...}
 113:         """
 114:         result = transition_node_state(self, new_state, reason=reason)
 115: 
 116:         if result["changed"]:
 117:             print(
 118:                 f"[{self.node_id}] "
 119:                 f"{result['old_state']} -> {result['new_state']} "
 120:                 f"(reason={result['state_reason']})"
 121:             )
 122: 
 123:         return result
 124: 
 125:     def tick(self):
 126:         """
 127:         Ejecuta la lógica de cada tick del nodo (~1s).
 128: 
 129:         Comprueba quién es el líder y transiciona automáticamente:
 130:             - Si soy el líder y estoy en STANDBY -> paso a ACTIVE
 131:             - Si no soy el líder y estoy en ACTIVE -> paso a STANDBY
 132: 
 133:         Note:
 134:             - Se llama en cada iteration del worker loop (~1s)
 135:             - La transición es automática, no requiere comando externo
 136:             - Si no hay líder (None), el nodo se queda en su estado actual
 137: 
 138:         Example:
 139:             >>> node.state = NodeState.STANDBY
 140:             >>> node.tick()  # Si soy líder
 141:             [CLUSTER] [lnx203hp] becoming ACTIVE
 142:             >>> node.state
 143:             <NodeState.ACTIVE: 'ACTIVE'>
 144:         """
 145:         #        if self.state == NodeState.BOOT:
 146:         #            self.transition(NodeState.STANDBY, reason="boot_complete")
 147:         #            return
 148: 
 149:         #log_state("yellow", "[NodeRunTime tick]", f"[{self.node_id}] ticking ...", 3)
 150: 
 151:         leader = compute_leader()
 152: 
 153:         if leader == self.node_id:
 154:             if self.state == NodeState.STANDBY:
 155:                 log_state("yellow", "[CLUSTER]", f"[{self.node_id}] becoming ACTIVE", 3)
 156:                 self.transition(NodeState.ACTIVE, reason="leader_selected")
 157:         else:
 158:             if self.state == NodeState.ACTIVE:
 159:                 log_state("yellow", "[CLUSTER]", f"[{self.node_id}] becoming STANDBY", 3)
 160:                 self.transition(NodeState.STANDBY, reason="leader_lost")
 161: 
 162:     def emit_heartbeat(self, peers):
 163:         """
 164:         Emite un heartbeat a todos los peers del cluster.
 165: 
 166:         Envía el estado actual del nodo (state, priority, state_since, ...)
 167:         a todos los peers para que actualicen cluster_state.
 168: 
 169:         Args:
 170:             peers: Lista de dicts con info de peers (cada uno tiene 'host' y 'port').
 171: 
 172:         Note:
 173:             - Se usa POST /heartbeat en cada peer (api_app.py)
 174:             - Timeout: 2s por peer
 175:             - Falla silenciosamente si un peer no responde (no levanta exception)
 176:             - Se llama en cada tick del worker (~1s)
 177: 
 178:         Example:
 179:             >>> peers = [
 180:             ...     {"host": "100.100.1.200", "port": 8000},
 181:             ...     {"host": "100.100.1.201", "port": 8000}
 182:             ... ]
 183:             >>> node.emit_heartbeat(peers)
 184:             # Envía POST http://100.100.1.200:8000/heartbeat y POST http://100.100.1.201:8000/heartbeat
 185:         """
 186:         hb = {
 187:             "node_id": self.node_id,
 188:             "state": self.state.value,
 189:             "priority": self.priority,
 190:             "state_since": getattr(self, "state_since", None),
 191:             "prev_state": getattr(self, "prev_state", None),
 192:             "state_reason": getattr(self, "state_reason", None),
 193:         }
 194: 
 195:         for peer in peers:
 196:             url = f"http://{peer['host']}:{peer['port']}/heartbeat"
 197:             try:
 198:                 requests.post(url, json=hb, timeout=2)
 199:             except requests.exceptions.RequestException:
 200:                 pass



===== ./runtime/node_worker.py =====
   1: # File: ./cluster/runtime/node_worker.py
   2: # Previous: none
   3: # Author: alftorres
   4: # Date: 2026-05-28T17:11:20+0200
   5: # Version: 0.0.0
   6: # Genealogy:
   7: #   ./cluster/runtime/node_worker.py 0.0.0 2026-05-28T17:11:20+0200
   8: #   God
   9: #
  10: # Purpose:
  11: #   Worker en background que ejecuta el tick del nodo cada ~1s.
  12: #   NodeWorker es un hilo daemon que ejecuta loop infinito llamando a tick()
  13: #   según el estado actual del nodo. Cada tick ejecuta: heartbeat, watchdog,
  14: #   replicación de logs, check de estado de eventos, y transiciones a DRAINING/SEGMENTATION
  15: #   si es necesario.
  16: # Notes:
  17: #   - Se arranca en run_node() como hilo daemon (no bloquea uvicorn)
  18: #   - interval=1.0s por defecto (se puede ajustar con env var)
  19: #   - tick_*() se llama según el estado: BOOT, STANDBY, ACTIVE, SEGMENTATION, DRAINING, ISOLATED, OFFLINE
  20: #   -EVENTSTATECHECKPERIODSEC=10s: check de estado de eventos cada 10s
  21: #   - STATEDEBUGPERIODSEC=30s: log de debug de estado cada 30s
  22: #   - MAX_SEGMENT_COUNT=2500:enter DRAINING si total_events > 2500
  23: #   - _can_segment(): solo se puede segmentar si created=0, executing=0, dirty=False
  24: #
  25: # FRV-ID: 09d53436254fce74
  26: # Header_End
  27: 
  28: import os
  29: import time
  30: import threading
  31: from pathlib import Path
  32: 
  33: from cluster.runtime.leader import compute_leader
  34: 
  35: from cluster.runtime.state import NodeState, get_state_age_s
  36: from cluster.runtime import context as ctx
  37: from cluster.utils.log_print import log_state
  38: from cluster.runtime.event_log import rebuild_event_state_index, load_events, load_completed_events, get_local_log_path
  39: from cluster.runtime.events.event_state import EventStatus
  40: from cluster.runtime.log_replication import replicate_eventlog, replicate_events
  41: from cluster.runtime.watchdog import emit_watchdog_if_due
  42: from cluster.runtime.cluster_store import cluster_state
  43: from cluster.runtime.api_app import _summarize_events
  44: 
  45: # =============================================================================
  46: # Configuración del worker (mediante env vars)
  47: # =============================================================================
  48: 
  49: #: Frecuencia de check de estado de eventos en segundos (default: 10s)
  50: EVENTSTATECHECKPERIODSEC = float(os.getenv("EVENTSTATECHECKPERIODSEC", 10))
  51: 
  52: #: Frecuencia de log de debug de estado en segundos (default: 30s)
  53: STATEDEBUGPERIODSEC = float(os.getenv("STATEDEBUGPERIODSEC", 30))
  54: 
  55: #: Máximo número de eventos antes de entrar en DRAINING (default: 2500)
  56: MAX_SEGMENT_COUNT = int(os.getenv("MAX_SEGMENT_COUNT", 2500))
  57: 
  58: #: Timestamp del último check de estado de eventos
  59: lasteventstatecheckts = 0.0
  60: 
  61: #: Timestamp del último log de debug de estado
  62: laststatedebugts = 0.0
  63: 
  64: 
  65: def _node_cache(node):
  66:     """
  67:     Obtiene el cache del nodo de cluster_state.
  68: 
  69:     Args:
  70:         node: NodeRuntime o dict del nodo.
  71: 
  72:     Returns:
  73:         dict: Cache del nodo (streams, counters, etc.), o {} si no existe.
  74:     """
  75:     node_id = _node_id(node)
  76:     if not node_id:
  77:         return {}
  78:     data = cluster_state.get(node_id, {}) or {}
  79:     return data if isinstance(data, dict) else {}
  80: 
  81: 
  82: def _node_id(node):
  83:     """
  84:     Extrae el node_id de un nodo (dict o NodeRuntime).
  85: 
  86:     Args:
  87:         node: NodeRuntime o dict.
  88: 
  89:     Returns:
  90:         str: node_id del nodo, o "?" si no se puede extraer.
  91:     """
  92:     if isinstance(node, dict):
  93:         return node.get("node_id", "?")
  94:     return getattr(node, "node_id", "?")
  95: 
  96: 
  97: def rebuild_node_event_cache(node_id: str):
  98:     """
  99:     Reconstruye el cache de eventos de un nodo en cluster_state.
 100: 
 101:     Carga eventos locales y completados, cuenta por status, y actualiza
 102:     streams con resúmenes (events_summary_local, events_summary_created, etc.).
 103: 
 104:     Args:
 105:         node_id: ID del nodo.
 106: 
 107:     Note:
 108:         - Se llama en cada tick para actualizar counters
 109:         - Actualiza cluster_state para que el dashboard muestre counters actualizados
 110:     """
 111:     if not isinstance(node_id, str):
 112:         node_id = getattr(node_id, "node_id", None)
 113: 
 114:     if not node_id:
 115:         log_state("red", "CACHE_BOOTSTRAP", "invalid node_id for event cache bootstrap", 3)
 116:         return
 117: 
 118:     node = cluster_state.get(node_id, {}) or {}
 119:     if not isinstance(node, dict):
 120:         node = {}
 121: 
 122:     streams = dict(node.get("streams", {}) or {})
 123: 
 124:     local_events = load_events() or []
 125:     completed_events = []
 126:     try:
 127:         completed_events = load_completed_events() or []
 128:     except Exception as e:
 129:         log_state("red", "CACHE_BOOTSTRAP", f"{node_id} completed_load_failed={e}", 3)
 130: 
 131:     created_events = [e for e in local_events if e.get("status") == EventStatus.CREATED.value]
 132:     executing_events = [e for e in local_events if e.get("status") == EventStatus.EXECUTING.value]
 133: 
 134:     streams["events_summary_local"] = _summarize_events(local_events)
 135:     streams["events_summary_created"] = _summarize_events(created_events)
 136:     streams["events_summary_executing"] = _summarize_events(executing_events)
 137:     streams["events_summary_completed"] = _summarize_events(completed_events)
 138: 
 139:     node["node_id"] = node_id
 140:     node["streams"] = streams
 141:     cluster_state[node_id] = node
 142: 
 143:     log_state("blue", "NODE STATE a", f"{_node_id(node)} local={len(local_events)} created={len(created_events)} executing={len(executing_events)} completed={len(completed_events)}", 3)
 144: 
 145: 
 146: def _node_streams(node):
 147:     """Obtiene streams del nodo (dict o NodeRuntime)."""
 148:     if isinstance(node, dict):
 149:         return node.get("streams", {}) or {}
 150:     return getattr(node, "streams", {}) or {}
 151: 
 152: 
 153: def _node_event_counters(node) -> tuple[int, int, int, int]:
 154:     """
 155:     Cuenta eventos por status del nodo.
 156: 
 157:     Returns:
 158:         tuple[int, int, int, int]: (created, executing, completed, total)
 159:     """
 160:     cache = _node_cache(node)
 161:     streams = cache.get("streams", {}) or {}
 162:     summary = streams.get("events_summary_local", {}) or {}
 163:     counts = summary.get("counts", {}) or {}
 164:     created = int(counts.get("created", 0))
 165:     executing = int(counts.get("executing", 0))
 166:     completed = int(counts.get("completed", 0))
 167:     total = int(summary.get("total_events", created + executing + completed))
 168:     return created, executing, completed, total
 169: 
 170: 
 171: def _can_segment(node) -> bool:
 172:     """
 173:     Comprueba si el nodo puede segmentar (rotar logs).
 174: 
 175:     Solo se puede segmentar si:
 176:         - created > 0 (hay eventos sin procesar)
 177:         - executing == 0 (no hay eventos en ejecución)
 178:         - dirty == False (no hay replicación pendiente)
 179: 
 180:     Args:
 181:         node: NodeRuntime del nodo.
 182: 
 183:     Returns:
 184:         bool: True si se puede segmentar.
 185:     """
 186:     created, executing, completed, total = _node_event_counters(node)
 187:     cache = _node_cache(node)
 188:     dirty = bool(cache.get("dirty", False))
 189:     return created > 0 and executing == 0 and not dirty
 190: 
 191: 
 192: def _should_enter_DRAINING(node) -> bool:
 193:     """
 194:     Comprueba si el nodo debe entrar en DRAINING.
 195: 
 196:     Entra en DRAINING si total_events > MAX_SEGMENT_COUNT.
 197: 
 198:     Args:
 199:         node: NodeRuntime del nodo.
 200: 
 201:     Returns:
 202:         bool: True si debe entrar en DRAINING.
 203:     """
 204:     created, executing, completed, total = _node_event_counters(node)
 205:     return total > MAX_SEGMENT_COUNT
 206: 
 207: 
 208: def _should_enter_segmentation(node) -> bool:
 209:     """
 210:     Comprueba si el nodo debe entrar en SEGMENTATION.
 211: 
 212:     Entra en SEGMENTATION si _can_segment() es True.
 213: 
 214:     Args:
 215:         node: NodeRuntime del nodo.
 216: 
 217:     Returns:
 218:         bool: True si debe entrar en SEGMENTATION.
 219:     """
 220:     return _can_segment(node)
 221: 
 222: 
 223: def leader_event_state_check_tick():
 224:     """
 225:     Check periódico del estado de eventos (cada EVENTSTATECHECKPERIODSEC).
 226: 
 227:     Carga eventos raw y del state_index, cuenta por status, y logea
 228:     diferencias (si hay).
 229: 
 230:     Note:
 231:         - Throttleado a EVENTSTATECHECKPERIODSEC=10s
 232:         - Actualmente no hace nada con los conteos (solo cuenta)
 233:     """
 234:     global lasteventstatecheckts
 235:     now = time.time()
 236:     if now - lasteventstatecheckts < EVENTSTATECHECKPERIODSEC:
 237:         return
 238:     lasteventstatecheckts = now
 239: 
 240:     raw_events = load_events() or []
 241:     state_index = rebuild_event_state_index()
 242: 
 243:     raw_created = raw_executing = raw_completed = 0
 244:     for e in raw_events:
 245:         status = e.get("status")
 246:         if hasattr(status, "value"):
 247:             status = status.value
 248:         status = str(status).strip().lower()
 249:         if status == EventStatus.CREATED.value:
 250:             raw_created += 1
 251:         elif status == EventStatus.EXECUTING.value:
 252:             raw_executing += 1
 253:         elif status == EventStatus.COMPLETED.value:
 254:             raw_completed += 1
 255: 
 256:     created = executing = completed = 0
 257:     for event in state_index.values():
 258:         status = event.get("status") if isinstance(event, dict) else getattr(event, "status", None)
 259:         if hasattr(status, "value"):
 260:             status = status.value
 261:         status = str(status).strip().lower()
 262:         if status == EventStatus.CREATED.value:
 263:             created += 1
 264:         elif status == EventStatus.EXECUTING.value:
 265:             executing += 1
 266:         elif status == EventStatus.COMPLETED.value:
 267:             completed += 1
 268: 
 269: 
 270: def cleanup_local_segment_files(node_id: str, segment: str = "000", files=None):
 271:     """
 272:     Elimina archivos de segmento local después de rotar.
 273: 
 274:     Args:
 275:         node_id: ID del nodo.
 276:         segment: Segmento a limpiar (default: "000").
 277:         files: Lista de tipos de archivos (default: ["events", "event_log"]).
 278: 
 279:     Returns:
 280:         dict: Resumen de archivos eliminados y faltantes.
 281:     """
 282:     files = files or ["events", "event_log"]
 283:     base_dir = Path(get_local_log_path(None)).resolve().parent
 284:     removed = []
 285:     missing = []
 286: 
 287:     for kind in files:
 288:         p = base_dir / f"{kind}.local.{segment}.jsonl"
 289:         if p.exists():
 290:             p.unlink()
 291:             removed.append(str(p))
 292:         else:
 293:             missing.append(str(p))
 294: 
 295:     return {
 296:         "node_id": node_id,
 297:         "segment": segment,
 298:         "removed": removed,
 299:         "missing": missing,
 300:     }
 301: 
 302: 
 303: def log_state_runtime_debug(node):
 304:     """
 305:     Log de debug de estado del nodo (cada STATEDEBUGPERIODSEC).
 306: 
 307:     Args:
 308:         node: NodeRuntime del nodo.
 309: 
 310:     Note:
 311:         - Throttleado a STATEDEBUGPERIODSEC=30s
 312:         - Reconstruye cache de eventos antes de logear
 313:     """
 314:     global laststatedebugts
 315:     now = time.time()
 316:     if now - laststatedebugts < STATEDEBUGPERIODSEC:
 317:         return
 318:     laststatedebugts = now
 319: 
 320:     age_s = get_state_age_s(node, now=now)
 321:     rebuild_node_event_cache(node.node_id)
 322: 
 323:     log_state("blue", "NODE STATE b", f"{_node_id(node)} state={node.state.value} age={age_s:.1f}s prev={getattr(node, 'prev_state', None)} reason={getattr(node, 'state_reason', None)}", 3)
 324: 
 325: 
 326: def rotate_segment_files(target_group: str, segment: str = "000", files=None, force: bool = False):
 327:     """
 328:     Rota archivos de segmento (renombra .local.000.jsonl a .{node_id}.001.jsonl).
 329: 
 330:     Args:
 331:         target_group: Grupo destino (no usado, se usa node_id local).
 332:         segment: Segmento a rotar (default: "000").
 333:         files: Lista de tipos de archivos (default: ["events", "event_log"]).
 334:         force: Si True, crea entry incluso si el archivo no existe.
 335: 
 336:     Returns:
 337:         dict: Resultado con before/after paths e índices.
 338: 
 339:     Raises:
 340:         RuntimeError: Si no hay node_id local.
 341:         FileNotFoundError: Si el archivo no existe y force=False.
 342:     """
 343:     files = files or ["events", "event_log"]
 344:     base_dir = Path(get_local_log_path(None)).resolve().parent
 345:     local_node_id = getattr(ctx, "node_id", None) or getattr(getattr(ctx, "node", None), "node_id", None)
 346: 
 347:     if not local_node_id:
 348:         raise RuntimeError("missing local node_id for segment rotation")
 349: 
 350:     result = {}
 351: 
 352:     for kind in files:
 353:         src = base_dir / f"{kind}.local.{segment}.jsonl"
 354:         if not src.exists():
 355:             if force:
 356:                 result[kind] = {"before": str(src), "after": None, "index": None, "forced": True}
 357:                 continue
 358:             raise FileNotFoundError(str(src))
 359: 
 360:         idx = _next_rotation_index(base_dir, f"{kind}.{local_node_id}")
 361:         dst = base_dir / f"{kind}.{local_node_id}.{idx:03d}.jsonl"
 362:         os.replace(str(src), str(dst))
 363:         result[kind] = {"before": str(src), "after": str(dst), "index": idx, "forced": False}
 364: 
 365:     return result
 366: 
 367: 
 368: def _next_rotation_index(base_dir, stem, suffix=".jsonl"):
 369:     """
 370:     Encuentra el próximo índice disponible para rotación.
 371: 
 372:     Args:
 373:         base_dir: Directorio base.
 374:         stem: Prefix del archivo (ej: "event_log.lnx203hp").
 375:         suffix: Suffix del archivo (default: ".jsonl").
 376: 
 377:     Returns:
 378:         int: Próximo índice disponible (001, 002, ...).
 379:     """
 380:     base_dir = Path(base_dir)
 381:     idx = 1
 382:     while True:
 383:         candidate = base_dir / f"{stem}.{idx:03d}{suffix}"
 384:         if not candidate.exists():
 385:             return idx
 386:         idx += 1
 387: 
 388: 
 389: class NodeWorker:
 390:     """
 391:     Worker en background que ejecuta el tick del nodo cada ~1s.
 392: 
 393:     Attributes:
 394:         node (NodeRuntime): Nodo del cluster.
 395:         peers (list[dict]): Lista de peers con host, port, node_id.
 396:         interval (float): Intervalo entre ticks en segundos (default: 1.0).
 397:         running (bool): Flag para controlar el loop.
 398: 
 399:     Example:
 400:         >>> worker = NodeWorker(node, peers, interval=1.0)
 401:         >>> worker.start()
 402:         # Worker empieza a ejecutar tick cada 1s en hilo background
 403:         >>> worker.stop()
 404:         # Worker para el loop
 405:     """
 406: 
 407:     def __init__(self, node, peers, interval=1.0):
 408:         """
 409:         Inicializa el worker.
 410: 
 411:         Args:
 412:             node: NodeRuntime del nodo.
 413:             peers: Lista de peers.
 414:             interval: Intervalo entre ticks en segundos.
 415:         """
 416:         self.node = node
 417:         self.peers = peers
 418:         self.interval = interval
 419:         self.running = False
 420: 
 421:     def start(self):
 422:         """
 423:         Arranca el worker en un hilo daemon.
 424: 
 425:         El hilo ejecuta loop() hasta que running=False.
 426:         """
 427:         self.running = True
 428:         t = threading.Thread(target=self.loop, daemon=True)
 429:         t.start()
 430: 
 431:     def stop(self):
 432:         """Detiene el worker (setting running=False)."""
 433:         self.running = False
 434: 
 435:     def tick_boot(self):
 436:         """
 437:         Tick del estado BOOT.
 438: 
 439:         - Emite watchdog busy=True
 440:         - Reconstruye cache de eventos
 441:         - Transiciona a STANDBY
 442:         """
 443:         emit_watchdog_if_due(self.peers, busy=True)
 444:         rebuild_node_event_cache(self.node.node_id)
 445:         self.node.event_cache_ready = True
 446:         self.node.transition(NodeState.STANDBY, reason="boot_complete")
 447: 
 448:     def tick_discovering(self):
 449:         """Tick del estado DISCOVERING (actualmente no hace nada)."""
 450:         pass
 451: 
 452:     def tick_standby(self):
 453:         """
 454:         Tick del estado STANDBY.
 455: 
 456:         - Emite heartbeat a peers
 457:         - Emite watchdog busy=True
 458:         - Replica event log y events
 459:         - Check de estado de eventos
 460:         - Si total_events > MAX_SEGMENT_COUNT, transiciona a DRAINING
 461:         """
 462:         self.node.emit_heartbeat(self.peers)
 463:         emit_watchdog_if_due(self.peers, busy=True)
 464: 
 465:         leader = compute_leader()
 466: 
 467:         replicate_eventlog()
 468:         replicate_events()
 469:         leader_event_state_check_tick()
 470:         if _should_enter_DRAINING(self.node):
 471:             self.node.transition(NodeState.DRAINING, reason="segment_max_count")
 472: 
 473:     def tick_active(self):
 474:         """
 475:         Tick del estado ACTIVE (líder).
 476: 
 477:         Igual que tick_standby() pero el nodo es el líder.
 478:         """
 479:         self.node.emit_heartbeat(self.peers)
 480:         emit_watchdog_if_due(self.peers, busy=True)
 481:         replicate_eventlog()
 482:         replicate_events()
 483:         leader_event_state_check_tick()
 484:         if _should_enter_DRAINING(self.node):
 485:             self.node.transition(NodeState.DRAINING, reason="segment_max_count")
 486: 
 487:     def tick_segmentation(self):
 488:         """
 489:         Tick del estado SEGMENTATION.
 490: 
 491:         - Si no se puede segmentar, retorna sin hacer nada
 492:         - Rota archivos de segmento (.local.000.jsonl -> .{node_id}.001.jsonl)
 493:         - Elimina archivos rotados
 494:         - Reconstruye cache de eventos
 495:         - Transiciona a STANDBY
 496:         """
 497:         self.node.emit_heartbeat(self.peers)
 498:         emit_watchdog_if_due(self.peers, busy=True)
 499: 
 500:         can_seg = _can_segment(self.node)
 501:         should_seg = _should_enter_segmentation(self.node)
 502: 
 503:         if not should_seg:
 504:             return False
 505: 
 506:         result = rotate_segment_files(self.node.node_id, segment="000", files=["events", "event_log"], force=False)
 507:         log_state("magenta", "SEGMENTATION", f"{self.node.node_id} rotate ok={bool(result)}", 3)
 508: 
 509:         cleanup_local_segment_files(self.node.node_id, segment="000", files=["events", "event_log"])
 510:         rebuild_node_event_cache(self.node.node_id)
 511:         self.node.transition(NodeState.STANDBY, reason="segment_closed")
 512: 
 513:         return True
 514: 
 515:     def tick_DRAINING(self):
 516:         """
 517:         Tick del estado DRAINING (preparando segmentación).
 518: 
 519:         - Emite heartbeat y watchdog
 520:         - Replica logs
 521:         - Reconstruye cache de eventos
 522:         - Check de estado de eventos
 523:         - Si _should_enter_segmentation(), transiciona a SEGMENTATION
 524:         """
 525:         self.node.emit_heartbeat(self.peers)
 526:         emit_watchdog_if_due(self.peers, busy=True)
 527:         replicate_eventlog()
 528:         replicate_events()
 529:         rebuild_node_event_cache(self.node.node_id)
 530:         leader_event_state_check_tick()
 531:         if _should_enter_segmentation(self.node):
 532:             self.node.transition(NodeState.SEGMENTATION, reason="segment_ready")
 533: 
 534:     def tick_isolated(self):
 535:         """Tick del estado ISOLATED (sleep/pausa, no hace nada)."""
 536:         pass
 537: 
 538:     def tick_offline(self):
 539:         """Tick del estado OFFLINE (desconectado, no hace nada)."""
 540:         pass
 541: 
 542:     def _tick_by_state(self):
 543:         """
 544:         Despacha el tick según el estado actual del nodo.
 545: 
 546:         Llama a tick_boot(), tick_standby(), tick_active(), etc. según node.state.
 547:         """
 548:         state = self.node.state
 549:         if state == NodeState.BOOT:
 550:             self.tick_boot()
 551:         elif state == NodeState.DISCOVERING:
 552:             self.tick_discovering()
 553:         elif state == NodeState.STANDBY:
 554:             self.tick_standby()
 555:         elif state == NodeState.ACTIVE:
 556:             self.tick_active()
 557:         elif state == NodeState.SEGMENTATION:
 558:             self.tick_segmentation()
 559:         elif state == NodeState.DRAINING:
 560:             self.tick_DRAINING()
 561:         elif state == NodeState.ISOLATED:
 562:             self.tick_isolated()
 563:         elif state == NodeState.OFFLINE:
 564:             self.tick_offline()
 565: 
 566:     def loop(self):
 567:         """
 568:         Loop infinito del worker.
 569: 
 570:         Ejecuta:
 571:             1. node.tick() (actualiza estado según quién es el líder)
 572:             2. log_state_runtime_debug() (log cada 30s)
 573:             3. Si estado es ISOLATED, skip el resto y sleep
 574:             4. _tick_by_state() (tick según estado)
 575:             5. Sleep hasta el próximo intervalo
 576:         """
 577:         while self.running:
 578:             self.node.tick()
 579:             log_state_runtime_debug(self.node)
 580:             if self.node.state == NodeState.ISOLATED:
 581:                 continue
 582:             self._tick_by_state()
 583:             time.sleep(self.interval)



===== ./runtime/registry.py =====
   1: # File: ./cluster/runtime/registry.py
   2: # Previous: none
   3: # Author: alftorres
   4: # Date: 2026-05-28T17:11:35+0200
   5: # Version: 0.0.0
   6: # Genealogy:
   7: #   ./cluster/runtime/registry.py 0.0.0 2026-05-28T17:11:35+0200
   8: #   God
   9: #
  10: # Purpose:
  11: #   Registro centralizado de nodos del cluster.
  12: #   Mantiene un diccionario global con la información de todos los nodos
  13: #   (host, port, priority) para permitir el enrutado de eventos y la
  14: #   comunicación entre nodos.
  15: # Notes:
  16: #   - Este registro se inicializa durante el bootstrap con los nodos configurados
  17: #   - Se usa en event_router.py para enrutar eventos al líder
  18: #   - En un cluster dinámico, podría ampliarse con registro/descubrimiento automático
  19: #   - No hay limpieza de nodos caídos (se asume estático o gestionado externamente)
  20: #
  21: # FRV-ID: 534531c72532d0c5
  22: # Header_End
  23: 
  24: # =============================================================================
  25: # Registro global de nodos del cluster
  26: # =============================================================================
  27: 
  28: #: Diccionario global que mapea node_id -> información del nodo
  29: #: Cada entry contiene: host, port, priority
  30: #: Tipo: dict[str, dict[str, str | int]]
  31: CLUSTER_REGISTRY = {}
  32: 
  33: 
  34: def register_node(node_id: str, host: str, port: int, priority: int = 100):
  35:     """
  36:     Registra un nodo en el cluster.
  37: 
  38:     Añade o actualiza un nodo en el registry con su información de conexión.
  39: 
  40:     Args:
  41:         node_id: ID único del nodo (string).
  42:         host: Hostname o IP del nodo (ej: "100.100.1.200", "localhost").
  43:         port: Puerto del nodo (ej: 8000, 7000).
  44:         priority: Prioridad del nodo para leader election (menor = más prioridad).
  45:                   Por defecto: 100.
  46: 
  47:     Returns:
  48:         dict: El entry del nodo recién registrado/actualizado.
  49: 
  50:     Example:
  51:         >>> register_node("lnx203hp", "100.100.1.200", 8000, priority=10)
  52:         {'host': '100.100.1.200', 'port': 8000, 'priority': 10}
  53: 
  54:         >>> register_node("lnx200nas", "100.100.1.201", 8000)
  55:         {'host': '100.100.1.201', 'port': 8000, 'priority': 100}
  56: 
  57:     Note:
  58:         - Si el node_id ya existe, se sobrescribe la información
  59:         - El priority se usa en compute_leader() para seleccionar el líder
  60:     """
  61:     CLUSTER_REGISTRY[node_id] = {
  62:         "host": host,
  63:         "port": port,
  64:         "priority": priority,
  65:     }
  66:     return CLUSTER_REGISTRY[node_id]
  67: 
  68: 
  69: def get_node(node_id: str):
  70:     """
  71:     Obtiene la información de un nodo del registry.
  72: 
  73:     Args:
  74:         node_id: ID del nodo a buscar.
  75: 
  76:     Returns:
  77:         dict | None: El dict del nodo si existe, None si no está registrado.
  78: 
  79:     Example:
  80:         >>> get_node("lnx203hp")
  81:         {'host': '100.100.1.200', 'port': 8000, 'priority': 10}
  82: 
  83:         >>> get_node("nodonotexist")
  84:         None
  85: 
  86:     Note:
  87:         - Se usa en event_router.py para obtener host/port del líder
  88:         - Retorna None si el nodo no está en el registry (no levanta exception)
  89:     """
  90:     return CLUSTER_REGISTRY.get(node_id)



