   7: #   ./cluster/runtime/cluster_store.py 0.0.0 2026-05-28T17:07:24+0200
   8: #   God
   9: #
  10: # Purpose:
  11: #   Almacenamiento en memoria del estado del cluster.
  12: #   Mantiene un diccionario global con el estado de todos los nodos del cluster,
  13: #   actualizado mediante heartbeats. Se usa para leader election, watchdog,
  14: #   y para consultar el estado de otros nodos.
  15: # Notes:
  16: #   - Este es un estado en memoria (no persiste, se reinicia al arrancar)
  17: #   - Se llena con heartbeats de los nodos (ver heartbeat() en api_app.py)
  18: #   - cluster_state vs CLUSTER_REGISTRY:
  19: #       * CLUSTER_REGISTRY: nodos configurados estáticamente (host, port, priority)
  20: #       * cluster_state: estado dinámico de nodos activos (state, last_seen, etc.)
  21: #   - En un futuro podría amplificarse con persistencia o replicación
  22: #
  23: # FRV-ID: ed651d710eb25af1
  24: # Header_End
  25: 
  26: import time
  27: 
  28: # =============================================================================
  29: # Estado global del cluster (en memoria)
  30: # =============================================================================
  31: 
  32: #: Diccionario global con el estado de todos los nodos del cluster
  33: #: Clave: node_id (str)
  34: #: Valor: dict con state, priority, last_seen, last_watchdog, watchdog_busy,
  35: #:        state_since, prev_state, state_reason, log_meta, cluster_integrity, streams
  36: #: Tipo: dict[str, dict[str, Any]]
  37: cluster_state = {}
  38: 
  39: 
  40: def get_active_cluster():
  41:     """
  42:     Devuelve el estado completo del cluster.
  43: 
  44:     Returns:
  45:         dict[str, dict]: Copia de referencia de cluster_state con todos los nodos.
  46: 
  47:     Note:
  48:         - Retorna la referencia directa (no una copia), así que cuidado con modificarlo
  49:         - Se usa principalmente para debugging/monitoring
  50: 
  51:     Example:
  52:         >>> cluster = get_active_cluster()
  53:         >>> for node_id, info in cluster.items():
  54:         ...     print(f"{node_id}: {info.get('state')}")
  55:     """
  56:     return cluster_state
  57: 
  58: 
  59: def upsert_node(node_id: str, payload: dict, now: float | None = None) -> dict:
  60:     """
  61:     Inserta o actualiza un nodo en el cluster_state.
  62: 
  63:     Fusiona el payload con el estado existente del nodo, actualizando
  64:     automáticamente `last_seen` al timestamp actual.
  65: 
  66:     Args:
  67:         node_id: ID único del nodo.
  68:         payload: Dict con los campos a actualizar (state, priority, last_watchdog, etc.).
  69:         now: Timestamp opcional. Si no se proporciona, usa time.time().
  70: 
  71:     Returns:
  72:         dict: El estado actualizado del nodo (después de la actualización).
  73: 
  74:     Example:
  75:         >>> upsert_node("lnx203hp", {"state": "ACTIVE", "priority": 10})
  76:         {'state': 'ACTIVE', 'priority': 10, 'last_seen': 1779956226.123}
  77: 
  78:     Note:
  79:         - fusiona payload con el estado existente (no lo sobrescribe completamente)
  80:         - last_seen siempre se actualiza al timestamp actual (a menos que payload lo fije)
  81:     """
  82:     now = now or time.time()
  83:     current = cluster_state.get(node_id, {})
  84: 
  85:     cluster_state[node_id] = {
  86:         **current,
  87:         **payload,
  88:         "last_seen": payload.get("last_seen", now),
  89:     }
  90:     return cluster_state[node_id]
  91: 
  92: 
  93: def refresh_node_seen(node_id: str, now: float | None = None) -> dict:
  94:     """
  95:     Actualiza solo el last_seen de un nodo (heartbeat).
  96: 
  97:     Útil para refreshar el timestamp de actividad sin cambiar otros campos.
  98: 
  99:     Args:
 100:         node_id: ID del nodo a refreshar.
 101:         now: Timestamp opcional. Si no se proporciona, usa time.time().
 102: 
 103:     Returns:
 104:         dict: El estado del nodo con last_seen actualizado.
 105: 
 106:     Example:
 107:         >>> refresh_node_seen("lnx203hp")
 108:         {'state': 'ACTIVE', 'priority': 10, 'last_seen': 1779956226.456}
 109: 
 110:     Note:
 111:         - Solo actualiza last_seen, no cambia state/priority/otros campos
 112:         - Se usa en heartbeats para marcar que el nodo sigue vivo
 113:         - Si el nodo no existe, se crea con solo last_seen
 114:     """
 115:     now = now or time.time()
 116:     current = cluster_state.get(node_id, {})
 117: 
 118:     cluster_state[node_id] = {
 119:         **current,
 120:         "last_seen": now,
 121:     }
 122:     return cluster_state[node_id]
 123: 
 124: 
 125: def get_node(node_id: str) -> dict:
 126:     """
 127:     Obtiene el estado de un nodo del cluster.
 128: 
 129:     Args:
 130:         node_id: ID del nodo a consultar.
 131: 
 132:     Returns:
 133:         dict: El estado del nodo si existe, dict vacío {} si no existe.
 134: 
 135:     Example:
 136:         >>> get_node("lnx203hp")
 137:         {'state': 'ACTIVE', 'priority': 10, 'last_seen': 1779956226.123}
 138: 
 139:         >>> get_node("nodonotexist")
 140:         {}
 141: 
 142:     Note:
 143:         - Retorna dict vacío en lugar de None para evitar checks de None
 144:         - Se usa en compute_leader(), compute_alive(), dashboard_compact(), etc.
 145:     """
 146:     return cluster_state.get(node_id, {})



