 221: # BOOTSTRAP
 222: # =====================================================
 223: def run_node(config):
 224: 
 225:     ctx.node_id = config["node_id"]
 226:     ctx.priority = config["priority"]
 227: 
 228:     node = NodeRuntime(
 229:         node_id=config["node_id"],
 230:         priority=config["priority"],
 231:     )
 232: 
 233:     ctx.node = node
 234: 
 235:     worker = NodeWorker(
 236:         node=node,
 237:         peers=config["peers"],
 238:         interval=1.0
 239:     )
 240: 
 241:     threading.Thread(target=worker.start, daemon=True).start()
 242: 
 243:     uvicorn.run(
 244:         app,
 245:         host=config.get("bind_host", "0.0.0.0"),
 246:         port=config.get("bind_port", 7000),
 247:         log_level="warning",
 248:         access_log=False
 249:     )
 250: 
 251: 
 252: # =====================================================
 253: # ENTRYPOINT
 254: # =====================================================
 255: if __name__ == "__main__":
 256: 
 257:     config = load_or_bootstrap_config()
 258:     run_node(config)



===== ./runtime/node_worker.py =====
   1: import time
   2: import threading
   3: 
   4: from cluster.runtime.dispatcher import dispatch_tick
   5: from cluster.runtime.reconciler.reconciler_loop import reconcile_tick
   6: from cluster.runtime.state import NodeState
   7: 
   8: 
   9: class NodeWorker:
  10: 
  11:     def __init__(self, node, peers, interval=1.0):
  12:         self.node = node
  13:         self.peers = peers
  14:         self.interval = interval
  15:         self._running = False
  16: 
  17:     # -------------------------
  18:     # START
  19:     # -------------------------
  20:     def start(self):
  21:         self._running = True
  22:         t = threading.Thread(target=self._loop, daemon=True)
  23:         t.start()
  24: 
  25:     # -------------------------
  26:     # STOP
  27:     # -------------------------
  28:     def stop(self):
  29:         self._running = False
  30: 
  31:     # -------------------------
  32:     # MAIN LOOP
  33:     # -------------------------
  34:     def _loop(self):
  35: 
  36:         while self._running:
  37: 
  38:             # cluster tick
  39:             self.node.tick()
  40: 
  41:             if self.node.state == NodeState.ISOLATED:
  42:                 time.sleep(self.interval)
  43:                 continue
  44:             else:
  45:                 self.node.emit_heartbeat(self.peers)
  46: 
  47:             # dispatch (leader only)
  48:             if self.node.state == NodeState.ISOLATED:
  49:                 time.sleep(self.interval)
  50:                 continue
  51:             else:
  52:                 dispatch_tick()
  53: 
  54:             # reconcile (leader only inside)
  55:             if self.node.state == NodeState.ISOLATED:
  56:                 time.sleep(self.interval)
  57:                 continue
  58:             else:
  59:                 reconcile_tick(self.node)
  60: 
  61:             time.sleep(self.interval)



===== ./runtime/reconciler/reconciler_loop.py =====
   1: import time
   2: from collections import defaultdict
   3: 
   4: from cluster.runtime.event_log import load_events, append_event
   5: from cluster.runtime.events.cluster_event import ClusterEvent
   6: from cluster.runtime.events.event_state import EventStatus
   7: 
   8: 
   9: EXECUTION_TIMEOUT = 10.0
  10: 
  11: 
  12: def reconcile_tick(node_runtime):
  13: 
  14:     if node_runtime.state != node_runtime.state.__class__.ACTIVE:
  15:         return
  16: 
  17:     events = load_events()
  18:     now = time.time()
  19: 
  20:     by_id = defaultdict(list)
  21: 
  22:     for e in events:
  23:         eid = e.get("event_id")
  24:         if not eid:
  25:             continue
  26:         by_id[eid].append(e)
  27: 
  28:     # -----------------------------------------
  29:     # SOLO DEBUG SI HAY INCOMPLETOS
  30:     # -----------------------------------------
  31:     incomplete = False
  32: 
  33:     for history in by_id.values():
  34:         latest_status = history[-1].get("status")
  35:         if latest_status not in (
  36:             EventStatus.COMPLETED.value,
  37:             EventStatus.FAILED.value
  38:         ):
  39:             incomplete = True
  40:             break
  41: 
  42:     if not incomplete:
  43:         return  # 🔥 SILENCIO TOTAL
  44: 
  45:     print("\n\n================ RECONCILER DEBUG ================\n")
  46: 
  47:     for eid, history in by_id.items():
  48: 
  49:         history.sort(key=lambda x: (
  50:             x.get("updated_at") or x.get("created_at") or 0
  51:         ))
  52: 
  53:         latest = history[-1]
  54:         latest_status = latest.get("status")
  55: 
  56:         # -----------------------------------------
  57:         # FILTRO FINAL: SOLO INCOMPLETOS
  58:         # -----------------------------------------
  59:         if latest_status in (
  60:             EventStatus.COMPLETED.value,
  61:             EventStatus.FAILED.value
  62:         ):
  63:             continue
  64: 
  65:         print(f"\nEVENT_ID: {eid}")
  66:         print("-" * 60)
  67: 
  68:         for i, h in enumerate(history):
  69: 
  70:             ts = h.get("updated_at") or h.get("created_at") or 0
  71:             status = h.get("status")
  72:             node = h.get("target_node")
  73:             attempt = h.get("attempt")
  74: 
  75:             print(
  76:                 f"[{i}] "
  77:                 f"ts={ts:.3f} "
  78:                 f"status={status:<10} "
  79:                 f"node={node} "
  80:                 f"attempt={attempt}"
  81:             )
  82: 
  83:         print("\n→ LATEST:", latest_status)
  84: 
  85:         # -----------------------------------------
  86:         # RECOVERY LOGIC
  87:         # -----------------------------------------
  88:         if latest_status == EventStatus.EXECUTING.value:
  89: 
  90:             last_update = latest.get("updated_at") or latest.get("created_at", 0)
  91: 
  92:             if now - last_update > EXECUTION_TIMEOUT:
  93: 
  94:                 print(f"⚠ RECOVERY: EXECUTING STUCK -> CREATED ({eid})")
  95: 
  96:                 recovered = dict(latest)
  97:                 recovered["status"] = EventStatus.CREATED.value
  98:                 recovered["updated_at"] = now
  99: 
 100:                 recovered["target_node"] = None
 101:                 recovered["execution_key"] = None
 102:                 recovered["attempt"] = 0
 103:                 recovered["route_hops"] = []
 104: 
 105:                 recovered.pop("owner", None)
 106: 
 107:                 append_event(ClusterEvent(**recovered))
 108: 
 109:         print("-" * 60)
 110: 
 111:     print("\n==================================================\n")



