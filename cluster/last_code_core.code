   1: 
   2: import time
   3: 
   4: from cluster.runtime.event_log import (
   5:     get_created_events,
   6:     get_completed_event_ids,
   7:     append_event,
   8: )
   9: 
  10: from cluster.runtime.cluster_store import cluster_state
  11: from cluster.runtime.event_router import forward_event
  12: 
  13: from cluster.utils.log_print import log_state
  14: from cluster.runtime.leader import compute_leader
  15: #from cluster.runtime.node_boot import node_id
  16: from cluster.runtime import context as ctx
  17: 
  18: from cluster.runtime.events.event_state import EventStatus
  19: 
  20: 
  21: # =========================
  22: # DISPATCH LOOP (LEADER ONLY)
  23: # =========================
  24: 
  25: def dispatch_tick():
  26: 
  27:     # ONLY LEADER EXECUTES DISPATCH
  28:     if compute_leader() != ctx.node_id:
  29:         return
  30: 
  31:     events = get_created_events()
  32: 
  33:     if not events:
  34:         return
  35: 
  36:     log_state(
  37:         "magenta",
  38:         "[DISPATCH]",
  39:         f"{len(events):3}",
  40:         3
  41:     )
  42: 
  43:     for event in events:
  44:         dispatch_created_event(event)
  45: 
  46: 
  47: # =========================
  48: # DISPATCH SINGLE EVENT
  49: # =========================
  50: 
  51: def dispatch_created_event(event):
  52: 
  53: #    log_state("yellow", "[DISPATCH]", f"event={event.event_id} start", 3)
  54: 
  55:     # -------------------------
  56:     # avoid duplicate completion
  57:     # -------------------------
  58:     completed = get_completed_event_ids()
  59:     if event.event_id in completed:
  60:         log_state("red", "[SKIP COMPLETED]", event.event_id, 3)
  61:         return
  62: 
  63:     # -------------------------
  64:     # select target
  65:     # -------------------------
  66:     alive = {
  67:         node_id_: data
  68:         for node_id_, data in cluster_state.items()
  69:         if (time.time() - data["last_seen"]) < 3.0
  70:     }
  71: 
  72:  #   log_state("cyan", "[ALIVE]", str(list(alive.keys())), 3)
  73: 
  74:     if not alive:
  75:         log_state("red", "[NO ALIVE NODES]", event.event_id, 3)
  76:         return
  77: 
  78:   #  log_state("yellow", "[DISPATCH]", f"event={event.event_id}", 3)
  79:   #  log_state("cyan", "[ALIVE]", str(list(alive.keys())), 3)
  80: 
  81: 
  82:     # calculo identico de worker que de leader
  83:     target = min(
  84:         alive.items(),
  85:         key=lambda x: (x[1]["priority"], x[0])
  86:     )[0]
  87: 
  88:    # log_state("magenta", "[WORKER SELECTED]", target, 3)
  89: 
  90:    # log_state("magenta", "[WORKER SELECTED]", f"{event.event_id} -> {target}", 3)
  91: 
  92:     # -------------------------
  93:     # ROUTING METADATA
  94:     # -------------------------
  95:     event.target_node = target
  96:     event.route_hops.append(f"dispatcher->{target}")
  97: 
  98:     #log_state("magenta", "[ROUTE]", f"{event.event_id} hop added", 3)
  99: 
 100:     # -------------------------
 101:     # STATE CHANGE
 102:     # -------------------------
 103: 
 104:     event.attempt = (event.attempt or 0) + 1   # 👈 AQUI
 105:     event.attempt = 0
 106: 
 107:     event.mark_status(EventStatus.EXECUTING)
 108: 
 109: 
 110:     msg = event.payload.get("msg", "<no-msg>")
 111: 
 112:     log_state("yellow", "(EVENT)", f"{msg:12} -> EXECUTING", 3)
 113: 
 114:     # -------------------------
 115:     # PERSIST
 116:     # -------------------------
 117:     event.updated_at = time.time()
 118:     append_event(event)
 119: 
 120:     #log_state("green", "[PERSIST]", event.event_id, 3)
 121: 
 122: #    log_state("magenta", "[DISPATCH SEND]", f"{event.event_id} -> {target}", 3)
 123: 
 124:     # -------------------------
 125:     # SEND
 126:     # -------------------------
 127: #    log_state("magenta", "[SEND]", f"{event.event_id} -> {target}", 3)
 128: 
 129:     forward_event(target, event)



===== ./runtime/event_log.py =====
   1: import json
   2: import os
   3: from typing import List
   4: 
   5: from cluster.runtime.events.cluster_event import ClusterEvent
   6: from cluster.runtime.events.event_state import EventStatus
   7: 
   8: BASE_DIR = os.path.dirname(os.path.dirname(os.path.dirname(__file__)))
   9: LOG_PATH = os.path.join(BASE_DIR, "cluster", "data", "event_log.local.jsonl")
  10: 
  11: 
  12: def get_latest_event(event_id: str):
  13:     events = load_events()
  14: 
  15:     for e in reversed(events):
  16:         if e["event_id"] == event_id:
  17:             return e
  18: 
  19:     return None
  20: 
  21: # =========================
  22: # LOAD EVENTS
  23: # =========================
  24: def load_events() -> List[dict]:
  25:     if not os.path.exists(LOG_PATH):
  26:         return []
  27: 
  28:     with open(LOG_PATH, "r") as f:
  29:         return [json.loads(line) for line in f if line.strip()]
  30: 
  31: 
  32: # =========================
  33: # ENSURE DIR
  34: # =========================
  35: def ensure_dir():
  36:     os.makedirs(os.path.dirname(LOG_PATH), exist_ok=True)
  37: 
  38: 
  39: # =========================
  40: # NORMALIZE RAW EVENT
  41: # =========================
  42: def _normalize_event(e: dict) -> dict:
  43:     e["schema_version"] = str(e.get("schema_version", "0.1"))
  44:     e.setdefault("received_at", None)
  45:     e.setdefault("attempt", 0)
  46:     e.setdefault("route_hops", [])
  47:     return e
  48: 
  49: 
  50: # =========================
  51: # GET CREATED EVENTS
  52: # =========================
  53: def get_created_events():
  54:     events = load_events()
  55: 
  56:     latest = {}
  57: 
  58:     for e in events:
  59:         e["schema_version"] = str(e.get("schema_version", "0.1"))
  60:         e.setdefault("received_at", None)
  61:         e.setdefault("attempt", 0)
  62:         e.setdefault("route_hops", [])
  63:         e.setdefault("execution_key", None)
  64:         latest[e["event_id"]] = e
  65: 
  66:     events = [
  67:         ClusterEvent(**e)
  68:         for e in latest.values()
  69:     ]
  70: 
  71:     return [
  72:         e for e in events
  73:         if e.status == EventStatus.CREATED
  74:     ]
  75: 
  76: 
  77: # =========================
  78: # GET COMPLETED IDS
  79: # =========================
  80: def get_completed_event_ids():
  81: 
  82:     events = load_events()
  83: 
  84:     latest = {}
  85: 
  86:     for e in events:
  87:         latest[e["event_id"]] = e
  88: 
  89:     domain_events = [
  90:         ClusterEvent(**_normalize_event(e))
  91:         for e in latest.values()
  92:     ]
  93: 
  94:     return {
  95:         e.event_id
  96:         for e in domain_events
  97:         if e.status == EventStatus.COMPLETED
  98:     }
  99: 
 100: 
 101: # =========================
 102: # APPEND EVENT
 103: # =========================
 104: def append_event(event: ClusterEvent):
 105:     ensure_dir()
 106: 
 107:     record = {
 108:         "event_id": event.event_id,
 109:         "event_type": event.event_type,
 110:         "schema_version": str(event.schema_version),
 111:         "created_at": event.created_at,
 112:         "received_at": getattr(event, "received_at", None),
 113:         "trace_id": event.trace_id,
 114:         "target_node": event.target_node,
 115:         "route_hops": event.route_hops,
 116:         "status": event.status,
 117:         "attempt": event.attempt,
 118:         "payload": event.payload,
 119:     }
 120: 
 121:     # dedup guard
 122:     if event.status == EventStatus.COMPLETED:
 123:         existing = load_events()
 124:         if any(
 125:             e["event_id"] == event.event_id and
 126:             e["status"] == EventStatus.COMPLETED.value
 127:             for e in existing
 128:         ):
 129:             return
 130: 
 131:     with open(LOG_PATH, "a") as f:
 132:         f.write(json.dumps(record) + "\n")
 133: 
 134: 
 135: # =========================
 136: # REPLAY
 137: # =========================
 138: def replay_events(handler):
 139:     """
 140:     Re-ejecuta eventos contra un handler(event)
 141:     """
 142:     events = load_events()
 143: 
 144:     for raw in events:
 145:         event = ClusterEvent(**_normalize_event(raw))
 146:         handler(event)



