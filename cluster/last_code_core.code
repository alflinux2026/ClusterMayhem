   1: from cluster.utils.log_print import log_state
   2: from cluster.runtime.cluster_store import cluster_state
   3: import time
   4: 
   5: 
   6: def is_alive(data, timeout=1.5):
   7:     return (time.time() - data["last_seen"]) < timeout
   8: 
   9: 
  10: def compute_leader(debug_node_id=None):
  11: 
  12:     now = time.time()
  13: 
  14: 
  15:     active_nodes = {}
  16: 
  17:     for node_id, data in cluster_state.items():
  18: 
  19:         age = now - data.get("last_seen", 0)
  20:         alive = is_alive(data)
  21: 
  22: 
  23: #        log_state("blue", "[NODE]", f"| {node_id:10} | {data.get('state'):8} | " \
  24: #            f"{data.get('priority'):1} | {age:6.3f}s | {alive}", 3)
  25: 
  26:         # if data.get('state') == '  GONE  ':
  27:         #   time.sleep(30)
  28: 
  29: 
  30: 
  31: 
  32:         if alive:
  33:             active_nodes[node_id] = data
  34: 
  35:         else:
  36:             data['state'] = '  GONE  '   # 👈 aquí lo marcas aunque esté muerto
  37: 
  38: 
  39: #    log_state("blue", "[NODE]", f"---------------------------------------------------", 3)
  40: 
  41:     if not active_nodes:
  42:         return None
  43: 
  44:     leader = min(
  45:         active_nodes.items(),
  46:         key=lambda x: (x[1]["priority"], x[0])
  47:     )[0]
  48: 
  49: 
  50:     return leader



