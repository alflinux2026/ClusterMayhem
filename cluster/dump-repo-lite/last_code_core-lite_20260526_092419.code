 435: @app.post("/heartbeat")
 436: def heartbeat(hb: Heartbeat):
 437:     if ctx.node.state == NodeState.ISOLATED:
 438:         return {"error": "node isolated"}
 439: 
 440:     existing = cluster_state.get(hb.node_id, {})
 441:     cluster_state[hb.node_id] = {
 442:         **existing,
 443:         "state": hb.state,
 444:         "priority": hb.priority,
 445:         "last_seen": time.time(),
 446:         "state_since": hb.state_since if hb.state_since is not None else existing.get("state_since"),
 447:         "prev_state": hb.prev_state if hb.prev_state is not None else existing.get("prev_state"),
 448:         "state_reason": hb.state_reason if hb.state_reason is not None else existing.get("state_reason"),
 449:         "log_meta": hb.log_meta or existing.get("log_meta", {}),
 450:         "cluster_integrity": hb.cluster_integrity or existing.get("cluster_integrity", {}),
 451:         "streams": hb.streams or existing.get("streams", {}),
 452:     }
 453: 
 454:     return {"ok": True}
 455: 
