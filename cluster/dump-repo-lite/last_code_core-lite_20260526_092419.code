 379:     local_entry = cluster_state.get(ctx.node_id, {})
 380:     local_node = {
 381:         "state_since": getattr(ctx.node, "state_since", None),
 382:         "last_seen": local_entry.get("last_seen"),
 383:         "last_watchdog": local_entry.get("last_watchdog"),
 384:         "watchdog_busy": local_entry.get("watchdog_busy"),
