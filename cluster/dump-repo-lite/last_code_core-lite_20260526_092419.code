  87: class NodeWorker:
  88:     def __init__(self, node, peers, interval=1.0):
  89:         self.node = node
  90:         self.peers = peers
  91:         self.interval = interval
  92:         self.running = False
  93: 
  94:     def start(self):
  95:         self.running = True
  96:         t = threading.Thread(target=self.loop, daemon=True)
  97:         t.start()
  98: 
  99:     def stop(self):
 100:         self.running = False
 101: 
 102:     def tick_boot(self):
 103:         emit_watchdog_if_due(self.peers, busy=True)
 104: 
 105:     def tick_discovering(self):
 106:         pass
 107: 
 108:     def tick_standby(self):
 109:         self.node.emit_heartbeat(self.peers)
 110:         emit_watchdog_if_due(self.peers, busy=True)
 111:         reconcile_tick(self.node)
 112:         replicate_eventlog()
 113:         replicate_events()
 114: 
 115:     def tick_active(self):
 116:         self.node.emit_heartbeat(self.peers)
 117:         emit_watchdog_if_due(self.peers, busy=True)
 118:         dispatch_tick()
 119:         reconcile_tick(self.node)
 120:         replicate_eventlog()
 121:         replicate_events()
 122:         leader_event_state_check_tick()
 123: 
 124:     def tick_degraded(self):
 125:         self.node.emit_heartbeat(self.peers)
 126:         emit_watchdog_if_due(self.peers, busy=True)
 127:         replicate_eventlog()
 128:         replicate_events()
 129:         leader_event_state_check_tick()
 130: 
 131:     def tick_isolated(self):
 132:         pass
 133: 
 134:     def tick_offline(self):
 135:         pass
 136: 
 137:     def _tick_by_state(self):
 138:         state = self.node.state
 139:         if state == NodeState.BOOT:
 140:             self.tick_boot()
 141:         elif state == NodeState.DISCOVERING:
 142:             self.tick_discovering()
 143:         elif state == NodeState.STANDBY:
 144:             self.tick_standby()
 145:         elif state == NodeState.ACTIVE:
 146:             self.tick_active()
 147:         elif state == NodeState.DEGRADED:
 148:             self.tick_degraded()
 149:         elif state == NodeState.ISOLATED:
 150:             self.tick_isolated()
 151:         elif state == NodeState.OFFLINE:
 152:             self.tick_offline()
 153: 
 154:     def loop(self):
 155:         while self.running:
 156:             self.node.tick()
 157:             log_state_runtime_debug(self.node)
 158: 
 159:             if self.node.state == NodeState.ISOLATED:
 160:                 time.sleep(self.interval)
 161:                 continue
 162: 
 163:             self._tick_by_state()
 164:             time.sleep(self.interval)
