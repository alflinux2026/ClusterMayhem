  51: class Watchdog(BaseModel):
  52:     node_id: str
  53:     busy: bool = True
  54:     emitted_at: float | None = None
  55: 
  56: 
  57: def _round_or_none(value: float | None, digits: int = 1) -> float | None:
  58:     if value is None:
  59:         return None
  60:     try:
  61:         return round(float(value), digits)
  62:     except Exception:
  63:         return None
  64: 
  65: 
  66: def _watchdog_age_s(node: dict, now: float | None = None) -> float | None:
  67:     now = now or time.time()
  68:     last_watchdog = node.get("last_watchdog")
  69:     if last_watchdog is None:
  70:         return None
  71:     try:
  72:         return max(0.0, now - float(last_watchdog))
  73:     except Exception:
  74:         return None
  75: 
  76: 
  77: def _state_age_s(node: dict, now: float | None = None) -> float | None:
  78:     now = now or time.time()
  79:     state_since = node.get("state_since")
  80:     if state_since is None:
  81:         return None
  82:     try:
  83:         return max(0.0, now - float(state_since))
  84:     except Exception:
  85:         return None
  86: 
  87: 
  88: def _seen_age_s(node: dict, now: float | None = None) -> float | None:
  89:     now = now or time.time()
  90:     last_seen = node.get("last_seen")
  91:     if last_seen is None:
  92:         return None
  93:     try:
  94:         return max(0.0, now - float(last_seen))
  95:     except Exception:
  96:         return None
  97: 
  98: 
  99: def _presence_age_s(node: dict, now: float | None = None) -> float | None:
 100:     now = now or time.time()
 101:     last_seen = node.get("last_seen")
 102:     last_watchdog = node.get("last_watchdog")
 103: 
 104:     candidates = []
 105:     for value in (last_seen, last_watchdog):
 106:         if value is None:
 107:             continue
 108:         try:
 109:             candidates.append(float(value))
 110:         except Exception:
 111:             continue
 112: 
 113:     if not candidates:
 114:         return None
 115: 
 116:     return max(0.0, now - max(candidates))
 117: 
 118: 
 119: def _presence_health(node: dict, now: float | None = None, stale_after_s: float = 3.0) -> str:
 120:     age = _presence_age_s(node, now)
 121:     if age is None:
 122:         return "stale"
 123:     return "ok" if age < stale_after_s else "stale"
 124: 
 125: 
 126: def _compact_node(node: dict) -> dict:
 127:     now = time.time()
 128:     return {
 129:         "state": node.get("state"),
 130:         "priority": node.get("priority"),
 131:         "last_seen": node.get("last_seen"),
 132:         "seen_age_s": _round_or_none(_seen_age_s(node, now), 3),
 133:         "last_watchdog": node.get("last_watchdog"),
 134:         "watchdog_age_s": _round_or_none(_watchdog_age_s(node, now), 3),
 135:         "watchdog_busy": node.get("watchdog_busy"),
 136:         "presence_age_s": _round_or_none(_presence_age_s(node, now), 3),
 137:         "presence_health": _presence_health(node, now),
 138:         "state_since": node.get("state_since"),
 139:         "state_age_s": _round_or_none(_state_age_s(node, now), 3),
 140:         "prev_state": node.get("prev_state"),
 141:         "state_reason": node.get("state_reason"),
 142:         "log_meta": node.get("log_meta", {}),
 143:         "streams": node.get("streams", {}),
 144:     }
 145: 
 146: 
 147: def _read_jsonl(path: str) -> list[dict]:
 148:     if not os.path.exists(path):
 149:         return []
 150: 
 151:     out: list[dict] = []
 152:     with open(path, "r", encoding="utf-8") as f:
 153:         for line in f:
 154:             line = line.strip()
 155:             if not line:
 156:                 continue
 157:             try:
 158:                 out.append(json.loads(line))
 159:             except Exception:
 160:                 continue
 161:     return out
 162: 
 163: 
 164: def _summarize_events(events: list[dict]) -> dict:
 165:     latest_by_event_id: dict[str, dict] = {}
 166:     last_event_id = None
 167: 
 168:     for event in events:
 169:         event_id = event.get("event_id")
 170:         if not event_id:
 171:             continue
 172:         latest_by_event_id[event_id] = event
 173:         last_event_id = event_id
 174: 
 175:     counts = Counter()
 176:     for event in latest_by_event_id.values():
 177:         status = event.get("status", "unknown")
 178:         counts[status] += 1
 179: 
 180:     return {
 181:         "total_events": len(latest_by_event_id),
 182:         "counts": {
 183:             "created": counts.get("created", 0),
 184:             "executing": counts.get("executing", 0),
 185:             "completed": counts.get("completed", 0),
 186:             "unknown": counts.get("unknown", 0),
 187:         },
 188:         "last_event_id": last_event_id,
 189:     }
