  23: def leader_event_state_check_tick():
  24:     global lasteventstatecheckts
  25:     now = time.time()
  26:     if now - lasteventstatecheckts < EVENTSTATECHECKPERIODSEC:
  27:         return
  28:     lasteventstatecheckts = now
  29: 
  30:     raw_events = load_events()
  31:     state_index = rebuild_event_state_index()
  32: 
  33:     raw_created = 0
  34:     raw_executing = 0
  35:     raw_completed = 0
  36:     for e in raw_events:
  37:         status = e.get("status")
  38:         if hasattr(status, "value"):
  39:             status = status.value
  40:         status = str(status).strip().lower()
  41:         if status == EventStatus.CREATED.value:
  42:             raw_created += 1
  43:         elif status == EventStatus.EXECUTING.value:
  44:             raw_executing += 1
  45:         elif status == EventStatus.COMPLETED.value:
  46:             raw_completed += 1
  47: 
  48:     created = 0
  49:     executing = 0
  50:     completed = 0
  51:     for event in state_index.values():
  52:         status = event.get("status") if isinstance(event, dict) else getattr(event, "status", None)
  53:         if hasattr(status, "value"):
  54:             status = status.value
  55:         status = str(status).strip().lower()
  56:         if status == EventStatus.CREATED.value:
  57:             created += 1
  58:         elif status == EventStatus.EXECUTING.value:
  59:             executing += 1
  60:         elif status == EventStatus.COMPLETED.value:
  61:             completed += 1
  62: 
