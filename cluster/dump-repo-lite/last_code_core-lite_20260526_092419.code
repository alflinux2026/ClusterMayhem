 349: @app.post("/sleep")
 350: def sleep():
 351:     log_state("red", "- SLEEP -", f"{ctx.node_id} -> SLEEP", 3)
 352:     ctx.node.transition(NodeState.ISOLATED, reason="sleep_command")
 353:     return {
 354:         "ok": True,
 355:         "node": ctx.node_id,
 356:         "state": ctx.node.state.value,
 357:         "state_since": getattr(ctx.node, "state_since", None),
 358:         "prev_state": getattr(ctx.node, "prev_state", None),
 359:         "state_reason": getattr(ctx.node, "state_reason", None),
 360:     }
 361: 
