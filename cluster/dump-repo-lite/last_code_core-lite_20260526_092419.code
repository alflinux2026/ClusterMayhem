 389:         "node": ctx.node_id,
 390:         "state": ctx.node.state.value,
 391:         "state_since": getattr(ctx.node, "state_since", None),
 392:         "state_age_s": _round_or_none(_state_age_s({"state_since": getattr(ctx.node, "state_since", None)}), 3),
 393:         "last_seen": local_node.get("last_seen"),
 394:         "seen_age_s": _round_or_none(_seen_age_s(local_node), 3),
 395:         "last_watchdog": local_node.get("last_watchdog"),
 396:         "watchdog_age_s": _round_or_none(_watchdog_age_s(local_node), 3),
 397:         "watchdog_busy": local_node.get("watchdog_busy"),
 398:         "presence_age_s": _round_or_none(_presence_age_s(local_node), 3),
 399:         "sleeping": ctx.node.state == NodeState.ISOLATED,
 400:     }
