 324: @app.post("/event")
 325: def handle_event(event: ClusterEvent):
 326:     if ctx.node.state == NodeState.ISOLATED:
 327:         return {"error": "node isolated"}
 328: 
 329:     leader = compute_leader()
 330:     if not leader:
 331:         log_state("red", "(NO LEADER)", event.event_id, 3)
 332:         return {"error": "no leader"}
 333: 
 334:     if leader != ctx.node_id:
 335:         msg = event.payload.get("msg", "<no-msg>")
 336:         log_state("cyan", "[EVENT FWD]", f"{msg:12} -> {leader}", 3)
 337:         node = CLUSTER_REGISTRY[leader]
 338:         url = f"http://{node['host']}:{node['port']}/event"
 339:         try:
 340:             resp = requests.post(url, json=event.model_dump(), timeout=2)
 341:             return resp.json()
 342:         except Exception as e:
 343:             return {"error": str(e)}
 344: 
 345:     result = ingest_event(event, ctx.node_id)
 346:     return {"status": "ok", "event_id": event.event_id, "result": result}
 347: 
