  25: PEERALIVETTLSEC = 3.0
  26: REPLICATION_ALLOWED_STATES = {
  27:     NodeState.ACTIVE.value,
  28:     NodeState.STANDBY.value,
  29:     NodeState.DEGRADED.value,
  30: }
  31: 
  32: 
  33: def canonical_replica_node_id() -> str:
  34:     return ctx.node_id
  35: 
  36: 
  37: def alive_peer_ids():
  38:     out = []
  39:     now = time.time()
  40:     for node_id, data in cluster_state.items():
  41:         if node_id == ctx.node_id:
  42:             continue
  43:         if now - data.get("last_seen", 0) > PEERALIVETTLSEC:
  44:             continue
  45:         out.append(node_id)
  46:     return sorted(set(out))
  47: 
  48: 
  49: def configured_peer_ids():
  50:     out = []
  51: 
  52:     for peer in getattr(ctx, "peers", []) or []:
  53:         peer_id = peer.get("node_id")
  54:         if peer_id and peer_id != ctx.node_id:
  55:             out.append(peer_id)
  56: 
  57:     for node_id in CLUSTER_REGISTRY.keys():
  58:         if node_id != ctx.node_id:
  59:             out.append(node_id)
  60: 
  61:     return sorted(set(out))
  62: 
  63: 
  64: def target_peer_ids():
  65:     alive = alive_peer_ids()
  66:     configured = configured_peer_ids()
  67:     return sorted(set(alive) | set(configured))
  68: 
  69: 
  70: def replicate_eventlog():
  71: 
  72:     node_id = canonical_replica_node_id()
  73:     node_state = getattr(getattr(ctx, "node", None), "state", None)
  74:     node_state_value = getattr(node_state, "value", None)
  75: 
  76: #    log_state("cyan", "REPL TICK", f"node={node_id}", 3)
  77: 
  78:     if node_state_value not in REPLICATION_ALLOWED_STATES:
  79:         log_state(
  80:             "yellow",
  81:             "REPL SKIP",
  82:             f"state={node_state_value} allowed={sorted(REPLICATION_ALLOWED_STATES)}",
  83:             3,
  84:         )
  85:         return
  86: 
  87:     state = read_state()
  88:     dirty = bool(state.get("dirty", False))
  89: #    log_state("cyan", "REPL FLAG", f"dirty={dirty} state_exists={bool(state)}", 3)
  90:     if not dirty:
  91:         return
  92: 
  93:     content = read_local_log_text()
  94:     completed_content = read_completed_log_text()
  95:     log_state("cyan", "REPL CONTENT", f"len={len(content)} empty={not content.strip()}", 3)
  96:     log_state("cyan", "REPL COMPLETED", f"len={len(completed_content)} empty={not completed_content.strip()}", 3)
  97:     if not content.strip():
  98:         log_state("yellow", "REPL SKIP", "empty content", 3)
  99:         return
 100: 
 101:     write_replica_log(node_id, content)
 102:     if completed_content.strip():
 103:         write_completed_log(completed_content)
 104:     log_state("cyan", "REPL SELF", f"{node_id} bytes={len(content)}", 3)
 105: 
 106:     peers = target_peer_ids()
 107:     log_state("cyan", "REPL PEERS", f"peers={peers}", 3)
 108: 
 109:     success = True
 110: 
 111:     for peer_id in peers:
 112:         node = CLUSTER_REGISTRY.get(peer_id)
 113:         if not node:
 114:             log_state("red", "LOG REPL FAIL", f"{peer_id} missing registry", 3)
 115:             success = False
 116:             continue
 117: 
 118:         url = f"http://{node['host']}:{node['port']}/debug/log/replica/{node_id}"
 119:         log_state("cyan", "REPL POST", f"peer={peer_id} url={url}", 3)
 120: 
 121:         try:
 122:             resp = requests.post(
 123:                 url,
 124:                 data=content.encode("utf-8"),
 125:                 headers={"Content-Type": "text/plain; charset=utf-8"},
 126:                 timeout=2,
 127:             )
 128: 
 129:             if resp.ok:
 130:                 log_state("cyan", "LOG REPL", f"{node_id} -> {peer_id}", 3)
 131:             else:
 132:                 success = False
 133:                 log_state("red", "LOG REPL FAIL", f"{peer_id} status={resp.status_code}", 3)
 134: 
 135:         except Exception as e:
 136:             success = False
 137:             log_state("red", "LOG REPL FAIL", f"{peer_id} err={e}", 3)
 138: 
 139:     if success:
 140:         clear_eventlog_dirty_state()
 141:         log_state("cyan", "REPL CLEAR", "dirty=false", 3)
 142: 
