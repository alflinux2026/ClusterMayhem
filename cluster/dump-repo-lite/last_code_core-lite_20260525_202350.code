 164: def read_state() -> dict:
 165:     if not STATE_PATH.exists():
 166:         return {}
 167: 
 168:     try:
 169:         with open(STATE_PATH, "r", encoding="utf-8") as f:
 170:             data = json.load(f)
 171:             return data if isinstance(data, dict) else {}
 172:     except (OSError, json.JSONDecodeError):
 173:         return {}
 174: 
 175: 
 176: def get_last_append_meta() -> dict:
 177:     state = read_state()
 178:     return state if isinstance(state, dict) else {}
 179: 
 180: 
 181: def write_state(state: dict):
 182:     _write_json_atomic(STATE_PATH, state)
 183: 
 184: 
 185: def clear_state():
 186:     write_state({
 187:         "dirty": False,
 188:         "events_dirty": False,
 189:         "last_append_event_id": None,
 190:         "last_append_created_at": None,
 191:         "last_append_updated_at": None,
 192:         "last_completed_event_id": None,
 193:         "last_completed_created_at": None,
 194:         "last_completed_updated_at": None,
 195:     })
 196: 
 197: 
 198: def load_events() -> List[dict]:
 199:     return load_events_from_path(str(LOCAL_LOG_PATH))
 200: 
 201: 
 202: def load_local_events() -> List[dict]:
 203:     return load_events_from_path(str(LOCAL_LOG_PATH))
 204: 
 205: 
 206: def load_completed_events() -> List[dict]:
 207:     return load_events_from_path(str(COMPLETED_LOG_PATH))
 208: 
 209: 
 210: def load_replica_events(node_id: str) -> List[dict]:
 211:     return load_events_from_path(get_replica_log_path(node_id))
 212: 
 213: 
 214: def load_all_replica_events() -> List[dict]:
 215:     events: List[dict] = []
 216:     for path in list_replica_log_paths():
 217:         events.extend(load_events_from_path(path))
 218:     return events
 219: 
 220: 
 221: def load_cluster_events() -> List[dict]:
 222:     return load_all_replica_events()
 223: 
 224: 
 225: def _normalize_event(e: dict) -> dict:
 226:     e = dict(e)
 227:     e["schema_version"] = str(e.get("schema_version", "0.1"))
 228:     e.setdefault("received_at", None)
 229:     e.setdefault("attempt", 0)
 230:     e.setdefault("route_hops", [])
 231:     e.setdefault("execution_key", None)
 232:     return e
 233: 
 234: 
 235: def _latest_map(events: List[dict]) -> Dict[str, dict]:
 236:     latest: Dict[str, dict] = {}
 237:     for e in events:
 238:         e = _normalize_event(e)
 239:         latest[e["event_id"]] = e
 240:     return latest
 241: 
 242: 
 243: def rebuild_event_state_index() -> Dict[str, dict]:
 244:     return _latest_map(load_events())
 245: 
 246: 
 247: def get_latest_event(event_id: str) -> Optional[dict]:
 248:     events = load_events()
 249:     for e in reversed(events):
 250:         if e["event_id"] == event_id:
 251:             return _normalize_event(e)
 252:     return None
 253: 
 254: 
 255: def get_created_events():
 256:     latest = rebuild_event_state_index()
 257:     domain_events = [ClusterEvent(**e) for e in latest.values()]
 258:     return [e for e in domain_events if e.status == EventStatus.CREATED]
 259: 
 260: 
 261: def get_completed_event_ids():
 262:     latest = rebuild_event_state_index()
 263:     domain_events = [ClusterEvent(**e) for e in latest.values()]
 264:     return {e.event_id for e in domain_events if e.status == EventStatus.COMPLETED}
 265: 
 266: 
 267: def append_event(event: ClusterEvent):
 268:     ensure_initial_files()
 269: 
 270:     record = {
 271:         "event_id": event.event_id,
 272:         "event_type": event.event_type,
 273:         "schema_version": str(event.schema_version),
 274:         "created_at": event.created_at,
 275:         "updated_at": getattr(event, "updated_at", None),
 276:         "received_at": getattr(event, "received_at", None),
 277:         "trace_id": event.trace_id,
 278:         "target_node": event.target_node,
 279:         "source_node": getattr(event, "source_node", None),
 280:         "route_hops": list(getattr(event, "route_hops", []) or []),
 281:         "status": event.status.value if hasattr(event.status, "value") else event.status,
 282:         "attempt": event.attempt,
 283:         "execution_key": getattr(event, "execution_key", None),
 284:         "payload": event.payload,
 285:     }
 286: 
 287:     line = json.dumps(record) + "\n"
 288:     with open(LOCAL_LOG_PATH, "a", encoding="utf-8") as f:
 289:         f.write(line)
 290:         f.flush()
 291:         os.fsync(f.fileno())
 292: 
 293:     state = read_state()
 294:     state["dirty"] = True
 295:     state["last_append_event_id"] = event.event_id
 296:     state["last_append_created_at"] = event.created_at
 297:     state["last_append_updated_at"] = getattr(event, "updated_at", None)
 298: 
 299: 
 300: 
 301:     if record["status"] == EventStatus.COMPLETED.value:
 302:         with open(COMPLETED_LOG_PATH, "a", encoding="utf-8") as f:
 303:             f.write(line)
 304:             f.flush()
 305:             os.fsync(f.fileno())
 306: 
 307:         state["events_dirty"] = True
 308:         state["last_completed_event_id"] = event.event_id
 309:         state["last_completed_created_at"] = event.created_at
 310:         state["last_completed_updated_at"] = getattr(event, "updated_at", None)
 311: 
 312:     try:
 313:         write_state(state)
 314: 
 315:     except Exception as e:
 316:         print(f"[STATE WRITE FAIL] {event.event_id} -> {e}")
 317: 
 318: 
 319: def replay_events(handler, stream: str | None = None):
 320:     events = load_events()
 321:     for raw in events:
 322:         event = ClusterEvent(**_normalize_event(raw))
 323:         handler(event)
 324: 



===== ./runtime/leader.py =====
   1: import time
   2: 
   3: from cluster.runtime.cluster_store import cluster_state
   4: from cluster.runtime import context as ctx
   5: 
   6: LEADER_ALIVE_TIMEOUT = 1.5
   7: 
   8: 
   9: def refresh_self_alive_entry(now=None):
  10:     now = now or time.time()
  11:     if not getattr(ctx, "node", None):
  12:         return
  13: 
  14:     existing = cluster_state.get(ctx.node_id, {})
  15: 
  16:     cluster_state[ctx.node_id] = {
  17:         **existing,
  18:         "state": ctx.node.state.value,
  19:         "priority": ctx.node.priority,
  20:         "last_seen": now,
  21:         "state_since": getattr(ctx.node, "state_since", None),
  22:         "prev_state": getattr(ctx.node, "prev_state", None),
  23:         "state_reason": getattr(ctx.node, "state_reason", None),
  24:     }
  25: 
  26: 
  27: def last_presence_ts(data: dict) -> float:
  28:     candidates = []
  29:     for key in ("last_seen", "last_watchdog"):
  30:         value = data.get(key, 0)
  31:         if value is None:
  32:             continue
  33:         try:
  34:             candidates.append(float(value))
  35:         except Exception:
  36:             continue
  37:     return max(candidates) if candidates else 0.0
  38: 
  39: 
  40: def is_alive(data, timeout=LEADER_ALIVE_TIMEOUT, now=None):
  41:     now = now or time.time()
  42:     last_presence = last_presence_ts(data)
  43:     return (now - last_presence) < timeout
  44: 
  45: 
  46: def compute_alive(timeout=LEADER_ALIVE_TIMEOUT, include_self=True):
  47:     now = time.time()
  48:     if include_self:
  49:         refresh_self_alive_entry(now)
  50: 
  51:     active_nodes = {}
  52:     for node_id, data in cluster_state.items():
  53:         if is_alive(data, timeout=timeout, now=now):
  54:             active_nodes[node_id] = data
  55:     return active_nodes
  56: 
  57: 
  58: def compute_leader(debug_node_id=None, timeout=LEADER_ALIVE_TIMEOUT):
  59:     active_nodes = compute_alive(timeout=timeout, include_self=True)
  60:     if not active_nodes:
  61:         return None
  62:     return min(
  63:         active_nodes.items(),
  64:         key=lambda x: (x[1].get("priority", 9999), x[0]),
  65:     )[0]



===== ./runtime/log_replication.py =====
   1: import logging
   2: import time
   3: import requests
   4: 
   5: from cluster.runtime import context as ctx
   6: from cluster.runtime.cluster_store import cluster_state
   7: from cluster.runtime.registry import CLUSTER_REGISTRY
   8: from cluster.runtime.event_log import (
   9:     read_local_log_text,
  10:     read_completed_log_text,
  11:     write_replica_log,
  12:     write_completed_log,
  13:     read_state,
  14:     clear_state,
  15: )
  16: from cluster.runtime.state import NodeState
  17: from cluster.utils.log_print import log_state
  18: 
  19: logging.getLogger("urllib3").setLevel(logging.ERROR)
  20: logging.getLogger("requests").setLevel(logging.ERROR)
  21: 
  22: PEERALIVETTLSEC = 3.0
  23: REPLICATION_ALLOWED_STATES = {
  24:     NodeState.ACTIVE.value,
  25:     NodeState.STANDBY.value,
  26:     NodeState.DEGRADED.value,
  27: }
  28: 
  29: 
  30: def canonical_replica_node_id() -> str:
  31:     return ctx.node_id
  32: 
  33: 
  34: def alive_peer_ids():
  35:     out = []
  36:     now = time.time()
  37:     for node_id, data in cluster_state.items():
  38:         if node_id == ctx.node_id:
  39:             continue
  40:         if now - data.get("last_seen", 0) > PEERALIVETTLSEC:
  41:             continue
  42:         out.append(node_id)
  43:     return sorted(set(out))
  44: 
  45: 
  46: def configured_peer_ids():
  47:     out = []
  48: 
  49:     for peer in getattr(ctx, "peers", []) or []:
  50:         peer_id = peer.get("node_id")
  51:         if peer_id and peer_id != ctx.node_id:
  52:             out.append(peer_id)
  53: 
  54:     for node_id in CLUSTER_REGISTRY.keys():
  55:         if node_id != ctx.node_id:
  56:             out.append(node_id)
  57: 
  58:     return sorted(set(out))
  59: 
  60: 
  61: def target_peer_ids():
  62:     alive = alive_peer_ids()
  63:     configured = configured_peer_ids()
  64:     return sorted(set(alive) | set(configured))
  65: 
  66: 
  67: def replicate_eventlog():
  68:     node_id = canonical_replica_node_id()
  69:     node_state = getattr(getattr(ctx, "node", None), "state", None)
  70:     node_state_value = getattr(node_state, "value", None)
  71: 
  72: #    log_state("cyan", "REPL TICK", f"node={node_id}", 3)
  73: 
  74:     if node_state_value not in REPLICATION_ALLOWED_STATES:
  75:         log_state(
  76:             "yellow",
  77:             "REPL SKIP",
  78:             f"state={node_state_value} allowed={sorted(REPLICATION_ALLOWED_STATES)}",
  79:             3,
  80:         )
  81:         return
  82: 
  83:     state = read_state()
  84:     dirty = bool(state.get("dirty", False))
  85: #    log_state("cyan", "REPL FLAG", f"dirty={dirty} state_exists={bool(state)}", 3)
  86:     if not dirty:
  87:         return
  88: 
  89:     content = read_local_log_text()
  90:     completed_content = read_completed_log_text()
  91:     log_state("cyan", "REPL CONTENT", f"len={len(content)} empty={not content.strip()}", 3)
  92:     log_state("cyan", "REPL COMPLETED", f"len={len(completed_content)} empty={not completed_content.strip()}", 3)
  93:     if not content.strip():
  94:         log_state("yellow", "REPL SKIP", "empty content", 3)
  95:         return
  96: 
  97:     write_replica_log(node_id, content)
  98:     if completed_content.strip():
  99:         write_completed_log(completed_content)
 100:     log_state("cyan", "REPL SELF", f"{node_id} bytes={len(content)}", 3)
 101: 
 102:     peers = target_peer_ids()
 103:     log_state("cyan", "REPL PEERS", f"peers={peers}", 3)
 104: 
 105:     success = True
 106: 
 107:     for peer_id in peers:
 108:         node = CLUSTER_REGISTRY.get(peer_id)
 109:         if not node:
 110:             log_state("red", "LOG REPL FAIL", f"{peer_id} missing registry", 3)
 111:             success = False
 112:             continue
 113: 
 114:         url = f"http://{node['host']}:{node['port']}/debug/log/replica/{node_id}"
 115:         log_state("cyan", "REPL POST", f"peer={peer_id} url={url}", 3)
 116: 
 117:         try:
 118:             resp = requests.post(
 119:                 url,
 120:                 data=content.encode("utf-8"),
 121:                 headers={"Content-Type": "text/plain; charset=utf-8"},
 122:                 timeout=2,
 123:             )
 124: 
 125:             if resp.ok:
 126:                 log_state("cyan", "LOG REPL", f"{node_id} -> {peer_id}", 3)
 127:             else:
 128:                 success = False
 129:                 log_state("red", "LOG REPL FAIL", f"{peer_id} status={resp.status_code}", 3)
 130: 
 131:         except Exception as e:
 132:             success = False
 133:             log_state("red", "LOG REPL FAIL", f"{peer_id} err={e}", 3)
 134: 
 135:     if success:
 136:         clear_state()
 137:         log_state("cyan", "REPL CLEAR", "dirty=false", 3)



