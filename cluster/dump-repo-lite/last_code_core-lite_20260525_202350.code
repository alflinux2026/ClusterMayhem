 387: @app.post("/watchdog")
 388: def watchdog(wd: Watchdog):
 389:     if ctx.node.state == NodeState.ISOLATED:
 390:         return {"error": "node isolated"}
 391: 
 392:     existing = cluster_state.get(wd.node_id, {})
 393:     ts = wd.emitted_at if wd.emitted_at is not None else time.time()
 394: 
 395:     cluster_state[wd.node_id] = {
 396:         **existing,
 397:         "last_watchdog": ts,
 398:         "watchdog_busy": bool(wd.busy),
 399:     }
 400: 
 401:     return {
 402:         "ok": True,
 403:         "node_id": wd.node_id,
 404:         "last_watchdog": ts,
 405:         "watchdog_busy": bool(wd.busy),
 406:     }
 407: 
