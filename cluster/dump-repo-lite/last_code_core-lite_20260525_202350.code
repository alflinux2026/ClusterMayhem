 409: @app.post("/heartbeat")
 410: def heartbeat(hb: Heartbeat):
 411:     if ctx.node.state == NodeState.ISOLATED:
 412:         return {"error": "node isolated"}
 413: 
 414:     existing = cluster_state.get(hb.node_id, {})
 415:     cluster_state[hb.node_id] = {
 416:         **existing,
 417:         "state": hb.state,
 418:         "priority": hb.priority,
 419:         "last_seen": time.time(),
 420:         "state_since": hb.state_since if hb.state_since is not None else existing.get("state_since"),
 421:         "prev_state": hb.prev_state if hb.prev_state is not None else existing.get("prev_state"),
 422:         "state_reason": hb.state_reason if hb.state_reason is not None else existing.get("state_reason"),
 423:         "log_meta": hb.log_meta or existing.get("log_meta", {}),
 424:         "cluster_integrity": hb.cluster_integrity or existing.get("cluster_integrity", {}),
 425:         "streams": hb.streams or existing.get("streams", {}),
 426:     }
 427: 
 428:     return {"ok": True}
 429: 
