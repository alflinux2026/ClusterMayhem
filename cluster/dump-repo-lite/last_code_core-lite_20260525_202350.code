 298: @app.post("/event")
 299: def handle_event(event: ClusterEvent):
 300:     if ctx.node.state == NodeState.ISOLATED:
 301:         return {"error": "node isolated"}
 302: 
 303:     leader = compute_leader()
 304:     if not leader:
 305:         log_state("red", "(NO LEADER)", event.event_id, 3)
 306:         return {"error": "no leader"}
 307: 
 308:     if leader != ctx.node_id:
 309:         msg = event.payload.get("msg", "<no-msg>")
 310:         log_state("cyan", "[EVENT FWD]", f"{msg:12} -> {leader}", 3)
 311:         node = CLUSTER_REGISTRY[leader]
 312:         url = f"http://{node['host']}:{node['port']}/event"
 313:         try:
 314:             resp = requests.post(url, json=event.model_dump(), timeout=2)
 315:             return resp.json()
 316:         except Exception as e:
 317:             return {"error": str(e)}
 318: 
 319:     result = ingest_event(event, ctx.node_id)
 320:     return {"status": "ok", "event_id": event.event_id, "result": result}
 321: 
