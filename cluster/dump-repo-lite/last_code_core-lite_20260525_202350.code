 431: @app.get("/dashboard/compact")
 432: def dashboard_compact():
 433:     now = time.time()
 434:     leader = compute_leader()
 435:     local_events = events_summary()
 436:     integrity = local_integrity_api()
 437: 
 438:     local_node = cluster_state.get(ctx.node_id, {}) or {}
 439: 
 440:     try:
 441:         from cluster.runtime.progress_watchdog import (
 442:             get_progress_age_s,
 443:             get_progress_duration_s,
 444:             get_progress_pct,
 445:             refresh_progress_stalled_flag,
 446:         )
 447:     except Exception:
 448:         get_progress_age_s = None
 449:         get_progress_duration_s = None
 450:         get_progress_pct = None
 451:         refresh_progress_stalled_flag = None
 452: 
 453:     nodes = []
 454:     for node_id, node in sorted(cluster_state.items()):
 455:         log_meta = node.get("log_meta", {}) or {}
 456:         counts = (((node.get("streams") or {}).get("events_summary_local") or {}).get("counts") or {})
 457: 
 458:         progress_age_s = None
 459:         progress_duration_s = None
 460:         progress_pct = None
 461:         progress_stalled = bool(node.get("progress_stalled", False))
 462: 
 463:         if refresh_progress_stalled_flag is not None:
 464:             try:
 465:                 progress_stalled = bool(refresh_progress_stalled_flag(node_id=node_id, now=now))
 466:                 node = cluster_state.get(node_id, node) or node
 467:             except Exception:
 468:                 progress_stalled = bool(node.get("progress_stalled", False))
 469: 
 470:         if get_progress_age_s is not None:
 471:             try:
 472:                 progress_age_s = get_progress_age_s(node=node, now=now)
 473:             except Exception:
 474:                 progress_age_s = None
 475: 
 476:         if get_progress_duration_s is not None:
 477:             try:
 478:                 progress_duration_s = get_progress_duration_s(node=node, now=now)
 479:             except Exception:
 480:                 progress_duration_s = None
 481: 
 482:         if get_progress_pct is not None:
 483:             try:
 484:                 progress_pct = get_progress_pct(node=node)
 485:             except Exception:
 486:                 progress_pct = None
 487:         else:
 488:             try:
 489:                 current = node.get("progress_current")
 490:                 total = node.get("progress_total")
 491:                 if current is not None and total not in (None, 0):
 492:                     progress_pct = round((float(current) / float(total)) * 100.0, 1)
 493:             except Exception:
 494:                 progress_pct = None
 495: 
 496:         item = {
 497:             "node_id": node_id,
 498:             "state": node.get("state"),
 499:             "state_since": node.get("state_since"),
 500:             "state_age_s": round(_state_age_s(node, now) or 0.0, 1),
 501:             "prev_state": node.get("prev_state"),
 502:             "state_reason": node.get("state_reason"),
 503:             "priority": node.get("priority"),
 504:             "last_seen": node.get("last_seen"),
 505:             "seen_age_s": round(_seen_age_s(node, now) or 0.0, 1),
 506:             "last_watchdog": node.get("last_watchdog"),
 507:             "watchdog_age_s": round(_watchdog_age_s(node, now) or 0.0, 1) if node.get("last_watchdog") is not None else None,
 508:             "watchdog_busy": node.get("watchdog_busy"),
 509:             "presence_age_s": round(_presence_age_s(node, now) or 0.0, 1),
 510:             "health": _presence_health(node, now, stale_after_s=3.0),
 511:             "local_size": log_meta.get("size", 0),
 512:             "local_events": ((node.get("streams") or {}).get("events_summary_local") or {}).get("total_events", 0),
 513:             "created": counts.get("created", 0),
 514:             "executing": counts.get("executing", 0),
 515:             "completed": counts.get("completed", 0),
 516:             "dirty": ((node.get("cluster_integrity") or {}).get("last_append_meta") or {}).get("dirty"),
 517: 
 518:             "progress_active": bool(node.get("progress_active", False)),
 519:             "progress_stage": node.get("progress_stage"),
 520:             "progress_started_at": node.get("progress_started_at"),
 521:             "progress_touched_at": node.get("progress_touched_at"),
 522:             "progress_age_s": round(progress_age_s, 1) if progress_age_s is not None else None,
 523:             "progress_duration_s": round(progress_duration_s, 1) if progress_duration_s is not None else None,
 524:             "progress_current": node.get("progress_current"),
 525:             "progress_total": node.get("progress_total"),
 526:             "progress_pct": progress_pct,
 527:             "progress_stalled": progress_stalled,
 528:             "progress_meta": node.get("progress_meta", {}) or {},
 529:         }
 530:         nodes.append(item)
 531: 
 532:     local_progress = {
 533:         "progress_active": bool(local_node.get("progress_active", False)),
 534:         "progress_stage": local_node.get("progress_stage"),
 535:         "progress_started_at": local_node.get("progress_started_at"),
 536:         "progress_touched_at": local_node.get("progress_touched_at"),
 537:         "progress_age_s": None,
 538:         "progress_duration_s": None,
 539:         "progress_current": local_node.get("progress_current"),
 540:         "progress_total": local_node.get("progress_total"),
 541:         "progress_pct": None,
 542:         "progress_stalled": bool(local_node.get("progress_stalled", False)),
 543:         "progress_meta": local_node.get("progress_meta", {}) or {},
 544:     }
 545: 
 546:     if refresh_progress_stalled_flag is not None:
 547:         try:
 548:             local_progress["progress_stalled"] = bool(refresh_progress_stalled_flag(node_id=ctx.node_id, now=now))
 549:             local_node = cluster_state.get(ctx.node_id, local_node) or local_node
 550:             local_progress["progress_active"] = bool(local_node.get("progress_active", False))
 551:             local_progress["progress_stage"] = local_node.get("progress_stage")
 552:             local_progress["progress_started_at"] = local_node.get("progress_started_at")
 553:             local_progress["progress_touched_at"] = local_node.get("progress_touched_at")
 554:             local_progress["progress_current"] = local_node.get("progress_current")
 555:             local_progress["progress_total"] = local_node.get("progress_total")
 556:             local_progress["progress_meta"] = local_node.get("progress_meta", {}) or {}
 557:         except Exception:
 558:             pass
 559: 
 560:     if get_progress_age_s is not None:
 561:         try:
 562:             age = get_progress_age_s(node=local_node, now=now)
 563:             local_progress["progress_age_s"] = round(age, 1) if age is not None else None
 564:         except Exception:
 565:             pass
 566: 
 567:     if get_progress_duration_s is not None:
 568:         try:
 569:             duration = get_progress_duration_s(node=local_node, now=now)
 570:             local_progress["progress_duration_s"] = round(duration, 1) if duration is not None else None
 571:         except Exception:
 572:             pass
 573: 
 574:     if get_progress_pct is not None:
 575:         try:
 576:             local_progress["progress_pct"] = get_progress_pct(node=local_node)
 577:         except Exception:
 578:             pass
 579:     else:
 580:         try:
 581:             current = local_node.get("progress_current")
 582:             total = local_node.get("progress_total")
 583:             if current is not None and total not in (None, 0):
 584:                 local_progress["progress_pct"] = round((float(current) / float(total)) * 100.0, 1)
 585:         except Exception:
 586:             pass
 587: 
 588:     return {
 589:         "cluster": {
 590:             "node_id": ctx.node_id,
 591:             "leader": leader,
 592:             "generated_at": now,
 593:             "integrity_ok": bool(integrity.get("integrity_ok", True)),
 594:             "local_state": ctx.node.state.value,
 595:             "local_state_since": getattr(ctx.node, "state_since", None),
 596:             "local_state_age_s": round(_state_age_s({
 597:                 "state_since": getattr(ctx.node, "state_since", None)
 598:             }, now) or 0.0, 1),
 599:         },
 600:         "local": {
 601:             "events_summary": local_events,
 602:             "integrity": integrity,
 603:             "progress": local_progress,
 604:         },
 605:         "nodes": nodes,
 606:     }
 607: 
 608: @app.get("/integrity")
 609: def integrity():
 610:     return local_integrity_api()
 611: 
 612: 
 613: @app.get("/integrity/cluster")
 614: def integrity_cluster():
 615:     return cluster_integrity_report()
 616: 



===== ./runtime/bootstrap.py =====
   1: import json
   2: import os
   3: import socket
   4: from pathlib import Path
   5: 
   6: 
   7: def _write_json_atomic(path: str, data: dict) -> None:
   8:     p = Path(path)
   9:     p.parent.mkdir(parents=True, exist_ok=True)
  10:     tmp = p.with_suffix(p.suffix + ".tmp")
  11:     with open(tmp, "w", encoding="utf-8") as f:
  12:         json.dump(data, f, ensure_ascii=False, indent=2)
  13:         f.flush()
  14:         os.fsync(f.fileno())
  15:     os.replace(tmp, p)
  16: 
  17: 
  18: def _node_get(node: dict, *keys, default=None):
  19:     for key in keys:
  20:         if key in node and node[key] is not None:
  21:             return node[key]
  22:     return default
  23: 
  24: 
  25: def _find_self_node(nodes: list[dict]) -> dict:
  26:     hostname = socket.gethostname()
  27: 
  28:     node_id_env = os.getenv("NODE_ID") or os.getenv("NODEID")
  29:     host_env = os.getenv("NODE_HOST") or os.getenv("NODEHOST")
  30:     ip_env = os.getenv("NODE_IP") or os.getenv("NODEIP")
  31: 
  32:     for node in nodes:
  33:         node_id = _node_get(node, "node_id", "nodeid")
  34:         host = _node_get(node, "host", "hostname", "ip")
  35: 
  36:         if node_id_env and node_id == node_id_env:
  37:             return node
  38:         if host_env and host == host_env:
  39:             return node
  40:         if ip_env and host == ip_env:
  41:             return node
  42:         if node_id == hostname:
  43:             return node
  44:         if host == hostname:
  45:             return node
  46: 
  47:     raise RuntimeError(
  48:         f"Cannot identify node for hostname={hostname!r} "
  49:         f"env NODE_ID={node_id_env!r} NODE_HOST={host_env!r} NODE_IP={ip_env!r}"
  50:     )
  51: 
  52: 
  53: def load_or_bootstrap_config():
  54:     nodes_path = Path(os.getenv("CLUSTER_NODES", "cluster/config/nodes.json"))
  55:     config_path = Path(os.getenv("CLUSTER_CONFIG", "config/node.json"))
  56: 
  57:     if not nodes_path.exists():
  58:         raise FileNotFoundError(f"Missing cluster nodes file: {nodes_path}")
  59: 
  60:     with open(nodes_path, "r", encoding="utf-8") as f:
  61:         cluster_cfg = json.load(f)
  62: 
  63:     if not isinstance(cluster_cfg, dict):
  64:         raise ValueError(f"Invalid cluster nodes file: {nodes_path}")
  65: 
  66:     nodes = cluster_cfg.get("nodes", [])
  67:     if not isinstance(nodes, list) or not nodes:
  68:         raise ValueError(f"Empty node list in: {nodes_path}")
  69: 
  70:     self_node = _find_self_node(nodes)
  71: 
  72:     self_node_id = _node_get(self_node, "node_id", "nodeid")
  73:     self_priority = int(_node_get(self_node, "priority", default=100))
  74:     self_host = _node_get(self_node, "host", "hostname", "ip", default=os.getenv("NODE_HOST", "0.0.0.0"))
  75:     self_port = int(_node_get(self_node, "port", default=os.getenv("NODE_PORT", "8000")))
  76:     self_bind_host = _node_get(self_node, "bind_host", default=self_host)
  77:     self_bind_port = int(_node_get(self_node, "bind_port", default=self_port))
  78: 
  79:     peers = []
  80:     for n in nodes:
  81:         peer_node_id = _node_get(n, "node_id", "nodeid")
  82:         if peer_node_id == self_node_id:
  83:             continue
  84:         peers.append({
  85:             "node_id": peer_node_id,
  86:             "host": _node_get(n, "host", "hostname", "ip"),
  87:             "port": int(_node_get(n, "port")),
  88:             "priority": int(_node_get(n, "priority", default=100)),
  89:         })
  90: 
  91:     cfg = {
  92:         "cluster_name": cluster_cfg.get("cluster_name", "mayhem-cluster"),
  93:         "node_id": self_node_id,
  94:         "priority": self_priority,
  95:         "port": self_port,
  96:         "host": self_host,
  97:         "bind_host": self_bind_host,
  98:         "bind_port": self_bind_port,
  99:         "tenant_id": os.getenv("TENANT_ID", "default"),
 100:         "app_id": os.getenv("APP_ID", "mayhem"),
 101:         "data_type": os.getenv("DATA_TYPE", "event"),
 102:         "schema_version": os.getenv("SCHEMA_VERSION", "0.1"),
 103:         "peers": peers,
 104:     }
 105: 
 106:     if config_path.exists():
 107:         try:
 108:             with open(config_path, "r", encoding="utf-8") as f:
 109:                 existing = json.load(f)
 110:             if isinstance(existing, dict) and existing.get("node_id") == cfg["node_id"]:
 111:                 merged = {**existing, **cfg}
 112:                 merged["peers"] = cfg["peers"]
 113:                 return merged
 114:         except (json.JSONDecodeError, OSError):
 115:             pass
 116: 
 117:     _write_json_atomic(str(config_path), cfg)
 118:     return cfg



===== ./runtime/dispatcher.py =====
   1: import time
   2: 
   3: from cluster.runtime.event_log import get_created_events, get_completed_event_ids, append_event
   4: from cluster.runtime.event_router import forward_event
   5: from cluster.utils.log_print import log_state
   6: from cluster.runtime.leader import compute_leader, compute_alive
   7: from cluster.runtime import context as ctx
   8: from cluster.runtime.events.event_state import EventStatus
   9: from cluster.runtime.progress_watchdog import progress_start, progress_touch, progress_done
  10: 
  11: DISPATCH_ALIVE_TIMEOUT = 1.5
  12: 
  13: 
  14: def dispatch_tick(stream: str | None = None):
  15:     if compute_leader() != ctx.node_id:
  16:         return
  17: 
  18:     events = get_created_events()
  19:     if not events:
  20:         return
  21: 
  22:     total = len(events)
  23:     log_state("magenta", "[DISPATCH]", f"{total:3}", 3)
  24: 
  25:     progress_start(
  26:         "dispatch_tick",
  27:         {
  28:             "total_events": total,
  29:             "stream": stream,
  30:         },
  31:     )
  32: 
  33:     dispatched = 0
  34:     skipped_completed = 0
  35:     skipped_no_alive = 0
  36:     failed = 0
  37: 
  38:     try:
  39:         for idx, event in enumerate(events, start=1):
  40:             progress_touch(
  41:                 stage="dispatch_scan",
  42:                 current=idx,
  43:                 total=total,
  44:                 meta={
  45:                     "event_id": event.event_id,
  46:                     "msg": event.payload.get("msg", ""),
  47:                     "phase": "before_dispatch",
  48:                     "dispatched": dispatched,
  49:                     "skipped_completed": skipped_completed,
  50:                     "skipped_no_alive": skipped_no_alive,
  51:                     "failed": failed,
  52:                 },
  53:             )
  54: 
  55:             result = dispatch_created_event(event, stream, current=idx, total=total)
  56: 
  57:             status = (result or {}).get("status")
  58:             if status == "dispatched":
  59:                 dispatched += 1
  60:             elif status == "skip_completed":
  61:                 skipped_completed += 1
  62:             elif status == "skip_no_alive":
  63:                 skipped_no_alive += 1
  64:             else:
  65:                 failed += 1
  66: 
  67:             progress_touch(
  68:                 stage="dispatch_scan",
  69:                 current=idx,
  70:                 total=total,
  71:                 meta={
  72:                     "event_id": event.event_id,
  73:                     "msg": event.payload.get("msg", ""),
  74:                     "phase": "after_dispatch",
  75:                     "result": status,
  76:                     "target": (result or {}).get("target"),
  77:                     "dispatched": dispatched,
  78:                     "skipped_completed": skipped_completed,
  79:                     "skipped_no_alive": skipped_no_alive,
  80:                     "failed": failed,
  81:                 },
  82:             )
  83: 
  84:     finally:
  85:         progress_done(
  86:             "dispatch_done",
  87:             {
  88:                 "total_events": total,
  89:                 "dispatched": dispatched,
  90:                 "skipped_completed": skipped_completed,
  91:                 "skipped_no_alive": skipped_no_alive,
  92:                 "failed": failed,
  93:                 "stream": stream,
  94:             },
  95:         )
  96: 
  97: 
  98: def dispatch_created_event(event, stream: str | None = None, current: int | None = None, total: int | None = None):
  99:     progress_touch(
 100:         stage="dispatch_check_completed",
 101:         current=current,
 102:         total=total,
 103:         meta={
 104:             "event_id": event.event_id,
 105:             "msg": event.payload.get("msg", ""),
 106:         },
 107:     )
 108: 
 109:     completed = get_completed_event_ids()
 110:     if event.event_id in completed:
 111:         log_state("red", "[SKIP COMPLETED]", event.event_id, 3)
 112:         progress_touch(
 113:             stage="dispatch_skip_completed",
 114:             current=current,
 115:             total=total,
 116:             meta={
 117:                 "event_id": event.event_id,
 118:                 "msg": event.payload.get("msg", ""),
 119:                 "result": "skip_completed",
 120:             },
 121:         )
 122:         return {
 123:             "status": "skip_completed",
 124:             "event_id": event.event_id,
 125:             "target": None,
 126:         }
 127: 
 128:     progress_touch(
 129:         stage="dispatch_compute_alive",
 130:         current=current,
 131:         total=total,
 132:         meta={
 133:             "event_id": event.event_id,
 134:             "msg": event.payload.get("msg", ""),
 135:         },
 136:     )
 137: 
 138:     alive = compute_alive(timeout=DISPATCH_ALIVE_TIMEOUT, include_self=True)
 139:     if not alive:
 140:         log_state("red", "[NO ALIVE NODES]", event.event_id, 3)
 141:         progress_touch(
 142:             stage="dispatch_no_alive",
 143:             current=current,
 144:             total=total,
 145:             meta={
 146:                 "event_id": event.event_id,
 147:                 "msg": event.payload.get("msg", ""),
 148:                 "result": "skip_no_alive",
 149:             },
 150:         )
 151:         return {
 152:             "status": "skip_no_alive",
 153:             "event_id": event.event_id,
 154:             "target": None,
 155:         }
 156: 
 157:     progress_touch(
 158:         stage="dispatch_select_target",
 159:         current=current,
 160:         total=total,
 161:         meta={
 162:             "event_id": event.event_id,
 163:             "msg": event.payload.get("msg", ""),
 164:             "alive_nodes": sorted(alive.keys()),
 165:         },
 166:     )
 167: 
 168:     target = min(alive.items(), key=lambda x: (x[1]["priority"], x[0]))[0]
 169:     event.target_node = target
 170:     event.route_hops.append(f"dispatcher->{target}")
 171:     event.attempt = (event.attempt or 0) + 1
 172:     event.mark_status(EventStatus.EXECUTING)
 173:     msg = event.payload.get("msg", "")
 174: 
 175:     log_state("yellow", "(EVENT)", f"{msg:12} -> EXECUTING", 3)
 176: 
 177:     progress_touch(
 178:         stage="dispatch_append_event",
 179:         current=current,
 180:         total=total,
 181:         meta={
 182:             "event_id": event.event_id,
 183:             "msg": msg,
 184:             "target": target,
 185:             "attempt": event.attempt,
 186:         },
 187:     )
 188: 
 189:     event.updated_at = time.time()
 190:     append_event(event)
 191: 
 192:     progress_touch(
 193:         stage="dispatch_forward_event",
 194:         current=current,
 195:         total=total,
 196:         meta={
 197:             "event_id": event.event_id,
 198:             "msg": msg,
 199:             "target": target,
 200:             "attempt": event.attempt,
 201:         },
 202:     )
 203: 
 204:     forward_event(target, event, stream)
 205: 
 206:     progress_touch(
 207:         stage="dispatch_forwarded",
 208:         current=current,
 209:         total=total,
 210:         meta={
 211:             "event_id": event.event_id,
 212:             "msg": msg,
 213:             "target": target,
 214:             "attempt": event.attempt,
 215:             "result": "dispatched",
 216:         },
 217:     )
 218: 
 219:     return {
 220:         "status": "dispatched",
 221:         "event_id": event.event_id,
 222:         "target": target,
 223:     }



