 351: @app.get("/health")
 352: def health():
 353:     local_entry = cluster_state.get(ctx.node_id, {})
 354:     local_node = {
 355:         "state_since": getattr(ctx.node, "state_since", None),
 356:         "last_seen": local_entry.get("last_seen"),
 357:         "last_watchdog": local_entry.get("last_watchdog"),
 358:         "watchdog_busy": local_entry.get("watchdog_busy"),
 359:     }
 360: 
 361:     return {
 362:         "status": _presence_health(local_node),
 363:         "node": ctx.node_id,
 364:         "state": ctx.node.state.value,
 365:         "state_since": getattr(ctx.node, "state_since", None),
 366:         "state_age_s": _round_or_none(_state_age_s({"state_since": getattr(ctx.node, "state_since", None)}), 3),
 367:         "last_seen": local_node.get("last_seen"),
 368:         "seen_age_s": _round_or_none(_seen_age_s(local_node), 3),
 369:         "last_watchdog": local_node.get("last_watchdog"),
 370:         "watchdog_age_s": _round_or_none(_watchdog_age_s(local_node), 3),
 371:         "watchdog_busy": local_node.get("watchdog_busy"),
 372:         "presence_age_s": _round_or_none(_presence_age_s(local_node), 3),
 373:         "sleeping": ctx.node.state == NodeState.ISOLATED,
 374:     }
