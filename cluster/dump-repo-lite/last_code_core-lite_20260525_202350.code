  49: class Watchdog(BaseModel):
  50:     node_id: str
  51:     busy: bool = True
  52:     emitted_at: float | None = None
  53: 
  54: 
  55: def _round_or_none(value: float | None, digits: int = 1) -> float | None:
  56:     if value is None:
  57:         return None
  58:     try:
  59:         return round(float(value), digits)
  60:     except Exception:
  61:         return None
  62: 
  63: 
  64: def _watchdog_age_s(node: dict, now: float | None = None) -> float | None:
  65:     now = now or time.time()
  66:     last_watchdog = node.get("last_watchdog")
  67:     if last_watchdog is None:
  68:         return None
  69:     try:
  70:         return max(0.0, now - float(last_watchdog))
  71:     except Exception:
  72:         return None
  73: 
  74: 
  75: def _state_age_s(node: dict, now: float | None = None) -> float | None:
  76:     now = now or time.time()
  77:     state_since = node.get("state_since")
  78:     if state_since is None:
  79:         return None
  80:     try:
  81:         return max(0.0, now - float(state_since))
  82:     except Exception:
  83:         return None
  84: 
  85: 
  86: def _seen_age_s(node: dict, now: float | None = None) -> float | None:
  87:     now = now or time.time()
  88:     last_seen = node.get("last_seen")
  89:     if last_seen is None:
  90:         return None
  91:     try:
  92:         return max(0.0, now - float(last_seen))
  93:     except Exception:
  94:         return None
  95: 
  96: 
  97: def _presence_age_s(node: dict, now: float | None = None) -> float | None:
  98:     now = now or time.time()
  99:     last_seen = node.get("last_seen")
 100:     last_watchdog = node.get("last_watchdog")
 101: 
 102:     candidates = []
 103:     for value in (last_seen, last_watchdog):
 104:         if value is None:
 105:             continue
 106:         try:
 107:             candidates.append(float(value))
 108:         except Exception:
 109:             continue
 110: 
 111:     if not candidates:
 112:         return None
 113: 
 114:     return max(0.0, now - max(candidates))
 115: 
 116: 
 117: def _presence_health(node: dict, now: float | None = None, stale_after_s: float = 3.0) -> str:
 118:     age = _presence_age_s(node, now)
 119:     if age is None:
 120:         return "stale"
 121:     return "ok" if age < stale_after_s else "stale"
 122: 
 123: 
 124: def _compact_node(node: dict) -> dict:
 125:     now = time.time()
 126:     return {
 127:         "state": node.get("state"),
 128:         "priority": node.get("priority"),
 129:         "last_seen": node.get("last_seen"),
 130:         "seen_age_s": _round_or_none(_seen_age_s(node, now), 3),
 131:         "last_watchdog": node.get("last_watchdog"),
 132:         "watchdog_age_s": _round_or_none(_watchdog_age_s(node, now), 3),
 133:         "watchdog_busy": node.get("watchdog_busy"),
 134:         "presence_age_s": _round_or_none(_presence_age_s(node, now), 3),
 135:         "presence_health": _presence_health(node, now),
 136:         "state_since": node.get("state_since"),
 137:         "state_age_s": _round_or_none(_state_age_s(node, now), 3),
 138:         "prev_state": node.get("prev_state"),
 139:         "state_reason": node.get("state_reason"),
 140:         "log_meta": node.get("log_meta", {}),
 141:         "streams": node.get("streams", {}),
 142:     }
 143: 
