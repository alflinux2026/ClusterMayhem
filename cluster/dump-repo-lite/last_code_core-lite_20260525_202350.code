 145: def _read_jsonl(path: str) -> list[dict]:
 146:     if not os.path.exists(path):
 147:         return []
 148: 
 149:     out: list[dict] = []
 150:     with open(path, "r", encoding="utf-8") as f:
 151:         for line in f:
 152:             line = line.strip()
 153:             if not line:
 154:                 continue
 155:             try:
 156:                 out.append(json.loads(line))
 157:             except Exception:
 158:                 continue
 159:     return out
 160: 
 161: 
 162: def _summarize_events(events: list[dict]) -> dict:
 163:     latest_by_event_id: dict[str, dict] = {}
 164:     last_event_id = None
 165: 
 166:     for event in events:
 167:         event_id = event.get("event_id")
 168:         if not event_id:
 169:             continue
 170:         latest_by_event_id[event_id] = event
 171:         last_event_id = event_id
 172: 
 173:     counts = Counter()
 174:     for event in latest_by_event_id.values():
 175:         status = event.get("status", "unknown")
 176:         counts[status] += 1
 177: 
 178:     return {
 179:         "total_events": len(latest_by_event_id),
 180:         "counts": {
 181:             "created": counts.get("created", 0),
 182:             "executing": counts.get("executing", 0),
 183:             "completed": counts.get("completed", 0),
 184:             "unknown": counts.get("unknown", 0),
 185:         },
 186:         "last_event_id": last_event_id,
 187:     }
