 222: @app.post("/debug/log/replica/{node_id}")
 223: async def log_replica_write(node_id: str, request: Request):
 224:     try:
 225:         content = await request.body()
 226:     except Exception as e:
 227:         return {"ok": False, "node_id": node_id, "error": str(e)}
 228: 
 229:     text = content.decode("utf-8") if content else ""
 230:     write_replica_log(node_id, text)
 231:     return {
 232:         "ok": True,
 233:         "node_id": node_id,
 234:         "path": get_replica_log_path(node_id),
 235:         "bytes": len(content),
