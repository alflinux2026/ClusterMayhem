   1: import json
   2: import os
   3: import tempfile
   4: import threading
   5: from pathlib import Path
   6: from typing import Dict, List, Optional
   7: 
   8: from cluster.runtime.events.cluster_event import ClusterEvent
   9: from cluster.runtime.events.event_state import EventStatus
  10: 
  11: DATA_DIR = Path(__file__).resolve().parents[1] / "data"
  12: LOCAL_LOG_PATH = DATA_DIR / "event_log.local.jsonl"
  13: COMPLETED_LOG_PATH = DATA_DIR / "events.local.jsonl"
  14: STATE_PATH = DATA_DIR / "last_append.state.json"
  15: 
  16: _STATE_LOCK = threading.Lock()
  17: 
  18: 
  19: def ensure_dir():
  20:     DATA_DIR.mkdir(parents=True, exist_ok=True)
  21: 
  22: 
  23: def ensure_initial_files():
  24:     ensure_dir()
  25: 
  26:     if not STATE_PATH.exists():
  27:         write_state({
  28:             "dirty": False,
  29:             "events_dirty": False,
  30:             "last_append_event_id": None,
  31:             "last_append_created_at": None,
  32:             "last_append_updated_at": None,
  33:             "last_completed_event_id": None,
  34:             "last_completed_created_at": None,
  35:             "last_completed_updated_at": None,
  36:         })
  37: 
  38:     if not LOCAL_LOG_PATH.exists():
  39:         LOCAL_LOG_PATH.touch()
  40: 
  41:     if not COMPLETED_LOG_PATH.exists():
  42:         COMPLETED_LOG_PATH.touch()
  43: 
  44: 
  45: def get_local_log_path(stream: str | None = None) -> str:
  46:     return str(LOCAL_LOG_PATH)
  47: 
  48: 
  49: def get_completed_log_path(stream: str | None = None) -> str:
  50:     return str(COMPLETED_LOG_PATH)
  51: 
  52: 
  53: def get_state_path() -> str:
  54:     return str(STATE_PATH)
  55: 
  56: 
  57: def get_replica_log_path(node_id: str) -> str:
  58:     return str(DATA_DIR / f"event_log.{node_id}.jsonl")
  59: 
  60: 
  61: def list_replica_log_paths() -> List[str]:
  62:     if not DATA_DIR.exists():
  63:         return []
  64: 
  65:     out: List[str] = []
  66:     for name in sorted(os.listdir(DATA_DIR)):
  67: #        if not name.startswith("event_log."):
  68: #            continue
  69:         if not name.endswith(".local.jsonl"):
  70:             continue
  71: #        if name == "event_log.local.jsonl":
  72: #            continue
  73: #        if name == "event_log.completed.jsonl":
  74: #            continue
  75:         out.append(str(DATA_DIR / name))
  76:     return out
  77: 
  78: 
  79: def load_events_from_path(path: str) -> List[dict]:
  80:     if not os.path.exists(path):
  81:         return []
  82: 
  83:     events = []
  84:     with open(path, "r", encoding="utf-8") as f:
  85:         for line in f:
  86:             line = line.strip()
  87:             if not line:
  88:                 continue
  89:             try:
  90:                 events.append(json.loads(line))
  91:             except json.JSONDecodeError:
  92:                 continue
  93:     return events
  94: 
  95: 
  96: def _write_json_atomic(target_path: Path, payload: dict):
  97:     ensure_dir()
  98:     with _STATE_LOCK:
  99:         fd, tmp_name = tempfile.mkstemp(
 100:             prefix=f"{target_path.name}.",
 101:             suffix=".tmp",
 102:             dir=str(target_path.parent),
 103:             text=True,
 104:         )
 105:         try:
 106:             with os.fdopen(fd, "w", encoding="utf-8") as f:
 107:                 json.dump(payload, f, ensure_ascii=False)
 108:                 f.flush()
 109:                 os.fsync(f.fileno())
 110:             os.replace(tmp_name, str(target_path))
 111:         except Exception:
 112:             try:
 113:                 os.remove(tmp_name)
 114:             except FileNotFoundError:
 115:                 pass
 116:             raise
 117: 
 118: 
 119: def write_text_atomic(path: str, content: str):
 120:     ensure_dir()
 121:     target_path = Path(path)
 122:     fd, tmp_name = tempfile.mkstemp(
 123:         prefix=f"{target_path.name}.",
 124:         suffix=".tmp",
 125:         dir=str(target_path.parent),
 126:         text=True,
 127:     )
 128:     try:
 129:         with os.fdopen(fd, "w", encoding="utf-8") as f:
 130:             f.write(content)
 131:             f.flush()
 132:             os.fsync(f.fileno())
 133:         os.replace(tmp_name, str(target_path))
 134:     except Exception:
 135:         try:
 136:             os.remove(tmp_name)
 137:         except FileNotFoundError:
 138:             pass
 139:         raise
 140: 
 141: 
 142: def read_local_log_text() -> str:
 143:     if not LOCAL_LOG_PATH.exists():
 144:         return ""
 145:     return LOCAL_LOG_PATH.read_text(encoding="utf-8")
 146: 
 147: 
 148: def read_completed_log_text() -> str:
 149:     if not COMPLETED_LOG_PATH.exists():
 150:         return ""
 151:     return COMPLETED_LOG_PATH.read_text(encoding="utf-8")
 152: 
 153: 
