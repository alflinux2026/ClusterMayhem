 109: @app.post("/event")
 110: def handle_event(event: ClusterEvent):
 111:     if ctx.node.state == NodeState.ISOLATED:
 112:         return {"error": "node isolated"}
 113: 
 114:     leader = compute_leader()
 115:     if not leader:
 116:         log_state("red", "(NO LEADER)", event.event_id, 3)
 117:         return {"error": "no leader"}
 118: 
 119:     if leader != ctx.node_id:
 120:         msg = event.payload.get("msg", "<no-msg>")
 121:         log_state("cyan", "[EVENT FWD]", f"{msg:12} -> {leader}", 3)
 122:         node = CLUSTER_REGISTRY[leader]
 123:         url = f"http://{node['host']}:{node['port']}/event"
 124:         try:
 125:             resp = requests.post(url, json=event.model_dump(), timeout=2)
 126:             return resp.json()
 127:         except Exception as e:
 128:             return {"error": str(e)}
 129: 
 130:     result = ingest_event(event, ctx.node_id)
 131:     return {"status": "ok", "event_id": event.event_id, "result": result}
 132: 
 133: 
