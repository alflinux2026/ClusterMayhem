   1: 
   2: import json
   3: import os
   4: from typing import Dict, List, Optional
   5: 
   6: from cluster.runtime.events.cluster_event import ClusterEvent
   7: from cluster.runtime.events.event_state import EventStatus
   8: 
   9: BASE_DIR = os.path.dirname(os.path.dirname(os.path.dirname(__file__)))
  10: DATA_DIR = os.path.join(BASE_DIR, "cluster", "data")
  11: LOCAL_LOG_PATH = os.path.join(DATA_DIR, "event_log.local.jsonl")
  12: STATE_PATH = os.path.join(DATA_DIR, "last_append.state.json")
  13: 
  14: 
  15: def ensure_dir():
  16:     os.makedirs(DATA_DIR, exist_ok=True)
  17: 
  18: 
  19: def get_local_log_path(stream: str | None = None) -> str:
  20:     return LOCAL_LOG_PATH
  21: 
  22: 
  23: def get_state_path() -> str:
  24:     return STATE_PATH
  25: 
  26: 
  27: def get_replica_log_path(node_id: str) -> str:
  28:     return os.path.join(DATA_DIR, f"event_log.{node_id}.jsonl")
  29: 
  30: 
  31: def list_replica_log_paths() -> List[str]:
  32:     if not os.path.exists(DATA_DIR):
  33:         return []
  34: 
  35:     out: List[str] = []
  36:     for name in sorted(os.listdir(DATA_DIR)):
  37:         if not name.startswith("event_log."):
  38:             continue
  39:         if not name.endswith(".jsonl"):
  40:             continue
  41:         if name == "event_log.local.jsonl":
  42:             continue
  43:         out.append(os.path.join(DATA_DIR, name))
  44:     return out
  45: 
  46: 
  47: def load_events_from_path(path: str) -> List[dict]:
  48:     if not os.path.exists(path):
  49:         return []
  50: 
  51:     events = []
  52:     with open(path, "r", encoding="utf-8") as f:
  53:         for line in f:
  54:             line = line.strip()
  55:             if not line:
  56:                 continue
  57:             try:
  58:                 events.append(json.loads(line))
  59:             except json.JSONDecodeError:
  60:                 continue
  61:     return events
  62: 
  63: 
  64: def write_text_atomic(path: str, content: str):
  65:     ensure_dir()
  66:     tmp_path = path + ".tmp"
  67:     with open(tmp_path, "w", encoding="utf-8") as f:
  68:         f.write(content)
  69:         f.flush()
  70:         os.fsync(f.fileno())
  71:     os.replace(tmp_path, path)
  72: 
  73: 
  74: def read_local_log_text() -> str:
  75:     if not os.path.exists(LOCAL_LOG_PATH):
  76:         return ""
  77:     with open(LOCAL_LOG_PATH, "r", encoding="utf-8") as f:
  78:         return f.read()
  79: 
  80: 
  81: def write_replica_log(node_id: str, content: str):
  82:     ensure_dir()
  83:     write_text_atomic(get_replica_log_path(node_id), content)
  84: 
  85: 
  86: def read_state() -> dict:
  87:     if not os.path.exists(STATE_PATH):
  88:         return {}
  89:     try:
  90:         with open(STATE_PATH, "r", encoding="utf-8") as f:
  91:             data = json.load(f)
  92:             return data if isinstance(data, dict) else {}
  93:     except (OSError, json.JSONDecodeError):
  94:         return {}
  95: 
  96: 
  97: def get_last_append_meta() -> dict:
  98:     state = read_state()
  99:     return state if isinstance(state, dict) else {}
 100: 
 101: 
 102: def write_state(state: dict):
 103:     ensure_dir()
 104:     tmp_path = STATE_PATH + ".tmp"
 105:     with open(tmp_path, "w", encoding="utf-8") as f:
 106:         json.dump(state, f, ensure_ascii=False)
 107:         f.flush()
 108:         os.fsync(f.fileno())
 109:     os.replace(tmp_path, STATE_PATH)
 110: 
 111: 
 112: def clear_state():
 113:     try:
 114:         os.remove(STATE_PATH)
 115:     except FileNotFoundError:
 116:         pass
 117: 
 118: 
 119: def load_events() -> List[dict]:
 120:     return load_events_from_path(LOCAL_LOG_PATH)
 121: 
 122: 
 123: def load_local_events() -> List[dict]:
 124:     return load_events_from_path(LOCAL_LOG_PATH)
 125: 
 126: 
 127: def load_replica_events(node_id: str) -> List[dict]:
 128:     return load_events_from_path(get_replica_log_path(node_id))
 129: 
 130: 
 131: def load_all_replica_events() -> List[dict]:
 132:     events: List[dict] = []
 133:     for path in list_replica_log_paths():
 134:         events.extend(load_events_from_path(path))
 135:     return events
 136: 
 137: 
 138: def load_cluster_events() -> List[dict]:
 139:     return load_all_replica_events()
 140: 
 141: 
 142: def _normalize_event(e: dict) -> dict:
 143:     e = dict(e)
 144:     e["schema_version"] = str(e.get("schema_version", "0.1"))
 145:     e.setdefault("received_at", None)
 146:     e.setdefault("attempt", 0)
 147:     e.setdefault("route_hops", [])
 148:     e.setdefault("execution_key", None)
 149:     return e
 150: 
 151: 
 152: def _latest_map(events: List[dict]) -> Dict[str, dict]:
 153:     latest: Dict[str, dict] = {}
 154:     for e in events:
 155:         e = _normalize_event(e)
 156:         latest[e["event_id"]] = e
 157:     return latest
 158: 
 159: 
 160: def rebuild_event_state_index() -> Dict[str, dict]:
 161:     return _latest_map(load_events())
 162: 
 163: 
 164: def get_latest_event(event_id: str) -> Optional[dict]:
 165:     events = load_events()
 166:     for e in reversed(events):
 167:         if e["event_id"] == event_id:
 168:             return _normalize_event(e)
 169:     return None
 170: 
 171: 
 172: def get_created_events():
 173:     latest = rebuild_event_state_index()
 174:     domain_events = [ClusterEvent(**e) for e in latest.values()]
 175:     return [e for e in domain_events if e.status == EventStatus.CREATED]
 176: 
 177: 
 178: def get_completed_event_ids():
 179:     latest = rebuild_event_state_index()
 180:     domain_events = [ClusterEvent(**e) for e in latest.values()]
 181:     return {e.event_id for e in domain_events if e.status == EventStatus.COMPLETED}
 182: 
 183: 
 184: def append_event(event: ClusterEvent):
 185:     ensure_dir()
 186: 
 187:     record = {
 188:         "event_id": event.event_id,
 189:         "event_type": event.event_type,
 190:         "schema_version": str(event.schema_version),
 191:         "created_at": event.created_at,
 192:         "updated_at": getattr(event, "updated_at", None),
 193:         "received_at": getattr(event, "received_at", None),
 194:         "trace_id": event.trace_id,
 195:         "target_node": event.target_node,
 196:         "source_node": getattr(event, "source_node", None),
 197:         "route_hops": list(getattr(event, "route_hops", []) or []),
 198:         "status": event.status.value if hasattr(event.status, "value") else event.status,
 199:         "attempt": event.attempt,
 200:         "execution_key": getattr(event, "execution_key", None),
 201:         "payload": event.payload,
 202:     }
 203: 
 204:     if record["status"] == EventStatus.COMPLETED.value:
 205:         existing = load_events()
 206:         if any(
 207:             e.get("event_id") == event.event_id and e.get("status") == EventStatus.COMPLETED.value
 208:             for e in existing
 209:         ):
 210:             return
 211: 
 212:     with open(LOCAL_LOG_PATH, "a", encoding="utf-8") as f:
 213:         f.write(json.dumps(record) + "\n")
 214:         f.flush()
 215:         os.fsync(f.fileno())
 216: 
 217:     try:
 218:         write_state({
 219:             "dirty": True,
 220:             "last_append_event_id": event.event_id,
 221:             "last_append_created_at": event.created_at,
 222:         })
 223:     except Exception as e:
 224:         print(f"[STATE WRITE FAIL] {event.event_id} -> {e}")
 225: 
 226: 
 227: def replay_events(handler, stream: str | None = None):
 228:     events = load_events()
 229:     for raw in events:
 230:         event = ClusterEvent(**_normalize_event(raw))
 231:         handler(event)



===== ./runtime/leader.py =====
   1: import time
   2: 
   3: from cluster.runtime.cluster_store import cluster_state
   4: from cluster.runtime import context as ctx
   5: 
   6: LEADER_ALIVE_TIMEOUT = 1.5
   7: 
   8: 
   9: def refresh_self_alive_entry(now=None):
  10:     now = now or time.time()
  11:     if not getattr(ctx, "node", None):
  12:         return
  13:     cluster_state[ctx.node_id] = {
  14:         "state": ctx.node.state.value,
  15:         "priority": ctx.node.priority,
  16:         "last_seen": now,
  17:     }
  18: 
  19: 
  20: def is_alive(data, timeout=LEADER_ALIVE_TIMEOUT, now=None):
  21:     now = now or time.time()
  22:     return (now - data.get("last_seen", 0)) < timeout
  23: 
  24: 
  25: def compute_alive(timeout=LEADER_ALIVE_TIMEOUT, include_self=True):
  26:     now = time.time()
  27:     if include_self:
  28:         refresh_self_alive_entry(now)
  29:     active_nodes = {}
  30:     for node_id, data in cluster_state.items():
  31:         if is_alive(data, timeout=timeout, now=now):
  32:             active_nodes[node_id] = data
  33:     return active_nodes
  34: 
  35: 
  36: def compute_leader(debug_node_id=None, timeout=LEADER_ALIVE_TIMEOUT):
  37:     active_nodes = compute_alive(timeout=timeout, include_self=True)
  38:     if not active_nodes:
  39:         return None
  40:     return min(active_nodes.items(), key=lambda x: (x[1].get("priority", 9999), x[0]))[0]



===== ./runtime/log_replication.py =====
   1: 
   2: import logging
   3: import time
   4: 
   5: import requests
   6: 
   7: from cluster.runtime import context as ctx
   8: from cluster.runtime.cluster_store import cluster_state
   9: from cluster.runtime.registry import CLUSTER_REGISTRY
  10: from cluster.runtime.event_log import read_local_log_text, write_replica_log, get_replica_log_path, read_state, write_state, clear_state
  11: from cluster.utils.log_print import log_state
  12: 
  13: logging.getLogger("urllib3").setLevel(logging.ERROR)
  14: logging.getLogger("requests").setLevel(logging.ERROR)
  15: 
  16: PEERALIVETTLSEC = 3.0
  17: 
  18: 
  19: def canonical_replica_node_id() -> str:
  20:     return ctx.node_id
  21: 
  22: 
  23: def alive_peer_ids():
  24:     out = []
  25:     now = time.time()
  26:     for node_id, data in cluster_state.items():
  27:         if node_id == ctx.node_id:
  28:             continue
  29:         if now - data.get("last_seen", 0) > PEERALIVETTLSEC:
  30:             continue
  31:         out.append(node_id)
  32:     return out
  33: 
  34: 
  35: def replicate_local():
  36:     node_id = canonical_replica_node_id()
  37: 
  38:     log_state("cyan", "REPL TICK", f"node={node_id}", 3)
  39: 
  40:     allowed_states = {"ACTIVE", "STANDBY", "DEGRADED"}
  41:     node_state = getattr(getattr(ctx, "node", None), "state", None)
  42:     node_state_value = getattr(node_state, "value", None)
  43:     log_state("cyan", "REPL STATE", f"state={node_state_value} allowed={node_state_value in allowed_states}", 3)
  44:     if node_state_value not in allowed_states:
  45:         return
  46: 
  47:     state = read_state()
  48:     dirty = bool(state.get("dirty", False))
  49:     log_state("cyan", "REPL FLAG", f"dirty={dirty} state_exists={bool(state)}", 3)
  50:     if not dirty:
  51:         return
  52: 
  53:     content = read_local_log_text()
  54:     log_state("cyan", "REPL CONTENT", f"len={len(content)} empty={not content.strip()}", 3)
  55:     if not content.strip():
  56:         log_state("yellow", "REPL SKIP", "empty content", 3)
  57:         return
  58: 
  59:     write_replica_log(node_id, content)
  60:     log_state("cyan", "REPL WRITE", f"bytes={len(content)}", 3)
  61: 
  62:     peers = alive_peer_ids()
  63:     log_state("cyan", "REPL PEERS", f"peers={peers}", 3)
  64:     if not peers:
  65:         log_state("yellow", "REPL SKIP", "no peers", 3)
  66:         return
  67: 
  68:     success = True
  69:     for peer_id in peers:
  70:         node = CLUSTER_REGISTRY.get(peer_id)
  71:         if not node:
  72:             log_state("red", "LOG REPL FAIL", f"{peer_id} missing registry", 3)
  73:             success = False
  74:             continue
  75: 
  76:         url = f"http://{node['host']}:{node['port']}/debug/log/replica/{node_id}"
  77:         log_state("cyan", "REPL POST", f"peer={peer_id} url={url}", 3)
  78:         try:
  79:             resp = requests.post(
  80:                 url,
  81:                 data=content.encode("utf-8"),
  82:                 headers={"Content-Type": "text/plain; charset=utf-8"},
  83:                 timeout=2,
  84:             )
  85:             if resp.ok:
  86:                 log_state("cyan", "LOG REPL", f"{node_id} -> {peer_id}", 3)
  87:             else:
  88:                 success = False
  89:                 log_state("red", "LOG REPL FAIL", f"{peer_id} status={resp.status_code}", 3)
  90:         except Exception as e:
  91:             success = False
  92:             log_state("red", "LOG REPL FAIL", f"{peer_id} err={e}", 3)
  93: 
  94:     if success:
  95:         clear_state()
  96:         log_state("cyan", "REPL CLEAR", "dirty=false", 3)



