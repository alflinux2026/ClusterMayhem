 166:         return {"error": "node isolated"}
 167: 
 168:     existing = cluster_state.get(hb.node_id, {})
 169:     cluster_state[hb.node_id] = {
 170:         "state": hb.state,
 171:         "priority": hb.priority,
 172:         "last_seen": time.time(),
 173:         "log_meta": hb.log_meta or {},
 174:         "cluster_integrity": {"integrity_ok": bool((hb.cluster_integrity or {}).get("integrity_ok", True))},
 175:         "streams": hb.streams or existing.get("streams", {}),
 176:     }
 177: 
 178:     return {"ok": True}
