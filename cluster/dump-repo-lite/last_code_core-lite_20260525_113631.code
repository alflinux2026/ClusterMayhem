 387: @app.post("/heartbeat")
 388: def heartbeat(hb: Heartbeat):
 389:     if ctx.node.state == NodeState.ISOLATED:
 390:         return {"error": "node isolated"}
 391: 
 392:     existing = cluster_state.get(hb.node_id, {})
 393:     cluster_state[hb.node_id] = {
 394:         **existing,
 395:         "state": hb.state,
 396:         "priority": hb.priority,
 397:         "last_seen": time.time(),
 398:         "state_since": hb.state_since if hb.state_since is not None else existing.get("state_since"),
 399:         "prev_state": hb.prev_state if hb.prev_state is not None else existing.get("prev_state"),
 400:         "state_reason": hb.state_reason if hb.state_reason is not None else existing.get("state_reason"),
 401:         "log_meta": hb.log_meta or existing.get("log_meta", {}),
 402:         "cluster_integrity": hb.cluster_integrity or existing.get("cluster_integrity", {}),
 403:         "streams": hb.streams or existing.get("streams", {}),
 404:     }
 405: 
 406:     return {"ok": True}
 407: 
