 301: @app.post("/sleep")
 302: def sleep():
 303:     log_state("red", "- SLEEP -", f"{ctx.node_id} -> SLEEP", 3)
 304:     ctx.node.transition(NodeState.ISOLATED, reason="sleep_command")
 305:     return {
 306:         "ok": True,
 307:         "node": ctx.node_id,
 308:         "state": ctx.node.state.value,
 309:         "state_since": getattr(ctx.node, "state_since", None),
 310:         "prev_state": getattr(ctx.node, "prev_state", None),
 311:         "state_reason": getattr(ctx.node, "state_reason", None),
 312:     }
