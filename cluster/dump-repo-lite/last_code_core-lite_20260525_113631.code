 409: @app.get("/dashboard/compact")
 410: def dashboard_compact():
 411:     now = time.time()
 412:     leader = compute_leader()
 413:     local_events = events_summary()
 414:     integrity = local_integrity_api()
 415: 
 416:     local_node = cluster_state.get(ctx.node_id, {}) or {}
 417: 
 418:     try:
 419:         from cluster.runtime.progress_watchdog import (
 420:             get_progress_age_s,
 421:             get_progress_duration_s,
 422:             get_progress_pct,
 423:             refresh_progress_stalled_flag,
 424:         )
 425:     except Exception:
 426:         get_progress_age_s = None
 427:         get_progress_duration_s = None
 428:         get_progress_pct = None
 429:         refresh_progress_stalled_flag = None
 430: 
 431:     nodes = []
 432:     for node_id, node in sorted(cluster_state.items()):
 433:         log_meta = node.get("log_meta", {}) or {}
 434:         counts = (((node.get("streams") or {}).get("events_summary_local") or {}).get("counts") or {})
 435: 
 436:         progress_age_s = None
 437:         progress_duration_s = None
 438:         progress_pct = None
 439:         progress_stalled = bool(node.get("progress_stalled", False))
 440: 
 441:         if refresh_progress_stalled_flag is not None:
 442:             try:
 443:                 progress_stalled = bool(refresh_progress_stalled_flag(node_id=node_id, now=now))
 444:                 node = cluster_state.get(node_id, node) or node
 445:             except Exception:
 446:                 progress_stalled = bool(node.get("progress_stalled", False))
 447: 
 448:         if get_progress_age_s is not None:
 449:             try:
 450:                 progress_age_s = get_progress_age_s(node=node, now=now)
 451:             except Exception:
 452:                 progress_age_s = None
 453: 
 454:         if get_progress_duration_s is not None:
 455:             try:
 456:                 progress_duration_s = get_progress_duration_s(node=node, now=now)
 457:             except Exception:
 458:                 progress_duration_s = None
 459: 
 460:         if get_progress_pct is not None:
 461:             try:
 462:                 progress_pct = get_progress_pct(node=node)
 463:             except Exception:
 464:                 progress_pct = None
 465:         else:
 466:             try:
 467:                 current = node.get("progress_current")
 468:                 total = node.get("progress_total")
 469:                 if current is not None and total not in (None, 0):
 470:                     progress_pct = round((float(current) / float(total)) * 100.0, 1)
 471:             except Exception:
 472:                 progress_pct = None
 473: 
 474:         item = {
 475:             "node_id": node_id,
 476:             "state": node.get("state"),
 477:             "state_since": node.get("state_since"),
 478:             "state_age_s": round(_state_age_s(node, now) or 0.0, 1),
 479:             "prev_state": node.get("prev_state"),
 480:             "state_reason": node.get("state_reason"),
 481:             "priority": node.get("priority"),
 482:             "last_seen": node.get("last_seen"),
 483:             "seen_age_s": round(_seen_age_s(node, now) or 0.0, 1),
 484:             "last_watchdog": node.get("last_watchdog"),
 485:             "watchdog_age_s": round(_watchdog_age_s(node, now) or 0.0, 1) if node.get("last_watchdog") is not None else None,
 486:             "watchdog_busy": node.get("watchdog_busy"),
 487:             "presence_age_s": round(_presence_age_s(node, now) or 0.0, 1),
 488:             "health": _presence_health(node, now, stale_after_s=3.0),
 489:             "local_size": log_meta.get("size", 0),
 490:             "local_events": ((node.get("streams") or {}).get("events_summary_local") or {}).get("total_events", 0),
 491:             "created": counts.get("created", 0),
 492:             "executing": counts.get("executing", 0),
 493:             "completed": counts.get("completed", 0),
 494:             "dirty": ((node.get("cluster_integrity") or {}).get("last_append_meta") or {}).get("dirty"),
 495: 
 496:             "progress_active": bool(node.get("progress_active", False)),
 497:             "progress_stage": node.get("progress_stage"),
 498:             "progress_started_at": node.get("progress_started_at"),
 499:             "progress_touched_at": node.get("progress_touched_at"),
 500:             "progress_age_s": round(progress_age_s, 1) if progress_age_s is not None else None,
 501:             "progress_duration_s": round(progress_duration_s, 1) if progress_duration_s is not None else None,
 502:             "progress_current": node.get("progress_current"),
 503:             "progress_total": node.get("progress_total"),
 504:             "progress_pct": progress_pct,
 505:             "progress_stalled": progress_stalled,
 506:             "progress_meta": node.get("progress_meta", {}) or {},
 507:         }
 508:         nodes.append(item)
 509: 
 510:     local_progress = {
 511:         "progress_active": bool(local_node.get("progress_active", False)),
 512:         "progress_stage": local_node.get("progress_stage"),
 513:         "progress_started_at": local_node.get("progress_started_at"),
 514:         "progress_touched_at": local_node.get("progress_touched_at"),
 515:         "progress_age_s": None,
 516:         "progress_duration_s": None,
 517:         "progress_current": local_node.get("progress_current"),
 518:         "progress_total": local_node.get("progress_total"),
 519:         "progress_pct": None,
 520:         "progress_stalled": bool(local_node.get("progress_stalled", False)),
 521:         "progress_meta": local_node.get("progress_meta", {}) or {},
 522:     }
 523: 
 524:     if refresh_progress_stalled_flag is not None:
 525:         try:
 526:             local_progress["progress_stalled"] = bool(refresh_progress_stalled_flag(node_id=ctx.node_id, now=now))
 527:             local_node = cluster_state.get(ctx.node_id, local_node) or local_node
 528:             local_progress["progress_active"] = bool(local_node.get("progress_active", False))
 529:             local_progress["progress_stage"] = local_node.get("progress_stage")
 530:             local_progress["progress_started_at"] = local_node.get("progress_started_at")
 531:             local_progress["progress_touched_at"] = local_node.get("progress_touched_at")
 532:             local_progress["progress_current"] = local_node.get("progress_current")
 533:             local_progress["progress_total"] = local_node.get("progress_total")
 534:             local_progress["progress_meta"] = local_node.get("progress_meta", {}) or {}
 535:         except Exception:
 536:             pass
 537: 
 538:     if get_progress_age_s is not None:
 539:         try:
 540:             age = get_progress_age_s(node=local_node, now=now)
 541:             local_progress["progress_age_s"] = round(age, 1) if age is not None else None
 542:         except Exception:
 543:             pass
 544: 
 545:     if get_progress_duration_s is not None:
 546:         try:
 547:             duration = get_progress_duration_s(node=local_node, now=now)
 548:             local_progress["progress_duration_s"] = round(duration, 1) if duration is not None else None
 549:         except Exception:
 550:             pass
 551: 
 552:     if get_progress_pct is not None:
 553:         try:
 554:             local_progress["progress_pct"] = get_progress_pct(node=local_node)
 555:         except Exception:
 556:             pass
 557:     else:
 558:         try:
 559:             current = local_node.get("progress_current")
 560:             total = local_node.get("progress_total")
 561:             if current is not None and total not in (None, 0):
 562:                 local_progress["progress_pct"] = round((float(current) / float(total)) * 100.0, 1)
 563:         except Exception:
 564:             pass
 565: 
 566:     return {
 567:         "cluster": {
 568:             "node_id": ctx.node_id,
 569:             "leader": leader,
 570:             "generated_at": now,
 571:             "integrity_ok": bool(integrity.get("integrity_ok", True)),
 572:             "local_state": ctx.node.state.value,
 573:             "local_state_since": getattr(ctx.node, "state_since", None),
 574:             "local_state_age_s": round(_state_age_s({
 575:                 "state_since": getattr(ctx.node, "state_since", None)
 576:             }, now) or 0.0, 1),
 577:         },
 578:         "local": {
 579:             "events_summary": local_events,
