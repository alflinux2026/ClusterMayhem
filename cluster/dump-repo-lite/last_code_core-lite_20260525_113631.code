 344:         "state_age_s": _round_or_none(_state_age_s({"state_since": getattr(ctx.node, "state_since", None)}), 3),
 345:         "last_seen": local_node.get("last_seen"),
 346:         "seen_age_s": _round_or_none(_seen_age_s(local_node), 3),
 347:         "last_watchdog": local_node.get("last_watchdog"),
 348:         "watchdog_age_s": _round_or_none(_watchdog_age_s(local_node), 3),
 349:         "watchdog_busy": local_node.get("watchdog_busy"),
 350:         "presence_age_s": _round_or_none(_presence_age_s(local_node), 3),
 351:         "sleeping": ctx.node.state == NodeState.ISOLATED,
 352:     }
