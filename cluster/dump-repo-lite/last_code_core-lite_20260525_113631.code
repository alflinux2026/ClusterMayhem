  47: class Watchdog(BaseModel):
  48:     node_id: str
  49:     busy: bool = True
  50:     emitted_at: float | None = None
  51: 
  52: 
  53: def _round_or_none(value: float | None, digits: int = 1) -> float | None:
  54:     if value is None:
  55:         return None
  56:     try:
  57:         return round(float(value), digits)
  58:     except Exception:
  59:         return None
  60: 
  61: 
  62: def _watchdog_age_s(node: dict, now: float | None = None) -> float | None:
  63:     now = now or time.time()
  64:     last_watchdog = node.get("last_watchdog")
  65:     if last_watchdog is None:
  66:         return None
  67:     try:
  68:         return max(0.0, now - float(last_watchdog))
  69:     except Exception:
  70:         return None
  71: 
  72: 
  73: def _state_age_s(node: dict, now: float | None = None) -> float | None:
  74:     now = now or time.time()
  75:     state_since = node.get("state_since")
  76:     if state_since is None:
  77:         return None
  78:     try:
  79:         return max(0.0, now - float(state_since))
  80:     except Exception:
  81:         return None
  82: 
  83: 
  84: def _seen_age_s(node: dict, now: float | None = None) -> float | None:
  85:     now = now or time.time()
  86:     last_seen = node.get("last_seen")
  87:     if last_seen is None:
  88:         return None
  89:     try:
  90:         return max(0.0, now - float(last_seen))
  91:     except Exception:
  92:         return None
  93: 
  94: 
  95: def _presence_age_s(node: dict, now: float | None = None) -> float | None:
  96:     now = now or time.time()
  97:     last_seen = node.get("last_seen")
  98:     last_watchdog = node.get("last_watchdog")
  99: 
 100:     candidates = []
 101:     for value in (last_seen, last_watchdog):
 102:         if value is None:
 103:             continue
 104:         try:
 105:             candidates.append(float(value))
 106:         except Exception:
 107:             continue
 108: 
 109:     if not candidates:
 110:         return None
 111: 
 112:     return max(0.0, now - max(candidates))
 113: 
 114: 
 115: def _presence_health(node: dict, now: float | None = None, stale_after_s: float = 3.0) -> str:
 116:     age = _presence_age_s(node, now)
 117:     if age is None:
 118:         return "stale"
 119:     return "ok" if age < stale_after_s else "stale"
 120: 
 121: 
 122: def _compact_node(node: dict) -> dict:
 123:     now = time.time()
 124:     return {
 125:         "state": node.get("state"),
 126:         "priority": node.get("priority"),
 127:         "last_seen": node.get("last_seen"),
 128:         "seen_age_s": _round_or_none(_seen_age_s(node, now), 3),
 129:         "last_watchdog": node.get("last_watchdog"),
 130:         "watchdog_age_s": _round_or_none(_watchdog_age_s(node, now), 3),
 131:         "watchdog_busy": node.get("watchdog_busy"),
 132:         "presence_age_s": _round_or_none(_presence_age_s(node, now), 3),
 133:         "presence_health": _presence_health(node, now),
 134:         "state_since": node.get("state_since"),
 135:         "state_age_s": _round_or_none(_state_age_s(node, now), 3),
 136:         "prev_state": node.get("prev_state"),
 137:         "state_reason": node.get("state_reason"),
 138:         "log_meta": node.get("log_meta", {}),
 139:         "streams": node.get("streams", {}),
 140:     }
 141: 
 142: 
 143: def _read_jsonl(path: str) -> list[dict]:
 144:     if not os.path.exists(path):
 145:         return []
 146: 
 147:     out: list[dict] = []
 148:     with open(path, "r", encoding="utf-8") as f:
 149:         for line in f:
 150:             line = line.strip()
 151:             if not line:
 152:                 continue
 153:             try:
 154:                 out.append(json.loads(line))
 155:             except Exception:
 156:                 continue
 157:     return out
 158: 
 159: 
 160: def _summarize_events(events: list[dict]) -> dict:
 161:     latest_by_event_id: dict[str, dict] = {}
 162:     last_event_id = None
 163: 
 164:     for event in events:
 165:         event_id = event.get("event_id")
 166:         if not event_id:
 167:             continue
 168:         latest_by_event_id[event_id] = event
 169:         last_event_id = event_id
 170: 
 171:     counts = Counter()
 172:     for event in latest_by_event_id.values():
 173:         status = event.get("status", "unknown")
 174:         counts[status] += 1
 175: 
 176:     return {
 177:         "total_events": len(latest_by_event_id),
 178:         "counts": {
 179:             "created": counts.get("created", 0),
 180:             "executing": counts.get("executing", 0),
 181:             "completed": counts.get("completed", 0),
 182:             "unknown": counts.get("unknown", 0),
 183:         },
 184:         "last_event_id": last_event_id,
 185:     }
