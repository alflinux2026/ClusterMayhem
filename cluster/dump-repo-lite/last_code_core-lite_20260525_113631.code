 329: @app.get("/health")
 330: def health():
 331:     local_entry = cluster_state.get(ctx.node_id, {})
 332:     local_node = {
 333:         "state_since": getattr(ctx.node, "state_since", None),
 334:         "last_seen": local_entry.get("last_seen"),
 335:         "last_watchdog": local_entry.get("last_watchdog"),
