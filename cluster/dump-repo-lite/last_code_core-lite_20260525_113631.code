 212: @app.post("/debug/log/replica/{node_id}")
 213: async def log_replica_write(node_id: str, request: Request):
 214:     try:
 215:         content = await request.body()
 216:     except Exception as e:
 217:         return {"ok": False, "node_id": node_id, "error": str(e)}
 218: 
 219:     text = content.decode("utf-8") if content else ""
 220:     write_replica_log(node_id, text)
 221:     return {
 222:         "ok": True,
 223:         "node_id": node_id,
 224:         "path": get_replica_log_path(node_id),
 225:         "bytes": len(content),
 226:     }
