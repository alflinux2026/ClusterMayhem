 276: @app.post("/event")
 277: def handle_event(event: ClusterEvent):
 278:     if ctx.node.state == NodeState.ISOLATED:
 279:         return {"error": "node isolated"}
 280: 
 281:     leader = compute_leader()
 282:     if not leader:
 283:         log_state("red", "(NO LEADER)", event.event_id, 3)
 284:         return {"error": "no leader"}
 285: 
 286:     if leader != ctx.node_id:
 287:         msg = event.payload.get("msg", "<no-msg>")
 288:         log_state("cyan", "[EVENT FWD]", f"{msg:12} -> {leader}", 3)
 289:         node = CLUSTER_REGISTRY[leader]
 290:         url = f"http://{node['host']}:{node['port']}/event"
 291:         try:
 292:             resp = requests.post(url, json=event.model_dump(), timeout=2)
 293:             return resp.json()
 294:         except Exception as e:
 295:             return {"error": str(e)}
 296: 
 297:     result = ingest_event(event, ctx.node_id)
 298:     return {"status": "ok", "event_id": event.event_id, "result": result}
 299: 
