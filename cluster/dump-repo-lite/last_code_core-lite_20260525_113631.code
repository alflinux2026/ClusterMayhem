 365: @app.post("/watchdog")
 366: def watchdog(wd: Watchdog):
 367:     if ctx.node.state == NodeState.ISOLATED:
 368:         return {"error": "node isolated"}
 369: 
 370:     existing = cluster_state.get(wd.node_id, {})
 371:     ts = wd.emitted_at if wd.emitted_at is not None else time.time()
 372: 
 373:     cluster_state[wd.node_id] = {
 374:         **existing,
 375:         "last_watchdog": ts,
 376:         "watchdog_busy": bool(wd.busy),
 377:     }
 378: 
 379:     return {
 380:         "ok": True,
 381:         "node_id": wd.node_id,
 382:         "last_watchdog": ts,
 383:         "watchdog_busy": bool(wd.busy),
 384:     }
 385: 
