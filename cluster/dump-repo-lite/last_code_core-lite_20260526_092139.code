 231: @app.post("/debug/log/replica/{node_id}")
 232: async def log_replica_write(node_id: str, request: Request):
 233:     try:
 234:         content = await request.body()
 235:     except Exception as e:
 236:         return {"ok": False, "node_id": node_id, "error": str(e)}
 237: 
 238:     text = content.decode("utf-8") if content else ""
 239:     write_replica_log(node_id, text)
 240:     return {
 241:         "ok": True,
 242:         "node_id": node_id,
 243:         "path": get_replica_log_path(node_id),
 244:         "bytes": len(content),
 245:     }
