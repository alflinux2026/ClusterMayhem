 232: def _normalize_event(e: dict) -> dict:
 233:     e = dict(e)
 234:     e["schema_version"] = str(e.get("schema_version", "0.1"))
 235:     e.setdefault("received_at", None)
 236:     e.setdefault("attempt", 0)
 237:     e.setdefault("route_hops", [])
 238:     e.setdefault("execution_key", None)
 239:     return e
 240: 
 241: 
 242: def _latest_map(events: List[dict]) -> Dict[str, dict]:
 243:     latest: Dict[str, dict] = {}
 244:     for e in events:
 245:         e = _normalize_event(e)
 246:         latest[e["event_id"]] = e
 247:     return latest
 248: 
 249: 
 250: def rebuild_event_state_index() -> Dict[str, dict]:
 251:     return _latest_map(load_events())
 252: 
 253: 
 254: def get_latest_event(event_id: str) -> Optional[dict]:
 255:     events = load_events()
 256:     for e in reversed(events):
 257:         if e["event_id"] == event_id:
 258:             return _normalize_event(e)
 259:     return None
 260: 
 261: 
 262: def get_created_events():
 263:     latest = rebuild_event_state_index()
 264:     domain_events = [ClusterEvent(**e) for e in latest.values()]
 265:     return [e for e in domain_events if e.status == EventStatus.CREATED]
 266: 
 267: 
 268: def get_completed_event_ids():
 269:     latest = rebuild_event_state_index()
 270:     domain_events = [ClusterEvent(**e) for e in latest.values()]
 271:     return {e.event_id for e in domain_events if e.status == EventStatus.COMPLETED}
 272: 
 273: 
 274: def append_event(event: ClusterEvent):
 275:     ensure_initial_files()
 276: 
 277:     record = {
 278:         "event_id": event.event_id,
 279:         "event_type": event.event_type,
 280:         "schema_version": str(event.schema_version),
 281:         "created_at": event.created_at,
 282:         "updated_at": getattr(event, "updated_at", None),
 283:         "received_at": getattr(event, "received_at", None),
 284:         "trace_id": event.trace_id,
 285:         "target_node": event.target_node,
 286:         "source_node": getattr(event, "source_node", None),
 287:         "route_hops": list(getattr(event, "route_hops", []) or []),
 288:         "status": event.status.value if hasattr(event.status, "value") else event.status,
 289:         "attempt": event.attempt,
 290:         "execution_key": getattr(event, "execution_key", None),
 291:         "payload": event.payload,
 292:     }
 293: 
 294:     line = json.dumps(record) + "\n"
 295:     with open(LOCAL_LOG_PATH, "a", encoding="utf-8") as f:
 296:         f.write(line)
 297:         f.flush()
 298:         os.fsync(f.fileno())
 299: 
 300:     state = read_state()
 301:     state["dirty"] = True
 302:     state["last_append_event_id"] = event.event_id
 303:     state["last_append_created_at"] = event.created_at
 304:     state["last_append_updated_at"] = getattr(event, "updated_at", None)
 305: 
 306: 
 307: 
 308:     if record["status"] == EventStatus.COMPLETED.value:
 309:         with open(COMPLETED_LOG_PATH, "a", encoding="utf-8") as f:
 310:             f.write(line)
 311:             f.flush()
 312:             os.fsync(f.fileno())
 313: 
 314:         state["events_dirty"] = True
 315:         state["last_completed_event_id"] = event.event_id
 316:         state["last_completed_created_at"] = event.created_at
 317:         state["last_completed_updated_at"] = getattr(event, "updated_at", None)
 318: 
 319:     try:
 320:         write_state(state)
 321: 
 322:     except Exception as e:
 323:         print(f"[STATE WRITE FAIL] {event.event_id} -> {e}")
 324: 
 325: 
 326: def replay_events(handler, stream: str | None = None):
 327:     events = load_events()
 328:     for raw in events:
 329:         event = ClusterEvent(**_normalize_event(raw))
 330:         handler(event)
 331: 



===== ./runtime/leader.py =====
   1: import time
   2: 
   3: from cluster.runtime.cluster_store import cluster_state
   4: from cluster.runtime import context as ctx
   5: 
   6: LEADER_ALIVE_TIMEOUT = 1.5
   7: 
   8: 
   9: def refresh_self_alive_entry(now=None):
  10:     now = now or time.time()
  11:     if not getattr(ctx, "node", None):
  12:         return
  13: 
  14:     existing = cluster_state.get(ctx.node_id, {})
  15: 
  16:     cluster_state[ctx.node_id] = {
  17:         **existing,
  18:         "state": ctx.node.state.value,
  19:         "priority": ctx.node.priority,
  20:         "last_seen": now,
  21:         "state_since": getattr(ctx.node, "state_since", None),
  22:         "prev_state": getattr(ctx.node, "prev_state", None),
  23:         "state_reason": getattr(ctx.node, "state_reason", None),
  24:     }
  25: 
  26: 
  27: def last_presence_ts(data: dict) -> float:
  28:     candidates = []
  29:     for key in ("last_seen", "last_watchdog"):
  30:         value = data.get(key, 0)
  31:         if value is None:
  32:             continue
  33:         try:
  34:             candidates.append(float(value))
  35:         except Exception:
  36:             continue
  37:     return max(candidates) if candidates else 0.0
  38: 
  39: 
  40: def is_alive(data, timeout=LEADER_ALIVE_TIMEOUT, now=None):
  41:     now = now or time.time()
  42:     last_presence = last_presence_ts(data)
  43:     return (now - last_presence) < timeout
  44: 
  45: 
  46: def compute_alive(timeout=LEADER_ALIVE_TIMEOUT, include_self=True):
  47:     now = time.time()
  48:     if include_self:
  49:         refresh_self_alive_entry(now)
  50: 
  51:     active_nodes = {}
  52:     for node_id, data in cluster_state.items():
  53:         if is_alive(data, timeout=timeout, now=now):
  54:             active_nodes[node_id] = data
  55:     return active_nodes
  56: 
  57: 
  58: def compute_leader(debug_node_id=None, timeout=LEADER_ALIVE_TIMEOUT):
  59:     active_nodes = compute_alive(timeout=timeout, include_self=True)
  60:     if not active_nodes:
  61:         return None
  62:     return min(
  63:         active_nodes.items(),
  64:         key=lambda x: (x[1].get("priority", 9999), x[0]),
  65:     )[0]



