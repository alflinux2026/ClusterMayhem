  39: class Heartbeat(BaseModel):
  40:     node_id: str
  41:     state: str
  42:     priority: int
  43:     state_since: float | None = None
  44:     prev_state: str | None = None
  45:     state_reason: str | None = None
  46:     log_meta: dict | None = None
  47:     cluster_integrity: dict | None = None
