 100: def _write_json_atomic(target_path: Path, payload: dict):
 101:     ensure_dir()
 102:     with _STATE_LOCK:
 103:         fd, tmp_name = tempfile.mkstemp(
 104:             prefix=f"{target_path.name}.",
 105:             suffix=".tmp",
 106:             dir=str(target_path.parent),
 107:             text=True,
 108:         )
 109:         try:
 110:             with os.fdopen(fd, "w", encoding="utf-8") as f:
 111:                 json.dump(payload, f, ensure_ascii=False)
 112:                 f.flush()
 113:                 os.fsync(f.fileno())
 114:             os.replace(tmp_name, str(target_path))
 115:         except Exception:
 116:             try:
 117:                 os.remove(tmp_name)
 118:             except FileNotFoundError:
 119:                 pass
 120:             raise
 121: 
 122: 
 123: def write_text_atomic(path: str, content: str):
 124:     ensure_dir()
 125:     target_path = Path(path)
 126:     fd, tmp_name = tempfile.mkstemp(
 127:         prefix=f"{target_path.name}.",
 128:         suffix=".tmp",
 129:         dir=str(target_path.parent),
 130:         text=True,
 131:     )
 132:     try:
 133:         with os.fdopen(fd, "w", encoding="utf-8") as f:
 134:             f.write(content)
 135:             f.flush()
 136:             os.fsync(f.fileno())
 137:         os.replace(tmp_name, str(target_path))
 138:     except Exception:
 139:         try:
 140:             os.remove(tmp_name)
 141:         except FileNotFoundError:
 142:             pass
 143:         raise
 144: 
 145: 
