 413: @app.post("/watchdog")
 414: def watchdog(wd: Watchdog):
 415:     if ctx.node.state == NodeState.ISOLATED:
 416:         return {"error": "node isolated"}
 417: 
 418:     existing = cluster_state.get(wd.node_id, {})
 419:     ts = wd.emitted_at if wd.emitted_at is not None else time.time()
 420: 
 421:     cluster_state[wd.node_id] = {
 422:         **existing,
 423:         "last_watchdog": ts,
 424:         "watchdog_busy": bool(wd.busy),
 425:     }
 426: 
 427:     return {
 428:         "ok": True,
 429:         "node_id": wd.node_id,
 430:         "last_watchdog": ts,
 431:         "watchdog_busy": bool(wd.busy),
 432:     }
 433: 
