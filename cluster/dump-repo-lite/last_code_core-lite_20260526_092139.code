 172: def read_state() -> dict:
 173:     if not STATE_PATH.exists():
 174:         return {}
 175: 
 176:     try:
 177:         with open(STATE_PATH, "r", encoding="utf-8") as f:
 178:             data = json.load(f)
 179:             return data if isinstance(data, dict) else {}
 180:     except (OSError, json.JSONDecodeError):
 181:         return {}
