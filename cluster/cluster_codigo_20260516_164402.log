def run_node(config):


    global node_id
    node_id = config["node_id"]


    node = NodeRuntime(
        node_id=config["node_id"],
        priority=config["priority"],
    )

    worker = NodeWorker(
        node=node,
        peers=config["peers"],
        interval=1.0
    )

    # start worker thread
    t = threading.Thread(target=worker.start, daemon=True)
    t.start()

    # start API
    uvicorn.run(
        app,
        host=config.get("bind_host", "0.0.0.0"),
        port=config.get("bind_port", 7000),
        log_level="warning",
        access_log=False
    )


