   8: 
   9: BASE_DIR = os.path.dirname(os.path.dirname(os.path.dirname(__file__)))
  10: DATA_DIR = os.path.join(BASE_DIR, "cluster", "data")
  11: LOCAL_LOG_PATH = os.path.join(DATA_DIR, "event_log.local.jsonl")
  12: STATE_PATH = os.path.join(DATA_DIR, "last_append.state.json")
  13: 
  14: 
  15: def ensure_dir():
  16:     os.makedirs(DATA_DIR, exist_ok=True)
  17: 
  18: 
  19: def ensure_initial_files():
  20:     ensure_dir()
  21: 
  22:     if not os.path.exists(STATE_PATH):
  23:         write_state({
  24:             "dirty": False,
  25:             "last_append_event_id": None,
  26:             "last_append_created_at": None,
  27:             "last_append_updated_at": None,
  28:         })
  29: 
  30:     if not os.path.exists(LOCAL_LOG_PATH):
  31:         with open(LOCAL_LOG_PATH, "a", encoding="utf-8"):
  32:             pass
  33: 
  34: 
  35: def get_local_log_path(stream: str | None = None) -> str:
  36:     return LOCAL_LOG_PATH
  37: 
  38: 
  39: def get_state_path() -> str:
  40:     return STATE_PATH
  41: 
  42: 
  43: def get_replica_log_path(node_id: str) -> str:
  44:     return os.path.join(DATA_DIR, f"event_log.{node_id}.jsonl")
  45: 
  46: 
  47: def list_replica_log_paths() -> List[str]:
  48:     if not os.path.exists(DATA_DIR):
  49:         return []
  50: 
  51:     out: List[str] = []
  52:     for name in sorted(os.listdir(DATA_DIR)):
  53:         if not name.startswith("event_log."):
  54:             continue
  55:         if not name.endswith(".jsonl"):
  56:             continue
  57:         if name == "event_log.local.jsonl":
  58:             continue
  59:         out.append(os.path.join(DATA_DIR, name))
  60:     return out
  61: 
  62: 
  63: def load_events_from_path(path: str) -> List[dict]:
  64:     if not os.path.exists(path):
  65:         return []
  66: 
  67:     events = []
  68:     with open(path, "r", encoding="utf-8") as f:
  69:         for line in f:
  70:             line = line.strip()
  71:             if not line:
  72:                 continue
  73:             try:
  74:                 events.append(json.loads(line))
  75:             except json.JSONDecodeError:
  76:                 continue
  77:     return events
  78: 
  79: 
  80: def write_text_atomic(path: str, content: str):
  81:     ensure_dir()
  82:     tmp_path = path + ".tmp"
  83:     with open(tmp_path, "w", encoding="utf-8") as f:
  84:         f.write(content)
  85:         f.flush()
  86:         os.fsync(f.fileno())
  87:     os.replace(tmp_path, path)
  88: 
  89: 
  90: def read_local_log_text() -> str:
  91:     if not os.path.exists(LOCAL_LOG_PATH):
  92:         return ""
  93:     with open(LOCAL_LOG_PATH, "r", encoding="utf-8") as f:
  94:         return f.read()
  95: 
  96: 
  97: def write_replica_log(node_id: str, content: str):
  98:     ensure_dir()
  99:     write_text_atomic(get_replica_log_path(node_id), content)
 100: 
 101: 
 102: def read_state() -> dict:
 103:     if not os.path.exists(STATE_PATH):
 104:         return {}
 105: 
 106:     try:
 107:         with open(STATE_PATH, "r", encoding="utf-8") as f:
 108:             data = json.load(f)
 109:             return data if isinstance(data, dict) else {}
 110:     except (OSError, json.JSONDecodeError):
 111:         return {}
 112: 
 113: 
 114: def get_last_append_meta() -> dict:
 115:     state = read_state()
 116:     return state if isinstance(state, dict) else {}
 117: 
 118: 
 119: def write_state(state: dict):
 120:     ensure_dir()
 121:     tmp_path = STATE_PATH + ".tmp"
 122:     with open(tmp_path, "w", encoding="utf-8") as f:
 123:         json.dump(state, f, ensure_ascii=False)
 124:         f.flush()
 125:         os.fsync(f.fileno())
 126:     os.replace(tmp_path, STATE_PATH)
 127: 
 128: 
 129: def clear_state():
 130:     write_state({
 131:         "dirty": False,
 132:         "last_append_event_id": None,
 133:         "last_append_created_at": None,
 134:         "last_append_updated_at": None,
 135:     })
 136: 
 137: 
 138: def load_events() -> List[dict]:
 139:     return load_events_from_path(LOCAL_LOG_PATH)
 140: 
 141: 
 142: def load_local_events() -> List[dict]:
 143:     return load_events_from_path(LOCAL_LOG_PATH)
 144: 
 145: 
 146: def load_replica_events(node_id: str) -> List[dict]:
 147:     return load_events_from_path(get_replica_log_path(node_id))
 148: 
 149: 
 150: def load_all_replica_events() -> List[dict]:
 151:     events: List[dict] = []
 152:     for path in list_replica_log_paths():
 153:         events.extend(load_events_from_path(path))
 154:     return events
 155: 
 156: 
 157: def load_cluster_events() -> List[dict]:
 158:     return load_all_replica_events()
 159: 
 160: 
 161: def _normalize_event(e: dict) -> dict:
 162:     e = dict(e)
 163:     e["schema_version"] = str(e.get("schema_version", "0.1"))
 164:     e.setdefault("received_at", None)
 165:     e.setdefault("attempt", 0)
 166:     e.setdefault("route_hops", [])
 167:     e.setdefault("execution_key", None)
 168:     return e
 169: 
 170: 
 171: def _latest_map(events: List[dict]) -> Dict[str, dict]:
 172:     latest: Dict[str, dict] = {}
 173:     for e in events:
 174:         e = _normalize_event(e)
 175:         latest[e["event_id"]] = e
 176:     return latest
 177: 
 178: 
 179: def rebuild_event_state_index() -> Dict[str, dict]:
 180:     return _latest_map(load_events())
 181: 
 182: 
 183: def get_latest_event(event_id: str) -> Optional[dict]:
 184:     events = load_events()
 185:     for e in reversed(events):
 186:         if e["event_id"] == event_id:
 187:             return _normalize_event(e)
 188:     return None
 189: 
 190: 
 191: def get_created_events():
 192:     latest = rebuild_event_state_index()
 193:     domain_events = [ClusterEvent(**e) for e in latest.values()]
 194:     return [e for e in domain_events if e.status == EventStatus.CREATED]
 195: 
 196: 
 197: def get_completed_event_ids():
 198:     latest = rebuild_event_state_index()
 199:     domain_events = [ClusterEvent(**e) for e in latest.values()]
 200:     return {e.event_id for e in domain_events if e.status == EventStatus.COMPLETED}
 201: 
 202: 
 203: def append_event(event: ClusterEvent):
 204:     ensure_initial_files()
 205: 
 206:     record = {
 207:         "event_id": event.event_id,
 208:         "event_type": event.event_type,
 209:         "schema_version": str(event.schema_version),
 210:         "created_at": event.created_at,
 211:         "updated_at": getattr(event, "updated_at", None),
 212:         "received_at": getattr(event, "received_at", None),
 213:         "trace_id": event.trace_id,
 214:         "target_node": event.target_node,
 215:         "source_node": getattr(event, "source_node", None),
 216:         "route_hops": list(getattr(event, "route_hops", []) or []),
 217:         "status": event.status.value if hasattr(event.status, "value") else event.status,
 218:         "attempt": event.attempt,
 219:         "execution_key": getattr(event, "execution_key", None),
 220:         "payload": event.payload,
 221:     }
 222: 
 223:     if record["status"] == EventStatus.COMPLETED.value:
 224:         existing = load_events()
 225:         if any(
 226:             e.get("event_id") == event.event_id and e.get("status") == EventStatus.COMPLETED.value
 227:             for e in existing
 228:         ):
 229:             return
 230: 
 231:     with open(LOCAL_LOG_PATH, "a", encoding="utf-8") as f:
 232:         f.write(json.dumps(record) + "\n")
 233:         f.flush()
 234:         os.fsync(f.fileno())
 235: 
 236:     try:
 237:         write_state({
 238:             "dirty": True,
 239:             "last_append_event_id": event.event_id,
 240:             "last_append_created_at": event.created_at,
 241:             "last_append_updated_at": getattr(event, "updated_at", None),
 242:         })
 243:     except Exception as e:
 244:         print(f"[STATE WRITE FAIL] {event.event_id} -> {e}")
 245: 
 246: 
 247: def replay_events(handler, stream: str | None = None):
 248:     events = load_events()
 249:     for raw in events:
 250:         event = ClusterEvent(**_normalize_event(raw))
 251:         handler(event)



