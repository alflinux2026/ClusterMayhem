 218: @app.post("/event")
 219: def handle_event(event: ClusterEvent):
 220:     if ctx.node.state == NodeState.ISOLATED:
 221:         return {"error": "node isolated"}
 222: 
 223:     leader = compute_leader()
 224:     if not leader:
 225:         log_state("red", "(NO LEADER)", event.event_id, 3)
 226:         return {"error": "no leader"}
 227: 
 228:     if leader != ctx.node_id:
 229:         msg = event.payload.get("msg", "<no-msg>")
 230:         log_state("cyan", "[EVENT FWD]", f"{msg:12} -> {leader}", 3)
 231:         node = CLUSTER_REGISTRY[leader]
 232:         url = f"http://{node['host']}:{node['port']}/event"
 233:         try:
 234:             resp = requests.post(url, json=event.model_dump(), timeout=2)
 235:             return resp.json()
 236:         except Exception as e:
 237:             return {"error": str(e)}
 238: 
 239:     result = ingest_event(event, ctx.node_id)
 240:     return {"status": "ok", "event_id": event.event_id, "result": result}
 241: 
