  35: class Heartbeat(BaseModel):
  36:     node_id: str
  37:     state: str
  38:     priority: int
  39:     state_since: float | None = None
  40:     prev_state: str | None = None
  41:     state_reason: str | None = None
  42:     log_meta: dict | None = None
  43:     cluster_integrity: dict | None = None
  44:     streams: dict | None = None
  45: 
  46: 
  47: def _state_age_s(node: dict, now: float | None = None) -> float | None:
  48:     now = now or time.time()
  49:     state_since = node.get("state_since")
  50:     if state_since is None:
  51:         return None
  52:     try:
  53:         return max(0.0, now - float(state_since))
  54:     except Exception:
  55:         return None
  56: 
  57: 
  58: def _seen_age_s(node: dict, now: float | None = None) -> float | None:
  59:     now = now or time.time()
  60:     last_seen = node.get("last_seen")
  61:     if last_seen is None:
  62:         return None
  63:     try:
  64:         return max(0.0, now - float(last_seen))
  65:     except Exception:
  66:         return None
  67: 
  68: 
  69: def _compact_node(node: dict) -> dict:
  70:     now = time.time()
  71:     return {
  72:         "state": node.get("state"),
  73:         "priority": node.get("priority"),
  74:         "last_seen": node.get("last_seen"),
  75:         "seen_age_s": _seen_age_s(node, now),
  76:         "state_since": node.get("state_since"),
  77:         "state_age_s": _state_age_s(node, now),
  78:         "prev_state": node.get("prev_state"),
  79:         "state_reason": node.get("state_reason"),
  80:         "log_meta": node.get("log_meta", {}),
  81:         "streams": node.get("streams", {}),
  82:     }
  83: 
  84: 
  85: def _read_jsonl(path: str) -> list[dict]:
  86:     if not os.path.exists(path):
  87:         return []
  88: 
  89:     out: list[dict] = []
  90:     with open(path, "r", encoding="utf-8") as f:
  91:         for line in f:
  92:             line = line.strip()
  93:             if not line:
  94:                 continue
  95:             try:
  96:                 out.append(json.loads(line))
  97:             except Exception:
  98:                 continue
  99:     return out
 100: 
 101: 
 102: def _summarize_events(events: list[dict]) -> dict:
 103:     latest_by_event_id: dict[str, dict] = {}
 104:     last_event_id = None
 105: 
 106:     for event in events:
 107:         event_id = event.get("event_id")
 108:         if not event_id:
 109:             continue
 110:         latest_by_event_id[event_id] = event
 111:         last_event_id = event_id
 112: 
 113:     counts = Counter()
 114:     for event in latest_by_event_id.values():
 115:         status = event.get("status", "unknown")
 116:         counts[status] += 1
 117: 
 118:     return {
 119:         "total_events": len(latest_by_event_id),
 120:         "counts": {
 121:             "created": counts.get("created", 0),
 122:             "executing": counts.get("executing", 0),
 123:             "completed": counts.get("completed", 0),
 124:             "unknown": counts.get("unknown", 0),
 125:         },
 126:         "last_event_id": last_event_id,
 127:     }
