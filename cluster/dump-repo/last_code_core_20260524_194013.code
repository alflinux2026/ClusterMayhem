   1: 
   2: import time
   3: import requests
   4: 
   5: from cluster.runtime.state import NodeState, ensure_state_meta, transition_node_state
   6: from cluster.runtime.leader import compute_leader
   7: from cluster.utils.log_print import log_state
   8: 
   9: 
  10: class NodeRuntime:
  11:     def __init__(self, node_id, priority):
  12:         self.node_id = node_id
  13:         self.priority = priority
  14:         self.state = NodeState.BOOT
  15:         self.last_heartbeat = time.time()
  16: 
  17:         ensure_state_meta(self)
  18:         self.state_reason = "node_init"
  19: 
  20:     def transition(self, new_state, reason=None):
  21:         result = transition_node_state(self, new_state, reason=reason)
  22: 
  23:         if result["changed"]:
  24:             print(
  25:                 f"[{self.node_id}] "
  26:                 f"{result['old_state']} -> {result['new_state']} "
  27:                 f"(reason={result['state_reason']})"
  28:             )
  29: 
  30:         return result
  31: 
  32:     def tick(self):
  33:         if self.state == NodeState.BOOT:
  34:             self.transition(NodeState.STANDBY, reason="boot_complete")
  35:             return
  36: 
  37:         leader = compute_leader()
  38: 
  39:         if leader == self.node_id:
  40:             if self.state == NodeState.STANDBY:
  41:                 log_state("yellow", "[CLUSTER]", f"[{self.node_id}] becoming ACTIVE", 3)
  42:                 self.transition(NodeState.ACTIVE, reason="leader_selected")
  43:         else:
  44:             if self.state == NodeState.ACTIVE:
  45:                 log_state("yellow", "[CLUSTER]", f"[{self.node_id}] becoming STANDBY", 3)
  46:                 self.transition(NodeState.STANDBY, reason="leader_lost")
  47: 
  48:     def emit_heartbeat(self, peers):
  49:         hb = {
  50:             "node_id": self.node_id,
  51:             "state": self.state.value,
  52:             "priority": self.priority,
  53:             "state_since": getattr(self, "state_since", None),
  54:             "prev_state": getattr(self, "prev_state", None),
  55:             "state_reason": getattr(self, "state_reason", None),
  56:         }
  57: 
  58:         for peer in peers:
  59:             url = f"http://{peer['host']}:{peer['port']}/heartbeat"
  60:             try:
  61:                 requests.post(url, json=hb, timeout=2)
  62:             except requests.exceptions.RequestException:
  63:                 pass



