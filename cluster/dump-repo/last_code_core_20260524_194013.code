 317: @app.get("/dashboard/compact")
 318: def dashboard_compact():
 319:     now = time.time()
 320:     leader = compute_leader()
 321:     local_events = events_summary()
 322:     integrity = local_integrity_api()
 323: 
 324:     nodes = []
 325:     for node_id, node in sorted(cluster_state.items()):
 326:         log_meta = node.get("log_meta", {}) or {}
 327:         counts = (((node.get("streams") or {}).get("events_summary_local") or {}).get("counts") or {})
 328: 
 329:         item = {
 330:             "node_id": node_id,
 331:             "state": node.get("state"),
 332:             "state_since": node.get("state_since"),
 333:             "state_age_s": round(_state_age_s(node, now) or 0.0, 1),
 334:             "prev_state": node.get("prev_state"),
 335:             "state_reason": node.get("state_reason"),
 336:             "priority": node.get("priority"),
 337:             "last_seen": node.get("last_seen"),
 338:             "seen_age_s": round(_seen_age_s(node, now) or 0.0, 1),
 339:             "health": "ok" if (_seen_age_s(node, now) or 9999) < 3.0 else "stale",
 340:             "local_size": log_meta.get("size", 0),
 341:             "local_events": ((node.get("streams") or {}).get("events_summary_local") or {}).get("total_events", 0),
 342:             "created": counts.get("created", 0),
 343:             "executing": counts.get("executing", 0),
 344:             "completed": counts.get("completed", 0),
 345:             "dirty": ((node.get("cluster_integrity") or {}).get("last_append_meta") or {}).get("dirty"),
 346:         }
 347:         nodes.append(item)
 348: 
 349:     return {
 350:         "cluster": {
 351:             "node_id": ctx.node_id,
 352:             "leader": leader,
 353:             "generated_at": now,
 354:             "integrity_ok": bool(integrity.get("integrity_ok", True)),
 355:             "local_state": ctx.node.state.value,
 356:             "local_state_since": getattr(ctx.node, "state_since", None),
 357:             "local_state_age_s": round(_state_age_s({
 358:                 "state_since": getattr(ctx.node, "state_since", None)
 359:             }, now) or 0.0, 1),
 360:         },
 361:         "local": {
 362:             "events_summary": local_events,
 363:             "integrity": integrity,
 364:         },
 365:         "nodes": nodes,
 366:     }
 367: 
