===== ./runtime/integrity.py =====
   1: 
   2: import os
   3: import hashlib
   4: from pathlib import Path
   5: from typing import Any
   6: 
   7: from cluster.runtime import context as ctx
   8: from cluster.runtime.cluster_store import cluster_state
   9: from cluster.runtime.event_log import get_local_log_path, get_last_append_meta
  10: from cluster.runtime.leader import compute_alive
  11: 
  12: IGNORED_NODE_KEYS = {"last_seen"}
  13: INTEGRITY_KEYS = (
  14:     "dirty",
  15:     "last_append_event_id",
  16:     "last_append_created_at",
  17:     "log_size",
  18:     "file_size",
  19:     "file_hash",
  20: )
  21: 
  22: 
  23: def file_sha256(path: str | Path, block_size: int = 65536) -> str | None:
  24:     path = str(path)
  25:     if not os.path.exists(path):
  26:         return None
  27:     h = hashlib.sha256()
  28:     with open(path, "rb") as f:
  29:         while True:
  30:             chunk = f.read(block_size)
  31:             if not chunk:
  32:                 break
  33:             h.update(chunk)
  34:     return h.hexdigest()
  35: 
  36: 
  37: def canonicalize(obj: Any, ignored_keys: set[str] | None = None) -> Any:
  38:     ignored_keys = ignored_keys or set()
  39:     if isinstance(obj, dict):
  40:         return {
  41:             k: canonicalize(v, ignored_keys)
  42:             for k, v in sorted(obj.items())
  43:             if k not in ignored_keys
  44:         }
  45:     if isinstance(obj, list):
  46:         return [canonicalize(v, ignored_keys) for v in obj]
  47:     return obj
  48: 
  49: 
  50: def compare_views(a: dict, b: dict) -> bool:
  51:     return canonicalize(a, IGNORED_NODE_KEYS) == canonicalize(b, IGNORED_NODE_KEYS)
  52: 
  53: 
  54: def log_meta_ok(local_meta: dict, peer_meta: dict) -> bool:
  55:     return all(local_meta.get(k) == peer_meta.get(k) for k in INTEGRITY_KEYS)
  56: 
  57: 
  58: def _compact_view(view: dict) -> dict:
  59:     if not isinstance(view, dict):
  60:         return {}
  61:     return {
  62:         "state": view.get("state"),
  63:         "state_since": view.get("state_since"),
  64:         "prev_state": view.get("prev_state"),
  65:         "state_reason": view.get("state_reason"),
  66:         "priority": view.get("priority"),
  67:         "log_meta": view.get("log_meta", {}),
  68:         "streams": view.get("streams", {}),
  69:     }
  70: 
  71: 
  72: def local_integrity_api() -> dict:
  73:     path = get_local_log_path()
  74:     alive = compute_alive(include_self=True)
  75: 
  76:     local_meta = {
  77:         "path": path,
  78:         "size": os.path.getsize(path) if os.path.exists(path) else 0,
  79:         "sha256": file_sha256(path),
  80:     }
  81: 
  82:     peer_status = {}
  83:     self_view = canonicalize(cluster_state.get(ctx.node_id, {}), IGNORED_NODE_KEYS)
  84:     self_meta = self_view.get("log_meta", {}) if isinstance(self_view, dict) else {}
  85: 
  86:     for node_id, data in alive.items():
  87:         view = canonicalize(data, IGNORED_NODE_KEYS)
  88:         meta = view.get("log_meta", {}) if isinstance(view, dict) else {}
  89:         peer_status[node_id] = {
  90:             "view": _compact_view(view),
  91:             "view_ok": view == canonicalize(cluster_state.get(node_id, {}), IGNORED_NODE_KEYS),
  92:             "log_meta_ok": log_meta_ok(self_meta, meta) if node_id == ctx.node_id else True,
  93:         }
  94: 
  95:     return {
  96:         "node_id": ctx.node_id,
  97:         "alive_nodes": sorted(alive.keys()),
  98:         "self_view": _compact_view(self_view),
  99:         "peer_status": peer_status,
 100:         "local_log_meta": local_meta,
 101:         "last_append_meta": get_last_append_meta(),
 102:         "integrity_ok": all(v["view_ok"] and v["log_meta_ok"] for v in peer_status.values()),
 103:     }
 104: 
 105: 
 106: def cluster_integrity_report() -> dict:
 107:     alive = compute_alive(include_self=True)
 108:     reference = canonicalize(cluster_state, IGNORED_NODE_KEYS)
 109:     per_peer = {}
 110: 
 111:     for node_id, data in alive.items():
 112:         view = canonicalize(data, IGNORED_NODE_KEYS)
 113:         meta = view.get("log_meta", {}) if isinstance(view, dict) else {}
 114:         ref_view = reference.get(node_id, {})
 115:         ref_meta = ref_view.get("log_meta", {}) if isinstance(ref_view, dict) else {}
 116: 
 117:         per_peer[node_id] = {
 118:             "matches_reference": view == ref_view,
 119:             "matches_log_meta": meta == ref_meta,
 120:             "state": view.get("state"),
 121:             "state_since": view.get("state_since"),
 122:             "prev_state": view.get("prev_state"),
 123:             "state_reason": view.get("state_reason"),
 124:             "priority": view.get("priority"),
 125:             "streams": view.get("streams", {}),
 126:         }
 127: 
 128:     return {
 129:         "node_id": ctx.node_id,
 130:         "alive_nodes": sorted(alive.keys()),
 131:         "reference": {k: _compact_view(v) for k, v in reference.items()} if isinstance(reference, dict) else {},
 132:         "per_peer": per_peer,
 133:         "integrity_ok": all(v["matches_reference"] and v["matches_log_meta"] for v in per_peer.values()),
 134:     }



===== ./runtime/leader.py =====
   1: 
   2: import time
   3: 
   4: from cluster.runtime.cluster_store import cluster_state
   5: from cluster.runtime import context as ctx
   6: 
   7: LEADER_ALIVE_TIMEOUT = 1.5
   8: 
   9: 
  10: def refresh_self_alive_entry(now=None):
  11:     now = now or time.time()
  12:     if not getattr(ctx, "node", None):
  13:         return
  14: 
  15:     existing = cluster_state.get(ctx.node_id, {})
  16: 
  17:     cluster_state[ctx.node_id] = {
  18:         **existing,
  19:         "state": ctx.node.state.value,
  20:         "priority": ctx.node.priority,
  21:         "last_seen": now,
  22:         "state_since": getattr(ctx.node, "state_since", None),
  23:         "prev_state": getattr(ctx.node, "prev_state", None),
  24:         "state_reason": getattr(ctx.node, "state_reason", None),
  25:     }
  26: 
  27: 
  28: def is_alive(data, timeout=LEADER_ALIVE_TIMEOUT, now=None):
  29:     now = now or time.time()
  30:     return (now - data.get("last_seen", 0)) < timeout
  31: 
  32: 
  33: def compute_alive(timeout=LEADER_ALIVE_TIMEOUT, include_self=True):
  34:     now = time.time()
  35:     if include_self:
  36:         refresh_self_alive_entry(now)
  37: 
  38:     active_nodes = {}
  39:     for node_id, data in cluster_state.items():
  40:         if is_alive(data, timeout=timeout, now=now):
  41:             active_nodes[node_id] = data
  42:     return active_nodes
  43: 
  44: 
  45: def compute_leader(debug_node_id=None, timeout=LEADER_ALIVE_TIMEOUT):
  46:     active_nodes = compute_alive(timeout=timeout, include_self=True)
  47:     if not active_nodes:
  48:         return None
  49:     return min(
  50:         active_nodes.items(),
  51:         key=lambda x: (x[1].get("priority", 9999), x[0]),
  52:     )[0]



