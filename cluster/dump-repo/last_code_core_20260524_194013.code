 295: @app.post("/heartbeat")
 296: def heartbeat(hb: Heartbeat):
 297:     if ctx.node.state == NodeState.ISOLATED:
 298:         return {"error": "node isolated"}
 299: 
 300:     existing = cluster_state.get(hb.node_id, {})
 301:     cluster_state[hb.node_id] = {
 302:         **existing,
 303:         "state": hb.state,
 304:         "priority": hb.priority,
 305:         "last_seen": time.time(),
 306:         "state_since": hb.state_since if hb.state_since is not None else existing.get("state_since"),
 307:         "prev_state": hb.prev_state if hb.prev_state is not None else existing.get("prev_state"),
 308:         "state_reason": hb.state_reason if hb.state_reason is not None else existing.get("state_reason"),
 309:         "log_meta": hb.log_meta or existing.get("log_meta", {}),
 310:         "cluster_integrity": hb.cluster_integrity or existing.get("cluster_integrity", {}),
 311:         "streams": hb.streams or existing.get("streams", {}),
 312:     }
 313: 
 314:     return {"ok": True}
 315: 
