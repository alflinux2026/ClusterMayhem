 104: @app.post("/event")
 105: def handle_event(event: ClusterEvent):
 106:     if ctx.node.state == NodeState.ISOLATED:
 107:         return {"error": "node isolated"}
 108: 
 109:     leader = compute_leader()
 110: 
 111:     if not leader:
 112:         log_state("red", "(NO LEADER)", event.event_id, 3)
 113:         return {"error": "no leader"}
 114: 
 115:     if leader != ctx.node_id:
 116:         msg = event.payload.get("msg", "<no-msg>")
 117:         log_state("cyan", "[EVENT FWD]", f"{msg:12} -> {leader}", 3)
 118: 
 119:         node = CLUSTER_REGISTRY[leader]
 120:         url = f"http://{node['host']}:{node['port']}/event"
 121: 
 122:         try:
 123:             resp = requests.post(
 124:                 url,
 125:                 json=event.model_dump(),
 126:                 timeout=2
 127:             )
 128:             return resp.json()
 129:         except Exception as e:
 130:             return {"error": str(e)}
 131: 
 132:     result = ingest_event(event, ctx.node_id)
 133: 
 134:     return {
 135:         "status": "ok",
 136:         "event_id": event.event_id,
 137:         "result": result
 138:     }
 139: 
 140: 
 141: @app.post("/sleep")
 142: def sleep():
 143:     log_state("red", "- SLEEP -", f"{ctx.node_id} -> SLEEP", 3)
 144:     ctx.node.transition(NodeState.ISOLATED)
 145:     return {"ok": True, "node": ctx.node_id, "state": ctx.node.state.value}
 146: 
 147: 
 148: @app.post("/revive")
 149: def revive():
 150:     log_state("red", "- WAKEUP -", f"{ctx.node_id} -> WAKEUP", 3)
 151:     ctx.node.transition(NodeState.STANDBY)
 152:     return {"ok": True, "node": ctx.node_id, "state": ctx.node.state.value}
 153: 
 154: 
 155: @app.get("/health")
 156: def health():
 157:     return {
 158:         "status": "ok",
 159:         "node": ctx.node_id,
 160:         "sleeping": ctx.node.state == NodeState.ISOLATED
 161:     }
 162: 
 163: 
