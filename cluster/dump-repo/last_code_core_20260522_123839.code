   6: def ingest_event(event, node_id):
   7:     event.mark_status(EventStatus.CREATED)
   8:     append_event(event)
   9: 
  10:     msg = event.payload.get("msg", "<no-msg>")
  11: 
  12:     log_state("yellow", "(EVENT)", f"{msg:12} -> CREATED", 3)
  13:     log_state("cyan", "[EVENT OK]", f"{msg:12}", 3)
  14: 
  15:     return {
  16:         "event_id": event.event_id,
  17:         "status": "accepted",
  18:         "leader": node_id,
  19:         "trace_id": event.trace_id
  20:     }



===== ./runtime/leader.py =====
   1: import time
   2: 
   3: from cluster.utils.log_print import log_state
   4: from cluster.runtime.cluster_store import cluster_state
   5: from cluster.runtime import context as ctx
   6: 
   7: 
   8: LEADER_ALIVE_TIMEOUT = 1.5
   9: 
  10: 
  11: def refresh_self_alive_entry(now=None):
  12:     now = now or time.time()
  13: 
  14:     if not getattr(ctx, "node", None):
  15:         return
  16: 
  17:     cluster_state[ctx.node_id] = {
  18:         "state": ctx.node.state.value,
  19:         "priority": ctx.node.priority,
  20:         "last_seen": now,
  21:     }
  22: 
  23: 
  24: def is_alive(data, timeout=LEADER_ALIVE_TIMEOUT, now=None):
  25:     now = now or time.time()
  26:     return (now - data.get("last_seen", 0)) < timeout
  27: 
  28: 
  29: def compute_alive(timeout=LEADER_ALIVE_TIMEOUT, include_self=True):
  30:     now = time.time()
  31: 
  32:     if include_self:
  33:         refresh_self_alive_entry(now)
  34: 
  35:     active_nodes = {}
  36: 
  37:     for node_id, data in cluster_state.items():
  38:         alive = is_alive(data, timeout=timeout, now=now)
  39:         if alive:
  40:             active_nodes[node_id] = data
  41:         else:
  42:             data["state"] = "GONE"
  43: 
  44:     return active_nodes
  45: 
  46: 
  47: def compute_leader(debug_node_id=None, timeout=LEADER_ALIVE_TIMEOUT):
  48:     active_nodes = compute_alive(timeout=timeout, include_self=True)
  49: 
  50:     if not active_nodes:
  51:         return None
  52: 
  53:     leader = min(
  54:         active_nodes.items(),
  55:         key=lambda x: (x[1]["priority"], x[0])
  56:     )[0]
  57: 
  58:     return leader



===== ./runtime/log_replication.py =====
   1: import logging
   2: import time
   3: 
   4: import requests
   5: 
   6: from cluster.runtime import context as ctx
   7: from cluster.runtime.cluster_store import cluster_state
   8: from cluster.runtime.registry import CLUSTER_REGISTRY
   9: from cluster.runtime.event_log import read_local_log_text, write_replica_log, get_replica_log_path, read_state, write_state, clear_state
  10: from cluster.utils.log_print import log_state
  11: 
  12: logging.getLogger("urllib3").setLevel(logging.ERROR)
  13: logging.getLogger("requests").setLevel(logging.ERROR)
  14: 
  15: PEERALIVETTLSEC = 3.0
  16: 
  17: 
  18: def canonical_replica_node_id() -> str:
  19:     return ctx.node_id
  20: 
  21: 
  22: def alive_peer_ids():
  23:     out = []
  24:     now = time.time()
  25:     for node_id, data in cluster_state.items():
  26:         if node_id == ctx.node_id:
  27:             continue
  28:         if now - data.get("last_seen", 0) > PEERALIVETTLSEC:
  29:             continue
  30:         out.append(node_id)
  31:     return out
  32: 
  33: 
  34: def replicate_local():
  35:     node_id = canonical_replica_node_id()
  36: 
  37:     log_state("cyan", "REPL TICK", f"node={node_id}", 3)
  38: 
  39:     allowed_states = {"ACTIVE", "STANDBY", "DEGRADED"}
  40:     node_state = getattr(getattr(ctx, "node", None), "state", None)
  41:     node_state_value = getattr(node_state, "value", None)
  42:     log_state("cyan", "REPL STATE", f"state={node_state_value} allowed={node_state_value in allowed_states}", 3)
  43:     if node_state_value not in allowed_states:
  44:         return
  45: 
  46:     state = read_state()
  47:     dirty = bool(state.get("dirty", False))
  48:     log_state("cyan", "REPL FLAG", f"dirty={dirty} state_exists={bool(state)}", 3)
  49:     if not dirty:
  50:         return
  51: 
  52:     content = read_local_log_text()
  53:     log_state("cyan", "REPL CONTENT", f"len={len(content)} empty={not content.strip()}", 3)
  54:     if not content.strip():
  55:         log_state("yellow", "REPL SKIP", "empty content", 3)
  56:         return
  57: 
  58:     write_replica_log(node_id, content)
  59:     log_state("cyan", "REPL WRITE", f"bytes={len(content)}", 3)
  60: 
  61:     peers = alive_peer_ids()
  62:     log_state("cyan", "REPL PEERS", f"peers={peers}", 3)
  63:     if not peers:
  64:         log_state("yellow", "REPL SKIP", "no peers", 3)
  65:         return
  66: 
  67:     success = True
  68:     for peer_id in peers:
  69:         node = CLUSTER_REGISTRY.get(peer_id)
  70:         if not node:
  71:             log_state("red", "LOG REPL FAIL", f"{peer_id} missing registry", 3)
  72:             success = False
  73:             continue
  74: 
  75:         url = f"http://{node['host']}:{node['port']}/debug/log/replica/{node_id}"
  76:         log_state("cyan", "REPL POST", f"peer={peer_id} url={url}", 3)
  77:         try:
  78:             resp = requests.post(
  79:                 url,
  80:                 data=content.encode("utf-8"),
  81:                 headers={"Content-Type": "text/plain; charset=utf-8"},
  82:                 timeout=2,
  83:             )
  84:             if resp.ok:
  85:                 log_state("cyan", "LOG REPL", f"{node_id} -> {peer_id}", 3)
  86:             else:
  87:                 success = False
  88:                 log_state("red", "LOG REPL FAIL", f"{peer_id} status={resp.status_code}", 3)
  89:         except Exception as e:
  90:             success = False
  91:             log_state("red", "LOG REPL FAIL", f"{peer_id} err={e}", 3)
  92: 
  93:     if success:
  94:         clear_state()
  95:         log_state("cyan", "REPL CLEAR", "dirty=false", 3)



