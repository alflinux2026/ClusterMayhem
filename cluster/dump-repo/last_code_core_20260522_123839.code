  15: executed_keys = set()
  16: 
  17: 
  18: # -------------------------
  19: # BUSINESS EXECUTION PLACEHOLDER
  20: # -------------------------
  21: def run_business_logic(payload: dict):
  22:     # Aquí va tu lógica real
  23:     return {"ok": True, "payload": payload}
  24: 
  25: 
  26: # -------------------------
  27: # EXECUTE EVENT (IDEMPOTENT)
  28: # -------------------------
  29: def execute_event(event):
  30: 
  31:     #log_state("red", "[EXECUTE entry ...]", event.event_id, 3)
  32: 
  33: 
  34:     # -------------------------
  35:     # BUILD EXECUTION KEY
  36:     # -------------------------
  37:     event.execution_key = f"{event.event_id}:{event.attempt}"
  38: 
  39:     #log_state("red", "[EXECUTION KEY]", event.execution_key, 3)
  40:     #log_state("red", "[EXECUTED KEYS SIZE]", str(len(executed_keys)), 3)
  41: 
  42:     # -------------------------
  43:     # IDEMPOTENCY CHECK NO FUNCIONA
  44:     # -------------------------
  45: 
  46:     if event.execution_key in executed_keys:
  47:         log_state("red", "[CACHE HIT]", event.execution_key, 3)
  48:         return {
  49:             "status": "completed",
  50:             "cached": True,
  51:             "event_id": event.event_id,
  52:             "execution_key": event.execution_key
  53:         }
  54: 
  55:     # -------------------------
  56:     # EXECUTE BUSINESS LOGIC
  57:     # -------------------------
  58:     result = run_business_logic(event.payload)
  59: 
  60:     # -------------------------
  61:     # MARK EXECUTION AS DONE
  62:     # -------------------------
  63:     executed_keys.add(event.execution_key)
  64: 
  65:     msg = event.payload.get("msg", "<no-msg>")
  66: 
  67:     log_state("green", "[EXECUTE]", f"{msg:12}", 3)
  68: 
  69: #    event.mark_status(EventStatus.COMPLETED)
  70: 
  71: #    log_state("yellow", "[STATE]", f"{event.event_id} -> EVENT COMPLETED", 3)
  72: 
  73: #    append_event(event)
  74: 
  75:     # -------------------------
  76:     # RETURN RESULT
  77:     # -------------------------
  78:     return {
  79:         "status": "completed",
  80:         "event_id": event.event_id,
  81:         "execution_key": event.execution_key,
  82:         "result": result
  83:     }



===== ./utils/log_print.py =====
   1: 
   2: from datetime import datetime
   3: 
   4: modeGhost = False
   5: 
   6: def log_state(color, typ, msg, decimals=0):
   7: 
   8:     if modeGhost:
   9:         return
  10: 
  11:     colors = {
  12:         "red": "\033[91m",
  13:         "green": "\033[92m",
  14:         "yellow": "\033[93m",
  15:         "blue": "\033[94m",
  16:         "magenta": "\033[95m",
  17:         "cyan": "\033[96m",
  18:         "white": "\033[97m",
  19:         "reset": "\033[0m",
  20:     }
  21: 
  22:     c = colors.get(color.lower(), colors["white"])
  23:     reset = colors["reset"]
  24: 
  25:     decimals = max(0, min(6, int(decimals)))
  26: 
  27:     # -----------------------------------------
  28:     # fixed-width timestamp
  29:     # -----------------------------------------
  30: 
  31:     now = datetime.now()
  32: 
  33:     if decimals == 0:
  34: 
  35:         # reserva espacio para ".000"
  36:         ts = now.strftime("%H:%M:%S") + "    "
  37: 
  38:     else:
  39: 
  40:         micros = f"{now.microsecond:06d}"[:decimals]
  41:         ts = f"{now.strftime('%H:%M:%S')}.{micros}"
  42: 
  43:         # padding fijo hasta longitud 12
  44:         ts = f"{ts:<12}"
  45: 
  46:     # -----------------------------------------
  47:     # aligned tag
  48:     # -----------------------------------------
  49: 
  50:     tag = f"{typ:>14}"
  51: 
  52:     # -----------------------------------------
  53:     # print
  54:     # -----------------------------------------
  55: 
  56:     print(f"[{ts}] {c}{tag}{reset} {msg}")
  57: 
  58: 
