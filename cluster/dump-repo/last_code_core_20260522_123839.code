   1: # cluster_store.py
   2: import time
   3: 
   4: cluster_state = {}
   5: NODE_TTL = 5.0
   6: 
   7: 
   8: def cleanup_cluster():
   9:     now = time.time()
  10:     to_delete = [node_id for node_id, data in list(cluster_state.items()) if (now - data.get("last_seen", 0)) > NODE_TTL]
  11:     for node_id in to_delete:
  12:         print(f"[GC] removing {node_id}")
  13:         del cluster_state[node_id]
  14: 
  15: 
  16: def get_active_cluster():
  17:     cleanup_cluster()
  18:     return cluster_state



