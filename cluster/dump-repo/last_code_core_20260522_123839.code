===== ./runtime/dispatcher.py =====
   1: import time
   2: 
   3: from cluster.runtime.event_log import get_created_events, get_completed_event_ids, append_event
   4: from cluster.runtime.event_router import forward_event
   5: from cluster.utils.log_print import log_state
   6: from cluster.runtime.leader import compute_leader, compute_alive
   7: from cluster.runtime import context as ctx
   8: from cluster.runtime.events.event_state import EventStatus
   9: 
  10: DISPATCH_ALIVE_TIMEOUT = 1.5
  11: 
  12: 
  13: def dispatch_tick():
  14:     if compute_leader() != ctx.node_id:
  15:         return
  16:     events = get_created_events()
  17:     if not events:
  18:         return
  19:     log_state("magenta", "[DISPATCH]", f"{len(events):3}", 3)
  20:     for event in events:
  21:         dispatch_created_event(event)
  22: 
  23: 
  24: def dispatch_created_event(event):
  25:     completed = get_completed_event_ids()
  26:     if event.event_id in completed:
  27:         log_state("red", "[SKIP COMPLETED]", event.event_id, 3)
  28:         return
  29:     alive = compute_alive(timeout=DISPATCH_ALIVE_TIMEOUT, include_self=True)
  30:     if not alive:
  31:         log_state("red", "[NO ALIVE NODES]", event.event_id, 3)
  32:         return
  33:     target = min(alive.items(), key=lambda x: (x[1]["priority"], x[0]))[0]
  34:     event.target_node = target
  35:     event.route_hops.append(f"dispatcher->{target}")
  36:     event.attempt = (event.attempt or 0) + 1
  37:     event.mark_status(EventStatus.EXECUTING)
  38:     msg = event.payload.get("msg", "")
  39:     log_state("yellow", "(EVENT)", f"{msg:12} -> EXECUTING", 3)
  40:     event.updated_at = time.time()
  41:     append_event(event)
  42:     forward_event(target, event)



===== ./runtime/event_log.py =====
   1: import json
   2: import os
   3: from typing import Dict, List, Optional
   4: 
   5: from cluster.runtime.events.cluster_event import ClusterEvent
   6: from cluster.runtime.events.event_state import EventStatus
   7: 
   8: BASE_DIR = os.path.dirname(os.path.dirname(os.path.dirname(__file__)))
   9: DATA_DIR = os.path.join(BASE_DIR, "cluster", "data")
  10: LOCAL_LOG_PATH = os.path.join(DATA_DIR, "event_log.local.jsonl")
  11: STATE_PATH = os.path.join(DATA_DIR, "last_append.state.json")
  12: 
  13: 
  14: def ensure_dir():
  15:     os.makedirs(DATA_DIR, exist_ok=True)
  16: 
  17: 
  18: def get_local_log_path() -> str:
  19:     return LOCAL_LOG_PATH
  20: 
  21: 
  22: def get_state_path() -> str:
  23:     return STATE_PATH
  24: 
  25: 
  26: def get_replica_log_path(node_id: str) -> str:
  27:     return os.path.join(DATA_DIR, f"event_log.{node_id}.jsonl")
  28: 
  29: 
  30: def list_replica_log_paths() -> List[str]:
  31:     if not os.path.exists(DATA_DIR):
  32:         return []
  33:     out: List[str] = []
  34:     for name in sorted(os.listdir(DATA_DIR)):
  35:         if not name.startswith("event_log."):
  36:             continue
  37:         if not name.endswith(".jsonl"):
  38:             continue
  39:         if name == "event_log.local.jsonl":
  40:             continue
  41:         out.append(os.path.join(DATA_DIR, name))
  42:     return out
  43: 
  44: 
  45: def load_events_from_path(path: str) -> List[dict]:
  46:     if not os.path.exists(path):
  47:         return []
  48:     events = []
  49:     with open(path, "r", encoding="utf-8") as f:
  50:         for line in f:
  51:             line = line.strip()
  52:             if not line:
  53:                 continue
  54:             try:
  55:                 events.append(json.loads(line))
  56:             except json.JSONDecodeError:
  57:                 continue
  58:     return events
  59: 
  60: 
  61: def write_text_atomic(path: str, content: str):
  62:     ensure_dir()
  63:     tmp_path = path + ".tmp"
  64:     with open(tmp_path, "w", encoding="utf-8") as f:
  65:         f.write(content)
  66:         f.flush()
  67:         os.fsync(f.fileno())
  68:     os.replace(tmp_path, path)
  69: 
  70: 
  71: def read_local_log_text() -> str:
  72:     if not os.path.exists(LOCAL_LOG_PATH):
  73:         return ""
  74:     with open(LOCAL_LOG_PATH, "r", encoding="utf-8") as f:
  75:         return f.read()
  76: 
  77: 
  78: def write_replica_log(node_id: str, content: str):
  79:     write_text_atomic(get_replica_log_path(node_id), content)
  80: 
  81: 
  82: def read_state() -> dict:
  83:     if not os.path.exists(STATE_PATH):
  84:         return {}
  85:     try:
  86:         with open(STATE_PATH, "r", encoding="utf-8") as f:
  87:             data = json.load(f)
  88:             return data if isinstance(data, dict) else {}
  89:     except (OSError, json.JSONDecodeError):
  90:         return {}
  91: 
  92: 
  93: def write_state(state: dict):
  94:     ensure_dir()
  95:     with open(STATE_PATH, "w", encoding="utf-8") as f:
  96:         json.dump(state, f, ensure_ascii=False)
  97: 
  98: 
  99: def clear_state():
 100:     try:
 101:         os.remove(STATE_PATH)
 102:     except FileNotFoundError:
 103:         pass
 104: 
 105: 
 106: def load_events() -> List[dict]:
 107:     return load_events_from_path(LOCAL_LOG_PATH)
 108: 
 109: 
 110: def load_local_events() -> List[dict]:
 111:     return load_events_from_path(LOCAL_LOG_PATH)
 112: 
 113: 
 114: def load_replica_events(node_id: str) -> List[dict]:
 115:     return load_events_from_path(get_replica_log_path(node_id))
 116: 
 117: 
 118: def load_all_replica_events() -> List[dict]:
 119:     events: List[dict] = []
 120:     for path in list_replica_log_paths():
 121:         events.extend(load_events_from_path(path))
 122:     return events
 123: 
 124: 
 125: def load_cluster_events() -> List[dict]:
 126:     return load_all_replica_events()
 127: 
 128: 
 129: def _normalize_event(e: dict) -> dict:
 130:     e = dict(e)
 131:     e["schema_version"] = str(e.get("schema_version", "0.1"))
 132:     e.setdefault("received_at", None)
 133:     e.setdefault("attempt", 0)
 134:     e.setdefault("route_hops", [])
 135:     e.setdefault("execution_key", None)
 136:     return e
 137: 
 138: 
 139: def _latest_map(events: List[dict]) -> Dict[str, dict]:
 140:     latest: Dict[str, dict] = {}
 141:     for e in events:
 142:         e = _normalize_event(e)
 143:         latest[e["event_id"]] = e
 144:     return latest
 145: 
 146: 
 147: def rebuild_event_state_index() -> Dict[str, dict]:
 148:     return _latest_map(load_events())
 149: 
 150: 
 151: def get_latest_event(event_id: str) -> Optional[dict]:
 152:     events = load_events()
 153:     for e in reversed(events):
 154:         if e["event_id"] == event_id:
 155:             return _normalize_event(e)
 156:     return None
 157: 
 158: 
 159: def get_created_events():
 160:     latest = rebuild_event_state_index()
 161:     domain_events = [ClusterEvent(**e) for e in latest.values()]
 162:     return [e for e in domain_events if e.status == EventStatus.CREATED]
 163: 
 164: 
 165: def get_completed_event_ids():
 166:     latest = rebuild_event_state_index()
 167:     domain_events = [ClusterEvent(**e) for e in latest.values()]
 168:     return {e.event_id for e in domain_events if e.status == EventStatus.COMPLETED}
 169: 
 170: 
 171: def append_event(event: ClusterEvent):
 172:     ensure_dir()
 173:     record = {
 174:         "event_id": event.event_id,
 175:         "event_type": event.event_type,
 176:         "schema_version": str(event.schema_version),
 177:         "created_at": event.created_at,
 178:         "received_at": getattr(event, "received_at", None),
 179:         "trace_id": event.trace_id,
 180:         "target_node": event.target_node,
 181:         "route_hops": event.route_hops,
 182:         "status": event.status.value if hasattr(event.status, "value") else event.status,
 183:         "attempt": event.attempt,
 184:         "payload": event.payload,
 185:     }
 186:     if record["status"] == EventStatus.COMPLETED.value:
 187:         existing = load_events()
 188:         if any(e.get("event_id") == event.event_id and e.get("status") == EventStatus.COMPLETED.value for e in existing):
 189:             return
 190:     with open(LOCAL_LOG_PATH, "a", encoding="utf-8") as f:
 191:         f.write(json.dumps(record) + "\n")
 192:         f.flush()
 193:         os.fsync(f.fileno())
 194:     write_state({
 195:         "dirty": True,
 196:         "last_append_event_id": event.event_id,
 197:         "last_append_created_at": event.created_at,
 198:     })
 199: 
 200: 
 201: def replay_events(handler):
 202:     events = load_events()
 203:     for raw in events:
 204:         event = ClusterEvent(**_normalize_event(raw))
 205:         handler(event)



===== ./runtime/event_router.py =====
   1: import requests
   2: 
   3: from cluster.runtime.registry import CLUSTER_REGISTRY
   4: from cluster.utils.log_print import log_state
   5: from cluster.runtime.events.cluster_event import ClusterEvent
   6: from cluster.runtime.event_log import append_event
   7: from cluster.runtime.events.event_state import EventStatus
   8: 
   9: 
  10: def forward_to_leader(event: ClusterEvent):
  11:     raise NotImplementedError("forward_to_leader is not used in the current flow")
  12: 
  13: 
  14: def forward_event(node_id: str, event: ClusterEvent):
  15:     node = CLUSTER_REGISTRY[node_id]
  16:     url = f"http://{node['host']}:{node['port']}/execute"
  17: 
  18:     event.add_hop(f"worker:{node_id}")
  19: 
  20:     msg = event.payload.get("msg", "<no-msg>")
  21: 
  22:     log_state(
  23:         "magenta",
  24:         "[WORKER SEND]",
  25:         f"{msg:12} -> {node_id}",
  26:         3
  27:     )
  28: 
  29:     try:
  30:         resp = requests.post(
  31:             url,
  32:             json=event.model_dump(),
  33:             timeout=2
  34:         )
  35:         worker_result = resp.json()
  36:     except Exception as e:
  37:         log_state(
  38:             "red",
  39:             "[WORKER SEND FAIL]",
  40:             f"{msg:12} -> {node_id} | {e}",
  41:             3
  42:         )
  43:         return {"error": "worker_send_failed"}
  44: 
  45:     if worker_result.get("status") == "completed":
  46:         from cluster.runtime.state_machine import transition_event
  47: 
  48:         transition_event(
  49:             event.event_id,
  50:             EventStatus.COMPLETED
  51:         )
  52: 
  53:         log_state(
  54:             "yellow",
  55:             "(EVENT)",
  56:             f"{msg:12} -> COMPLETED",
  57:             3
  58:         )
  59: 
  60:     return {
  61:         "status": "forwarded",
  62:         "event_id": event.event_id,
  63:         "target": node_id
  64:     }



===== ./runtime/events/cluster_event.py =====
   1: from pydantic import BaseModel, Field
   2: from typing import Optional
   3: from uuid import uuid4
   4: import time
   5: 
   6: from cluster.runtime.events.event_state import EventStatus
   7: 
   8: 
   9: class ClusterEvent(BaseModel):
  10: 
  11:     event_id: str = Field(default_factory=lambda: str(uuid4()))
  12:     trace_id: str = Field(default_factory=lambda: str(uuid4()))
  13: 
  14:     schema_version: str = "0.1"   # 👈 FIJO: string ONLY
  15: 
  16:     event_type: str
  17: 
  18:     payload: dict = {}
  19: 
  20:     status: EventStatus = EventStatus.CREATED
  21: 
  22:     route_hops: list[str] = []
  23: 
  24:     target_node: Optional[str] = None
  25:     source_node: Optional[str] = None   # 👈 LO USA event_log
  26: 
  27:     created_at: float = 0.0
  28:     updated_at: float = 0.0
  29: 
  30:     received_at: Optional[float] = None  # 👈 LO USA event_log
  31: 
  32:     attempt: int = 0
  33: 
  34:     execution_key: Optional[str] = None  # 👈 LO USA worker
  35: 
  36:     # -------------------------
  37:     # HELPERS
  38:     # -------------------------
  39: 
  40:     def add_hop(self, hop: str):
  41:         self.route_hops.append(hop)
  42: 
  43:     def mark_status(self, status: EventStatus):
  44:         self.status = status
  45: 
  46:     def mark_received(self):
  47:         self.received_at = time.time()



===== ./runtime/events/event_state.py =====
   1: from enum import Enum
   2: 
   3: 
   4: class EventStatus(str, Enum):
   5:     CREATED = "created"
   6:     EXECUTING = "executing"
   7:     COMPLETED = "completed"
   8:     FAILED = "failed"
   9: 
  10: 
  11: VALID_TRANSITIONS = {
  12:     EventStatus.CREATED: [
  13:         EventStatus.EXECUTING,
  14:     ],
  15: 
  16:     EventStatus.EXECUTING: [
  17:         EventStatus.COMPLETED,
  18:         EventStatus.FAILED,
  19:         EventStatus.CREATED,  # retry
  20:     ],
  21: 
  22:     EventStatus.COMPLETED: [],
  23: 
  24:     EventStatus.FAILED: [],
  25: }
  26: 
  27: 
  28: def validate_transition(old_status, new_status):
  29: 
  30:     if old_status == new_status:
  31:         return  # IDEMPOTENTE NO-OP
  32: 
  33:     allowed = VALID_TRANSITIONS.get(old_status, [])
  34: 
  35:     if new_status not in allowed:
  36:         raise ValueError(
  37:             f"Invalid transition: {old_status} -> {new_status}"
  38:         )



