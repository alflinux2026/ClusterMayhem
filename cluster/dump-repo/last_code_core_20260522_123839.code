   1: import os
   2: import time
   3: import threading
   4: 
   5: from cluster.runtime.dispatcher import dispatch_tick
   6: from cluster.runtime.reconciler.reconciler_loop import reconcile_tick
   7: from cluster.runtime.state import NodeState
   8: from cluster.runtime import context as ctx
   9: from cluster.utils.log_print import log_state
  10: from cluster.runtime.event_log import rebuild_event_state_index, load_events
  11: from cluster.runtime.events.event_state import EventStatus
  12: from cluster.runtime.log_replication import replicate_local
  13: 
  14: EVENTSTATECHECKPERIODSEC = float(os.getenv("EVENTSTATECHECKPERIODSEC", 10))
  15: 
  16: lasteventstatecheckts = 0.0
  17: 
  18: 
  19: def leadereventstatechecktick():
  20:     global lasteventstatecheckts
  21:     now = time.time()
  22:     if now - lasteventstatecheckts < EVENTSTATECHECKPERIODSEC:
  23:         return
  24:     lasteventstatecheckts = now
  25: 
  26:     rawevents = load_events()
  27:     stateindex = rebuild_event_state_index()
  28: 
  29:     rawcreated = 0
  30:     rawexecuting = 0
  31:     rawcompleted = 0
  32:     for e in rawevents:
  33:         status = e.get("status")
  34:         if hasattr(status, "value"):
  35:             status = status.value
  36:         status = str(status).strip().lower()
  37:         if status == EventStatus.CREATED.value:
  38:             rawcreated += 1
  39:         elif status == EventStatus.EXECUTING.value:
  40:             rawexecuting += 1
  41:         elif status == EventStatus.COMPLETED.value:
  42:             rawcompleted += 1
  43: 
  44:     created = 0
  45:     executing = 0
  46:     completed = 0
  47:     for event in stateindex.values():
  48:         status = event.get("status") if isinstance(event, dict) else getattr(event, "status", None)
  49:         if hasattr(status, "value"):
  50:             status = status.value
  51:         status = str(status).strip().lower()
  52:         if status == EventStatus.CREATED.value:
  53:             created += 1
  54:         elif status == EventStatus.EXECUTING.value:
  55:             executing += 1
  56:         elif status == EventStatus.COMPLETED.value:
  57:             completed += 1
  58: 
  59:     log_state(
  60:         "cyan",
  61:         "EVENT STATE",
  62:         f"leader={ctx.node_id} latest(c={created},e={executing},d={completed}) raw(c={rawcreated},e={rawexecuting},d={rawcompleted}) raw_total={len(rawevents)} latest_total={len(stateindex)}",
  63:         3,
  64:     )
  65: 
  66: 
  67: class NodeWorker:
  68:     def __init__(self, node, peers, interval=1.0):
  69:         self.node = node
  70:         self.peers = peers
  71:         self.interval = interval
  72:         self.running = False
  73: 
  74:     def start(self):
  75:         self.running = True
  76:         t = threading.Thread(target=self.loop, daemon=True)
  77:         t.start()
  78: 
  79:     def stop(self):
  80:         self.running = False
  81: 
  82:     def tick_boot(self):
  83:         pass
  84: 
  85:     def tick_discovering(self):
  86:         pass
  87: 
  88:     def tick_standby(self):
  89:         self.node.emit_heartbeat(self.peers)
  90:         reconcile_tick(self.node)
  91:         replicate_local()
  92: 
  93:     def tick_active(self):
  94:         self.node.emit_heartbeat(self.peers)
  95:         dispatch_tick()
  96:         reconcile_tick(self.node)
  97:         replicate_local()
  98:         leadereventstatechecktick()
  99: 
 100:     def tick_degraded(self):
 101:         self.node.emit_heartbeat(self.peers)
 102:         replicate_local()
 103:         leadereventstatechecktick()
 104: 
 105:     def tick_isolated(self):
 106:         pass
 107: 
 108:     def tick_offline(self):
 109:         pass
 110: 
 111:     def _tick_by_state(self):
 112:         state = self.node.state
 113:         if state == NodeState.BOOT:
 114:             self.tick_boot()
 115:         elif state == NodeState.DISCOVERING:
 116:             self.tick_discovering()
 117:         elif state == NodeState.STANDBY:
 118:             self.tick_standby()
 119:         elif state == NodeState.ACTIVE:
 120:             self.tick_active()
 121:         elif state == NodeState.DEGRADED:
 122:             self.tick_degraded()
 123:         elif state == NodeState.ISOLATED:
 124:             self.tick_isolated()
 125:         elif state == NodeState.OFFLINE:
 126:             self.tick_offline()
 127: 
 128:     def loop(self):
 129:         while self.running:
 130:             self.node.tick()
 131:             if self.node.state == NodeState.ISOLATED:
 132:                 time.sleep(self.interval)
 133:                 continue
 134:             self._tick_by_state()
 135:             time.sleep(self.interval)



===== ./runtime/reconciler/reconciler_loop.py =====
   1: import time
   2: from collections import defaultdict
   3: 
   4: from cluster.runtime.event_log import load_events, append_event
   5: from cluster.runtime.events.cluster_event import ClusterEvent
   6: from cluster.runtime.events.event_state import EventStatus
   7: 
   8: 
   9: EXECUTION_TIMEOUT = 10.0
  10: 
  11: 
  12: def reconcile_tick(node_runtime):
  13:     if node_runtime.state != node_runtime.state.__class__.ACTIVE:
  14:         return
  15: 
  16:     events = load_events()
  17:     now = time.time()
  18: 
  19:     by_id = defaultdict(list)
  20:     for e in events:
  21:         eid = e.get("event_id")
  22:         if not eid:
  23:             continue
  24:         by_id[eid].append(e)
  25: 
  26:     incomplete = False
  27:     for history in by_id.values():
  28:         latest_status = history[-1].get("status")
  29:         if latest_status not in (EventStatus.COMPLETED.value, EventStatus.FAILED.value):
  30:             incomplete = True
  31:             break
  32: 
  33:     if not incomplete:
  34:         return
  35: 
  36:     print("\n\n================ RECONCILER DEBUG ================\n")
  37: 
  38:     for eid, history in by_id.items():
  39:         history.sort(key=lambda x: (x.get("updated_at") or x.get("created_at") or 0))
  40:         latest = history[-1]
  41:         latest_status = latest.get("status")
  42: 
  43:         if latest_status in (EventStatus.COMPLETED.value, EventStatus.FAILED.value):
  44:             continue
  45: 
  46:         print(f"\nEVENT_ID: {eid}")
  47:         print("-" * 60)
  48: 
  49:         for i, h in enumerate(history):
  50:             ts = h.get("updated_at") or h.get("created_at") or 0
  51:             status = h.get("status")
  52:             node = h.get("target_node")
  53:             attempt = h.get("attempt")
  54: 
  55:             print(
  56:                 f"[{i}] "
  57:                 f"ts={ts:.3f} "
  58:                 f"status={status:<10} "
  59:                 f"node={node} "
  60:                 f"attempt={attempt}"
  61:             )
  62: 
  63:         print("\n→ LATEST:", latest_status)
  64: 
  65:         if latest_status == EventStatus.EXECUTING.value:
  66:             last_update = latest.get("updated_at") or latest.get("created_at", 0)
  67: 
  68:             if now - last_update > EXECUTION_TIMEOUT:
  69:                 print(f"⚠ RECOVERY: EXECUTING STUCK -> CREATED ({eid})")
  70: 
  71:                 recovered = dict(latest)
  72:                 recovered["status"] = EventStatus.CREATED.value
  73:                 recovered["updated_at"] = now
  74:                 recovered["target_node"] = None
  75:                 recovered["execution_key"] = None
  76:                 recovered["attempt"] = 0
  77:                 recovered["route_hops"] = []
  78:                 recovered.pop("owner", None)
  79: 
  80:                 append_event(ClusterEvent(**recovered))
  81: 
  82:         print("-" * 60)
  83: 
  84:     print("\n==================================================\n")



