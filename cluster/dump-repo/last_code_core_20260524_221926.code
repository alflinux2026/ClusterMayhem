   9: DATA_DIR = Path(__file__).resolve().parents[1] / "data"
  10: LOCAL_LOG_PATH = DATA_DIR / "event_log.local.jsonl"
  11: STATE_PATH = DATA_DIR / "last_append.state.json"
  12: 
  13: 
  14: def ensure_dir():
  15:     DATA_DIR.mkdir(parents=True, exist_ok=True)
  16: 
  17: 
  18: def ensure_initial_files():
  19:     ensure_dir()
  20: 
  21:     if not STATE_PATH.exists():
  22:         write_state({
  23:             "dirty": False,
  24:             "last_append_event_id": None,
  25:             "last_append_created_at": None,
  26:             "last_append_updated_at": None,
  27:         })
  28: 
  29:     if not LOCAL_LOG_PATH.exists():
  30:         LOCAL_LOG_PATH.touch()
  31: 
  32: 
  33: def get_local_log_path(stream: str | None = None) -> str:
  34:     return str(LOCAL_LOG_PATH)
  35: 
  36: 
  37: def get_state_path() -> str:
  38:     return str(STATE_PATH)
  39: 
  40: 
  41: def get_replica_log_path(node_id: str) -> str:
  42:     return str(DATA_DIR / f"event_log.{node_id}.jsonl")
  43: 
  44: 
  45: def list_replica_log_paths() -> List[str]:
  46:     if not DATA_DIR.exists():
  47:         return []
  48: 
  49:     out: List[str] = []
  50:     for name in sorted(os.listdir(DATA_DIR)):
  51:         if not name.startswith("event_log."):
  52:             continue
  53:         if not name.endswith(".jsonl"):
  54:             continue
  55:         if name == "event_log.local.jsonl":
  56:             continue
  57:         out.append(str(DATA_DIR / name))
  58:     return out
  59: 
  60: 
  61: def load_events_from_path(path: str) -> List[dict]:
  62:     if not os.path.exists(path):
  63:         return []
  64: 
  65:     events = []
  66:     with open(path, "r", encoding="utf-8") as f:
  67:         for line in f:
  68:             line = line.strip()
  69:             if not line:
  70:                 continue
  71:             try:
  72:                 events.append(json.loads(line))
  73:             except json.JSONDecodeError:
  74:                 continue
  75:     return events
  76: 
  77: 
  78: def write_text_atomic(path: str, content: str):
  79:     ensure_dir()
  80:     tmp_path = path + ".tmp"
  81:     with open(tmp_path, "w", encoding="utf-8") as f:
  82:         f.write(content)
  83:         f.flush()
  84:         os.fsync(f.fileno())
  85:     os.replace(tmp_path, path)
  86: 
  87: 
  88: def read_local_log_text() -> str:
  89:     if not LOCAL_LOG_PATH.exists():
  90:         return ""
  91:     return LOCAL_LOG_PATH.read_text(encoding="utf-8")
  92: 
  93: 
  94: def write_replica_log(node_id: str, content: str):
  95:     ensure_dir()
  96:     write_text_atomic(get_replica_log_path(node_id), content)
  97: 
  98: 
  99: def read_state() -> dict:
 100:     if not STATE_PATH.exists():
 101:         return {}
 102: 
 103:     try:
 104:         with open(STATE_PATH, "r", encoding="utf-8") as f:
 105:             data = json.load(f)
 106:             return data if isinstance(data, dict) else {}
 107:     except (OSError, json.JSONDecodeError):
 108:         return {}
 109: 
 110: 
 111: def get_last_append_meta() -> dict:
 112:     state = read_state()
 113:     return state if isinstance(state, dict) else {}
 114: 
 115: 
 116: def write_state(state: dict):
 117:     ensure_dir()
 118:     tmp_path = str(STATE_PATH) + ".tmp"
 119:     with open(tmp_path, "w", encoding="utf-8") as f:
 120:         json.dump(state, f, ensure_ascii=False)
 121:         f.flush()
 122:         os.fsync(f.fileno())
 123:     os.replace(tmp_path, str(STATE_PATH))
 124: 
 125: 
 126: def clear_state():
 127:     write_state({
 128:         "dirty": False,
 129:         "last_append_event_id": None,
 130:         "last_append_created_at": None,
 131:         "last_append_updated_at": None,
 132:     })
 133: 
 134: 
 135: def load_events() -> List[dict]:
 136:     return load_events_from_path(str(LOCAL_LOG_PATH))
 137: 
 138: 
 139: def load_local_events() -> List[dict]:
 140:     return load_events_from_path(str(LOCAL_LOG_PATH))
 141: 
 142: 
 143: def load_replica_events(node_id: str) -> List[dict]:
 144:     return load_events_from_path(get_replica_log_path(node_id))
 145: 
 146: 
 147: def load_all_replica_events() -> List[dict]:
 148:     events: List[dict] = []
 149:     for path in list_replica_log_paths():
 150:         events.extend(load_events_from_path(path))
 151:     return events
 152: 
 153: 
 154: def load_cluster_events() -> List[dict]:
 155:     return load_all_replica_events()
 156: 
 157: 
 158: def _normalize_event(e: dict) -> dict:
 159:     e = dict(e)
 160:     e["schema_version"] = str(e.get("schema_version", "0.1"))
 161:     e.setdefault("received_at", None)
 162:     e.setdefault("attempt", 0)
 163:     e.setdefault("route_hops", [])
 164:     e.setdefault("execution_key", None)
 165:     return e
 166: 
 167: 
 168: def _latest_map(events: List[dict]) -> Dict[str, dict]:
 169:     latest: Dict[str, dict] = {}
 170:     for e in events:
 171:         e = _normalize_event(e)
 172:         latest[e["event_id"]] = e
 173:     return latest
 174: 
 175: 
 176: def rebuild_event_state_index() -> Dict[str, dict]:
 177:     return _latest_map(load_events())
 178: 
 179: 
 180: def get_latest_event(event_id: str) -> Optional[dict]:
 181:     events = load_events()
 182:     for e in reversed(events):
 183:         if e["event_id"] == event_id:
 184:             return _normalize_event(e)
 185:     return None
 186: 
 187: 
 188: def get_created_events():
 189:     latest = rebuild_event_state_index()
 190:     domain_events = [ClusterEvent(**e) for e in latest.values()]
 191:     return [e for e in domain_events if e.status == EventStatus.CREATED]
 192: 
 193: 
 194: def get_completed_event_ids():
 195:     latest = rebuild_event_state_index()
 196:     domain_events = [ClusterEvent(**e) for e in latest.values()]
 197:     return {e.event_id for e in domain_events if e.status == EventStatus.COMPLETED}
 198: 
 199: 
 200: def append_event(event: ClusterEvent):
 201:     ensure_initial_files()
 202: 
 203:     record = {
 204:         "event_id": event.event_id,
 205:         "event_type": event.event_type,
 206:         "schema_version": str(event.schema_version),
 207:         "created_at": event.created_at,
 208:         "updated_at": getattr(event, "updated_at", None),
 209:         "received_at": getattr(event, "received_at", None),
 210:         "trace_id": event.trace_id,
 211:         "target_node": event.target_node,
 212:         "source_node": getattr(event, "source_node", None),
 213:         "route_hops": list(getattr(event, "route_hops", []) or []),
 214:         "status": event.status.value if hasattr(event.status, "value") else event.status,
 215:         "attempt": event.attempt,
 216:         "execution_key": getattr(event, "execution_key", None),
 217:         "payload": event.payload,
 218:     }
 219: 
 220:     if record["status"] == EventStatus.COMPLETED.value:
 221:         existing = load_events()
 222:         if any(
 223:             e.get("event_id") == event.event_id and e.get("status") == EventStatus.COMPLETED.value
 224:             for e in existing
 225:         ):
 226:             return
 227: 
 228:     with open(LOCAL_LOG_PATH, "a", encoding="utf-8") as f:
 229:         f.write(json.dumps(record) + "\n")
 230:         f.flush()
 231:         os.fsync(f.fileno())
 232: 
 233:     try:
 234:         write_state({
 235:             "dirty": True,
 236:             "last_append_event_id": event.event_id,
 237:             "last_append_created_at": event.created_at,
 238:             "last_append_updated_at": getattr(event, "updated_at", None),
 239:         })
 240:     except Exception as e:
 241:         print(f"[STATE WRITE FAIL] {event.event_id} -> {e}")
 242: 
 243: 
 244: def replay_events(handler, stream: str | None = None):
 245:     events = load_events()
 246:     for raw in events:
 247:         event = ClusterEvent(**_normalize_event(raw))
 248:         handler(event)



