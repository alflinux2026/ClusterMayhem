  10: def upsert_node(node_id: str, payload: dict, now: float | None = None) -> dict:
  11:     now = now or time.time()
  12:     current = cluster_state.get(node_id, {})
  13: 
  14:     cluster_state[node_id] = {
  15:         **current,
  16:         **payload,
  17:         "last_seen": payload.get("last_seen", now),
  18:     }
  19:     return cluster_state[node_id]
  20: 
  21: 
  22: def refresh_node_seen(node_id: str, now: float | None = None) -> dict:
  23:     now = now or time.time()
  24:     current = cluster_state.get(node_id, {})
  25: 
  26:     cluster_state[node_id] = {
  27:         **current,
  28:         "last_seen": now,
  29:     }
  30:     return cluster_state[node_id]
  31: 
  32: 
  33: def get_node(node_id: str) -> dict:
  34:     return cluster_state.get(node_id, {})



