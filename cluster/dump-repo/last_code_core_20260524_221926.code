 113: def _compact_node(node: dict) -> dict:
 114:     now = time.time()
 115:     return {
 116:         "state": node.get("state"),
 117:         "priority": node.get("priority"),
 118:         "last_seen": node.get("last_seen"),
 119:         "seen_age_s": _seen_age_s(node, now),
 120:         "last_watchdog": node.get("last_watchdog"),
 121:         "watchdog_age_s": _watchdog_age_s(node, now),
 122:         "watchdog_busy": node.get("watchdog_busy"),
 123:         "presence_age_s": _presence_age_s(node, now),
 124:         "presence_health": _presence_health(node, now),
 125:         "state_since": node.get("state_since"),
 126:         "state_age_s": _state_age_s(node, now),
 127:         "prev_state": node.get("prev_state"),
 128:         "state_reason": node.get("state_reason"),
 129:         "log_meta": node.get("log_meta", {}),
 130:         "streams": node.get("streams", {}),
 131:     }
