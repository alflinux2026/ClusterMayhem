 267: @app.post("/event")
 268: def handle_event(event: ClusterEvent):
 269:     if ctx.node.state == NodeState.ISOLATED:
 270:         return {"error": "node isolated"}
 271: 
 272:     leader = compute_leader()
 273:     if not leader:
 274:         log_state("red", "(NO LEADER)", event.event_id, 3)
 275:         return {"error": "no leader"}
 276: 
 277:     if leader != ctx.node_id:
 278:         msg = event.payload.get("msg", "<no-msg>")
 279:         log_state("cyan", "[EVENT FWD]", f"{msg:12} -> {leader}", 3)
 280:         node = CLUSTER_REGISTRY[leader]
 281:         url = f"http://{node['host']}:{node['port']}/event"
 282:         try:
 283:             resp = requests.post(url, json=event.model_dump(), timeout=2)
 284:             return resp.json()
 285:         except Exception as e:
 286:             return {"error": str(e)}
 287: 
 288:     result = ingest_event(event, ctx.node_id)
 289:     return {"status": "ok", "event_id": event.event_id, "result": result}
 290: 
