 393: @app.get("/dashboard/compact")
 394: def dashboard_compact():
 395:     now = time.time()
 396:     leader = compute_leader()
 397:     local_events = events_summary()
 398:     integrity = local_integrity_api()
 399: 
 400:     nodes = []
 401:     for node_id, node in sorted(cluster_state.items()):
 402:         log_meta = node.get("log_meta", {}) or {}
 403:         counts = (((node.get("streams") or {}).get("events_summary_local") or {}).get("counts") or {})
 404: 
 405:         item = {
 406:             "node_id": node_id,
 407:             "state": node.get("state"),
 408:             "state_since": node.get("state_since"),
 409:             "state_age_s": round(_state_age_s(node, now) or 0.0, 1),
 410:             "prev_state": node.get("prev_state"),
 411:             "state_reason": node.get("state_reason"),
 412:             "priority": node.get("priority"),
 413:             "last_seen": node.get("last_seen"),
 414:             "seen_age_s": round(_seen_age_s(node, now) or 0.0, 1),
 415:             "last_watchdog": node.get("last_watchdog"),
 416:             "watchdog_age_s": round(_watchdog_age_s(node, now) or 0.0, 1),
 417:             "watchdog_busy": node.get("watchdog_busy"),
 418:             "presence_age_s": round(_presence_age_s(node, now) or 0.0, 1),
 419:             "health": _presence_health(node, now, stale_after_s=3.0),
 420:             "local_size": log_meta.get("size", 0),
 421:             "local_events": ((node.get("streams") or {}).get("events_summary_local") or {}).get("total_events", 0),
 422:             "created": counts.get("created", 0),
 423:             "executing": counts.get("executing", 0),
 424:             "completed": counts.get("completed", 0),
 425:             "dirty": ((node.get("cluster_integrity") or {}).get("last_append_meta") or {}).get("dirty"),
 426:         }
 427:         nodes.append(item)
 428: 
 429:     return {
 430:         "cluster": {
 431:             "node_id": ctx.node_id,
 432:             "leader": leader,
 433:             "generated_at": now,
 434:             "integrity_ok": bool(integrity.get("integrity_ok", True)),
 435:             "local_state": ctx.node.state.value,
 436:             "local_state_since": getattr(ctx.node, "state_since", None),
 437:             "local_state_age_s": round(_state_age_s({
 438:                 "state_since": getattr(ctx.node, "state_since", None)
 439:             }, now) or 0.0, 1),
 440:         },
 441:         "local": {
 442:             "events_summary": local_events,
 443:             "integrity": integrity,
 444:         },
 445:         "nodes": nodes,
 446:     }
