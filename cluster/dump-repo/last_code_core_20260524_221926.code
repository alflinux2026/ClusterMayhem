   1: import requests
   2: 
   3: from cluster.runtime.registry import CLUSTER_REGISTRY
   4: from cluster.utils.log_print import log_state
   5: from cluster.runtime.events.cluster_event import ClusterEvent
   6: from cluster.runtime.events.event_state import EventStatus
   7: from cluster.runtime import context as ctx
   8: from cluster.runtime.worker.event_worker import execute_event
   9: 
  10: 
  11: def forward_to_leader(event: ClusterEvent):
  12:     raise NotImplementedError("forward_to_leader is not used in the current flow")
  13: 
  14: 
  15: def forward_event(node_id: str, event: ClusterEvent, stream: str | None = None):
  16:     if node_id == getattr(ctx, "node_id", None):
  17:         log_state("cyan", "[WORKER LOCAL]", f"{event.event_id} -> {node_id}", 3)
  18:         return execute_event(event, stream)
  19: 
  20:     node = CLUSTER_REGISTRY.get(node_id)
  21:     if not node:
  22:         log_state("red", "[WORKER SEND FAIL]", f"{event.event_id} -> {node_id} missing registry", 3)
  23:         return {"error": "worker_route_missing", "target": node_id, "stream": stream}
  24: 
  25:     url = f"http://{node['host']}:{node['port']}/execute"
  26:     event.add_hop(f"worker:{node_id}")
  27: 
  28:     msg = event.payload.get("msg", "<no-msg>")
  29: 
  30:     log_state(
  31:         "magenta",
  32:         "[WORKER SEND]",
  33:         f"{msg:12} -> {node_id}",
  34:         3
  35:     )
  36: 
  37:     try:
  38:         resp = requests.post(
  39:             url,
  40:             json=event.model_dump(),
  41:             timeout=2
  42:         )
  43:         worker_result = resp.json()
  44:     except Exception as e:
  45:         log_state(
  46:             "red",
  47:             "[WORKER SEND FAIL]",
  48:             f"{msg:12} -> {node_id} | {e}",
  49:             3
  50:         )
  51:         return {"error": "worker_send_failed", "target": node_id, "stream": stream}
  52: 
  53:     if worker_result.get("status") == "completed":
  54:         from cluster.runtime.state_machine import transition_event
  55: 
  56:         transition_event(
  57:             event.event_id,
  58:             EventStatus.COMPLETED
  59:         )
  60: 
  61:         log_state(
  62:             "yellow",
  63:             "(EVENT)",
  64:             f"{msg:12} -> COMPLETED",
  65:             3
  66:         )
  67: 
  68:     return {
  69:         "status": "forwarded",
  70:         "event_id": event.event_id,
  71:         "target": node_id,
  72:         "stream": stream
  73:     }



