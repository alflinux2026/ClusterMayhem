 134: def _read_jsonl(path: str) -> list[dict]:
 135:     if not os.path.exists(path):
 136:         return []
 137: 
 138:     out: list[dict] = []
 139:     with open(path, "r", encoding="utf-8") as f:
 140:         for line in f:
 141:             line = line.strip()
 142:             if not line:
 143:                 continue
 144:             try:
 145:                 out.append(json.loads(line))
 146:             except Exception:
 147:                 continue
 148:     return out
 149: 
 150: 
 151: def _summarize_events(events: list[dict]) -> dict:
 152:     latest_by_event_id: dict[str, dict] = {}
 153:     last_event_id = None
 154: 
 155:     for event in events:
 156:         event_id = event.get("event_id")
 157:         if not event_id:
 158:             continue
 159:         latest_by_event_id[event_id] = event
 160:         last_event_id = event_id
 161: 
 162:     counts = Counter()
 163:     for event in latest_by_event_id.values():
 164:         status = event.get("status", "unknown")
 165:         counts[status] += 1
 166: 
 167:     return {
 168:         "total_events": len(latest_by_event_id),
 169:         "counts": {
 170:             "created": counts.get("created", 0),
 171:             "executing": counts.get("executing", 0),
 172:             "completed": counts.get("completed", 0),
 173:             "unknown": counts.get("unknown", 0),
 174:         },
 175:         "last_event_id": last_event_id,
 176:     }
