   5: from cluster.runtime.dispatcher import dispatch_tick
   6: from cluster.runtime.reconciler.reconciler_loop import reconcile_tick
   7: from cluster.runtime.state import NodeState, get_state_age_s
   8: from cluster.runtime import context as ctx
   9: from cluster.utils.log_print import log_state
  10: from cluster.runtime.event_log import rebuild_event_state_index, load_events
  11: from cluster.runtime.events.event_state import EventStatus
  12: from cluster.runtime.log_replication import replicate_local
  13: from cluster.runtime.watchdog import emit_watchdog_if_due
  14: 
  15: EVENTSTATECHECKPERIODSEC = float(os.getenv("EVENTSTATECHECKPERIODSEC", 10))
  16: STATEDEBUGPERIODSEC = float(os.getenv("STATEDEBUGPERIODSEC", 30))
  17: 
  18: lasteventstatecheckts = 0.0
  19: laststatedebugts = 0.0
  20: 
  21: 
  22: def leader_event_state_check_tick():
  23:     global lasteventstatecheckts
  24:     now = time.time()
  25:     if now - lasteventstatecheckts < EVENTSTATECHECKPERIODSEC:
  26:         return
  27:     lasteventstatecheckts = now
  28: 
  29:     raw_events = load_events()
  30:     state_index = rebuild_event_state_index()
  31: 
  32:     raw_created = 0
  33:     raw_executing = 0
  34:     raw_completed = 0
  35:     for e in raw_events:
  36:         status = e.get("status")
  37:         if hasattr(status, "value"):
  38:             status = status.value
  39:         status = str(status).strip().lower()
  40:         if status == EventStatus.CREATED.value:
  41:             raw_created += 1
  42:         elif status == EventStatus.EXECUTING.value:
  43:             raw_executing += 1
  44:         elif status == EventStatus.COMPLETED.value:
  45:             raw_completed += 1
  46: 
  47:     created = 0
  48:     executing = 0
  49:     completed = 0
  50:     for event in state_index.values():
  51:         status = event.get("status") if isinstance(event, dict) else getattr(event, "status", None)
  52:         if hasattr(status, "value"):
  53:             status = status.value
  54:         status = str(status).strip().lower()
  55:         if status == EventStatus.CREATED.value:
  56:             created += 1
  57:         elif status == EventStatus.EXECUTING.value:
  58:             executing += 1
  59:         elif status == EventStatus.COMPLETED.value:
  60:             completed += 1
  61: 
  62:     log_state(
  63:         "cyan",
  64:         "EVENT STATE",
  65:         f"leader={ctx.node_id} latest(c={created},e={executing},d={completed}) raw(c={raw_created},e={raw_executing},d={raw_completed}) raw_total={len(raw_events)} latest_total={len(state_index)}",
  66:         3,
  67:     )
  68: 
  69: 
  70: def log_state_runtime_debug(node):
  71:     global laststatedebugts
  72:     now = time.time()
  73:     if now - laststatedebugts < STATEDEBUGPERIODSEC:
  74:         return
  75:     laststatedebugts = now
  76: 
  77:     age_s = get_state_age_s(node, now=now)
  78:     log_state(
  79:         "blue",
  80:         "NODE STATE",
  81:         f"{node.node_id} state={node.state.value} age={age_s:.1f}s prev={getattr(node, 'prev_state', None)} reason={getattr(node, 'state_reason', None)}",
  82:         3,
  83:     )
  84: 
  85: 
  86: class NodeWorker:
  87:     def __init__(self, node, peers, interval=1.0):
  88:         self.node = node
  89:         self.peers = peers
  90:         self.interval = interval
  91:         self.running = False
  92: 
  93:     def start(self):
  94:         self.running = True
  95:         t = threading.Thread(target=self.loop, daemon=True)
  96:         t.start()
  97: 
  98:     def stop(self):
  99:         self.running = False
 100: 
 101:     def tick_boot(self):
 102:         pass
 103: 
 104:     def tick_discovering(self):
 105:         pass
 106: 
 107:     def tick_standby(self):
 108:         self.node.emit_heartbeat(self.peers)
 109:         reconcile_tick(self.node)
 110:         replicate_local()
 111: 
 112:     def tick_active(self):
 113:         self.node.emit_heartbeat(self.peers)
 114:         dispatch_tick()
 115:         reconcile_tick(self.node)
 116:         replicate_local()
 117:         leader_event_state_check_tick()
 118: 
 119:     def tick_degraded(self):
 120:         self.node.emit_heartbeat(self.peers)
 121:         replicate_local()
 122:         leader_event_state_check_tick()
 123: 
 124:     def tick_isolated(self):
 125:         pass
 126: 
 127:     def tick_offline(self):
 128:         pass
 129: 
 130:     def _tick_by_state(self):
 131:         state = self.node.state
 132:         if state == NodeState.BOOT:
 133:             self.tick_boot()
 134:         elif state == NodeState.DISCOVERING:
 135:             self.tick_discovering()
 136:         elif state == NodeState.STANDBY:
 137:             self.tick_standby()
 138:         elif state == NodeState.ACTIVE:
 139:             self.tick_active()
 140:         elif state == NodeState.DEGRADED:
 141:             self.tick_degraded()
 142:         elif state == NodeState.ISOLATED:
 143:             self.tick_isolated()
 144:         elif state == NodeState.OFFLINE:
 145:             self.tick_offline()
 146: 
 147:     def loop(self):
 148:         while self.running:
 149:             self.node.tick()
 150:             log_state_runtime_debug(self.node)
 151: 
 152:             if self.node.state == NodeState.ISOLATED:
 153:                 time.sleep(self.interval)
 154:                 continue
 155: 
 156:             emit_watchdog_if_due(self.peers, busy=True)
 157: 
 158:             self._tick_by_state()
 159: 
 160:             emit_watchdog_if_due(self.peers, busy=True)
 161: 
 162:             time.sleep(self.interval)



===== ./runtime/reconciler/reconciler_loop.py =====
   1: 
   2: import time
   3: from collections import defaultdict
   4: 
   5: from cluster.runtime.event_log import load_events, append_event
   6: from cluster.runtime.events.cluster_event import ClusterEvent
   7: from cluster.runtime.events.event_state import EventStatus
   8: 
   9: 
  10: EXECUTION_TIMEOUT = 10.0
  11: 
  12: 
  13: def reconcile_tick(node_runtime):
  14:     if node_runtime.state != node_runtime.state.__class__.ACTIVE:
  15:         return
  16: 
  17:     events = load_events()
  18:     now = time.time()
  19: 
  20:     by_id = defaultdict(list)
  21:     for e in events:
  22:         eid = e.get("event_id")
  23:         if not eid:
  24:             continue
  25:         by_id[eid].append(e)
  26: 
  27:     incomplete = False
  28:     for history in by_id.values():
  29:         latest_status = history[-1].get("status")
  30:         if latest_status not in (EventStatus.COMPLETED.value, EventStatus.FAILED.value):
  31:             incomplete = True
  32:             break
  33: 
  34:     if not incomplete:
  35:         return
  36: 
  37:     print("\n\n================ RECONCILER DEBUG ================\n")
  38: 
  39:     for eid, history in by_id.items():
  40:         history.sort(key=lambda x: (x.get("updated_at") or x.get("created_at") or 0))
  41:         latest = history[-1]
  42:         latest_status = latest.get("status")
  43: 
  44:         if latest_status in (EventStatus.COMPLETED.value, EventStatus.FAILED.value):
  45:             continue
  46: 
  47:         print(f"\nEVENT_ID: {eid}")
  48:         print("-" * 60)
  49: 
  50:         for i, h in enumerate(history):
  51:             ts = h.get("updated_at") or h.get("created_at") or 0
  52:             status = h.get("status")
  53:             node = h.get("target_node")
  54:             attempt = h.get("attempt")
  55: 
  56:             print(
  57:                 f"[{i}] "
  58:                 f"ts={ts:.3f} "
  59:                 f"status={status:<10} "
  60:                 f"node={node} "
  61:                 f"attempt={attempt}"
  62:             )
  63: 
  64:         print("\n→ LATEST:", latest_status)
  65: 
  66:         if latest_status == EventStatus.EXECUTING.value:
  67:             last_update = latest.get("updated_at") or latest.get("created_at", 0)
  68: 
  69:             if now - last_update > EXECUTION_TIMEOUT:
  70:                 print(f"⚠ RECOVERY: EXECUTING STUCK -> CREATED ({eid})")
  71: 
  72:                 recovered = dict(latest)
  73:                 recovered["status"] = EventStatus.CREATED.value
  74:                 recovered["updated_at"] = now
  75:                 recovered["target_node"] = None
  76:                 recovered["execution_key"] = None
  77:                 recovered["attempt"] = 0
  78:                 recovered["route_hops"] = []
  79:                 recovered.pop("owner", None)
  80: 
  81:                 append_event(ClusterEvent(**recovered))
  82: 
  83:         print("-" * 60)
  84: 
  85:     print("\n==================================================\n")



===== ./runtime/registry.py =====
   1: CLUSTER_REGISTRY = {}
   2: 
   3: 
   4: def register_node(node_id: str, host: str, port: int, priority: int = 100):
   5:     CLUSTER_REGISTRY[node_id] = {
   6:         "host": host,
   7:         "port": port,
   8:         "priority": priority,
   9:     }
  10:     return CLUSTER_REGISTRY[node_id]
  11: 
  12: 
  13: def get_node(node_id: str):
  14:     return CLUSTER_REGISTRY.get(node_id)



===== ./runtime/state.py =====
   1: # state.py
   2: import time
   3: from enum import Enum
   4: 
   5: 
   6: class NodeState(str, Enum):
   7:     BOOT = "BOOT"
   8:     DISCOVERING = "DISCOVERING"
   9:     STANDBY = "STAND-BY"
  10:     ACTIVE = "ACTIVE"
  11:     DEGRADED = "DEGRADED"
  12:     ISOLATED = "ISOLATED"
  13:     OFFLINE = "OFFLINE"
  14: 
  15: 
  16: def _state_value(value):
  17:     return value.value if isinstance(value, Enum) else str(value)
  18: 
  19: 
  20: def ensure_state_meta(node, now=None):
  21:     now = now or time.time()
  22: 
  23:     if not hasattr(node, "state_since") or node.state_since is None:
  24:         node.state_since = now
  25: 
  26:     if not hasattr(node, "prev_state"):
  27:         node.prev_state = None
  28: 
  29:     if not hasattr(node, "state_reason"):
  30:         node.state_reason = None
  31: 
  32:     return node
  33: 
  34: 
  35: def transition_node_state(node, new_state, reason=None, now=None):
  36:     now = now or time.time()
  37:     ensure_state_meta(node, now=now)
  38: 
  39:     old_state = _state_value(node.state)
  40:     new_state_value = _state_value(new_state)
  41: 
  42:     changed = old_state != new_state_value
  43: 
  44:     if changed:
  45:         node.prev_state = old_state
  46:         node.state = new_state if isinstance(new_state, Enum) else NodeState(new_state_value)
  47:         node.state_since = now
  48:         node.state_reason = reason
  49:     else:
  50:         if reason is not None:
  51:             node.state_reason = reason
  52: 
  53:     return {
  54:         "changed": changed,
  55:         "old_state": old_state,
  56:         "new_state": _state_value(node.state),
  57:         "state_since": node.state_since,
  58:         "state_reason": node.state_reason,
  59:     }
  60: 
  61: 
  62: def get_state_age_s(node, now=None):
  63:     now = now or time.time()
  64:     ensure_state_meta(node, now=now)
  65:     return max(0.0, now - float(node.state_since))



===== ./runtime/state_machine.py =====
   1: from cluster.runtime.events.event_state import EventStatus, validate_transition
   2: from cluster.runtime.event_log import load_events, append_event
   3: from cluster.runtime.events.cluster_event import ClusterEvent
   4: 
   5: 
   6: def transition_event(event_id: str, new_status):
   7:     events = load_events()
   8: 
   9:     latest_raw = None
  10:     for e in reversed(events):
  11:         if e["event_id"] == event_id:
  12:             latest_raw = e
  13:             break
  14: 
  15:     if not latest_raw:
  16:         return None
  17: 
  18:     latest = ClusterEvent(**latest_raw)
  19:     old_status = latest.status
  20: 
  21:     validate_transition(old_status, new_status)
  22: 
  23:     latest.status = new_status
  24:     append_event(latest)
  25: 
  26:     return latest



===== ./runtime/watchdog.py =====
   1: import os
   2: import time
   3: import logging
   4: 
   5: import requests
   6: 
   7: from cluster.runtime import context as ctx
   8: from cluster.utils.log_print import log_state
   9: 
  10: logging.getLogger("urllib3").setLevel(logging.ERROR)
  11: logging.getLogger("requests").setLevel(logging.ERROR)
  12: 
  13: WATCHDOG_PERIODSEC = float(os.getenv("WATCHDOG_PERIODSEC", 0.5))
  14: WATCHDOG_TIMEOUTSEC = float(os.getenv("WATCHDOG_TIMEOUTSEC", 1.0))
  15: 
  16: _last_watchdog_emit_ts = 0.0
  17: 
  18: 
  19: def _iter_targets(peers):
  20:     if isinstance(peers, dict):
  21:         for peer_id, node in peers.items():
  22:             if not isinstance(node, dict):
  23:                 continue
  24:             yield peer_id, node
  25:         return
  26: 
  27:     if isinstance(peers, list):
  28:         for node in peers:
  29:             if not isinstance(node, dict):
  30:                 continue
  31:             peer_id = node.get("node_id") or node.get("name") or node.get("host")
  32:             if not peer_id:
  33:                 continue
  34:             yield peer_id, node
  35:         return
  36: 
  37: 
  38: def emit_watchdog(peers, force=False, busy=True):
  39:     global _last_watchdog_emit_ts
  40: 
  41:     now = time.time()
  42:     if not force and (now - _last_watchdog_emit_ts) < WATCHDOG_PERIODSEC:
  43:         return False
  44: 
  45:     emitted_at = now
  46:     payload = {
  47:         "node_id": ctx.node_id,
  48:         "busy": bool(busy),
  49:         "emitted_at": emitted_at,
  50:     }
  51: 
  52:     sent = 0
  53: 
  54:     for peer_id, node in _iter_targets(peers):
  55:         host = node.get("host")
  56:         port = node.get("port")
  57:         if not host or not port:
  58:             continue
  59: 
  60:         url = f"http://{host}:{port}/watchdog"
  61:         try:
  62:             resp = requests.post(url, json=payload, timeout=WATCHDOG_TIMEOUTSEC)
  63:             if resp.ok:
  64:                 sent += 1
  65:         except Exception:
  66:             pass
  67: 
  68:     _last_watchdog_emit_ts = emitted_at
  69: 
  70:     log_state(
  71:         "cyan",
  72:         "WATCHDOG",
  73:         f"node={ctx.node_id} sent={sent} busy={bool(busy)} ts={emitted_at:.3f}",
  74:         3,
  75:     )
  76:     return sent > 0
  77: 
  78: 
  79: def emit_watchdog_if_due(peers, busy=True):
  80:     return emit_watchdog(peers=peers, force=False, busy=busy)
  81: 
  82: 
  83: def emit_watchdog_now(peers, busy=True):
  84:     return emit_watchdog(peers=peers, force=True, busy=busy)



