  47: class Watchdog(BaseModel):
  48:     node_id: str
  49:     busy: bool = True
  50:     emitted_at: float | None = None
  51: 
  52: 
  53: def _watchdog_age_s(node: dict, now: float | None = None) -> float | None:
  54:     now = now or time.time()
  55:     last_watchdog = node.get("last_watchdog")
  56:     if last_watchdog is None:
  57:         return None
  58:     try:
  59:         return max(0.0, now - float(last_watchdog))
  60:     except Exception:
  61:         return None
  62: 
  63: 
  64: def _state_age_s(node: dict, now: float | None = None) -> float | None:
  65:     now = now or time.time()
  66:     state_since = node.get("state_since")
  67:     if state_since is None:
  68:         return None
  69:     try:
  70:         return max(0.0, now - float(state_since))
  71:     except Exception:
  72:         return None
  73: 
  74: 
  75: def _seen_age_s(node: dict, now: float | None = None) -> float | None:
  76:     now = now or time.time()
  77:     last_seen = node.get("last_seen")
  78:     if last_seen is None:
  79:         return None
  80:     try:
  81:         return max(0.0, now - float(last_seen))
  82:     except Exception:
  83:         return None
  84: 
  85: 
  86: def _presence_age_s(node: dict, now: float | None = None) -> float | None:
  87:     now = now or time.time()
  88:     last_seen = node.get("last_seen")
  89:     last_watchdog = node.get("last_watchdog")
  90: 
  91:     candidates = []
  92:     for value in (last_seen, last_watchdog):
  93:         if value is None:
  94:             continue
  95:         try:
  96:             candidates.append(float(value))
  97:         except Exception:
  98:             continue
  99: 
 100:     if not candidates:
 101:         return None
 102: 
 103:     return max(0.0, now - max(candidates))
 104: 
 105: 
 106: def _presence_health(node: dict, now: float | None = None, stale_after_s: float = 3.0) -> str:
 107:     age = _presence_age_s(node, now)
 108:     if age is None:
 109:         return "stale"
 110:     return "ok" if age < stale_after_s else "stale"
 111: 
