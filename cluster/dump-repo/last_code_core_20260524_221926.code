   1: from cluster.runtime.event_log import append_event
   2: from cluster.runtime.events.event_state import EventStatus
   3: from cluster.utils.log_print import log_state
   4: 
   5: executed_keys = set()
   6: 
   7: 
   8: def run_business_logic(payload: dict):
   9:     return {"ok": True, "payload": payload}
  10: 
  11: 
  12: def execute_event(event, stream=None):
  13:     event.execution_key = f"{event.event_id}:{event.attempt}"
  14: 
  15:     if event.execution_key in executed_keys:
  16:         log_state("red", "[CACHE HIT]", event.execution_key, 3)
  17:         return {
  18:             "status": "completed",
  19:             "cached": True,
  20:             "event_id": event.event_id,
  21:             "execution_key": event.execution_key,
  22:         }
  23: 
  24:     result = run_business_logic(event.payload)
  25:     executed_keys.add(event.execution_key)
  26: 
  27:     msg = event.payload.get("msg", "<no-msg>")
  28:     log_state("green", "[EXECUTE]", f"{msg:12}", 3)
  29: 
  30:     event.mark_status(EventStatus.COMPLETED)
  31:     append_event(event)
  32: 
  33:     return {
  34:         "status": "completed",
  35:         "event_id": event.event_id,
  36:         "execution_key": event.execution_key,
  37:         "result": result,
  38:     }



===== ./utils/log_print.py =====
   1: 
   2: from datetime import datetime
   3: 
   4: modeGhost = False
   5: 
   6: def log_state(color, typ, msg, decimals=0):
   7: 
   8:     if modeGhost:
   9:         return
  10: 
  11:     colors = {
  12:         "red": "\033[91m",
  13:         "green": "\033[92m",
  14:         "yellow": "\033[93m",
  15:         "blue": "\033[94m",
  16:         "magenta": "\033[95m",
  17:         "cyan": "\033[96m",
  18:         "white": "\033[97m",
  19:         "reset": "\033[0m",
  20:     }
  21: 
  22:     c = colors.get(color.lower(), colors["white"])
  23:     reset = colors["reset"]
  24: 
  25:     decimals = max(0, min(6, int(decimals)))
  26: 
  27:     # -----------------------------------------
  28:     # fixed-width timestamp
  29:     # -----------------------------------------
  30: 
  31:     now = datetime.now()
  32: 
  33:     if decimals == 0:
  34: 
  35:         # reserva espacio para ".000"
  36:         ts = now.strftime("%H:%M:%S") + "    "
  37: 
  38:     else:
  39: 
  40:         micros = f"{now.microsecond:06d}"[:decimals]
  41:         ts = f"{now.strftime('%H:%M:%S')}.{micros}"
  42: 
  43:         # padding fijo hasta longitud 12
  44:         ts = f"{ts:<12}"
  45: 
  46:     # -----------------------------------------
  47:     # aligned tag
  48:     # -----------------------------------------
  49: 
  50:     tag = f"{typ:>14}"
  51: 
  52:     # -----------------------------------------
  53:     # print
  54:     # -----------------------------------------
  55: 
  56:     print(f"[{ts}] {c}{tag}{reset} {msg}")
  57: 
  58: 
