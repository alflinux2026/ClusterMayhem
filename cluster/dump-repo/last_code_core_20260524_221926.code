 353: @app.post("/watchdog")
 354: def watchdog(wd: Watchdog):
 355:     if ctx.node.state == NodeState.ISOLATED:
 356:         return {"error": "node isolated"}
 357: 
 358:     existing = cluster_state.get(wd.node_id, {})
 359:     ts = wd.emitted_at if wd.emitted_at is not None else time.time()
 360: 
 361:     cluster_state[wd.node_id] = {
 362:         **existing,
 363:         "last_watchdog": ts,
 364:         "last_seen": ts,
 365:         "watchdog_busy": bool(wd.busy),
 366:     }
 367: 
 368:     return {"ok": True, "node_id": wd.node_id, "last_watchdog": ts}
 369: 
