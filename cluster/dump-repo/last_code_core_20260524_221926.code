===== ./runtime/integrity.py =====
   1: 
   2: import os
   3: import hashlib
   4: from pathlib import Path
   5: from typing import Any
   6: 
   7: from cluster.runtime import context as ctx
   8: from cluster.runtime.cluster_store import cluster_state
   9: from cluster.runtime.event_log import get_local_log_path, get_last_append_meta
  10: from cluster.runtime.leader import compute_alive
  11: 
  12: IGNORED_NODE_KEYS = {"last_seen"}
  13: INTEGRITY_KEYS = (
  14:     "dirty",
  15:     "last_append_event_id",
  16:     "last_append_created_at",
  17:     "log_size",
  18:     "file_size",
  19:     "file_hash",
  20: )
  21: 
  22: 
  23: def file_sha256(path: str | Path, block_size: int = 65536) -> str | None:
  24:     path = str(path)
  25:     if not os.path.exists(path):
  26:         return None
  27:     h = hashlib.sha256()
  28:     with open(path, "rb") as f:
  29:         while True:
  30:             chunk = f.read(block_size)
  31:             if not chunk:
  32:                 break
  33:             h.update(chunk)
  34:     return h.hexdigest()
  35: 
  36: 
  37: def canonicalize(obj: Any, ignored_keys: set[str] | None = None) -> Any:
  38:     ignored_keys = ignored_keys or set()
  39:     if isinstance(obj, dict):
  40:         return {
  41:             k: canonicalize(v, ignored_keys)
  42:             for k, v in sorted(obj.items())
  43:             if k not in ignored_keys
  44:         }
  45:     if isinstance(obj, list):
  46:         return [canonicalize(v, ignored_keys) for v in obj]
  47:     return obj
  48: 
  49: 
  50: def compare_views(a: dict, b: dict) -> bool:
  51:     return canonicalize(a, IGNORED_NODE_KEYS) == canonicalize(b, IGNORED_NODE_KEYS)
  52: 
  53: 
  54: def log_meta_ok(local_meta: dict, peer_meta: dict) -> bool:
  55:     return all(local_meta.get(k) == peer_meta.get(k) for k in INTEGRITY_KEYS)
  56: 
  57: 
  58: def _compact_view(view: dict) -> dict:
  59:     if not isinstance(view, dict):
  60:         return {}
  61:     return {
  62:         "state": view.get("state"),
  63:         "state_since": view.get("state_since"),
  64:         "prev_state": view.get("prev_state"),
  65:         "state_reason": view.get("state_reason"),
  66:         "priority": view.get("priority"),
  67:         "log_meta": view.get("log_meta", {}),
  68:         "streams": view.get("streams", {}),
  69:     }
  70: 
  71: 
  72: def local_integrity_api() -> dict:
  73:     path = get_local_log_path()
  74:     alive = compute_alive(include_self=True)
  75: 
  76:     local_meta = {
  77:         "path": path,
  78:         "size": os.path.getsize(path) if os.path.exists(path) else 0,
  79:         "sha256": file_sha256(path),
  80:     }
  81: 
  82:     peer_status = {}
  83:     self_view = canonicalize(cluster_state.get(ctx.node_id, {}), IGNORED_NODE_KEYS)
  84:     self_meta = self_view.get("log_meta", {}) if isinstance(self_view, dict) else {}
  85: 
  86:     for node_id, data in alive.items():
  87:         view = canonicalize(data, IGNORED_NODE_KEYS)
  88:         meta = view.get("log_meta", {}) if isinstance(view, dict) else {}
  89:         peer_status[node_id] = {
  90:             "view": _compact_view(view),
  91:             "view_ok": view == canonicalize(cluster_state.get(node_id, {}), IGNORED_NODE_KEYS),
  92:             "log_meta_ok": log_meta_ok(self_meta, meta) if node_id == ctx.node_id else True,
  93:         }
  94: 
  95:     return {
  96:         "node_id": ctx.node_id,
  97:         "alive_nodes": sorted(alive.keys()),
  98:         "self_view": _compact_view(self_view),
  99:         "peer_status": peer_status,
 100:         "local_log_meta": local_meta,
 101:         "last_append_meta": get_last_append_meta(),
 102:         "integrity_ok": all(v["view_ok"] and v["log_meta_ok"] for v in peer_status.values()),
 103:     }
 104: 
 105: 
 106: def cluster_integrity_report() -> dict:
 107:     alive = compute_alive(include_self=True)
 108:     reference = canonicalize(cluster_state, IGNORED_NODE_KEYS)
 109:     per_peer = {}
 110: 
 111:     for node_id, data in alive.items():
 112:         view = canonicalize(data, IGNORED_NODE_KEYS)
 113:         meta = view.get("log_meta", {}) if isinstance(view, dict) else {}
 114:         ref_view = reference.get(node_id, {})
 115:         ref_meta = ref_view.get("log_meta", {}) if isinstance(ref_view, dict) else {}
 116: 
 117:         per_peer[node_id] = {
 118:             "matches_reference": view == ref_view,
 119:             "matches_log_meta": meta == ref_meta,
 120:             "state": view.get("state"),
 121:             "state_since": view.get("state_since"),
 122:             "prev_state": view.get("prev_state"),
 123:             "state_reason": view.get("state_reason"),
 124:             "priority": view.get("priority"),
 125:             "streams": view.get("streams", {}),
 126:         }
 127: 
 128:     return {
 129:         "node_id": ctx.node_id,
 130:         "alive_nodes": sorted(alive.keys()),
 131:         "reference": {k: _compact_view(v) for k, v in reference.items()} if isinstance(reference, dict) else {},
 132:         "per_peer": per_peer,
 133:         "integrity_ok": all(v["matches_reference"] and v["matches_log_meta"] for v in per_peer.values()),
 134:     }



===== ./runtime/leader.py =====
   1: import time
   2: 
   3: from cluster.runtime.cluster_store import cluster_state
   4: from cluster.runtime import context as ctx
   5: 
   6: LEADER_ALIVE_TIMEOUT = 1.5
   7: 
   8: 
   9: def refresh_self_alive_entry(now=None):
  10:     now = now or time.time()
  11:     if not getattr(ctx, "node", None):
  12:         return
  13: 
  14:     existing = cluster_state.get(ctx.node_id, {})
  15: 
  16:     cluster_state[ctx.node_id] = {
  17:         **existing,
  18:         "state": ctx.node.state.value,
  19:         "priority": ctx.node.priority,
  20:         "last_seen": now,
  21:         "state_since": getattr(ctx.node, "state_since", None),
  22:         "prev_state": getattr(ctx.node, "prev_state", None),
  23:         "state_reason": getattr(ctx.node, "state_reason", None),
  24:     }
  25: 
  26: 
  27: def last_presence_ts(data: dict) -> float:
  28:     candidates = []
  29:     for key in ("last_seen", "last_watchdog"):
  30:         value = data.get(key, 0)
  31:         if value is None:
  32:             continue
  33:         try:
  34:             candidates.append(float(value))
  35:         except Exception:
  36:             continue
  37:     return max(candidates) if candidates else 0.0
  38: 
  39: 
  40: def is_alive(data, timeout=LEADER_ALIVE_TIMEOUT, now=None):
  41:     now = now or time.time()
  42:     last_presence = last_presence_ts(data)
  43:     return (now - last_presence) < timeout
  44: 
  45: 
  46: def compute_alive(timeout=LEADER_ALIVE_TIMEOUT, include_self=True):
  47:     now = time.time()
  48:     if include_self:
  49:         refresh_self_alive_entry(now)
  50: 
  51:     active_nodes = {}
  52:     for node_id, data in cluster_state.items():
  53:         if is_alive(data, timeout=timeout, now=now):
  54:             active_nodes[node_id] = data
  55:     return active_nodes
  56: 
  57: 
  58: def compute_leader(debug_node_id=None, timeout=LEADER_ALIVE_TIMEOUT):
  59:     active_nodes = compute_alive(timeout=timeout, include_self=True)
  60:     if not active_nodes:
  61:         return None
  62:     return min(
  63:         active_nodes.items(),
  64:         key=lambda x: (x[1].get("priority", 9999), x[0]),
  65:     )[0]



===== ./runtime/log_replication.py =====
   1: 
   2: import logging
   3: import time
   4: 
   5: import requests
   6: 
   7: from cluster.runtime import context as ctx
   8: from cluster.runtime.cluster_store import cluster_state
   9: from cluster.runtime.registry import CLUSTER_REGISTRY
  10: from cluster.runtime.event_log import (
  11:     read_local_log_text,
  12:     write_replica_log,
  13:     read_state,
  14:     clear_state,
  15: )
  16: from cluster.runtime.state import NodeState
  17: from cluster.utils.log_print import log_state
  18: 
  19: logging.getLogger("urllib3").setLevel(logging.ERROR)
  20: logging.getLogger("requests").setLevel(logging.ERROR)
  21: 
  22: PEERALIVETTLSEC = 3.0
  23: REPLICATION_ALLOWED_STATES = {
  24:     NodeState.ACTIVE.value,
  25:     NodeState.STANDBY.value,
  26:     NodeState.DEGRADED.value,
  27: }
  28: 
  29: 
  30: def canonical_replica_node_id() -> str:
  31:     return ctx.node_id
  32: 
  33: 
  34: def alive_peer_ids():
  35:     out = []
  36:     now = time.time()
  37:     for node_id, data in cluster_state.items():
  38:         if node_id == ctx.node_id:
  39:             continue
  40:         if now - data.get("last_seen", 0) > PEERALIVETTLSEC:
  41:             continue
  42:         out.append(node_id)
  43:     return sorted(set(out))
  44: 
  45: 
  46: def configured_peer_ids():
  47:     out = []
  48: 
  49:     for peer in getattr(ctx, "peers", []) or []:
  50:         peer_id = peer.get("node_id")
  51:         if peer_id and peer_id != ctx.node_id:
  52:             out.append(peer_id)
  53: 
  54:     for node_id in CLUSTER_REGISTRY.keys():
  55:         if node_id != ctx.node_id:
  56:             out.append(node_id)
  57: 
  58:     return sorted(set(out))
  59: 
  60: 
  61: def target_peer_ids():
  62:     alive = alive_peer_ids()
  63:     configured = configured_peer_ids()
  64:     return sorted(set(alive) | set(configured))
  65: 
  66: 
  67: def replicate_local():
  68:     node_id = canonical_replica_node_id()
  69:     node_state = getattr(getattr(ctx, "node", None), "state", None)
  70:     node_state_value = getattr(node_state, "value", None)
  71: 
  72:     log_state("cyan", "REPL TICK", f"node={node_id}", 3)
  73: 
  74:     if node_state_value not in REPLICATION_ALLOWED_STATES:
  75:         log_state(
  76:             "yellow",
  77:             "REPL SKIP",
  78:             f"state={node_state_value} allowed={sorted(REPLICATION_ALLOWED_STATES)}",
  79:             3,
  80:         )
  81:         return
  82: 
  83:     state = read_state()
  84:     dirty = bool(state.get("dirty", False))
  85:     log_state("cyan", "REPL FLAG", f"dirty={dirty} state_exists={bool(state)}", 3)
  86:     if not dirty:
  87:         return
  88: 
  89:     content = read_local_log_text()
  90:     log_state("cyan", "REPL CONTENT", f"len={len(content)} empty={not content.strip()}", 3)
  91:     if not content.strip():
  92:         log_state("yellow", "REPL SKIP", "empty content", 3)
  93:         return
  94: 
  95:     write_replica_log(node_id, content)
  96:     log_state("cyan", "REPL SELF", f"{node_id} bytes={len(content)}", 3)
  97: 
  98:     peers = target_peer_ids()
  99:     log_state("cyan", "REPL PEERS", f"peers={peers}", 3)
 100: 
 101:     success = True
 102: 
 103:     for peer_id in peers:
 104:         node = CLUSTER_REGISTRY.get(peer_id)
 105:         if not node:
 106:             log_state("red", "LOG REPL FAIL", f"{peer_id} missing registry", 3)
 107:             success = False
 108:             continue
 109: 
 110:         url = f"http://{node['host']}:{node['port']}/debug/log/replica/{node_id}"
 111:         log_state("cyan", "REPL POST", f"peer={peer_id} url={url}", 3)
 112: 
 113:         try:
 114:             resp = requests.post(
 115:                 url,
 116:                 data=content.encode("utf-8"),
 117:                 headers={"Content-Type": "text/plain; charset=utf-8"},
 118:                 timeout=2,
 119:             )
 120: 
 121:             if resp.ok:
 122:                 log_state("cyan", "LOG REPL", f"{node_id} -> {peer_id}", 3)
 123:             else:
 124:                 success = False
 125:                 log_state("red", "LOG REPL FAIL", f"{peer_id} status={resp.status_code}", 3)
 126: 
 127:         except Exception as e:
 128:             success = False
 129:             log_state("red", "LOG REPL FAIL", f"{peer_id} err={e}", 3)
 130: 
 131:     if success:
 132:         clear_state()
 133:         log_state("cyan", "REPL CLEAR", "dirty=false", 3)



