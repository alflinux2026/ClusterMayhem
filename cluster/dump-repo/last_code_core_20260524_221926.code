 380:         "priority": hb.priority,
 381:         "last_seen": time.time(),
 382:         "state_since": hb.state_since if hb.state_since is not None else existing.get("state_since"),
 383:         "prev_state": hb.prev_state if hb.prev_state is not None else existing.get("prev_state"),
 384:         "state_reason": hb.state_reason if hb.state_reason is not None else existing.get("state_reason"),
 385:         "log_meta": hb.log_meta or existing.get("log_meta", {}),
 386:         "cluster_integrity": hb.cluster_integrity or existing.get("cluster_integrity", {}),
 387:         "streams": hb.streams or existing.get("streams", {}),
 388:     }
 389: 
 390:     return {"ok": True}
