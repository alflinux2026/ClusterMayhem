   1: from cluster.runtime.cluster_store import get_active_cluster
   2: 
   3: class ElectionEngine:
   4: 
   5:     @staticmethod
   6:     def can_become_leader(node_id, priority):
   7: 
   8:         active_nodes = get_active_cluster()
   9: 
  10:         # si hay líder activo estable, no competir
  11:         if any(n["state"] == "ACTIVE" for n in active_nodes.values()):
  12:             return False
  13: 
  14:         return True



