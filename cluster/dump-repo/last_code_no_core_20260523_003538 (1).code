  12: # =====================================================
  13: # DEFAULT CONFIG
  14: # =====================================================
  15: 
  16: DEFAULT_NODES = [
  17:     "http://100.100.1.200:7000",
  18:     "http://100.100.1.202:7000",
  19:     "http://100.100.1.203:7000",
  20: ]
  21: 
  22: DEFAULT_EVENTS = 100
  23: DEFAULT_EVENT_DELAY_MIN = 0.05
  24: DEFAULT_EVENT_DELAY_MAX = 0.2
  25: DEFAULT_KILL_PROBABILITY = 0.1
  26: DEFAULT_DEATH_TIME_MIN = 5.0
  27: DEFAULT_DEATH_TIME_MAX = 10.0
  28: DEFAULT_REQUEST_TIMEOUT = 5.0
  29: DEFAULT_MAX_RETRIES = 10
  30: DEFAULT_SLOW_EVENT_THRESHOLD_MS = 500.0
  31: DEFAULT_SLEEP_ONLY_NODE = None
  32: 
  33: 
  34: # =====================================================
  35: # CLI
  36: # =====================================================
  37: 
  38: def parse_args():
  39:     parser = argparse.ArgumentParser(description="Universal chaos torture runner (Termux/server)")
  40:     parser.add_argument("--nodes", nargs="+", default=DEFAULT_NODES, help="Node base URLs")
  41:     parser.add_argument("--events", type=int, default=DEFAULT_EVENTS, help="Number of events")
  42:     parser.add_argument("--delay-min", type=float, default=DEFAULT_EVENT_DELAY_MIN, help="Min delay between events")
  43:     parser.add_argument("--delay-max", type=float, default=DEFAULT_EVENT_DELAY_MAX, help="Max delay between events")
  44:     parser.add_argument("--kill-prob", type=float, default=DEFAULT_KILL_PROBABILITY, help="Probability of kill per event")
  45:     parser.add_argument("--death-min", type=float, default=DEFAULT_DEATH_TIME_MIN, help="Min isolation time")
  46:     parser.add_argument("--death-max", type=float, default=DEFAULT_DEATH_TIME_MAX, help="Max isolation time")
  47:     parser.add_argument("--timeout", type=float, default=DEFAULT_REQUEST_TIMEOUT, help="HTTP request timeout")
  48:     parser.add_argument("--retries", type=int, default=DEFAULT_MAX_RETRIES, help="Max retries per event")
  49:     parser.add_argument("--sleep-only-node", default=DEFAULT_SLEEP_ONLY_NODE, help="Always kill the same node")
  50:     parser.add_argument("--slow-ms", type=float, default=DEFAULT_SLOW_EVENT_THRESHOLD_MS, help="Slow event threshold in ms")
  51:     parser.add_argument("--seed", type=int, default=None, help="Random seed for reproducibility")
  52:     parser.add_argument("--output", default=None, help="Optional explicit output JSON filename")
  53:     return parser.parse_args()
  54: 
  55: 
  56: ARGS = parse_args()
  57: 
  58: if ARGS.seed is not None:
  59:     random.seed(ARGS.seed)
  60: 
  61: NODES = ARGS.nodes
  62: EVENTS = ARGS.events
  63: EVENT_DELAY_RANGE = (ARGS.delay_min, ARGS.delay_max)
  64: KILL_PROBABILITY = ARGS.kill_prob
  65: DEATH_TIME_RANGE = (ARGS.death_min, ARGS.death_max)
  66: REQUEST_TIMEOUT = ARGS.timeout
  67: MAX_RETRIES = ARGS.retries
  68: SLEEP_ONLY_NODE = ARGS.sleep_only_node
  69: SLOW_EVENT_THRESHOLD_MS = ARGS.slow_ms
  70: 
  71: 
  72: # =====================================================
  73: # RUN META
  74: # =====================================================
  75: 
  76: TEST_STARTED_AT = time.time()
  77: RUN_ID = datetime.now().strftime("%Y%m%d_%H%M%S")
  78: STATS_FILE = ARGS.output or f"chaos_stats_{RUN_ID}.json"
  79: 
  80: TEST_CONFIG = {
  81:     "nodes": NODES,
  82:     "events": EVENTS,
  83:     "event_delay_range": EVENT_DELAY_RANGE,
  84:     "kill_probability": KILL_PROBABILITY,
  85:     "death_time_range": DEATH_TIME_RANGE,
  86:     "request_timeout": REQUEST_TIMEOUT,
  87:     "max_retries": MAX_RETRIES,
  88:     "sleep_only_node": SLEEP_ONLY_NODE,
  89:     "slow_event_threshold_ms": SLOW_EVENT_THRESHOLD_MS,
  90:     "seed": ARGS.seed,
  91:     "run_id": RUN_ID,
  92:     "stats_file": STATS_FILE,
  93: }
  94: 
  95: 
  96: # =====================================================
  97: # GLOBALS
  98: # =====================================================
  99: 
 100: kill_threads = []
 101: dead_nodes = set()
 102: 
 103: dead_lock = threading.Lock()
 104: stats_lock = threading.Lock()
 105: 
 106: stats = {
 107:     "events_total": 0,
 108:     "events_ok": 0,
 109:     "events_failed": 0,
 110:     "events_retried": 0,
 111:     "events_no_leader": 0,
 112:     "events_timeout": 0,
 113:     "events_connection_error": 0,
 114:     "events_forward_error": 0,
 115:     "events_unexpected_fail": 0,
 116:     "events_slow": 0,
 117:     "kills": 0,
 118:     "revives": 0,
 119:     "kill_attempts": 0,
 120:     "kill_failures": 0,
 121:     "revive_failures": 0,
 122:     "per_node_ok": defaultdict(int),
 123:     "per_node_fail": defaultdict(int),
 124:     "leaders_seen": defaultdict(int),
 125:     "latency": [],
 126:     "unexpected_failures": [],
 127:     "slow_events": [],
 128:     "kill_events": [],
 129: }
 130: 
 131: 
 132: # =====================================================
 133: # HELPERS
 134: # =====================================================
 135: 
 136: def build_event(i):
 137:     return {
 138:         "event_id": str(uuid.uuid4()),
 139:         "event_type": "chaos.test",
 140:         "schema_version": "1",
 141:         "created_at": time.time(),
 142:         "received_at": None,
 143:         "trace_id": str(uuid.uuid4()),
 144:         "parent_event_id": None,
 145:         "source_node": None,
 146:         "target_node": None,
 147:         "route_hops": [],
 148:         "status": "created",
 149:         "attempt": 0,
 150:         "payload": {
 151:             "msg": f"msg-203: {i}",
 152:             "seq": i,
 153:             "source": "chaos_203"
 154:         }
 155:     }
 156: 
 157: 
 158: def stat_inc(key, amount=1):
 159:     with stats_lock:
 160:         stats[key] += amount
 161: 
 162: 
 163: def stat_node_ok(node):
 164:     with stats_lock:
 165:         stats["per_node_ok"][node] += 1
 166: 
 167: 
 168: def stat_node_fail(node):
 169:     with stats_lock:
 170:         stats["per_node_fail"][node] += 1
 171: 
 172: 
 173: def stat_leader(name):
 174:     with stats_lock:
 175:         stats["leaders_seen"][name] += 1
 176: 
 177: 
 178: def stat_latency(ms):
 179:     with stats_lock:
 180:         stats["latency"].append(ms)
 181: 
 182: 
 183: def stat_unexpected_failure(event_index, attempt, node, status_code=None, payload=None, reason=None):
 184:     with stats_lock:
 185:         stats["events_unexpected_fail"] += 1
 186:         stats["unexpected_failures"].append({
 187:             "event_index": event_index,
 188:             "attempt": attempt,
 189:             "node": node,
 190:             "status_code": status_code,
 191:             "payload": payload,
 192:             "reason": reason,
 193:             "timestamp": datetime.now().isoformat(),
 194:         })
 195: 
 196: 
 197: def stat_slow_event(event_index, attempt, node, latency_ms, leader=None, payload=None):
 198:     with stats_lock:
 199:         stats["events_slow"] += 1
 200:         stats["slow_events"].append({
 201:             "event_index": event_index,
 202:             "attempt": attempt,
 203:             "node": node,
 204:             "latency_ms": round(latency_ms, 3),
 205:             "leader": leader,
 206:             "payload": payload,
 207:             "timestamp": datetime.now().isoformat(),
 208:         })
 209: 
 210: 
 211: def stat_kill_event(node, action, ok, payload=None, error=None, seconds=None):
 212:     with stats_lock:
 213:         stats["kill_events"].append({
 214:             "action": action,
 215:             "node": node,
 216:             "ok": ok,
 217:             "seconds": seconds,
 218:             "payload": payload,
 219:             "error": error,
 220:             "timestamp": datetime.now().isoformat(),
 221:         })
 222: 
 223: 
 224: def percentile(data, p):
 225:     if not data:
 226:         return 0.0
 227:     values = sorted(data)
 228:     if len(values) == 1:
 229:         return float(values[0])
 230:     rank = (len(values) - 1) * (p / 100.0)
 231:     low = int(rank)
 232:     high = min(low + 1, len(values) - 1)
 233:     fraction = rank - low
 234:     return float(values[low] + (values[high] - values[low]) * fraction)
 235: 
 236: 
 237: def is_event_submit_ok(status_code, payload):
 238:     if status_code != 200:
 239:         return False
 240: 
 241:     if not isinstance(payload, dict):
 242:         return False
 243: 
 244:     if payload.get("ok") is True:
 245:         return True
 246: 
 247:     result = payload.get("result")
 248:     if isinstance(result, dict) and result.get("ok") is True:
 249:         return True
 250: 
 251:     return False
 252: 
 253: 
 254: def is_retryable_response(payload):
 255:     if not isinstance(payload, dict):
 256:         return False
 257: 
 258:     if payload.get("error") in {"no leader", "node isolated"}:
 259:         return True
 260: 
 261:     error = str(payload.get("error", "")).lower()
 262: 
 263:     retry_patterns = [
 264:         "timeout",
 265:         "connection",
 266:         "refused",
 267:         "temporarily unavailable",
 268:         "isolated",
 269:     ]
 270: 
 271:     return any(p in error for p in retry_patterns)
 272: 
 273: 
 274: def print_test_config():
 275:     print("\n" + "="* 56)
 276:     print("CHAOS TEST CONFIG v2")
 277:     print("="* 56)
 278:     print(f"run_id..............: {RUN_ID}")
 279:     print(f"stats_file..........: {STATS_FILE}")
 280:     print(f"started_at..........: {datetime.fromtimestamp(TEST_STARTED_AT).isoformat()}")
 281:     print(f"nodes...............: {NODES}")
 282:     print(f"events..............: {EVENTS}")
 283:     print(f"event_delay_range...: {EVENT_DELAY_RANGE}")
 284:     print(f"kill_probability....: {KILL_PROBABILITY}")
 285:     print(f"death_time_range....: {DEATH_TIME_RANGE}")
 286:     print(f"request_timeout.....: {REQUEST_TIMEOUT}")
 287:     print(f"max_retries.........: {MAX_RETRIES}")
 288:     print(f"sleep_only_node.....: {SLEEP_ONLY_NODE}")
 289:     print(f"slow_threshold_ms...: {SLOW_EVENT_THRESHOLD_MS}")
 290:     print(f"seed................: {ARGS.seed}")
 291:     print("="* 56 + "\n")
 292: 
 293: 
 294: # =====================================================
 295: # KILL / REVIVE
 296: # =====================================================
 297: 
 298: def kill_node(node, seconds=None):
 299:     stat_inc("kill_attempts")
 300: 
 301:     try:
 302:         resp = requests.post(f"{node}/sleep", timeout=2)
 303:         payload = {}
 304: 
 305:         try:
 306:             payload = resp.json()
 307:         except Exception:
 308:             payload = {"raw_text": resp.text}
 309: 
 310:         if resp.status_code == 200 and payload.get("ok") is True:
 311:             with dead_lock:
 312:                 dead_nodes.add(node)
 313: 
 314:             stat_inc("kills")
 315:             stat_kill_event(node=node, action="sleep", ok=True, payload=payload, seconds=seconds)
 316:             print(f"[CHAOS] SLEEP {node}")
 317:             return True
 318: 
 319:         stat_inc("kill_failures")
 320:         stat_kill_event(node=node, action="sleep", ok=False, payload=payload, seconds=seconds)
 321:         print(f"[CHAOS FAIL SLEEP] {node} -> status={resp.status_code} payload={payload}")
 322:         return False
 323: 
 324:     except Exception as e:
 325:         stat_inc("kill_failures")
 326:         stat_kill_event(node=node, action="sleep", ok=False, error=str(e), seconds=seconds)
 327:         print(f"[CHAOS FAIL SLEEP] {node} -> {e}")
 328:         return False
 329: 
 330: 
 331: def revive_node(node):
 332:     try:
 333:         resp = requests.post(f"{node}/revive", timeout=2)
 334:         payload = {}
 335: 
 336:         try:
 337:             payload = resp.json()
 338:         except Exception:
 339:             payload = {"raw_text": resp.text}
 340: 
 341:         if resp.status_code == 200 and payload.get("ok") is True:
 342:             with dead_lock:
 343:                 dead_nodes.discard(node)
 344: 
 345:             stat_inc("revives")
 346:             stat_kill_event(node=node, action="revive", ok=True, payload=payload)
 347:             print(f"[CHAOS] REVIVE {node}")
 348:             return True
 349: 
 350:         stat_inc("revive_failures")
 351:         stat_kill_event(node=node, action="revive", ok=False, payload=payload)
 352:         print(f"[CHAOS FAIL REVIVE] {node} -> status={resp.status_code} payload={payload}")
 353:         return False
 354: 
 355:     except Exception as e:
 356:         stat_inc("revive_failures")
 357:         stat_kill_event(node=node, action="revive", ok=False, error=str(e))
 358:         print(f"[CHAOS FAIL REVIVE] {node} -> {e}")
 359:         return False
 360: 
 361: 
 362: def kill_cycle(node, seconds):
 363:     try:
 364:         ok = kill_node(node, seconds=seconds)
 365:         if ok:
 366:             print(f"[CHAOS] DEAD {node} for {seconds:.2f}s")
 367:             time.sleep(seconds)
 368:     finally:
 369:         revive_node(node)
 370: 
 371: 
 372: # =====================================================
 373: # EVENT SENDING
 374: # =====================================================
 375: 
 376: def send_event(i):
 377:     stat_inc("events_total")
 378:     tried = set()
 379: 
 380:     event = build_event(i)
 381: 
 382:     for attempt in range(MAX_RETRIES):
 383:         available = [n for n in NODES if n not in tried]
 384: 
 385:         if not available:
 386:             break
 387: 
 388:         node = random.choice(available)
 389:         tried.add(node)
 390:         start = time.time()
 391: 
 392:         try:
 393:             r = requests.post(
 394:                 f"{node}/event",
 395:                 json=event,
 396:                 timeout=REQUEST_TIMEOUT
 397:             )
 398: 
 399:             elapsed_ms = (time.time() - start) * 1000
 400:             stat_latency(elapsed_ms)
 401: 
 402:             payload = {}
 403:             try:
 404:                 payload = r.json()
 405:             except Exception:
 406:                 payload = {"raw_text": r.text}
 407: 
 408:             leader = None
 409:             if isinstance(payload, dict):
 410:                 if "result" in payload and isinstance(payload["result"], dict):
 411:                     leader = payload["result"].get("leader")
 412:                 else:
 413:                     leader = payload.get("leader")
 414: 
 415:             if leader:
 416:                 stat_leader(leader)
 417: 
 418:             if elapsed_ms >= SLOW_EVENT_THRESHOLD_MS:
 419:                 stat_slow_event(
 420:                     event_index=i,
 421:                     attempt=attempt + 1,
 422:                     node=node,
 423:                     latency_ms=elapsed_ms,
 424:                     leader=leader,
 425:                     payload=payload,
 426:                 )
 427: 
 428:             if is_event_submit_ok(r.status_code, payload):
 429:                 stat_inc("events_ok")
 430:                 stat_node_ok(node)
 431: 
 432:                 print(
 433:                     f"[TORTURE] "
 434:                     f"{i:03} "
 435:                     f"OK "
 436:                     f"attempt={attempt + 1} "
 437:                     f"node={node} "
 438:                     f"leader={leader} "
 439:                     f"latency={elapsed_ms:.1f}ms"
 440:                 )
 441: 
 442:                 return True
 443: 
 444:             if is_retryable_response(payload) or r.status_code >= 500:
 445:                 stat_inc("events_retried")
 446: 
 447:                 if isinstance(payload, dict) and payload.get("error") == "no leader":
 448:                     stat_inc("events_no_leader")
 449: 
 450:                 print(
 451:                     f"[RETRY] "
 452:                     f"{i:03} "
 453:                     f"attempt={attempt + 1} "
 454:                     f"node={node} "
 455:                     f"status={r.status_code} "
 456:                     f"payload={payload}"
 457:                 )
 458: 
 459:                 time.sleep(0.5)
 460:                 continue
 461: 
 462:             stat_inc("events_failed")
 463:             stat_node_fail(node)
 464:             stat_unexpected_failure(
 465:                 event_index=i,
 466:                 attempt=attempt + 1,
 467:                 node=node,
 468:                 status_code=r.status_code,
 469:                 payload=payload,
 470:                 reason="hard_fail_non_retryable_response",
 471:             )
 472: 
 473:             print(
 474:                 f"[FAIL] "
 475:                 f"{i:03} "
 476:                 f"node={node} "
 477:                 f"status={r.status_code} "
 478:                 f"payload={payload}"
 479:             )
 480: 
 481:             return False
 482: 
 483:         except requests.Timeout as e:
 484:             stat_inc("events_timeout")
 485:             stat_inc("events_retried")
 486: 
 487:             print(
 488:                 f"[TIMEOUT] "
 489:                 f"{i:03} "
 490:                 f"attempt={attempt + 1} "
 491:                 f"{node} -> {e}"
 492:             )
 493: 
 494:         except requests.ConnectionError as e:
 495:             stat_inc("events_connection_error")
 496:             stat_inc("events_retried")
 497: 
 498:             print(
 499:                 f"[CONNECTION] "
 500:                 f"{i:03} "
 501:                 f"attempt={attempt + 1} "
 502:                 f"{node} -> {e}"
 503:             )
 504: 
 505:         except Exception as e:
 506:             stat_inc("events_forward_error")
 507:             stat_inc("events_retried")
 508:             stat_unexpected_failure(
 509:                 event_index=i,
 510:                 attempt=attempt + 1,
 511:                 node=node,
 512:                 reason=f"exception:{type(e).__name__}",
 513:                 payload={"exception": str(e)},
 514:             )
 515: 
 516:             print(
 517:                 f"[ERROR] "
 518:                 f"{i:03} "
 519:                 f"attempt={attempt + 1} "
 520:                 f"{node} -> {e}"
 521:             )
 522: 
 523:         time.sleep(0.5)
 524: 
 525:     stat_inc("events_failed")
 526:     stat_unexpected_failure(
 527:         event_index=i,
 528:         attempt=MAX_RETRIES,
 529:         node=None,
 530:         reason="dropped_after_retries",
 531:         payload={"tried_nodes": list(tried)},
 532:     )
 533: 
 534:     print(f"[DROP] {i:03} event dropped after retries")
 535:     return False
 536: 
 537: 
 538: # =====================================================
 539: # MAIN LOOP
 540: # =====================================================
 541: 
 542: def chaos_loop():
 543:     for i in range(EVENTS):
 544:         if random.random() < KILL_PROBABILITY:
 545:             if SLEEP_ONLY_NODE:
 546:                 node = SLEEP_ONLY_NODE
 547:             else:
 548:                 node = random.choice(NODES)
 549: 
 550:             seconds = random.uniform(*DEATH_TIME_RANGE)
 551: 
 552:             t = threading.Thread(
 553:                 target=kill_cycle,
 554:                 args=(node, seconds),
 555:                 daemon=True
 556:             )
 557: 
 558:             t.start()
 559:             kill_threads.append(t)
 560: 
 561:         send_event(i)
 562:         time.sleep(random.uniform(*EVENT_DELAY_RANGE))
 563: 
 564: 
 565: # =====================================================
 566: # FORCE REVIVE ALL
 567: # =====================================================
 568: 
 569: def revive_everything():
 570:     print("\n[MAIN] REVIVING ALL NODES\n")
 571: 
 572:     unique_nodes = sorted(set(NODES))
 573: 
 574:     for node in unique_nodes:
 575:         try:
 576:             requests.post(f"{node}/revive", timeout=2)
 577:             print(f"[FORCE REVIVE] {node}")
 578:         except Exception as e:
 579:             print(f"[FORCE REVIVE FAIL] {node} -> {e}")
 580: 
 581: 
 582: # =====================================================
 583: # WAIT ALL KILL THREADS
 584: # =====================================================
 585: 
 586: def wait_kills():
 587:     print("\n[MAIN] waiting active kill cycles...\n")
 588: 
 589:     for t in kill_threads:
 590:         t.join(timeout=30)
 591: 
 592: 
