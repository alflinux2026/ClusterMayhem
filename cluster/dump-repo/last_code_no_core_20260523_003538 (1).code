 873:                 "ended_at_epoch": ended_at,
 874:                 "started_at_iso": datetime.fromtimestamp(TEST_STARTED_AT).isoformat(),
 875:                 "ended_at_iso": datetime.fromtimestamp(ended_at).isoformat(),
 876:                 "duration_seconds": round(ended_at - TEST_STARTED_AT, 3),
 877:             },
 878:             "stats": {
 879:                 **stats,
