===== ./node/node_runtime.py =====
   1: import time
   2: 
   3: from cluster.runtime.state import NodeState
   4: from cluster.runtime.leader import compute_leader
   5: from cluster.runtime.cluster_store import cluster_state
   6: 
   7: import requests
   8: 
   9: from cluster.utils.log_print import log_state
  10: 
  11: 
  12: class NodeRuntime:
  13: 
  14:     def __init__(self, node_id, priority):
  15:         self.node_id = node_id
  16:         self.priority = priority
  17: 
  18:         self.state = NodeState.BOOT
  19:         self.last_heartbeat = time.time()
  20: 
  21:     # -----------------------------------------------------
  22:     # STATE TRANSITION
  23:     # -----------------------------------------------------
  24: 
  25:     def transition(self, new_state):
  26: 
  27:         if self.state == new_state:
  28:             return
  29: 
  30:         print(f"[{self.node_id}] {self.state} -> {new_state}")
  31:         self.state = new_state
  32: 
  33:     # -----------------------------------------------------
  34:     # MAIN TICK LOOP
  35:     # -----------------------------------------------------
  36: 
  37:     def tick(self):
  38: 
  39: #        print(f"[TICK] {self.node_id} state={self.state.value}")
  40: #        print(f"[STATE] {self.state.value}")
  41: #        log_state("yellow", "CLUSTER", f"State: {self.state.value}")
  42: 
  43:         # BOOT -> STANDBY (una sola vez)
  44:         if self.state == NodeState.BOOT:
  45:             self.transition(NodeState.STANDBY)
  46:             return
  47: 
  48: #        if self.state == NodeState.ISOLATED:
  49: #           print(f"[{self.node_id}] becoming ACTIVE")
  50: #            log_state("yellow", "    [CLUSTER]", f"[{self.node_id}] becoming ISOLATED")
  51: #            self.transition(NodeState.ISOLATED)
  52: 
  53:         # -------------------------------------------------
  54:         # GLOBAL LEADER DECISION (external authority)
  55:         # -------------------------------------------------
  56: 
  57:         leader = compute_leader()
  58: 
  59: 
  60: # oculto de momento        log_state("yellow", "    (CLUSTER)", f"State: {self.state.value} - Leader: {leader}")
  61: 
  62:         # -------------------------------------------------
  63:         # APPLY RESULT (no decision, only reflection)
  64:         # -------------------------------------------------
  65: 
  66:         if leader == self.node_id:
  67:             if self.state == NodeState.STANDBY:
  68: #                print(f"[{self.node_id}] becoming ACTIVE")
  69:                 log_state("yellow", "    [CLUSTER]", f"[{self.node_id}] becoming ACTIVE")
  70:                 self.transition(NodeState.ACTIVE)
  71:         else:
  72:             if self.state == NodeState.ACTIVE:
  73: #                print(f"[{self.node_id}] becoming STANDBY")
  74:                 log_state("yellow", "    [CLUSTER]", f"[{self.node_id}] becoming STANDBY")
  75:                 self.transition(NodeState.STANDBY)
  76: 
  77:     # -----------------------------------------------------
  78:     # HEARTBEAT (ONLY TELEMETRY)
  79:     # -----------------------------------------------------
  80: 
  81: 
  82:     def emit_heartbeat(self, peers):
  83: 
  84:         hb = {
  85:             "node_id": self.node_id,
  86:             "state": self.state.value,
  87:             "priority": self.priority,
  88:         }
  89: 
  90:         for peer in peers:
  91:             url = f"http://{peer['host']}:{peer['port']}/heartbeat"
  92: 
  93:             try:
  94:                 requests.post(url, json=hb, timeout=2)
  95: 
  96:             except requests.exceptions.RequestException:
  97:                 pass  # nodo offline = estado normal del cluster



