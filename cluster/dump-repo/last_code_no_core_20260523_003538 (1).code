 899: # =====================================================
 900: # MAIN
 901: # =====================================================
 902: 
 903: def main():
 904:     print("[MAIN] starting UNIVERSAL chaos torture v3")
 905:     print_test_config()
 906: 
 907:     workers = []
 908:     for idx in range(SEND_WORKERS):
 909:         t = threading.Thread(target=sender_worker, args=(idx,), daemon=True)
 910:         t.start()
 911:         workers.append(t)
 912: 
 913:     drained = False
 914: 
 915:     try:
 916:         chaos_loop()
 917:         drained = wait_queue_drain()
 918:         pending_queue.join()
 919: 
 920:         for t in workers:
 921:             t.join(timeout=5)
 922: 
 923:     finally:
 924:         wait_kills()
 925:         revive_everything()
 926: 
 927:         if not drained:
 928:             print(f"\n[MAIN WARN] queue drain timeout reached after {DRAIN_TIMEOUT:.1f}s\n")
 929: 
 930:         print_test_config()
 931:         print_stats()
 932:         print("\n[MAIN] cluster restored\n")
 933: 
 934: 
 935: # =====================================================
 936: # ENTRYPOINT
 937: # =====================================================
 938: 
 939: if __name__ == "__main__":
 940:     main()



