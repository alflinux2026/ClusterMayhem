 755: 
 756: def print_stats():
 757:     ended_at = time.time()
 758: 
 759:     print("\n")
 760:     print("=" * 56)
 761:     print("FINAL CHAOS STATS v3")
 762:     print("=" * 56)
 763: 
 764:     with stats_lock:
 765:         total = stats["events_total"]
 766:         ok = stats["events_ok"]
 767:         failed = stats["events_failed"]
 768: 
 769:         success_rate = ((ok / total) * 100) if total else 0
 770: 
 771:         avg_latency = (sum(stats["latency"]) / len(stats["latency"])) if stats["latency"] else 0
 772:         max_latency = max(stats["latency"]) if stats["latency"] else 0
 773:         min_latency = min(stats["latency"]) if stats["latency"] else 0
 774:         p50_latency = percentile(stats["latency"], 50)
 775:         p95_latency = percentile(stats["latency"], 95)
 776:         p99_latency = percentile(stats["latency"], 99)
 777: 
 778:         print(f"events_total........: {total}")
 779:         print(f"events_ok...........: {ok}")
 780:         print(f"events_failed.......: {failed}")
 781:         print(f"success_rate........: {success_rate:.2f}%")
 782: 
 783:         print()
 784: 
 785:         print(f"events_retried......: {stats['events_retried']}")
 786:         print(f"events_no_leader....: {stats['events_no_leader']}")
 787:         print(f"timeouts............: {stats['events_timeout']}")
 788:         print(f"connection_errors...: {stats['events_connection_error']}")
 789:         print(f"forward_errors......: {stats['events_forward_error']}")
 790:         print(f"unexpected_fail.....: {stats['events_unexpected_fail']}")
 791:         print(f"slow_events.........: {stats['events_slow']}")
 792: 
 793:         print()
 794: 
 795:         print(f"submit_http_200.....: {stats['submit_http_200']}")
 796:         print(f"submit_semantic_ok..: {stats['submit_semantic_ok']}")
 797:         print(f"submit_hard_fail....: {stats['submit_hard_fail']}")
 798:         print(f"queue_requeues......: {stats['queue_requeues']}")
 799:         print(f"queue_max_depth.....: {stats['queue_max_depth']}")
 800: 
 801:         print()
 802: 
 803:         print(f"kill_attempts.......: {stats['kill_attempts']}")
 804:         print(f"kills...............: {stats['kills']}")
 805:         print(f"kill_failures.......: {stats['kill_failures']}")
 806:         print(f"revives.............: {stats['revives']}")
 807:         print(f"revive_failures.....: {stats['revive_failures']}")
 808: 
 809:         print()
 810: 
 811:         print(f"latency_avg.........: {avg_latency:.1f} ms")
 812:         print(f"latency_min.........: {min_latency:.1f} ms")
 813:         print(f"latency_p50.........: {p50_latency:.1f} ms")
