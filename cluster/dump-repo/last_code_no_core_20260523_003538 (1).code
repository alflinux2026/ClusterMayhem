  94: def build_groups(rows):
  95:     groups = {}
  96:     for row in rows:
  97:         groups.setdefault(row["source"], []).append(row)
  98:     return groups
  99: 
 100: def check_consistency(groups):
 101:     for source, entries in groups.items():
 102:         for file_name in set(e["file"] for e in entries):
 103:             entries_file = [e for e in entries if e["file"] == file_name]
 104:             sizes = {e["node"]: e["size"] for e in entries_file}
 105:             mtimes = {e["node"]: (e["mtime_date"], e["mtime_time"]) for e in entries_file}
 106:             size_ok = len(set(sizes.values())) == 1
 107:             mtime_ok = len(set(mtimes.values())) <= 2
 108: 
 109:             print(
 110:                 f"[INFO] {source}/{file_name}: "
 111:                 f"size={'OK' if size_ok else 'MISMATCH'} "
 112:                 f"mtime={'OK' if mtime_ok else 'MISMATCH'}"
 113:             )
 114: 
 115: def render_markdown(groups):
 116:     source_order = ["lnx200nas", "lnx202pc", "lnx203hp"]
 117:     NODE_WIDTH  = 16
 118:     FILE_WIDTH  = 30
 119:     SIZE_WIDTH  = 10
 120:     MTIME_WIDTH = 25
 121: 
 122:     lines = []
 123: 
 124:     for source in source_order:
 125:         if source not in groups:
 126:             continue
 127:         entries = groups[source]
 128:         lines.append(f"### log de {source}:")
 129:         lines.append("")
 130: 
 131:         # Ordenamos por nodo, luego por archivo
 132:         entries.sort(key=lambda x: (x["node"], x["file"]))
 133: 
 134:         for e in entries:
 135:             node  = (e["node"] + " " * NODE_WIDTH)[:NODE_WIDTH]
 136:             file  = (e["file"] + " " * FILE_WIDTH)[:FILE_WIDTH]
 137:             size  = (f"{e['size']}" + " " * SIZE_WIDTH)[:SIZE_WIDTH]
 138:             mtime = (
 139:                 e["mtime_date"] + "T" + e["mtime_time"] + e["mtime_tz"] + " " * MTIME_WIDTH
 140:             )[:MTIME_WIDTH]
 141:             lines.append(f"- {node}  {file}  {size}  {mtime}")
 142:         lines.append("")
 143: 
 144:     return "\n".join(lines).strip() + "\n"
 145: 
 146: def main():
 147:     all_rows = []
 148:     for node in NODES:
 149:         print(f"[INFO] Consultando {node['name']} ({node['host']})...")
 150:         try:
 151:             text = ssh_ls(node)
 152:             rows = parse_ls_output(node["name"], text)
 153:             all_rows.extend(rows)
 154:         except Exception as e:
 155:             print(f"[ERROR] {node['name']}: {e}")
 156: 
 157:     groups = build_groups(all_rows)
 158:     check_consistency(groups)
 159: 
 160:     md = render_markdown(groups)
 161:     OUT_MD.write_text(md, encoding="utf-8")
 162: 
 163:     with OUT_CSV.open("w", newline="", encoding="utf-8") as f:
 164:         writer = csv.DictWriter(
 165:             f,
 166:             fieldnames=["node", "file", "source", "mtime_date", "mtime_time", "mtime_tz", "size"],
 167:         )
 168:         writer.writeheader()
 169:         writer.writerows(all_rows)
 170: 
 171:     print(f"[OK] Markdown: {OUT_MD}")
 172:     print(f"[OK] CSV: {OUT_CSV}")
 173: 
 174: if __name__ == "__main__":
 175:     main()



