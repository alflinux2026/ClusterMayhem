 202: def percentile(data, p):
 203:     if not data:
 204:         return 0.0
 205:     values = sorted(data)
 206:     if len(values) == 1:
 207:         return float(values[0])
 208:     rank = (len(values) - 1) * (p / 100.0)
 209:     low = int(rank)
 210:     high = min(low + 1, len(values) - 1)
 211:     return float(values[low] + (values[high] - values[low]) * (rank - low))
 212: 
 213: 
 214: def is_retryable_response(payload):
 215:     if not isinstance(payload, dict):
 216:         return False
 217:     if payload.get("error") in {"no leader", "node isolated"}:
 218:         return True
 219:     return any(p in str(payload.get("error", "")).lower() for p in ["timeout", "connection", "refused", "temporarily unavailable", "isolated", "no leader"])
 220: 
 221: 
 222: def extract_leader(payload):
 223:     if not isinstance(payload, dict):
 224:         return None
 225:     if "result" in payload and isinstance(payload["result"], dict):
 226:         return payload["result"].get("leader")
 227:     return payload.get("leader")
 228: 
 229: 
 230: def classify_submit_response(status_code, payload):
 231:     if status_code != 200:
 232:         return "http_not_ok"
 233:     if not isinstance(payload, dict):
 234:         return "submit_ok"
 235:     if payload.get("error"):
 236:         return "retryable_error" if is_retryable_response(payload) else "hard_fail"
 237:     result = payload.get("result")
 238:     if isinstance(result, dict) and result.get("error"):
 239:         return "retryable_error" if is_retryable_response(result) else "hard_fail"
 240:     return "submit_ok"
