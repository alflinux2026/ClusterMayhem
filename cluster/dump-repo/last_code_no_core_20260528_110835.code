 144: def fetch_api_snapshot(node):
 145:     base = f"http://{node['host']}:{node['api_port']}"
 146:     dashboard = fetch_json(f"{base}/dashboard/compact")
 147:     health = fetch_json(f"{base}/health")
 148:     integrity = fetch_json(f"{base}/integrity")
 149:     events_summary_local = fetch_json(f"{base}/debug/events/summary")
 150: 
