   1: import json
   2: 
   3: from cluster.node.node_runtime import NodeRuntime
   4: 
   5: from cluster.runtime.state import NodeState
   6: from cluster.workers.cluster_worker import ClusterWorker
   7: from cluster.transport.server import register_local_node
   8: 
   9: 
  10: 
  11: 
  12: def load_config():
  13: 
  14:     with open("cluster/config/nodes.json") as f:
  15:         return json.load(f)
  16: 
  17: 
  18: def build_peers(config, self_id):
  19: 
  20:     return [
  21:         n for n in config["nodes"]
  22:         if n["node_id"] != self_id
  23:     ]
  24: 
  25: 
  26: def main(node_id, priority):
  27: 
  28:     config = load_config()
  29:     peers = build_peers(config, node_id)
  30: 
  31:     node = NodeRuntime(
  32:         node_id=node_id,
  33:         priority=priority,
  34:     )
  35: 
  36:     node.state = NodeState.ACTIVE
  37: 
  38:     worker = ClusterWorker(node, peers)
  39: 
  40:     worker.start()
  41: 
  42: 
  43: if __name__ == "__main__":
  44: 
  45:     import sys
  46: 
  47:     main(
  48:         node_id=sys.argv[1],
  49:         priority=int(sys.argv[2]),
  50:     )



