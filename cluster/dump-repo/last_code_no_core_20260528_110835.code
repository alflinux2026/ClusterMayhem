 203: def percentile(data, p):
 204:     if not data:
 205:         return 0.0
 206:     values = sorted(data)
 207:     if len(values) == 1:
 208:         return float(values[0])
 209:     rank = (len(values) - 1) * (p / 100.0)
 210:     low = int(rank)
 211:     high = min(low + 1, len(values) - 1)
 212:     return float(values[low] + (values[high] - values[low]) * (rank - low))
