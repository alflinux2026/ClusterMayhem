 174: def check_consistency(groups):
 175:     for source, entries in groups.items():
 176:         for file_name in set(e["file"] for e in entries):
 177:             entries_file = [e for e in entries if e["file"] == file_name]
 178:             sizes = {e["node"]: e["size"] for e in entries_file}
 179:             mtimes = {e["node"]: (e["mtime_date"], e["mtime_time"]) for e in entries_file}
 180:             size_ok = len(set(sizes.values())) == 1
 181:             mtime_ok = len(set(mtimes.values())) <= 2
 182:             print(
 183:                 f"[INFO] {source}/{file_name}: size={'OK' if size_ok else 'MISMATCH'} "
 184:                 f"mtime={'OK' if mtime_ok else 'MISMATCH'}"
 185:             )
