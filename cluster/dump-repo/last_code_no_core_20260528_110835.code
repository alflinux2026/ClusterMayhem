 146:     "revives": 0,
 147:     "kill_attempts": 0,
 148:     "kill_failures": 0,
 149:     "revive_failures": 0,
 150:     "per_node_ok": defaultdict(int),
 151:     "per_node_fail": defaultdict(int),
 152:     "leaders_seen": defaultdict(int),
 153:     "latency": [],
 154:     "unexpected_failures": [],
