 135: def fetch_json(url, timeout=4):
 136:     try:
 137:         resp = HTTP.get(url, timeout=timeout)
 138:         resp.raise_for_status()
 139:         return resp.json()
 140:     except Exception as e:
 141:         return {"error": str(e), "url": url}
