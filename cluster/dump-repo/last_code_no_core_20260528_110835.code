 188: def _node_runtime_view(api_snapshots, node_name):
 189:     def fallback(*values):
 190:         for value in values:
 191:             if value is not None:
 192:                 return value
 193:         return None
 194: 
 195:     def score_row(row):
 196:         if not isinstance(row, dict):
 197:             return -1
 198:         score = 0
 199:         if row.get("node_id") == node_name:
 200:             score += 1
 201:         if row.get("presence_age_s") is not None:
 202:             score += 2
 203:         if row.get("watchdog_age_s") is not None:
 204:             score += 4
 205:         if row.get("watchdog_busy") is not None:
 206:             score += 2
 207:         if row.get("health") == "ok":
 208:             score += 1
 209:         if row.get("progress_stage") is not None:
 210:             score += 1
 211:         if row.get("progress_age_s") is not None:
 212:             score += 1
 213:         return score
 214: 
 215:     local_snap = api_snapshots.get(node_name, {}) or {}
 216:     local_health = local_snap.get("health", {}) or {}
 217:     local_integrity = local_snap.get("integrity", {}) or {}
 218:     local_summary = local_snap.get("events_summary_local", {}) or {}
 219: 
 220:     candidate_rows = []
 221: 
 222:     for snap_name, snap in (api_snapshots or {}).items():
 223:         dashboard = (snap or {}).get("dashboard", {}) or {}
 224:         for r in dashboard.get("nodes", []) or []:
 225:             if r.get("node_id") == node_name:
 226:                 candidate_rows.append((snap_name, r))
 227: 
 228:     best_row = {}
 229:     if candidate_rows:
 230:         candidate_rows.sort(key=lambda item: score_row(item[1]), reverse=True)
 231:         best_row = candidate_rows[0][1] or {}
 232: 
 233:     counts = local_summary.get("counts", {}) if isinstance(local_summary, dict) else {}
 234:     local_meta = local_integrity.get("local_log_meta", {}) if isinstance(local_integrity, dict) else {}
 235:     last_append = local_integrity.get("last_append_meta", {}) if isinstance(local_integrity, dict) else {}
 236: 
 237:     state_raw = fallback(best_row.get("state"), local_health.get("state"))
 238:     state_value = state_raw if state_raw in (
 239:         "ACTIVE", "STAND-BY", "STANDBY", "DRAINING", "SEGMENTATION", "ISOLATED", "OFFLINE"
 240:     ) else "???"
 241: 
 242:     progress_active = fallback(best_row.get("progress_active"), local_health.get("progress_active"), False)
 243:     progress_stage = fallback(best_row.get("progress_stage"), local_health.get("progress_stage"))
 244:     progress_age_s = fallback(best_row.get("progress_age_s"), local_health.get("progress_age_s"))
 245:     progress_current = fallback(best_row.get("progress_current"), local_health.get("progress_current"))
 246:     progress_total = fallback(best_row.get("progress_total"), local_health.get("progress_total"))
 247:     progress_stalled = fallback(best_row.get("progress_stalled"), local_health.get("progress_stalled"), False)
 248: 
 249:     progress_pct = None
 250:     try:
 251:         if progress_current is not None and progress_total not in (None, 0):
 252:             progress_pct = round((float(progress_current) / float(progress_total)) * 100.0, 1)
 253:     except Exception:
 254:         progress_pct = None
 255: 
 256:     return {
 257:         "health": fallback(best_row.get("health"), local_health.get("status"), "?"),
 258:         "state": state_value,
 259:         "state_age_s": fallback(best_row.get("state_age_s"), local_health.get("state_age_s")),
 260:         "presence_age_s": fallback(best_row.get("presence_age_s"), local_health.get("presence_age_s")),
 261:         "watchdog_age_s": fallback(best_row.get("watchdog_age_s"), local_health.get("watchdog_age_s")),
 262:         "watchdog_busy": fallback(best_row.get("watchdog_busy"), local_health.get("watchdog_busy")),
 263:         "progress_active": bool(progress_active),
 264:         "progress_stage": progress_stage,
 265:         "progress_age_s": progress_age_s,
 266:         "progress_current": progress_current,
 267:         "progress_total": progress_total,
 268:         "progress_pct": progress_pct,
 269:         "progress_stalled": bool(progress_stalled),
 270:         "local_size": int(local_meta.get("size", 0) or 0),
 271:         "local_events": int(local_summary.get("total_events", 0) or 0),
 272:         "created": int(counts.get("created", 0) or 0),
 273:         "executing": int(counts.get("executing", 0) or 0),
 274:         "completed": int(counts.get("completed", 0) or 0),
 275:         "dirty": last_append.get("dirty", "-"),
 276:     }
