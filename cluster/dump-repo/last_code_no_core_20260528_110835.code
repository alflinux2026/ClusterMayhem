 295: def kill_node(node, seconds=None):
 296:     stat_inc("kill_attempts")
 297:     try:
 298:         resp = requests.post(f"{node}/sleep", timeout=2)
 299:         try:
 300:             payload = resp.json()
 301:         except Exception:
 302:             payload = {"raw_text": resp.text}
 303:         if resp.status_code == 200 and payload.get("ok") is True:
 304:             with dead_lock:
 305:                 dead_nodes.add(node)
 306:             stat_inc("kills")
 307:             stat_kill_event(node=node, action="sleep", ok=True, payload=payload, seconds=seconds)
 308:             print(f"[CHAOS] SLEEP {node}")
 309:             return True
 310:         stat_inc("kill_failures")
 311:         stat_kill_event(node=node, action="sleep", ok=False, payload=payload, seconds=seconds)
 312:         print(f"[CHAOS FAIL SLEEP] {node} -> status={resp.status_code} payload={payload}")
 313:         return False
 314:     except Exception as e:
 315:         stat_inc("kill_failures")
 316:         stat_kill_event(node=node, action="sleep", ok=False, error=str(e), seconds=seconds)
 317:         print(f"[CHAOS FAIL SLEEP] {node} -> {e}")
 318:         return False
 319: 
