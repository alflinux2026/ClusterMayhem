 284: def get_session(worker_id):
 285:     with worker_sessions_lock:
 286:         if worker_id not in worker_sessions:
 287:             s = requests.Session()
 288:             adapter = requests.adapters.HTTPAdapter(pool_connections=16, pool_maxsize=16, max_retries=0)
 289:             s.mount("http://", adapter)
 290:             s.mount("https://", adapter)
 291:             worker_sessions[worker_id] = s
 292:         return worker_sessions[worker_id]
