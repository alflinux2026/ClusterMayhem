===== ./core/transitions.py =====
   1: from cluster.core.state import NodeState
   2: 
   3: ALLOWED_TRANSITIONS = {
   4:     NodeState.BOOT: {
   5:         NodeState.DISCOVERING,
   6:     },
   7:     NodeState.DISCOVERING: {
   8:         NodeState.STANDBY,
   9:         NodeState.ACTIVE,
  10:         NodeState.ISOLATED,
  11:     },
  12:     NodeState.STANDBY: {
  13:         NodeState.ACTIVE,
  14:         NodeState.DRAINING,
  15:         NodeState.OFFLINE,
  16:         NodeState.ISOLATED,
  17:         NodeState.SEGMENTATION,
  18:     },
  19:     NodeState.ACTIVE: {
  20:         NodeState.STANDBY,
  21:         NodeState.DRAINING,
  22:         NodeState.OFFLINE,
  23:     },
  24:     NodeState.DRAINING: {
  25:         NodeState.STANDBY,
  26:         NodeState.OFFLINE,
  27:     },
  28:     NodeState.ISOLATED: {
  29:         NodeState.DISCOVERING,
  30:         NodeState.OFFLINE,
  31:     },
  32:     NodeState.SEGMENT: {
  33:         NodeState.DISCOVERING,
  34:         NodeState.OFFLINE,
  35:     },
  36: }
  37: 
  38: def can_transition(from_state: NodeState, to_state: NodeState) -> bool:
  39:     return to_state in ALLOWED_TRANSITIONS.get(from_state, set())



