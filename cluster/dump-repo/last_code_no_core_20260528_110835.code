 587:         max_latency = max(stats["latency"]) if stats["latency"] else 0
 588:         min_latency = min(stats["latency"]) if stats["latency"] else 0
 589:         p50_latency = percentile(stats["latency"], 50)
 590:         p95_latency = percentile(stats["latency"], 95)
