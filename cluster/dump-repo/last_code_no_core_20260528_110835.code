 215: def is_retryable_response(payload):
 216:     if not isinstance(payload, dict):
 217:         return False
 218:     if payload.get("error") in {"no leader", "node isolated"}:
 219:         return True
 220:     return any(p in str(payload.get("error", "")).lower() for p in ["timeout", "connection", "refused", "temporarily unavailable", "isolated", "no leader"])
 221: 
 222: 
 223: def extract_leader(payload):
 224:     if not isinstance(payload, dict):
 225:         return None
 226:     if "result" in payload and isinstance(payload["result"], dict):
 227:         return payload["result"].get("leader")
 228:     return payload.get("leader")
 229: 
 230: 
 231: def classify_submit_response(status_code, payload):
 232:     if status_code != 200:
 233:         return "http_not_ok"
 234:     if not isinstance(payload, dict):
 235:         return "submit_ok"
 236:     if payload.get("error"):
 237:         return "retryable_error" if is_retryable_response(payload) else "hard_fail"
 238:     result = payload.get("result")
 239:     if isinstance(result, dict) and result.get("error"):
 240:         return "retryable_error" if is_retryable_response(result) else "hard_fail"
 241:     return "submit_ok"
