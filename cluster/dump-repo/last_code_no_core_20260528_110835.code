 244: def next_enqueue_seq():
 245:     global enqueue_seq
 246:     with enqueue_seq_lock:
 247:         enqueue_seq += 1
 248:         return enqueue_seq
 249: 
 250: 
 251: def enqueue_pending(pending, delay_seconds=0.0):
 252:     run_at = time.time() + max(0.0, delay_seconds)
 253:     pending_queue.put((run_at, next_enqueue_seq(), pending))
 254:     with stats_lock:
 255:         stats["queue_max_depth"] = max(stats["queue_max_depth"], pending_queue.qsize())
 256: 
 257: 
 258: def mark_producer_done():
 259:     global producer_done
 260:     with producer_done_lock:
 261:         producer_done = True
 262: 
 263: 
 264: def is_producer_done():
 265:     with producer_done_lock:
 266:         return producer_done
 267: 
 268: 
 269: def compute_retry_backoff(retries_done):
 270:     return min(RETRY_BACKOFF_BASE * (2 ** max(0, retries_done - 1)), RETRY_BACKOFF_MAX)
 271: 
