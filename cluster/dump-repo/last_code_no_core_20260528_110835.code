 250: def enqueue_pending(pending, delay_seconds=0.0):
 251:     run_at = time.time() + max(0.0, delay_seconds)
 252:     pending_queue.put((run_at, next_enqueue_seq(), pending))
 253:     with stats_lock:
 254:         stats["queue_max_depth"] = max(stats["queue_max_depth"], pending_queue.qsize())
 255: 
