 211: def stat_kill_event(node, action, ok, payload=None, error=None, seconds=None):
 212:     with stats_lock:
 213:         stats["kill_events"].append({
 214:             "action": action,
 215:             "node": node,
 216:             "ok": ok,
 217:             "seconds": seconds,
 218:             "payload": payload,
 219:             "error": error,
 220:             "timestamp": datetime.now().isoformat(),
 221:         })
