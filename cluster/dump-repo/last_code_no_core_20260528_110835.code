 241: def setup_colors():
 242:     if not curses.has_colors():
 243:         return False
 244: 
 245:     curses.start_color()
 246:     curses.use_default_colors()
 247: 
 248:     curses.init_pair(1, curses.COLOR_GREEN, -1)
 249:     curses.init_pair(2, curses.COLOR_YELLOW, -1)
 250:     curses.init_pair(3, curses.COLOR_RED, -1)
 251:     curses.init_pair(4, curses.COLOR_CYAN, -1)
 252:     curses.init_pair(5, curses.COLOR_WHITE, -1)
 253:     curses.init_pair(6, curses.COLOR_MAGENTA, -1)
 254:     return True
 255: 
 256: 
 257: def color_for_health(value):
 258:     v = str(value or "").lower()
 259:     if v == "ok":
 260:         return curses.color_pair(1) | curses.A_BOLD
 261:     if v == "stale":
 262:         return curses.color_pair(3) | curses.A_BOLD
 263:     return curses.color_pair(2) | curses.A_BOLD
 264: 
 265: 
 266: def color_for_state(state, stale=False):
 267:     if stale:
 268:         return curses.color_pair(3) | curses.A_BOLD
 269: 
 270:     s = str(state or "").upper()
 271:     if s == "ACTIVE":
 272:         return curses.color_pair(1) | curses.A_BOLD
 273:     if s in ("STAND-BY", "STANDBY"):
 274:         return curses.color_pair(2) | curses.A_BOLD
 275:     if s == "DEGRADED":
 276:         return curses.color_pair(6) | curses.A_BOLD
 277:     if s in ("ISOLATED", "OFFLINE", "???"):
 278:         return curses.color_pair(3) | curses.A_BOLD
 279:     return curses.color_pair(5)
 280: 
 281: 
 282: def color_for_dirty(value):
 283:     if value is True or str(value).lower() == "true":
 284:         return curses.color_pair(3) | curses.A_BOLD
 285:     return curses.color_pair(1)
 286: 
 287: 
 288: def color_for_count(label, value):
 289:     try:
 290:         n = int(value)
 291:     except Exception:
 292:         n = 0
 293: 
 294:     if label == "executing" and n > 0:
 295:         return curses.color_pair(2) | curses.A_BOLD
 296:     if label == "created" and n > 0:
 297:         return curses.color_pair(6) | curses.A_BOLD
 298:     if label == "completed" and n > 0:
 299:         return curses.color_pair(1)
 300:     return curses.color_pair(5)
 301: 
 302: 
 303: def color_for_age(value, warn_s=1.5, stale_s=3.0):
 304:     if value is None:
 305:         return curses.color_pair(5)
 306:     try:
 307:         age = float(value)
 308:     except Exception:
 309:         return curses.color_pair(5)
 310:     if age >= stale_s:
 311:         return curses.color_pair(3) | curses.A_BOLD
 312:     if age >= warn_s:
 313:         return curses.color_pair(2) | curses.A_BOLD
 314:     return curses.color_pair(1)
 315: 
 316: 
 317: def color_for_busy(value):
 318:     if value is True:
 319:         return curses.color_pair(6) | curses.A_BOLD
 320:     if value is False:
 321:         return curses.color_pair(1)
 322:     return curses.color_pair(5)
 323: 
 324: 
 325: def color_for_progress_active(value):
 326:     if value is True:
 327:         return curses.color_pair(6) | curses.A_BOLD
 328:     return curses.color_pair(5)
 329: 
 330: 
 331: def color_for_progress_stalled(value):
 332:     if value is True:
 333:         return curses.color_pair(3) | curses.A_BOLD
 334:     return curses.color_pair(1)
 335: 
 336: 
 337: def color_for_progress_stage(stage):
 338:     if not stage:
 339:         return curses.color_pair(5)
 340:     return curses.color_pair(4)
 341: 
 342: 
 343: def render_top_summary_1(api_snapshots, groups):
 344:     source_order = ["lnx200nas", "lnx202pc", "lnx203hp"]
 345:     lines = []
 346: 
 347:     NODE_W = 12
 348:     HEALTH_W = 8
 349:     STATE_W = 12
 350:     TSTATE_W = 8
 351:     PRES_W = 7
 352:     WDOG_W = 7
 353:     BUSY_W = 5
 354:     STAGE_W = 18
 355:     PROG_W = 12
 356:     PAGE_W = 7
 357:     STALL_W = 6
 358:     SIZE_W = 10
 359:     EVENTS_W = 12
 360:     COUNT_W = 9
 361:     DIRTY_W = 7
 362: 
 363:     def cut(value, width):
 364:         s = "-" if value is None else str(value)
 365:         return s if len(s) <= width else s[: max(0, width - 1)] + "…"
 366: 
 367:     def fmt_age(value):
 368:         if value is None:
 369:             return "-"
 370:         try:
 371:             value = float(value)
 372:         except Exception:
 373:             return "-"
 374:         if value < 60:
 375:             return f"{value:.0f}s"
 376:         if value < 3600:
 377:             return f"{value / 60:.1f}m"
 378:         return f"{value / 3600:.1f}h"
 379: 
 380:     def fmt_busy(value):
 381:         if value is True:
 382:             return "Y"
 383:         if value is False:
 384:             return "N"
 385:         return "?"
 386: 
 387:     def fmt_progress(current, total, pct):
 388:         if current is None and total is None:
 389:             return "-"
 390:         try:
 391:             if pct is not None and current is not None and total is not None:
 392:                 return f"{int(current)}/{int(total)} {pct:.0f}%"
 393:             if current is not None and total is not None:
 394:                 return f"{int(current)}/{int(total)}"
 395:             return str(current if current is not None else "-")
 396:         except Exception:
 397:             return "-"
 398: 
 399:     lines.append("### resumen cluster")
 400:     lines.append("")
 401:     lines.append(
 402:         "- leader esperado: "
 403:         + ", ".join(
 404:             f"{node}: {api_snapshots.get(node, {}).get('dashboard', {}).get('cluster', {}).get('leader', '?')}"
 405:             for node in source_order
 406:         )
 407:     )
 408:     lines.append("")
 409:     lines.append(
 410:         f"- {'nodo':<{NODE_W}}  {'health':<{HEALTH_W}}  {'state':<{STATE_W}}  {'t_state':>{TSTATE_W}}  "
 411:         f"{'pres':>{PRES_W}}  {'wdog':>{WDOG_W}}  {'busy':<{BUSY_W}}  "
 412:         f"{'stage':<{STAGE_W}}  {'prog':>{PROG_W}}  {'p_age':>{PAGE_W}}  {'stall':<{STALL_W}}  "
 413:         f"{'local_size':>{SIZE_W}}  {'local_events':>{EVENTS_W}}  "
 414:         f"{'created':>{COUNT_W}}  {'executing':>{COUNT_W}}  {'completed':>{COUNT_W}}  "
 415:         f"{'dirty':<{DIRTY_W}}"
 416:     )
 417: 
 418:     for node_name in source_order:
 419:         view = _node_runtime_view(api_snapshots, node_name)
 420:         lines.append(
 421:             f"- {node_name:<{NODE_W}}  "
 422:             f"{cut(view['health'], HEALTH_W):<{HEALTH_W}}  "
 423:             f"{cut(view['state'], STATE_W):<{STATE_W}}  "
 424:             f"{fmt_age(view['state_age_s']):>{TSTATE_W}}  "
 425:             f"{fmt_age(view['presence_age_s']):>{PRES_W}}  "
 426:             f"{fmt_age(view['watchdog_age_s']):>{WDOG_W}}  "
 427:             f"{fmt_busy(view['watchdog_busy']):<{BUSY_W}}  "
 428:             f"{cut(view['progress_stage'], STAGE_W):<{STAGE_W}}  "
 429:             f"{cut(fmt_progress(view['progress_current'], view['progress_total'], view['progress_pct']), PROG_W):>{PROG_W}}  "
 430:             f"{fmt_age(view['progress_age_s']):>{PAGE_W}}  "
 431:             f"{('Y' if view['progress_stalled'] else 'N'):<{STALL_W}}  "
 432:             f"{view['local_size']:>{SIZE_W}}  "
 433:             f"{view['local_events']:>{EVENTS_W}}  "
 434:             f"{view['created']:>{COUNT_W}}  "
 435:             f"{view['executing']:>{COUNT_W}}  "
 436:             f"{view['completed']:>{COUNT_W}}  "
 437:             f"{cut(view['dirty'], DIRTY_W):<{DIRTY_W}}"
 438:         )
 439: 
 440:     lines.append("")
 441:     return lines
 442: 
 443: 
 444: def draw_top_summary_curses(stdscr, start_y, api_snapshots, width):
 445:     source_order = ["lnx200nas", "lnx202pc", "lnx203hp"]
 446: 
 447:     NODE_W = 12
 448:     HEALTH_W = 8
 449:     STATE_W = 12
 450:     TSTATE_W = 8
 451:     PRES_W = 7
 452:     WDOG_W = 7
 453:     BUSY_W = 5
 454:     STAGE_W = 18
 455:     PROG_W = 12
 456:     PAGE_W = 7
 457:     STALL_W = 6
 458:     SIZE_W = 10
 459:     EVENTS_W = 12
 460:     COUNT_W = 9
 461:     DIRTY_W = 7
 462: 
 463:     def cut(value, width):
 464:         s = "-" if value is None else str(value)
 465:         return s if len(s) <= width else s[: max(0, width - 1)] + "…"
 466: 
 467:     def fmt_age(value):
 468:         if value is None:
 469:             return "-"
 470:         try:
 471:             value = float(value)
 472:         except Exception:
 473:             return "-"
 474:         if value < 60:
 475:             return f"{value:.0f}s"
 476:         if value < 3600:
 477:             return f"{value / 60:.1f}m"
 478:         return f"{value / 3600:.1f}h"
 479: 
 480:     def fmt_busy(value):
 481:         if value is True:
 482:             return "Y"
 483:         if value is False:
 484:             return "N"
 485:         return "?"
 486: 
 487:     def fmt_progress(current, total, pct):
 488:         if current is None and total is None:
 489:             return "-"
 490:         try:
 491:             if pct is not None and current is not None and total is not None:
 492:                 return f"{int(current)}/{int(total)} {pct:.0f}%"
 493:             if current is not None and total is not None:
 494:                 return f"{int(current)}/{int(total)}"
 495:             return str(current if current is not None else "-")
 496:         except Exception:
 497:             return "-"
 498: 
 499:     def put(y, x, text, attr=0):
 500:         if y < 0 or x >= width - 1:
 501:             return
 502:         stdscr.addnstr(y, x, text, max(1, width - 1 - x), attr)
 503: 
 504:     y = start_y
 505: 
 506:     put(y, 0, "### resumen cluster", curses.color_pair(4) | curses.A_BOLD)
 507:     y += 2
 508:     put(
 509:         y,
 510:         0,
 511:         "- leader esperado: "
 512:         + ", ".join(
 513:             f"{node}: {api_snapshots.get(node, {}).get('dashboard', {}).get('cluster', {}).get('leader', '?')}"
 514:             for node in source_order
 515:         ),
 516:         curses.color_pair(4),
 517:     )
 518:     y += 2
 519: 
 520:     header = (
 521:         f"- {'nodo':<{NODE_W}}  {'health':<{HEALTH_W}}  {'state':<{STATE_W}}  {'t_state':>{TSTATE_W}}  "
 522:         f"{'pres':>{PRES_W}}  {'wdog':>{WDOG_W}}  {'busy':<{BUSY_W}}  "
 523:         f"{'stage':<{STAGE_W}}  {'prog':>{PROG_W}}  {'p_age':>{PAGE_W}}  {'stall':<{STALL_W}}  "
 524:         f"{'local_size':>{SIZE_W}}  {'local_events':>{EVENTS_W}}  "
 525:         f"{'created':>{COUNT_W}}  {'executing':>{COUNT_W}}  {'completed':>{COUNT_W}}  {'dirty':<{DIRTY_W}}"
 526:     )
 527:     put(y, 0, header, curses.color_pair(4) | curses.A_BOLD)
 528:     y += 1
 529: 
 530:     for node_name in source_order:
 531:         view = _node_runtime_view(api_snapshots, node_name)
 532:         health_value = cut(view["health"], HEALTH_W)
 533:         state_value = cut(view["state"], STATE_W)
 534:         stale_state = str(health_value).lower() == "stale"
 535: 
 536:         cols = [
 537:             (f"- {node_name:<{NODE_W}}  ", curses.color_pair(5)),
 538:             (f"{health_value:<{HEALTH_W}}  ", color_for_health(health_value)),
 539:             (f"{state_value:<{STATE_W}}  ", color_for_state(state_value, stale=stale_state)),
 540:             (f"{fmt_age(view['state_age_s']):>{TSTATE_W}}  ", curses.color_pair(5)),
 541:             (f"{fmt_age(view['presence_age_s']):>{PRES_W}}  ", color_for_age(view["presence_age_s"], warn_s=1.5, stale_s=3.0)),
 542:             (f"{fmt_age(view['watchdog_age_s']):>{WDOG_W}}  ", color_for_age(view["watchdog_age_s"], warn_s=1.5, stale_s=3.0)),
 543:             (f"{fmt_busy(view['watchdog_busy']):<{BUSY_W}}  ", color_for_busy(view["watchdog_busy"])),
 544:             (f"{cut(view['progress_stage'], STAGE_W):<{STAGE_W}}  ", color_for_progress_stage(view["progress_stage"])),
 545:             (
 546:                 f"{cut(fmt_progress(view['progress_current'], view['progress_total'], view['progress_pct']), PROG_W):>{PROG_W}}  ",
 547:                 color_for_progress_active(view["progress_active"]),
 548:             ),
 549:             (
 550:                 f"{fmt_age(view['progress_age_s']):>{PAGE_W}}  ",
 551:                 color_for_age(view["progress_age_s"], warn_s=1.5, stale_s=3.0),
 552:             ),
 553:             (
 554:                 f"{('Y' if view['progress_stalled'] else 'N'):<{STALL_W}}  ",
 555:                 color_for_progress_stalled(view["progress_stalled"]),
 556:             ),
 557:             (f"{view['local_size']:>{SIZE_W}}  ", curses.color_pair(5)),
 558:             (f"{view['local_events']:>{EVENTS_W}}  ", curses.color_pair(5)),
 559:             (f"{view['created']:>{COUNT_W}}  ", color_for_count("created", view["created"])),
 560:             (f"{view['executing']:>{COUNT_W}}  ", color_for_count("executing", view["executing"])),
 561:             (f"{view['completed']:>{COUNT_W}}  ", color_for_count("completed", view["completed"])),
 562:             (f"{cut(view['dirty'], DIRTY_W):<{DIRTY_W}}", color_for_dirty(view["dirty"])),
 563:         ]
 564: 
 565:         x = 0
 566:         for text, attr in cols:
 567:             put(y, x, text, attr)
 568:             x += len(text)
 569: 
 570:         y += 1
 571: 
 572:     return y + 1
 573: 
 574: 
 575: def render_file_inventory(groups):
 576:     source_order = ["lnx200nas", "lnx202pc", "lnx203hp"]
 577:     NODE_WIDTH = 16
 578:     FILE_WIDTH = 30
 579:     SIZE_WIDTH = 10
 580:     MTIME_WIDTH = 30
 581:     lines = []
 582: 
 583:     for source in source_order:
 584:         if source not in groups:
 585:             continue
 586:         entries = groups[source]
 587:         lines.append(f"### log de {source}:")
 588:         lines.append("")
 589: 
 590:         local = next((e for e in entries if e["node"] == source and "local" in e["file"]), None)
 591:         local_replica = next(
 592:             (e for e in entries if e["node"] == source and e["file"] == f"event_log.{source}.jsonl"),
 593:             None,
 594:         )
 595:         remotes = [
 596:             e for e in entries if e["file"] == f"event_log.{source}.jsonl" and e["node"] != source
 597:         ]
 598:         remotes.sort(key=lambda x: x["node"])
 599: 
 600:         for e in [local, local_replica, *remotes]:
 601:             if not e:
 602:                 continue
 603:             node = (e["node"] + " " * NODE_WIDTH)[:NODE_WIDTH]
 604:             file = (e["file"] + " " * FILE_WIDTH)[:FILE_WIDTH]
 605:             size = (f"{e['size']}" + " " * SIZE_WIDTH)[:SIZE_WIDTH]
 606:             mtime = (e["mtime_date"] + "T" + e["mtime_time"] + e["mtime_tz"] + " " * MTIME_WIDTH)[:MTIME_WIDTH]
 607:             lines.append(f"- {node}  {file}  {size}  {mtime}")
 608: 
 609:         lines.append("")
 610: 
 611:     return lines
 612: 
 613: 
 614: def render_markdown(groups, api_snapshots):
 615:     lines = []
 616:     lines.extend(render_top_summary_1(api_snapshots, groups))
 617:     lines.extend(render_file_inventory(groups))
 618:     return "\n".join(lines).strip() + "\n"
 619: 
 620: 
 621: def collect_snapshot():
 622:     all_rows = []
 623:     api_snapshots = {}
 624:     errors = []
 625: 
 626:     for node in NODES:
 627:         try:
 628:             text = ssh_ls(node)
 629:             rows = parse_ls_output(node["name"], text)
 630:             all_rows.extend(rows)
 631:         except Exception as e:
 632:             errors.append(f"SSH {node['name']}: {e}")
 633: 
 634:         try:
 635:             api_snapshots[node["name"]] = fetch_api_snapshot(node)
 636:         except Exception as e:
 637:             errors.append(f"API {node['name']}: {e}")
 638:             api_snapshots[node["name"]] = {"node": node["name"], "error": str(e)}
 639: 
 640:     groups = build_groups(all_rows)
 641:     return groups, api_snapshots, errors
 642: 
 643: 
 644: def write_outputs(groups, api_snapshots):
 645:     all_rows = []
 646:     for entries in groups.values():
 647:         all_rows.extend(entries)
 648: 
 649:     md = render_markdown(groups, api_snapshots)
 650:     OUT_MD.write_text(md, encoding="utf-8")
 651: 
 652:     with OUT_CSV.open("w", newline="", encoding="utf-8") as f:
 653:         writer = csv.DictWriter(
 654:             f,
 655:             fieldnames=["node", "file", "source", "mtime_date", "mtime_time", "mtime_tz", "size"],
 656:         )
 657:         writer.writeheader()
 658:         writer.writerows(all_rows)
 659: 
 660:     OUT_API_JSON.write_text(json.dumps(api_snapshots, ensure_ascii=False, indent=2), encoding="utf-8")
 661: 
 662: 
 663: def save_snapshot(lines, groups, api_snapshots, errors, started_at, refresh_seconds):
 664:     OUT_SNAPSHOT_DIR.mkdir(parents=True, exist_ok=True)
 665:     ts_file = datetime.now().strftime("%Y%m%d_%H%M%S")
 666: 
 667:     md_path = OUT_SNAPSHOT_DIR / f"cluster_live_snapshot_{ts_file}.md"
 668:     json_path = OUT_SNAPSHOT_DIR / f"cluster_live_snapshot_{ts_file}.json"
 669: 
 670:     md_content = "\n".join(lines).strip() + "\n"
 671:     md_path.write_text(md_content, encoding="utf-8")
 672: 
 673:     snapshot_payload = {
 674:         "captured_at": datetime.now().isoformat(),
 675:         "refresh_seconds": refresh_seconds,
 676:         "monitor_uptime_s": round(time.time() - started_at, 3),
 677:         "errors": errors,
 678:         "groups": groups,
 679:         "api_snapshots": api_snapshots,
 680:         "rendered_lines": lines,
 681:     }
 682:     json_path.write_text(json.dumps(snapshot_payload, ensure_ascii=False, indent=2), encoding="utf-8")
 683: 
 684:     return md_path, json_path
 685: 
 686: 
 687: def build_screen_lines(groups, api_snapshots, errors, started_at, refresh_seconds):
 688:     ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
 689:     lines = []
 690:     lines.append(
 691:         f"cluster_live.py  actualizado: {ts}  refresh={refresh_seconds:.1f}s  "
 692:         f"[s]=snapshot md+json  [q]=salir"
 693:     )
 694:     lines.append("")
 695:     if errors:
 696:         lines.append("errores:")
 697:         for err in errors:
 698:             lines.append(f"- {err}")
 699:         lines.append("")
 700:     lines.extend(render_top_summary_1(api_snapshots, groups))
 701:     lines.extend(render_file_inventory(groups))
 702:     lines.append(f"uptime monitor: {time.time() - started_at:.1f}s")
 703:     if LAST_STATUS_LINE:
 704:         lines.append("")
 705:         lines.append(LAST_STATUS_LINE)
 706:     return lines
 707: 
 708: 
 709: def ui_loop(stdscr, refresh_seconds=1.5):
 710:     global LAST_STATUS_LINE
 711: 
 712:     curses.curs_set(0)
 713:     curses.noecho()
 714:     curses.cbreak()
 715:     stdscr.nodelay(True)
 716:     stdscr.keypad(True)
 717:     setup_colors()
 718:     started_at = time.time()
 719: 
 720:     while True:
 721:         cycle_start = time.time()
 722:         groups, api_snapshots, errors = collect_snapshot()
 723:         write_outputs(groups, api_snapshots)
 724:         lines = build_screen_lines(groups, api_snapshots, errors, started_at, refresh_seconds)
 725: 
 726:         stdscr.erase()
 727:         height, width = stdscr.getmaxyx()
 728:         usable_height = max(1, height - 1)
 729: 
 730:         stdscr.addnstr(
 731:             0,
 732:             0,
 733:             f"cluster_live.py  actualizado: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}  refresh={refresh_seconds:.1f}s  [s]=snapshot md+json  [q]=salir",
 734:             max(1, width - 1),
 735:             curses.color_pair(4) | curses.A_BOLD,
 736:         )
 737: 
 738:         y = 2
 739: 
 740:         if errors:
 741:             stdscr.addnstr(y, 0, "errores:", max(1, width - 1), curses.color_pair(3) | curses.A_BOLD)
 742:             y += 1
 743:             for err in errors:
 744:                 if y >= usable_height:
 745:                     break
 746:                 stdscr.addnstr(y, 0, f"- {err}", max(1, width - 1), curses.color_pair(3))
 747:                 y += 1
 748:             y += 1
 749: 
 750:         if y < usable_height:
 751:             y = draw_top_summary_curses(stdscr, y, api_snapshots, width)
 752: 
 753:         plain_lines = render_file_inventory(groups)
 754:         plain_lines.append(f"uptime monitor: {time.time() - started_at:.1f}s")
 755:         if LAST_STATUS_LINE:
 756:             plain_lines.append("")
 757:             plain_lines.append(LAST_STATUS_LINE)
 758: 
 759:         for line in plain_lines:
 760:             if y >= usable_height:
 761:                 break
 762:             stdscr.addnstr(y, 0, line, max(1, width - 1))
 763:             y += 1
 764: 
 765:         stdscr.refresh()
 766: 
 767:         while True:
 768:             key = stdscr.getch()
 769: 
 770:             if key in (ord("q"), ord("Q")):
 771:                 return
 772: 
 773:             if key in (ord("s"), ord("S")):
 774:                 try:
 775:                     md_path, json_path = save_snapshot(
 776:                         lines=lines,
 777:                         groups=groups,
 778:                         api_snapshots=api_snapshots,
 779:                         errors=errors,
 780:                         started_at=started_at,
 781:                         refresh_seconds=refresh_seconds,
 782:                     )
 783:                     LAST_STATUS_LINE = f"[snapshot] guardado md={md_path} json={json_path}"
 784:                 except Exception as e:
 785:                     LAST_STATUS_LINE = f"[snapshot] error: {e}"
 786:                 break
 787: 
 788:             if key == -1:
 789:                 pass
 790:             else:
 791:                 continue
 792: 
 793:             if time.time() - cycle_start >= refresh_seconds:
 794:                 break
 795: 
 796:             time.sleep(0.05)
 797: 
 798: 
 799: def run_live_monitor(refresh_seconds=1.5):
 800:     curses.wrapper(lambda stdscr: ui_loop(stdscr, refresh_seconds=refresh_seconds))
 801: 
 802: 
 803: def run_once():
 804:     all_rows = []
 805:     api_snapshots = {}
 806: 
 807:     for node in NODES:
 808:         print(f"[INFO] Consultando SSH {node['name']} ({node['host']})...")
 809:         try:
 810:             text = ssh_ls(node)
 811:             rows = parse_ls_output(node["name"], text)
 812:             all_rows.extend(rows)
 813:         except Exception as e:
 814:             print(f"[ERROR] SSH {node['name']}: {e}")
 815: 
 816:         print(f"[INFO] Consultando API {node['name']} ({node['host']})...")
 817:         api_snapshots[node["name"]] = fetch_api_snapshot(node)
 818: 
 819:     groups = build_groups(all_rows)
 820:     check_consistency(groups)
 821:     write_outputs(groups, api_snapshots)
 822: 
 823:     print(f"[OK] Markdown: {OUT_MD}")
 824:     print(f"[OK] CSV: {OUT_CSV}")
 825:     print(f"[OK] API JSON: {OUT_API_JSON}")
 826: 
 827: 
 828: if __name__ == "__main__":
 829:     run_live_monitor()



