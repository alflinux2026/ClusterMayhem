 164: 
 165: @dataclass
 166: class PendingEvent:
 167:     event_index: int
 168:     event: dict
 169:     retries_done: int = 0
 170:     tried_nodes: set = field(default_factory=set)
 171:     first_enqueued_at: float = field(default_factory=time.time)
 172: 
 173: 
 174: def build_event(i):
 175:     return {
 176:         "event_id": str(uuid.uuid4()),
 177:         "trace_id": str(uuid.uuid4()),
 178:         "event_type": "chaos.test",
 179:         "payload": {
 180:             "msg": f"msg-203: {i}",
 181:             "seq": i,
 182:             "source": "chaos_203",
 183:             "run_id": RUN_ID,
 184:             "stream_id": STREAM_KEY.stream_id(),
 185:         },
 186:         "stream": {
 187:             "tenant_id": STREAM_KEY.tenant_id,
 188:             "app_id": STREAM_KEY.app_id,
 189:             "data_type": STREAM_KEY.data_type,
 190:             "schema_version": STREAM_KEY.schema_version,
 191:             "stream_id": STREAM_KEY.stream_id(),
 192:         },
 193:         "stream_id": STREAM_KEY.stream_id(),
 194:         "tenant_id": STREAM_KEY.tenant_id,
 195:         "app_id": STREAM_KEY.app_id,
 196:         "data_type": STREAM_KEY.data_type,
 197:         "schema_version": STREAM_KEY.schema_version,
 198:         "status": "created",
 199:         "route_hops": [],
 200:         "source_node": None,
 201:         "target_node": None,
 202:         "execution_key": None,
 203:         "created_at": time.time(),
 204:         "updated_at": time.time(),
 205:         "received_at": None,
 206:         "attempt": 0,
 207:     }
 208: 
 209: 
 210: def stat_inc(key, amount=1):
 211:     with stats_lock:
 212:         stats[key] += amount
 213: 
 214: 
 215: def stat_node_ok(node):
 216:     with stats_lock:
 217:         stats["per_node_ok"][node] += 1
 218: 
 219: 
 220: def stat_node_fail(node):
 221:     with stats_lock:
 222:         stats["per_node_fail"][node] += 1
 223: 
 224: 
 225: def stat_leader(name):
 226:     with stats_lock:
 227:         stats["leaders_seen"][name] += 1
 228: 
 229: 
 230: def stat_latency(ms):
 231:     with stats_lock:
 232:         stats["latency"].append(ms)
 233: 
 234: 
 235: def stat_unexpected_failure(event_index, attempt, node, status_code=None, payload=None, reason=None):
 236:     with stats_lock:
 237:         stats["events_unexpected_fail"] += 1
 238:         stats["unexpected_failures"].append({"event_index": event_index, "attempt": attempt, "node": node, "status_code": status_code, "payload": payload, "reason": reason, "timestamp": datetime.now().isoformat()})
 239: 
 240: 
 241: def stat_slow_event(event_index, attempt, node, latency_ms, leader=None, payload=None):
 242:     with stats_lock:
 243:         stats["events_slow"] += 1
 244:         stats["slow_events"].append({"event_index": event_index, "attempt": attempt, "node": node, "latency_ms": round(latency_ms, 3), "leader": leader, "payload": payload, "timestamp": datetime.now().isoformat()})
 245: 
 246: 
 247: def stat_kill_event(node, action, ok, payload=None, error=None, seconds=None):
 248:     with stats_lock:
 249:         stats["kill_events"].append({"action": action, "node": node, "ok": ok, "seconds": seconds, "payload": payload, "error": error, "timestamp": datetime.now().isoformat()})
 250: 
 251: 
 252: def percentile(data, p):
 253:     if not data:
 254:         return 0.0
 255:     values = sorted(data)
 256:     if len(values) == 1:
 257:         return float(values[0])
 258:     rank = (len(values) - 1) * (p / 100.0)
 259:     low = int(rank)
 260:     high = min(low + 1, len(values) - 1)
 261:     return float(values[low] + (values[high] - values[low]) * (rank - low))
 262: 
 263: 
 264: def is_retryable_response(payload):
 265:     if not isinstance(payload, dict):
 266:         return False
 267:     if payload.get("error") in {"no leader", "node isolated"}:
 268:         return True
 269:     error = str(payload.get("error", "")).lower()
 270:     return any(p in error for p in ["timeout", "connection", "refused", "temporarily unavailable", "isolated", "no leader"])
 271: 
 272: 
 273: def extract_leader(payload):
 274:     if not isinstance(payload, dict):
 275:         return None
 276:     if "result" in payload and isinstance(payload["result"], dict):
 277:         return payload["result"].get("leader")
 278:     return payload.get("leader")
 279: 
 280: 
 281: def classify_submit_response(status_code, payload):
 282:     if status_code != 200:
 283:         return "http_not_ok"
 284:     if not isinstance(payload, dict):
 285:         return "submit_ok"
 286:     if payload.get("error"):
 287:         return "retryable_error" if is_retryable_response(payload) else "hard_fail"
 288:     result = payload.get("result")
 289:     if isinstance(result, dict) and result.get("error"):
 290:         return "retryable_error" if is_retryable_response(result) else "hard_fail"
 291:     return "submit_ok"
 292: 
 293: 
 294: def next_enqueue_seq():
 295:     global enqueue_seq
 296:     with enqueue_seq_lock:
 297:         enqueue_seq += 1
 298:         return enqueue_seq
 299: 
 300: 
 301: def enqueue_pending(pending, delay_seconds=0.0):
 302:     run_at = time.time() + max(0.0, delay_seconds)
 303:     pending_queue.put((run_at, next_enqueue_seq(), pending))
 304:     with stats_lock:
 305:         stats["queue_max_depth"] = max(stats["queue_max_depth"], pending_queue.qsize())
 306: 
 307: 
 308: def mark_producer_done():
 309:     global producer_done
 310:     with producer_done_lock:
 311:         producer_done = True
 312: 
 313: 
 314: def is_producer_done():
 315:     with producer_done_lock:
 316:         return producer_done
 317: 
 318: 
 319: def compute_retry_backoff(retries_done):
 320:     return min(RETRY_BACKOFF_BASE * (2 ** max(0, retries_done - 1)), RETRY_BACKOFF_MAX)
 321: 
 322: 
 323: def print_test_config():
 324:     print("
 325: " + "=" * 56)
 326:     print("CHAOS TEST CONFIG FINAL")
 327:     print("=" * 56)
 328:     for k, v in TEST_CONFIG.items():
 329:         if k == "stream":
 330:             print(f"{k}: {v['stream_id']}")
 331:         else:
 332:             print(f"{k}: {v}")
 333:     print("=" * 56 + "
 334: ")
