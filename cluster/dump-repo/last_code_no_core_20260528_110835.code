  29: LINE_RE = re.compile(
  30:     r"^(?P<perm>\S+)\s+"
  31:     r"(?P<links>\d+)\s+"
  32:     r"(?P<owner>\S+)\s+"
  33:     r"(?P<group>\S+)\s+"
  34:     r"(?P<size>\d+)\s+"
  35:     r"(?P<date>\d{4}-\d{2}-\d{2})\s+"
  36:     r"(?P<time>\d{2}:\d{2}:\d{2}\.\d+)\s+"
  37:     r"(?P<tz>[+-]\d{4})\s+"
  38:     r"(?P<name>.+)$"
  39: )
  40: 
  41: HTTP = requests.Session()
  42: LAST_STATUS_LINE = ""
  43: 
  44: 
  45: def ssh_ls(node):
  46:     remote_dir = REMOTE_DIRS[node["name"]]
  47:     client = paramiko.SSHClient()
  48:     client.set_missing_host_key_policy(paramiko.AutoAddPolicy())
  49:     client.connect(
  50:         hostname=node["host"],
  51:         port=node["port"],
  52:         username=node["user"],
  53:         password=node["password"],
  54:         timeout=5,
  55:         look_for_keys=False,
  56:         allow_agent=False,
  57:     )
  58:     cmd = f'ls -lb --full-time "{remote_dir}"'
  59:     stdin, stdout, stderr = client.exec_command(cmd)
  60:     out = stdout.read().decode("utf-8", errors="replace")
  61:     err = stderr.read().decode("utf-8", errors="replace")
  62:     client.close()
  63: 
  64:     if err.strip() and not out.strip():
  65:         raise RuntimeError(f"{node['name']}: {err.strip()}")
  66: 
  67:     return out
  68: 
  69: 
  70: def parse_ls_output(node_name, text):
  71:     rows = []
  72:     for line in text.splitlines():
  73:         line = line.rstrip()
  74:         if not line or line.startswith("total "):
  75:             continue
  76:         m = LINE_RE.match(line)
  77:         if not m:
  78:             continue
  79:         d = m.groupdict()
  80:         file_name = d["name"]
  81:         m_source = re.match(r"^event_log\.(.+)\.000.jsonl$", file_name)
  82:         if not m_source and file_name != "event_log.local.000.jsonl":
  83:             continue
  84: 
  85:         source = m_source.group(1) if m_source else None
  86:         if file_name == "event_log.local.000.jsonl":
  87:             source = node_name
  88: 
  89:         rows.append(
  90:             {
  91:                 "node": node_name,
  92:                 "file": file_name,
  93:                 "source": source,
  94:                 "mtime_date": d["date"],
  95:                 "mtime_time": d["time"],
  96:                 "mtime_tz": d["tz"],
  97:                 "size": int(d["size"]),
  98:             }
  99:         )
 100:     return rows
 101: 
 102: def parse_ev_output(node_name, text):
 103:     rows = []
 104:     for line in text.splitlines():
 105:         line = line.rstrip()
 106:         if not line or line.startswith("total "):
 107:             continue
 108:         m = LINE_RE.match(line)
 109:         if not m:
 110:             continue
 111:         d = m.groupdict()
 112:         file_name = d["name"]
 113:         m_source = re.match(r"^events\.(.+)\.000.jsonl$", file_name)
 114:         if not m_source and file_name != "events.local.000.jsonl":
 115:             continue
 116: 
 117:         source = m_source.group(1) if m_source else None
 118:         if file_name == "events.local.000.jsonl":
 119:             source = node_name
 120: 
 121:         rows.append(
 122:             {
 123:                 "node": node_name,
 124:                 "file": file_name,
 125:                 "source": source,
 126:                 "mtime_date": d["date"],
 127:                 "mtime_time": d["time"],
 128:                 "mtime_tz": d["tz"],
 129:                 "size": int(d["size"]),
 130:             }
 131:         )
 132:     return rows
