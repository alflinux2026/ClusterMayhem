 156: 
 157:     def score_row(row):
 158:         if not isinstance(row, dict):
 159:             return -1
 160:         score = 0
 161:         if row.get("node_id") == node_name:
 162:             score += 1
 163:         if row.get("presence_age_s") is not None:
 164:             score += 2
 165:         if row.get("watchdog_age_s") is not None:
 166:             score += 4
 167:         if row.get("watchdog_busy") is not None:
 168:             score += 2
 169:         if row.get("health") == "ok":
 170:             score += 1
 171:         if row.get("progress_stage") is not None:
 172:             score += 1
 173:         if row.get("progress_age_s") is not None:
 174:             score += 1
 175:         return score
 176: 
 177:     local_snap = api_snapshots.get(node_name, {}) or {}
 178:     local_health = local_snap.get("health", {}) or {}
 179:     local_integrity = local_snap.get("integrity", {}) or {}
 180:     local_summary = local_snap.get("events_summary_local", {}) or {}
 181: 
 182:     candidate_rows = []
 183: 
 184:     for snap_name, snap in (api_snapshots or {}).items():
 185:         dashboard = (snap or {}).get("dashboard", {}) or {}
 186:         for r in dashboard.get("nodes", []) or []:
 187:             if r.get("node_id") == node_name:
 188:                 candidate_rows.append((snap_name, r))
 189: 
 190:     best_row = {}
 191:     if candidate_rows:
 192:         candidate_rows.sort(key=lambda item: score_row(item[1]), reverse=True)
 193:         best_row = candidate_rows[0][1] or {}
 194: 
 195:     counts = local_summary.get("counts", {}) if isinstance(local_summary, dict) else {}
 196:     local_meta = local_integrity.get("local_log_meta", {}) if isinstance(local_integrity, dict) else {}
 197:     last_append = local_integrity.get("last_append_meta", {}) if isinstance(local_integrity, dict) else {}
 198: 
 199:     state_raw = fallback(best_row.get("state"), local_health.get("state"))
 200:     state_value = state_raw if state_raw in (
 201:         "ACTIVE", "STAND-BY", "STANDBY", "DEGRADED", "ISOLATED", "OFFLINE"
 202:     ) else "???"
 203: 
 204:     progress_active = fallback(best_row.get("progress_active"), local_health.get("progress_active"), False)
 205:     progress_stage = fallback(best_row.get("progress_stage"), local_health.get("progress_stage"))
 206:     progress_age_s = fallback(best_row.get("progress_age_s"), local_health.get("progress_age_s"))
 207:     progress_current = fallback(best_row.get("progress_current"), local_health.get("progress_current"))
 208:     progress_total = fallback(best_row.get("progress_total"), local_health.get("progress_total"))
 209:     progress_stalled = fallback(best_row.get("progress_stalled"), local_health.get("progress_stalled"), False)
 210: 
 211:     progress_pct = None
 212:     try:
 213:         if progress_current is not None and progress_total not in (None, 0):
 214:             progress_pct = round((float(progress_current) / float(progress_total)) * 100.0, 1)
 215:     except Exception:
 216:         progress_pct = None
 217: 
 218:     return {
 219:         "health": fallback(best_row.get("health"), local_health.get("status"), "?"),
 220:         "state": state_value,
 221:         "state_age_s": fallback(best_row.get("state_age_s"), local_health.get("state_age_s")),
 222:         "presence_age_s": fallback(best_row.get("presence_age_s"), local_health.get("presence_age_s")),
 223:         "watchdog_age_s": fallback(best_row.get("watchdog_age_s"), local_health.get("watchdog_age_s")),
 224:         "watchdog_busy": fallback(best_row.get("watchdog_busy"), local_health.get("watchdog_busy")),
 225:         "progress_active": bool(progress_active),
 226:         "progress_stage": progress_stage,
