 321: def revive_node(node):
 322:     try:
 323:         resp = requests.post(f"{node}/revive", timeout=2)
 324:         try:
 325:             payload = resp.json()
 326:         except Exception:
 327:             payload = {"raw_text": resp.text}
 328:         if resp.status_code == 200 and payload.get("ok") is True:
 329:             with dead_lock:
 330:                 dead_nodes.discard(node)
 331:             stat_inc("revives")
 332:             stat_kill_event(node=node, action="revive", ok=True, payload=payload)
 333:             print(f"[CHAOS] REVIVE {node}")
 334:             return True
 335:         stat_inc("revive_failures")
 336:         stat_kill_event(node=node, action="revive", ok=False, payload=payload)
 337:         print(f"[CHAOS FAIL REVIVE] {node} -> status={resp.status_code} payload={payload}")
 338:         return False
 339:     except Exception as e:
 340:         stat_inc("revive_failures")
 341:         stat_kill_event(node=node, action="revive", ok=False, error=str(e))
 342:         print(f"[CHAOS FAIL REVIVE] {node} -> {e}")
 343:         return False
 344: 
 345: 
 346: def kill_cycle(node, seconds):
 347:     try:
 348:         if kill_node(node, seconds=seconds):
 349:             print(f"[CHAOS] DEAD {node} for {seconds:.2f}s")
 350:             time.sleep(seconds)
 351:     finally:
 352:         revive_node(node)
 353: 
 354: 
 355: def process_pending_event(pending: PendingEvent, worker_id: int):
 356:     i = pending.event_index
 357:     event = pending.event
 358:     attempt_number = pending.retries_done + 1
 359:     available = [n for n in NODES if n not in pending.tried_nodes]
 360:     if not available:
 361:         pending.tried_nodes.clear()
 362:         available = list(NODES)
 363:     node = random.choice(available)
 364:     pending.tried_nodes.add(node)
 365:     start = time.time()
 366:     session = get_session(worker_id)
 367:     try:
 368:         r = session.post(f"{node}/event", json=event, timeout=REQUEST_TIMEOUT)
 369:         elapsed_ms = (time.time() - start) * 1000
 370:         stat_latency(elapsed_ms)
 371:         try:
 372:             payload = r.json()
 373:         except Exception:
 374:             payload = {"raw_text": r.text}
 375:         leader = extract_leader(payload)
 376:         if leader:
 377:             stat_leader(leader)
 378:         if elapsed_ms >= SLOW_EVENT_THRESHOLD_MS:
 379:             stat_slow_event(i, attempt_number, node, elapsed_ms, leader, payload)
 380:         if r.status_code == 200:
 381:             stat_inc("submit_http_200")
 382:         result = classify_submit_response(r.status_code, payload)
 383:         row = {"event_index": i, "attempt": attempt_number, "node": node, "status_code": r.status_code, "elapsed_ms": round(elapsed_ms, 3), "leader": leader, "result": result, "final": None}
 384:         if result == "submit_ok":
 385:             stat_inc("events_ok")
 386:             stat_inc("submit_semantic_ok")
 387:             stat_node_ok(node)
 388:             row["final"] = "ok"
 389:             with results_lock:
 390:                 results.append(row)
 391:             print(f"[TORTURE] {i:03} OK attempt={attempt_number} node={node} leader={leader} latency={elapsed_ms:.1f}ms")
 392:             return True
 393:         if result == "retryable_error" or r.status_code >= 500:
 394:             stat_inc("events_retried")
 395:             if isinstance(payload, dict) and payload.get("error") == "no leader":
 396:                 stat_inc("events_no_leader")
 397:             result_payload = payload.get("result") if isinstance(payload.get("result"), dict) else None
 398:             if isinstance(result_payload, dict) and result_payload.get("error") == "no leader":
 399:                 stat_inc("events_no_leader")
 400:             row["final"] = "retry"
 401:             with results_lock:
 402:                 results.append(row)
 403:             print(f"[RETRY] {i:03} attempt={attempt_number} node={node} status={r.status_code} payload={payload}")
 404:             if pending.retries_done + 1 >= MAX_RETRIES:
 405:                 stat_inc("events_failed")
 406:                 stat_unexpected_failure(i, attempt_number, node, r.status_code, payload, "dropped_after_retries_retryable_response")
 407:                 print(f"[DROP] {i:03} event dropped after retries")
 408:                 return False
 409:             pending.retries_done += 1
 410:             stat_inc("queue_requeues")
 411:             enqueue_pending(pending, compute_retry_backoff(pending.retries_done))
 412:             return False
 413:         stat_inc("events_failed")
 414:         stat_inc("submit_hard_fail")
 415:         stat_node_fail(node)
 416:         stat_unexpected_failure(i, attempt_number, node, r.status_code, payload, "hard_fail_non_retryable_response")
 417:         row["final"] = "hard_fail"
 418:         with results_lock:
 419:             results.append(row)
 420:         print(f"[FAIL] {i:03} attempt={attempt_number} node={node} status={r.status_code} payload={payload}")
 421:         return False
 422:     except requests.Timeout as e:
 423:         stat_inc("events_timeout")
 424:         stat_inc("events_retried")
 425:         print(f"[TIMEOUT] {i:03} attempt={attempt_number} {node} -> {e}")
 426:     except requests.ConnectionError as e:
 427:         stat_inc("events_connection_error")
 428:         stat_inc("events_retried")
 429:         print(f"[CONNECTION] {i:03} attempt={attempt_number} {node} -> {e}")
 430:     except Exception as e:
 431:         stat_inc("events_forward_error")
 432:         stat_inc("events_retried")
 433:         stat_unexpected_failure(i, attempt_number, node, reason=f"exception:{type(e).__name__}", payload={"exception": str(e)})
 434:         print(f"[ERROR] {i:03} attempt={attempt_number} {node} -> {e}")
 435:     if pending.retries_done + 1 >= MAX_RETRIES:
 436:         stat_inc("events_failed")
 437:         stat_unexpected_failure(i, attempt_number, node, reason="dropped_after_retries_exception", payload={"tried_nodes": list(pending.tried_nodes)})
 438:         print(f"[DROP] {i:03} event dropped after retries")
 439:         return False
 440:     pending.retries_done += 1
 441:     stat_inc("queue_requeues")
 442:     enqueue_pending(pending, compute_retry_backoff(pending.retries_done))
 443:     return False
 444: 
 445: 
 446: def sender_worker(worker_id):
 447:     while True:
 448:         try:
 449:             run_at, _, pending = pending_queue.get(timeout=0.5)
 450:         except queue.Empty:
 451:             if is_producer_done() and pending_queue.empty():
 452:                 return
 453:             continue
 454:         now = time.time()
 455:         if run_at > now:
 456:             pending_queue.put((run_at, next_enqueue_seq(), pending))
 457:             pending_queue.task_done()
 458:             time.sleep(min(run_at - now, 0.2))
 459:             continue
 460:         try:
 461:             process_pending_event(pending, worker_id)
 462:         finally:
 463:             pending_queue.task_done()
 464: 
 465: 
 466: def chaos_loop():
 467:     for i in range(EVENTS):
 468:         if random.random() < KILL_PROBABILITY:
 469:             node = SLEEP_ONLY_NODE if SLEEP_ONLY_NODE else random.choice(NODES)
 470:             seconds = random.uniform(*DEATH_TIME_RANGE)
 471:             t = threading.Thread(target=kill_cycle, args=(node, seconds), daemon=True)
 472:             t.start()
 473:             kill_threads.append(t)
 474:         stat_inc("events_total")
 475:         enqueue_pending(PendingEvent(event_index=i, event=build_event(i)), delay_seconds=0.0)
 476:         time.sleep(random.uniform(*EVENT_DELAY_RANGE))
 477:     mark_producer_done()
 478: 
 479: 
 480: def revive_everything():
 481:     print("\\n[MAIN] REVIVING ALL NODES\\n")
 482:     for node in sorted(set(NODES)):
 483:         try:
 484:             requests.post(f"{node}/revive", timeout=2)
 485:             print(f"[FORCE REVIVE] {node}")
 486:         except Exception as e:
 487:             print(f"[FORCE REVIVE FAIL] {node} -> {e}")
 488: 
 489: 
 490: def wait_kills():
 491:     print("\\n[MAIN] waiting active kill cycles...\\n")
 492:     for t in kill_threads:
 493:         t.join(timeout=30)
 494: 
 495: 
 496: def wait_queue_drain():
 497:     deadline = time.time() + DRAIN_TIMEOUT
 498:     while time.time() < deadline:
 499:         if pending_queue.empty():
 500:             time.sleep(0.5)
 501:             if pending_queue.empty():
 502:                 return True
 503:         time.sleep(0.2)
 504:     return False
 505: 
 506: 
 507: def write_csv_and_json():
 508:     with results_lock:
 509:         rows = list(results)
 510:     with open(EVENTS_CSV, "w", newline="", encoding="utf-8") as f:
 511:         writer = csv.DictWriter(f, fieldnames=["event_index", "attempt", "node", "status_code", "elapsed_ms", "leader", "result", "final"])
 512:         writer.writeheader()
 513:         writer.writerows(rows)
 514:     with stats_lock:
 515:         total = stats["events_total"]
 516:         ok = stats["events_ok"]
 517:         failed = stats["events_failed"]
 518:         success_rate = ((ok / total) * 100) if total else 0
 519:         avg_latency = (sum(stats["latency"]) / len(stats["latency"])) if stats["latency"] else 0
 520:         max_latency = max(stats["latency"]) if stats["latency"] else 0
 521:         min_latency = min(stats["latency"]) if stats["latency"] else 0
 522:         p50_latency = percentile(stats["latency"], 50)
 523:         p95_latency = percentile(stats["latency"], 95)
 524:         p99_latency = percentile(stats["latency"], 99)
 525:         report = {"test_config": TEST_CONFIG, "run_meta": {"started_at_epoch": TEST_STARTED_AT, "ended_at_epoch": time.time(), "started_at_iso": datetime.fromtimestamp(TEST_STARTED_AT).isoformat(), "ended_at_iso": datetime.now().isoformat(), "duration_seconds": round(time.time() - TEST_STARTED_AT, 3)}, "stats": {**stats, "success_rate": round(success_rate, 2), "latency_avg": round(avg_latency, 3), "latency_min": round(min_latency, 3), "latency_p50": round(p50_latency, 3), "latency_p95": round(p95_latency, 3), "latency_p99": round(p99_latency, 3), "latency_max": round(max_latency, 3), "per_node_ok": dict(stats["per_node_ok"]), "per_node_fail": dict(stats["per_node_fail"]), "leaders_seen": dict(stats["leaders_seen"]), "results_csv": str(EVENTS_CSV)}}
 526:     with open(STATS_FILE, "w", encoding="utf-8") as f:
 527:         json.dump(report, f, indent=2, ensure_ascii=False)
 528: 
 529: 
 530: def print_stats():
 531:     with stats_lock:
 532:         total = stats["events_total"]
 533:         ok = stats["events_ok"]
 534:         failed = stats["events_failed"]
 535:         success_rate = ((ok / total) * 100) if total else 0
 536:         avg_latency = (sum(stats["latency"]) / len(stats["latency"])) if stats["latency"] else 0
 537:         max_latency = max(stats["latency"]) if stats["latency"] else 0
 538:         min_latency = min(stats["latency"]) if stats["latency"] else 0
 539:         p50_latency = percentile(stats["latency"], 50)
 540:         p95_latency = percentile(stats["latency"], 95)
 541:         p99_latency = percentile(stats["latency"], 99)
 542:     print("\\n" + "=" * 56)
 543:     print("FINAL CHAOS STATS v5")
 544:     print("=" * 56)
 545:     print(f"events_total........: {total}")
 546:     print(f"events_ok...........: {ok}")
 547:     print(f"events_failed.......: {failed}")
 548:     print(f"success_rate........: {success_rate:.2f}%")
 549:     print(f"latency_avg.........: {avg_latency:.1f} ms")
 550:     print(f"latency_min.........: {min_latency:.1f} ms")
 551:     print(f"latency_p50.........: {p50_latency:.1f} ms")
 552:     print(f"latency_p95.........: {p95_latency:.1f} ms")
 553:     print(f"latency_p99.........: {p99_latency:.1f} ms")
 554:     print(f"latency_max.........: {max_latency:.1f} ms")
 555:     print(f"stats_file..........: {STATS_FILE}")
 556:     print(f"events_csv..........: {EVENTS_CSV}")
 557:     print("=" * 56)
 558: 
 559: 
 560: def main():
 561:     print(f"[MAIN] starting UNIVERSAL chaos torture final v5 ({ARGS.mode})")
 562:     print_test_config()
 563:     workers = []
 564:     for idx in range(SEND_WORKERS):
 565:         t = threading.Thread(target=sender_worker, args=(idx,), daemon=True)
 566:         t.start()
 567:         workers.append(t)
 568:     drained = False
 569:     try:
 570:         chaos_loop()
 571:         drained = wait_queue_drain()
 572:         pending_queue.join()
 573:         for t in workers:
 574:             t.join(timeout=5)
 575:     finally:
 576:         wait_kills()
 577:         revive_everything()
 578:         if not drained:
 579:             print(f"\\n[MAIN WARN] queue drain timeout reached after {DRAIN_TIMEOUT:.1f}s\\n")
 580:         write_csv_and_json()
 581:         print_stats()
 582:         print("\\n[MAIN] cluster restored\\n")
 583: 
 584: 
 585: if __name__ == "__main__":
 586:     main()



