 381: def render_top_summary_1(api_snapshots, groups):
 382:     source_order = ["lnx200nas", "lnx202pc", "lnx203hp"]
 383:     lines = []
 384: 
 385:     NODE_W = 12
 386:     HEALTH_W = 8
 387:     STATE_W = 12
 388:     TSTATE_W = 8
 389:     PRES_W = 7
 390:     WDOG_W = 7
 391:     BUSY_W = 5
 392:     STAGE_W = 18
 393:     PROG_W = 12
 394:     PAGE_W = 7
 395:     STALL_W = 6
 396:     SIZE_W = 10
 397:     EVENTS_W = 12
 398:     COUNT_W = 9
 399:     DIRTY_W = 7
 400: 
 401:     def cut(value, width):
 402:         s = "-" if value is None else str(value)
 403:         return s if len(s) <= width else s[: max(0, width - 1)] + "…"
 404: 
 405:     def fmt_age(value):
 406:         if value is None:
 407:             return "-"
 408:         try:
 409:             value = float(value)
 410:         except Exception:
 411:             return "-"
 412:         if value < 60:
 413:             return f"{value:.0f}s"
 414:         if value < 3600:
 415:             return f"{value / 60:.1f}m"
 416:         return f"{value / 3600:.1f}h"
 417: 
 418:     def fmt_busy(value):
 419:         if value is True:
 420:             return "Y"
 421:         if value is False:
 422:             return "N"
 423:         return "?"
 424: 
 425:     def fmt_progress(current, total, pct):
 426:         if current is None and total is None:
 427:             return "-"
 428:         try:
 429:             if pct is not None and current is not None and total is not None:
 430:                 return f"{int(current)}/{int(total)} {pct:.0f}%"
 431:             if current is not None and total is not None:
 432:                 return f"{int(current)}/{int(total)}"
 433:             return str(current if current is not None else "-")
 434:         except Exception:
 435:             return "-"
 436: 
 437:     lines.append("### resumen cluster")
 438:     lines.append("")
 439:     lines.append(
 440:         "- leader esperado: "
 441:         + ", ".join(
 442:             f"{node}: {api_snapshots.get(node, {}).get('dashboard', {}).get('cluster', {}).get('leader', '?')}"
 443:             for node in source_order
 444:         )
 445:     )
 446:     lines.append("")
 447:     lines.append(
 448:         f"- {'nodo':<{NODE_W}}  {'health':<{HEALTH_W}}  {'state':<{STATE_W}}  {'t_state':>{TSTATE_W}}  "
 449:         f"{'pres':>{PRES_W}}  {'wdog':>{WDOG_W}}  {'busy':<{BUSY_W}}  "
 450:         f"{'stage':<{STAGE_W}}  {'prog':>{PROG_W}}  {'p_age':>{PAGE_W}}  {'stall':<{STALL_W}}  "
 451:         f"{'local_size':>{SIZE_W}}  {'local_events':>{EVENTS_W}}  "
 452:         f"{'created':>{COUNT_W}}  {'executing':>{COUNT_W}}  {'completed':>{COUNT_W}}  "
 453:         f"{'dirty':<{DIRTY_W}}"
 454:     )
 455: 
 456:     for node_name in source_order:
 457:         view = _node_runtime_view(api_snapshots, node_name)
 458:         lines.append(
 459:             f"- {node_name:<{NODE_W}}  "
 460:             f"{cut(view['health'], HEALTH_W):<{HEALTH_W}}  "
 461:             f"{cut(view['state'], STATE_W):<{STATE_W}}  "
 462:             f"{fmt_age(view['state_age_s']):>{TSTATE_W}}  "
 463:             f"{fmt_age(view['presence_age_s']):>{PRES_W}}  "
 464:             f"{fmt_age(view['watchdog_age_s']):>{WDOG_W}}  "
 465:             f"{fmt_busy(view['watchdog_busy']):<{BUSY_W}}  "
 466:             f"{cut(view['progress_stage'], STAGE_W):<{STAGE_W}}  "
 467:             f"{cut(fmt_progress(view['progress_current'], view['progress_total'], view['progress_pct']), PROG_W):>{PROG_W}}  "
 468:             f"{fmt_age(view['progress_age_s']):>{PAGE_W}}  "
 469:             f"{('Y' if view['progress_stalled'] else 'N'):<{STALL_W}}  "
 470:             f"{view['local_size']:>{SIZE_W}}  "
 471:             f"{view['local_events']:>{EVENTS_W}}  "
 472:             f"{view['created']:>{COUNT_W}}  "
 473:             f"{view['executing']:>{COUNT_W}}  "
 474:             f"{view['completed']:>{COUNT_W}}  "
 475:             f"{cut(view['dirty'], DIRTY_W):<{DIRTY_W}}"
 476:         )
 477: 
 478:     lines.append("")
 479:     return lines
 480: 
 481: 
 482: def draw_top_summary_curses(stdscr, start_y, api_snapshots, width):
 483:     source_order = ["lnx200nas", "lnx202pc", "lnx203hp"]
 484: 
 485:     NODE_W = 12
 486:     HEALTH_W = 8
 487:     STATE_W = 12
 488:     TSTATE_W = 8
 489:     PRES_W = 7
 490:     WDOG_W = 7
 491:     BUSY_W = 5
 492:     STAGE_W = 18
 493:     PROG_W = 12
 494:     PAGE_W = 7
 495:     STALL_W = 6
 496:     SIZE_W = 10
 497:     EVENTS_W = 12
 498:     COUNT_W = 9
 499:     DIRTY_W = 7
 500: 
 501:     def cut(value, width):
 502:         s = "-" if value is None else str(value)
 503:         return s if len(s) <= width else s[: max(0, width - 1)] + "…"
 504: 
 505:     def fmt_age(value):
 506:         if value is None:
 507:             return "-"
 508:         try:
 509:             value = float(value)
 510:         except Exception:
 511:             return "-"
 512:         if value < 60:
 513:             return f"{value:.0f}s"
 514:         if value < 3600:
 515:             return f"{value / 60:.1f}m"
 516:         return f"{value / 3600:.1f}h"
 517: 
 518:     def fmt_busy(value):
 519:         if value is True:
 520:             return "Y"
 521:         if value is False:
 522:             return "N"
 523:         return "?"
 524: 
 525:     def fmt_progress(current, total, pct):
 526:         if current is None and total is None:
 527:             return "-"
 528:         try:
 529:             if pct is not None and current is not None and total is not None:
 530:                 return f"{int(current)}/{int(total)} {pct:.0f}%"
 531:             if current is not None and total is not None:
 532:                 return f"{int(current)}/{int(total)}"
 533:             return str(current if current is not None else "-")
 534:         except Exception:
 535:             return "-"
 536: 
 537:     def put(y, x, text, attr=0):
 538:         if y < 0 or x >= width - 1:
 539:             return
 540:         stdscr.addnstr(y, x, text, max(1, width - 1 - x), attr)
 541: 
 542:     y = start_y
 543: 
 544:     put(y, 0, "### resumen cluster", curses.color_pair(4) | curses.A_BOLD)
 545:     y += 2
 546:     put(
 547:         y,
 548:         0,
 549:         "- leader esperado: "
 550:         + ", ".join(
 551:             f"{node}: {api_snapshots.get(node, {}).get('dashboard', {}).get('cluster', {}).get('leader', '?')}"
 552:             for node in source_order
 553:         ),
 554:         curses.color_pair(4),
 555:     )
 556:     y += 2
 557: 
 558:     header = (
 559:         f"- {'nodo':<{NODE_W}}  {'health':<{HEALTH_W}}  {'state':<{STATE_W}}  {'t_state':>{TSTATE_W}}  "
 560:         f"{'pres':>{PRES_W}}  {'wdog':>{WDOG_W}}  {'busy':<{BUSY_W}}  "
 561:         f"{'stage':<{STAGE_W}}  {'prog':>{PROG_W}}  {'p_age':>{PAGE_W}}  {'stall':<{STALL_W}}  "
 562:         f"{'local_size':>{SIZE_W}}  {'local_events':>{EVENTS_W}}  "
 563:         f"{'created':>{COUNT_W}}  {'executing':>{COUNT_W}}  {'completed':>{COUNT_W}}  {'dirty':<{DIRTY_W}}"
 564:     )
 565:     put(y, 0, header, curses.color_pair(4) | curses.A_BOLD)
 566:     y += 1
 567: 
 568:     for node_name in source_order:
 569:         view = _node_runtime_view(api_snapshots, node_name)
 570:         health_value = cut(view["health"], HEALTH_W)
 571:         state_value = cut(view["state"], STATE_W)
 572:         stale_state = str(health_value).lower() == "stale"
 573: 
 574:         cols = [
 575:             (f"- {node_name:<{NODE_W}}  ", curses.color_pair(5)),
 576:             (f"{health_value:<{HEALTH_W}}  ", color_for_health(health_value)),
 577:             (f"{state_value:<{STATE_W}}  ", color_for_state(state_value, stale=stale_state)),
 578:             (f"{fmt_age(view['state_age_s']):>{TSTATE_W}}  ", curses.color_pair(5)),
 579:             (f"{fmt_age(view['presence_age_s']):>{PRES_W}}  ", color_for_age(view["presence_age_s"], warn_s=1.5, stale_s=3.0)),
 580:             (f"{fmt_age(view['watchdog_age_s']):>{WDOG_W}}  ", color_for_age(view["watchdog_age_s"], warn_s=1.5, stale_s=3.0)),
 581:             (f"{fmt_busy(view['watchdog_busy']):<{BUSY_W}}  ", color_for_busy(view["watchdog_busy"])),
 582:             (f"{cut(view['progress_stage'], STAGE_W):<{STAGE_W}}  ", color_for_progress_stage(view["progress_stage"])),
 583:             (
 584:                 f"{cut(fmt_progress(view['progress_current'], view['progress_total'], view['progress_pct']), PROG_W):>{PROG_W}}  ",
 585:                 color_for_progress_active(view["progress_active"]),
 586:             ),
 587:             (
 588:                 f"{fmt_age(view['progress_age_s']):>{PAGE_W}}  ",
 589:                 color_for_age(view["progress_age_s"], warn_s=1.5, stale_s=3.0),
 590:             ),
 591:             (
 592:                 f"{('Y' if view['progress_stalled'] else 'N'):<{STALL_W}}  ",
 593:                 color_for_progress_stalled(view["progress_stalled"]),
 594:             ),
 595:             (f"{view['local_size']:>{SIZE_W}}  ", curses.color_pair(5)),
 596:             (f"{view['local_events']:>{EVENTS_W}}  ", curses.color_pair(5)),
 597:             (f"{view['created']:>{COUNT_W}}  ", color_for_count("created", view["created"])),
 598:             (f"{view['executing']:>{COUNT_W}}  ", color_for_count("executing", view["executing"])),
 599:             (f"{view['completed']:>{COUNT_W}}  ", color_for_count("completed", view["completed"])),
 600:             (f"{cut(view['dirty'], DIRTY_W):<{DIRTY_W}}", color_for_dirty(view["dirty"])),
 601:         ]
 602: 
 603:         x = 0
 604:         for text, attr in cols:
 605:             put(y, x, text, attr)
 606:             x += len(text)
 607: 
 608:         y += 1
 609: 
 610:     return y + 1
 611: 
 612: 
 613: def render_file_inventory(groups):
 614:     source_order = ["lnx200nas", "lnx202pc", "lnx203hp"]
 615:     NODE_WIDTH = 16
 616:     FILE_WIDTH = 30
 617:     SIZE_WIDTH = 10
 618:     MTIME_WIDTH = 30
 619:     lines = []
 620: 
 621:     for source in source_order:
 622:         if source not in groups:
 623:             continue
 624:         entries = groups[source]
 625:         lines.append(f"### log de {source}:")
 626:         lines.append("")
 627: 
 628:         local = next((e for e in entries if e["node"] == source and "event_log.local.000" in e["file"]), None)
 629:         local_replica = next(
 630:             (e for e in entries if e["file"] == f"event_log.{source}.000.jsonl"),
 631:             None,
 632:         )
 633:         remotes = [
 634:             e for e in entries if e["file"] == f"event_log.{source}.000.jsonl" and e["node"] != source
 635:         ]
 636:         remotes.sort(key=lambda x: x["node"])
 637: 
 638:         for e in [local, local_replica, *remotes]:
 639:             if not e:
 640:                 continue
 641:             node = (e["node"] + " " * NODE_WIDTH)[:NODE_WIDTH]
 642:             file = (e["file"] + " " * FILE_WIDTH)[:FILE_WIDTH]
 643:             size = (f"{e['size']}" + " " * SIZE_WIDTH)[:SIZE_WIDTH]
 644:             mtime = (e["mtime_date"] + "T" + e["mtime_time"] + e["mtime_tz"] + " " * MTIME_WIDTH)[:MTIME_WIDTH]
 645:             lines.append(f"- {node}  {file}  {size}  {mtime}")
 646: 
 647:         lines.append("")
 648: 
 649:     return lines
 650: 
 651: def render_events_inventory(groups_ev):
 652:     source_order = ["lnx200nas", "lnx202pc", "lnx203hp"]
 653:     NODE_WIDTH = 16
 654:     FILE_WIDTH = 30
 655:     SIZE_WIDTH = 10
 656:     MTIME_WIDTH = 30
 657:     lines = []
 658: 
 659:     for source in source_order:
 660:         if source not in groups_ev:
 661:             continue
 662:         entries = groups_ev[source]
 663:         lines.append(f"### events de {source}:")
 664:         lines.append("")
 665: 
 666:         local = next((e for e in entries if e["node"] == source and "events.local.000" in e["file"]), None)
 667:         local_replica = next(
 668:             (e for e in entries if e["file"] == f"events.{source}.000.jsonl"),
 669:             None,
 670:         )
 671:         remotes = [
 672:             e for e in entries if e["file"] == f"events.{source}.000.jsonl" and e["node"] != source
 673:         ]
 674:         remotes.sort(key=lambda x: x["node"])
 675: 
 676:         for e in [local, local_replica, *remotes]:
 677:             if not e:
 678:                 continue
 679:             node = (e["node"] + " " * NODE_WIDTH)[:NODE_WIDTH]
 680:             file = (e["file"] + " " * FILE_WIDTH)[:FILE_WIDTH]
 681:             size = (f"{e['size']}" + " " * SIZE_WIDTH)[:SIZE_WIDTH]
 682:             mtime = (e["mtime_date"] + "T" + e["mtime_time"] + e["mtime_tz"] + " " * MTIME_WIDTH)[:MTIME_WIDTH]
 683:             lines.append(f"- {node}  {file}  {size}  {mtime}")
 684: 
 685:         lines.append("")
 686: 
 687:     return lines
 688: 
 689: 
 690: def render_markdown(groups_ev, groups, api_snapshots):
 691:     lines = []
 692:     lines.extend(render_top_summary_1(api_snapshots, groups))
 693:     lines.extend(render_events_inventory(groups_ev))
 694:     lines.extend(render_file_inventory(groups))
 695:     return "\n".join(lines).strip() + "\n"
 696: 
 697: 
 698: def collect_snapshot():
 699:     all_rows = []
 700:     api_snapshots = {}
 701:     errors = []
 702: 
 703:     for node in NODES:
 704:         try:
 705:             text = ssh_ls(node)
 706:             rows_ev = parse_ev_output(node["name"], text)
 707:             rows = parse_ls_output(node["name"], text)
 708:             all_rows.extend(rows_ev)
 709:             all_rows.extend(rows)
 710:         except Exception as e:
 711:             errors.append(f"SSH {node['name']}: {e}")
 712: 
 713:         try:
 714:             api_snapshots[node["name"]] = fetch_api_snapshot(node)
 715:         except Exception as e:
 716:             errors.append(f"API {node['name']}: {e}")
 717:             api_snapshots[node["name"]] = {"node": node["name"], "error": str(e)}
 718: 
 719:     groups = build_groups(all_rows)
 720:     groups_ev = build_groups_ev(all_rows)
 721:     return groups_ev, groups, api_snapshots, errors
 722: 
 723: 
 724: def write_outputs(groups_ev, groups, api_snapshots):
 725:     all_rows = []
 726: 
 727:     for entries in groups_ev.values():
 728:         all_rows.extend(entries)
 729: 
 730:     for entries in groups.values():
 731:         all_rows.extend(entries)
 732: 
 733:     md = render_markdown(groups_ev, groups, api_snapshots)
 734:     OUT_MD.write_text(md, encoding="utf-8")
 735: 
 736:     with OUT_CSV.open("w", newline="", encoding="utf-8") as f:
 737:         writer = csv.DictWriter(
 738:             f,
 739:             fieldnames=["node", "file", "source", "mtime_date", "mtime_time", "mtime_tz", "size"],
 740:         )
 741:         writer.writeheader()
 742:         writer.writerows(all_rows)
 743: 
 744:     OUT_API_JSON.write_text(json.dumps(api_snapshots, ensure_ascii=False, indent=2), encoding="utf-8")
 745: 
 746: 
 747: def save_snapshot(lines, groups, api_snapshots, errors, started_at, refresh_seconds):
 748:     OUT_SNAPSHOT_DIR.mkdir(parents=True, exist_ok=True)
 749:     ts_file = datetime.now().strftime("%Y%m%d_%H%M%S")
 750: 
 751:     md_path = OUT_SNAPSHOT_DIR / f"cluster_live_snapshot_{ts_file}.md"
 752:     json_path = OUT_SNAPSHOT_DIR / f"cluster_live_snapshot_{ts_file}.json"
 753: 
 754:     md_content = "\n".join(lines).strip() + "\n"
 755:     md_path.write_text(md_content, encoding="utf-8")
 756: 
 757:     snapshot_payload = {
 758:         "captured_at": datetime.now().isoformat(),
 759:         "refresh_seconds": refresh_seconds,
 760:         "monitor_uptime_s": round(time.time() - started_at, 3),
 761:         "errors": errors,
 762:         "groups": groups,
 763:         "api_snapshots": api_snapshots,
 764:         "rendered_lines": lines,
 765:     }
 766:     json_path.write_text(json.dumps(snapshot_payload, ensure_ascii=False, indent=2), encoding="utf-8")
 767: 
 768:     return md_path, json_path
 769: 
 770: 
 771: def build_screen_lines(groups_ev, groups, api_snapshots, errors, started_at, refresh_seconds):
 772:     ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
 773:     lines = []
 774:     lines.append(
 775:         f"cluster_live.py  actualizado: {ts}  refresh={refresh_seconds:.1f}s  "
 776:         f"[s]=snapshot md+json  [q]=salir"
 777:     )
 778:     lines.append("")
 779:     if errors:
 780:         lines.append("errores:")
 781:         for err in errors:
 782:             lines.append(f"- {err}")
 783:         lines.append("")
 784:     lines.extend(render_top_summary_1(api_snapshots, groups))
 785:     lines.extend(render_events_inventory(groups_ev))
 786:     lines.extend(render_file_inventory(groups))
 787:     lines.append(f"uptime monitor: {time.time() - started_at:.1f}s")
 788:     if LAST_STATUS_LINE:
 789:         lines.append("")
 790:         lines.append(LAST_STATUS_LINE)
 791:     return lines
 792: 
 793: 
 794: def ui_loop(stdscr, refresh_seconds=1.5):
 795:     global LAST_STATUS_LINE
 796: 
 797:     curses.curs_set(0)
 798:     curses.noecho()
 799:     curses.cbreak()
 800:     stdscr.nodelay(True)
 801:     stdscr.keypad(True)
 802:     setup_colors()
 803:     started_at = time.time()
 804: 
 805:     while True:
 806:         cycle_start = time.time()
 807:         groups_ev, groups, api_snapshots, errors = collect_snapshot()
 808:         write_outputs(groups_ev, groups, api_snapshots)
 809:         lines = build_screen_lines(groups_ev, groups, api_snapshots, errors, started_at, refresh_seconds)
 810: 
 811:         stdscr.erase()
 812:         height, width = stdscr.getmaxyx()
 813:         usable_height = max(1, height - 1)
 814: 
 815:         stdscr.addnstr(
 816:             0,
 817:             0,
 818:             f"cluster_live.py  actualizado: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}  refresh={refresh_seconds:.1f}s  [s]=snapshot md+json  [q]=salir",
 819:             max(1, width - 1),
 820:             curses.color_pair(4) | curses.A_BOLD,
 821:         )
 822: 
 823:         y = 2
 824: 
 825:         if errors:
 826:             stdscr.addnstr(y, 0, "errores:", max(1, width - 1), curses.color_pair(3) | curses.A_BOLD)
 827:             y += 1
 828:             for err in errors:
 829:                 if y >= usable_height:
 830:                     break
 831:                 stdscr.addnstr(y, 0, f"- {err}", max(1, width - 1), curses.color_pair(3))
 832:                 y += 1
 833:             y += 1
 834: 
 835:         if y < usable_height:
 836:             y = draw_top_summary_curses(stdscr, y, api_snapshots, width)
 837: 
 838:         plain_lines = render_events_inventory(groups_ev)
 839:         plain_lines.append("")
 840:         plain_lines.extend(render_file_inventory(groups))
 841:         plain_lines.append(f"uptime monitor: {time.time() - started_at:.1f}s")
 842:         if LAST_STATUS_LINE:
 843:             plain_lines.append("")
 844:             plain_lines.append(LAST_STATUS_LINE)
 845: 
 846:         for line in plain_lines:
 847:             if y >= usable_height:
 848:                 break
 849:             stdscr.addnstr(y, 0, line, max(1, width - 1))
 850:             y += 1
 851: 
 852:         stdscr.refresh()
 853: 
 854:         while True:
 855:             key = stdscr.getch()
 856: 
 857:             if key in (ord("q"), ord("Q")):
 858:                 return
 859: 
 860:             if key in (ord("s"), ord("S")):
 861:                 try:
 862:                     md_path, json_path = save_snapshot(
 863:                         lines=lines,
 864:                         groups=groups,
 865:                         api_snapshots=api_snapshots,
 866:                         errors=errors,
 867:                         started_at=started_at,
 868:                         refresh_seconds=refresh_seconds,
 869:                     )
 870:                     LAST_STATUS_LINE = f"[snapshot] guardado md={md_path} json={json_path}"
 871:                 except Exception as e:
 872:                     LAST_STATUS_LINE = f"[snapshot] error: {e}"
 873:                 break
 874: 
 875:             if key == -1:
 876:                 pass
 877:             else:
 878:                 continue
 879: 
 880:             if time.time() - cycle_start >= refresh_seconds:
 881:                 break
 882: 
 883:             time.sleep(0.05)
 884: 
 885: 
 886: def run_live_monitor(refresh_seconds=1.5):
 887:     curses.wrapper(lambda stdscr: ui_loop(stdscr, refresh_seconds=refresh_seconds))
 888: 
 889: 
 890: def run_once():
 891:     all_rows = []
 892:     api_snapshots = {}
 893: 
 894:     for node in NODES:
 895:         print(f"[INFO] Consultando SSH {node['name']} ({node['host']})...")
 896:         try:
 897:             text = ssh_ls(node)
 898:             rows_ev = parse_ev_output(node["name"], text)
 899:             rows = parse_ls_output(node["name"], text)
 900:             all_rows.extend(rows)
 901:         except Exception as e:
 902:             print(f"[ERROR] SSH {node['name']}: {e}")
 903: 
 904:         print(f"[INFO] Consultando API {node['name']} ({node['host']})...")
 905:         api_snapshots[node["name"]] = fetch_api_snapshot(node)
 906: 
 907:     groups = build_groups(all_rows)
 908: 
 909:     groups_ev = build_groups_ev(all_rows)
 910:     check_consistency(groups_ev)
 911:     check_consistency(groups)
 912:     write_outputs(groups_ev, groups, api_snapshots)
 913: 
 914:     print(f"[OK] Markdown: {OUT_MD}")
 915:     print(f"[OK] CSV: {OUT_CSV}")
 916:     print(f"[OK] API JSON: {OUT_API_JSON}")
 917: 
 918: 
 919: if __name__ == "__main__":
 920:     run_live_monitor()



