 294: # =====================================================
 295: # KILL / REVIVE
 296: # =====================================================
 297: 
 298: def kill_node(node, seconds=None):
 299:     stat_inc("kill_attempts")
 300: 
 301:     try:
 302:         resp = requests.post(f"{node}/sleep", timeout=2)
 303:         payload = {}
 304: 
 305:         try:
 306:             payload = resp.json()
 307:         except Exception:
 308:             payload = {"raw_text": resp.text}
 309: 
 310:         if resp.status_code == 200 and payload.get("ok") is True:
 311:             with dead_lock:
 312:                 dead_nodes.add(node)
 313: 
 314:             stat_inc("kills")
 315:             stat_kill_event(node=node, action="sleep", ok=True, payload=payload, seconds=seconds)
 316:             print(f"[CHAOS] SLEEP {node}")
 317:             return True
 318: 
 319:         stat_inc("kill_failures")
 320:         stat_kill_event(node=node, action="sleep", ok=False, payload=payload, seconds=seconds)
 321:         print(f"[CHAOS FAIL SLEEP] {node} -> status={resp.status_code} payload={payload}")
 322:         return False
 323: 
 324:     except Exception as e:
 325:         stat_inc("kill_failures")
 326:         stat_kill_event(node=node, action="sleep", ok=False, error=str(e), seconds=seconds)
 327:         print(f"[CHAOS FAIL SLEEP] {node} -> {e}")
 328:         return False
 329: 
 330: 
 331: def revive_node(node):
 332:     try:
 333:         resp = requests.post(f"{node}/revive", timeout=2)
 334:         payload = {}
 335: 
 336:         try:
 337:             payload = resp.json()
 338:         except Exception:
 339:             payload = {"raw_text": resp.text}
 340: 
 341:         if resp.status_code == 200 and payload.get("ok") is True:
 342:             with dead_lock:
 343:                 dead_nodes.discard(node)
 344: 
 345:             stat_inc("revives")
 346:             stat_kill_event(node=node, action="revive", ok=True, payload=payload)
 347:             print(f"[CHAOS] REVIVE {node}")
 348:             return True
 349: 
 350:         stat_inc("revive_failures")
 351:         stat_kill_event(node=node, action="revive", ok=False, payload=payload)
 352:         print(f"[CHAOS FAIL REVIVE] {node} -> status={resp.status_code} payload={payload}")
 353:         return False
 354: 
 355:     except Exception as e:
 356:         stat_inc("revive_failures")
 357:         stat_kill_event(node=node, action="revive", ok=False, error=str(e))
 358:         print(f"[CHAOS FAIL REVIVE] {node} -> {e}")
 359:         return False
 360: 
 361: 
 362: def kill_cycle(node, seconds):
 363:     try:
 364:         ok = kill_node(node, seconds=seconds)
 365:         if ok:
 366:             print(f"[CHAOS] DEAD {node} for {seconds:.2f}s")
 367:             time.sleep(seconds)
 368:     finally:
 369:         revive_node(node)
 370: 
 371: 
 372: # =====================================================
 373: # EVENT SENDING
 374: # =====================================================
 375: 
 376: def send_event(i):
 377:     stat_inc("events_total")
 378:     tried = set()
 379: 
 380:     event = build_event(i)
 381: 
 382:     for attempt in range(MAX_RETRIES):
 383:         available = [n for n in NODES if n not in tried]
 384: 
 385:         if not available:
 386:             break
 387: 
 388:         node = random.choice(available)
 389:         tried.add(node)
 390:         start = time.time()
 391: 
 392:         try:
 393:             r = requests.post(
 394:                 f"{node}/event",
 395:                 json=event,
 396:                 timeout=REQUEST_TIMEOUT
 397:             )
 398: 
 399:             elapsed_ms = (time.time() - start) * 1000
 400:             stat_latency(elapsed_ms)
 401: 
 402:             payload = {}
 403:             try:
 404:                 payload = r.json()
 405:             except Exception:
 406:                 payload = {"raw_text": r.text}
 407: 
 408:             leader = None
 409:             if isinstance(payload, dict):
 410:                 if "result" in payload and isinstance(payload["result"], dict):
 411:                     leader = payload["result"].get("leader")
 412:                 else:
 413:                     leader = payload.get("leader")
 414: 
 415:             if leader:
 416:                 stat_leader(leader)
 417: 
 418:             if elapsed_ms >= SLOW_EVENT_THRESHOLD_MS:
 419:                 stat_slow_event(
 420:                     event_index=i,
 421:                     attempt=attempt + 1,
 422:                     node=node,
 423:                     latency_ms=elapsed_ms,
 424:                     leader=leader,
 425:                     payload=payload,
 426:                 )
 427: 
 428:             if is_event_submit_ok(r.status_code, payload):
 429:                 stat_inc("events_ok")
 430:                 stat_node_ok(node)
 431: 
 432:                 print(
 433:                     f"[TORTURE] "
 434:                     f"{i:03} "
 435:                     f"OK "
 436:                     f"attempt={attempt + 1} "
 437:                     f"node={node} "
 438:                     f"leader={leader} "
 439:                     f"latency={elapsed_ms:.1f}ms"
 440:                 )
 441: 
 442:                 return True
 443: 
 444:             if is_retryable_response(payload) or r.status_code >= 500:
 445:                 stat_inc("events_retried")
 446: 
 447:                 if isinstance(payload, dict) and payload.get("error") == "no leader":
 448:                     stat_inc("events_no_leader")
 449: 
 450:                 print(
 451:                     f"[RETRY] "
 452:                     f"{i:03} "
 453:                     f"attempt={attempt + 1} "
 454:                     f"node={node} "
 455:                     f"status={r.status_code} "
 456:                     f"payload={payload}"
 457:                 )
 458: 
 459:                 time.sleep(0.5)
 460:                 continue
 461: 
 462:             stat_inc("events_failed")
 463:             stat_node_fail(node)
 464:             stat_unexpected_failure(
 465:                 event_index=i,
 466:                 attempt=attempt + 1,
 467:                 node=node,
 468:                 status_code=r.status_code,
 469:                 payload=payload,
 470:                 reason="hard_fail_non_retryable_response",
 471:             )
 472: 
 473:             print(
 474:                 f"[FAIL] "
 475:                 f"{i:03} "
 476:                 f"node={node} "
 477:                 f"status={r.status_code} "
 478:                 f"payload={payload}"
 479:             )
 480: 
 481:             return False
 482: 
 483:         except requests.Timeout as e:
 484:             stat_inc("events_timeout")
 485:             stat_inc("events_retried")
 486: 
 487:             print(
 488:                 f"[TIMEOUT] "
 489:                 f"{i:03} "
 490:                 f"attempt={attempt + 1} "
 491:                 f"{node} -> {e}"
 492:             )
 493: 
 494:         except requests.ConnectionError as e:
 495:             stat_inc("events_connection_error")
 496:             stat_inc("events_retried")
 497: 
 498:             print(
 499:                 f"[CONNECTION] "
 500:                 f"{i:03} "
 501:                 f"attempt={attempt + 1} "
 502:                 f"{node} -> {e}"
 503:             )
 504: 
 505:         except Exception as e:
 506:             stat_inc("events_forward_error")
 507:             stat_inc("events_retried")
 508:             stat_unexpected_failure(
 509:                 event_index=i,
 510:                 attempt=attempt + 1,
 511:                 node=node,
 512:                 reason=f"exception:{type(e).__name__}",
 513:                 payload={"exception": str(e)},
 514:             )
 515: 
 516:             print(
 517:                 f"[ERROR] "
 518:                 f"{i:03} "
 519:                 f"attempt={attempt + 1} "
 520:                 f"{node} -> {e}"
 521:             )
 522: 
 523:         time.sleep(0.5)
 524: 
 525:     stat_inc("events_failed")
 526:     stat_unexpected_failure(
 527:         event_index=i,
 528:         attempt=MAX_RETRIES,
 529:         node=None,
 530:         reason="dropped_after_retries",
 531:         payload={"tried_nodes": list(tried)},
 532:     )
 533: 
 534:     print(f"[DROP] {i:03} event dropped after retries")
 535:     return False
 536: 
 537: 
 538: # =====================================================
 539: # MAIN LOOP
 540: # =====================================================
 541: 
 542: def chaos_loop():
 543:     for i in range(EVENTS):
 544:         if random.random() < KILL_PROBABILITY:
 545:             if SLEEP_ONLY_NODE:
 546:                 node = SLEEP_ONLY_NODE
 547:             else:
 548:                 node = random.choice(NODES)
 549: 
 550:             seconds = random.uniform(*DEATH_TIME_RANGE)
 551: 
 552:             t = threading.Thread(
 553:                 target=kill_cycle,
 554:                 args=(node, seconds),
 555:                 daemon=True
 556:             )
 557: 
 558:             t.start()
 559:             kill_threads.append(t)
 560: 
 561:         send_event(i)
 562:         time.sleep(random.uniform(*EVENT_DELAY_RANGE))
 563: 
 564: 
 565: # =====================================================
 566: # FORCE REVIVE ALL
 567: # =====================================================
 568: 
 569: def revive_everything():
 570:     print("\n[MAIN] REVIVING ALL NODES\n")
 571: 
 572:     unique_nodes = sorted(set(NODES))
 573: 
 574:     for node in unique_nodes:
 575:         try:
 576:             requests.post(f"{node}/revive", timeout=2)
 577:             print(f"[FORCE REVIVE] {node}")
 578:         except Exception as e:
 579:             print(f"[FORCE REVIVE FAIL] {node} -> {e}")
 580: 
 581: 
 582: # =====================================================
 583: # WAIT ALL KILL THREADS
 584: # =====================================================
 585: 
 586: def wait_kills():
 587:     print("\n[MAIN] waiting active kill cycles...\n")
 588: 
 589:     for t in kill_threads:
 590:         t.join(timeout=30)
 591: 
 592: 
 593: # =====================================================
 594: # STATS REPORT
 595: # =====================================================
 596: 
 597: def print_stats():
 598:     ended_at = time.time()
 599: 
 600:     print("\n")
 601:     print("="* 56)
 602:     print("FINAL CHAOS STATS")
 603:     print("="* 56)
 604: 
 605:     with stats_lock:
 606:         total = stats["events_total"]
 607:         ok = stats["events_ok"]
 608:         failed = stats["events_failed"]
 609: 
 610:         success_rate = ((ok / total) * 100) if total else 0
 611: 
 612:         avg_latency = (sum(stats["latency"]) / len(stats["latency"])) if stats["latency"] else 0
 613:         max_latency = max(stats["latency"]) if stats["latency"] else 0
 614:         min_latency = min(stats["latency"]) if stats["latency"] else 0
 615:         p50_latency = percentile(stats["latency"], 50)
 616:         p95_latency = percentile(stats["latency"], 95)
 617:         p99_latency = percentile(stats["latency"], 99)
 618: 
 619:         print(f"events_total........: {total}")
 620:         print(f"events_ok...........: {ok}")
 621:         print(f"events_failed.......: {failed}")
 622:         print(f"success_rate........: {success_rate:.2f}%")
 623: 
 624:         print()
 625: 
 626:         print(f"events_retried......: {stats['events_retried']}")
 627:         print(f"events_no_leader....: {stats['events_no_leader']}")
 628:         print(f"timeouts............: {stats['events_timeout']}")
 629:         print(f"connection_errors...: {stats['events_connection_error']}")
 630:         print(f"forward_errors......: {stats['events_forward_error']}")
 631:         print(f"unexpected_fail.....: {stats['events_unexpected_fail']}")
 632:         print(f"slow_events.........: {stats['events_slow']}")
 633: 
 634:         print()
 635: 
 636:         print(f"kill_attempts.......: {stats['kill_attempts']}")
 637:         print(f"kills...............: {stats['kills']}")
 638:         print(f"kill_failures.......: {stats['kill_failures']}")
 639:         print(f"revives.............: {stats['revives']}")
 640:         print(f"revive_failures.....: {stats['revive_failures']}")
 641: 
 642:         print()
 643: 
 644:         print(f"latency_avg.........: {avg_latency:.1f} ms")
 645:         print(f"latency_min.........: {min_latency:.1f} ms")
 646:         print(f"latency_p50.........: {p50_latency:.1f} ms")
 647:         print(f"latency_p95.........: {p95_latency:.1f} ms")
 648:         print(f"latency_p99.........: {p99_latency:.1f} ms")
 649:         print(f"latency_max.........: {max_latency:.1f} ms")
 650: 
 651:         print()
 652:         print("LEADERS SEEN")
 653:         for leader, count in sorted(stats["leaders_seen"].items()):
 654:             print(f"  {leader:15} -> {count}")
 655: 
 656:         print()
 657:         print("NODE SUCCESS")
 658:         for node, count in sorted(stats["per_node_ok"].items()):
 659:             print(f"  {node:30} -> {count}")
 660: 
 661:         print()
 662:         print("NODE FAIL")
 663:         for node, count in sorted(stats["per_node_fail"].items()):
 664:             print(f"  {node:30} -> {count}")
 665: 
 666:         print()
 667:         print("SLOW EVENTS")
 668:         if stats["slow_events"]:
 669:             for idx, item in enumerate(stats["slow_events"][:20], start=1):
 670:                 print(
 671:                     f"  #{idx:02} "
 672:                     f"event={item.get('event_index')} "
 673:                     f"attempt={item.get('attempt')} "
 674:                     f"node={item.get('node')} "
 675:                     f"leader={item.get('leader')} "
 676:                     f"latency_ms={item.get('latency_ms')}"
 677:                 )
 678:             if len(stats["slow_events"]) > 20:
 679:                 print(f"  ... and {len(stats['slow_events']) - 20} more")
 680:         else:
 681:             print("  none")
 682: 
 683:         print()
 684:         print("UNEXPECTED FAILURES")
 685:         if stats["unexpected_failures"]:
 686:             for idx, item in enumerate(stats["unexpected_failures"][:20], start=1):
 687:                 print(
 688:                     f"  #{idx:02} "
 689:                     f"event={item.get('event_index')} "
 690:                     f"attempt={item.get('attempt')} "
 691:                     f"node={item.get('node')} "
 692:                     f"status={item.get('status_code')} "
 693:                     f"reason={item.get('reason')}"
 694:                 )
 695:             if len(stats["unexpected_failures"]) > 20:
 696:                 print(f"  ... and {len(stats['unexpected_failures']) - 20} more")
 697:         else:
 698:             print("  none")
 699: 
 700:         print("="* 56)
 701: 
 702:         report = {
 703:             "test_config": TEST_CONFIG,
 704:             "run_meta": {
 705:                 "started_at_epoch": TEST_STARTED_AT,
 706:                 "ended_at_epoch": ended_at,
 707:                 "started_at_iso": datetime.fromtimestamp(TEST_STARTED_AT).isoformat(),
 708:                 "ended_at_iso": datetime.fromtimestamp(ended_at).isoformat(),
 709:                 "duration_seconds": round(ended_at - TEST_STARTED_AT, 3),
 710:             },
 711:             "stats": {
 712:                 **stats,
 713:                 "success_rate": round(success_rate, 2),
 714:                 "latency_avg": round(avg_latency, 3),
 715:                 "latency_min": round(min_latency, 3),
 716:                 "latency_p50": round(p50_latency, 3),
 717:                 "latency_p95": round(p95_latency, 3),
 718:                 "latency_p99": round(p99_latency, 3),
 719:                 "latency_max": round(max_latency, 3),
 720:                 "per_node_ok": dict(stats["per_node_ok"]),
 721:                 "per_node_fail": dict(stats["per_node_fail"]),
 722:                 "leaders_seen": dict(stats["leaders_seen"]),
 723:             }
 724:         }
 725: 
 726:         with open(STATS_FILE, "w") as f:
 727:             json.dump(report, f, indent=2)
 728: 
 729:         print(f"\n[MAIN] stats saved to {STATS_FILE}\n")
 730: 
