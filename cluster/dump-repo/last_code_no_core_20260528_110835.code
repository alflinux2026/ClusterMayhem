 684: def main():
 685:     print("[MAIN] starting UNIVERSAL chaos torture v4")
 686:     print_test_config()
 687:     workers = []
 688:     for idx in range(SEND_WORKERS):
 689:         t = threading.Thread(target=sender_worker, args=(idx,), daemon=True)
 690:         t.start()
 691:         workers.append(t)
 692:     drained = False
 693:     try:
 694:         chaos_loop()
 695:         drained = wait_queue_drain()
 696:         pending_queue.join()
 697:         for t in workers:
 698:             t.join(timeout=5)
 699:     finally:
 700:         wait_kills()
 701:         revive_everything()
 702:         if not drained:
 703:             print(f"
 704: [MAIN WARN] queue drain timeout reached after {DRAIN_TIMEOUT:.1f}s
 705: ")
 706:         print_test_config()
 707:         print_stats()
 708:         print("
 709: [MAIN] cluster restored
 710: ")
 711: 
 712: 
 713: if __name__ == "__main__":
 714:     main()



