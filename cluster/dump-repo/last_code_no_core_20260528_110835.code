  70: def parse_ls_output(node_name, text):
  71:     rows = []
  72:     for line in text.splitlines():
  73:         line = line.rstrip()
  74:         if not line or line.startswith("total "):
  75:             continue
  76:         m = LINE_RE.match(line)
  77:         if not m:
  78:             continue
  79:         d = m.groupdict()
  80:         file_name = d["name"]
  81:         m_source = re.match(r"^event_log\.(.+)\.jsonl$", file_name)
  82:         if not m_source and file_name != "event_log.local.jsonl":
  83:             continue
  84: 
  85:         source = m_source.group(1) if m_source else None
  86:         if file_name == "event_log.local.jsonl":
  87:             source = node_name
  88: 
  89:         rows.append(
  90:             {
  91:                 "node": node_name,
  92:                 "file": file_name,
  93:                 "source": source,
  94:                 "mtime_date": d["date"],
  95:                 "mtime_time": d["time"],
  96:                 "mtime_tz": d["tz"],
  97:                 "size": int(d["size"]),
  98:             }
  99:         )
 100:     return rows
