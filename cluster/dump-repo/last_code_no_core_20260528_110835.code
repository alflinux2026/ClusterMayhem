 279: def setup_colors():
 280:     if not curses.has_colors():
 281:         return False
 282: 
 283:     curses.start_color()
 284:     curses.use_default_colors()
 285: 
 286:     curses.init_pair(1, curses.COLOR_GREEN, -1)
 287:     curses.init_pair(2, curses.COLOR_YELLOW, -1)
 288:     curses.init_pair(3, curses.COLOR_RED, -1)
 289:     curses.init_pair(4, curses.COLOR_CYAN, -1)
 290:     curses.init_pair(5, curses.COLOR_WHITE, -1)
 291:     curses.init_pair(6, curses.COLOR_MAGENTA, -1)
 292:     return True
 293: 
 294: 
 295: def color_for_health(value):
 296:     v = str(value or "").lower()
 297:     if v == "ok":
 298:         return curses.color_pair(1) | curses.A_BOLD
 299:     if v == "stale":
 300:         return curses.color_pair(3) | curses.A_BOLD
 301:     return curses.color_pair(2) | curses.A_BOLD
 302: 
 303: 
 304: def color_for_state(state, stale=False):
 305:     if stale:
 306:         return curses.color_pair(3) | curses.A_BOLD
 307: 
 308:     s = str(state or "").upper()
 309:     if s == "ACTIVE":
 310:         return curses.color_pair(1) | curses.A_BOLD
 311:     if s in ("STAND-BY", "STANDBY"):
 312:         return curses.color_pair(2) | curses.A_BOLD
 313:     if s == "DRAINING":
 314:         return curses.color_pair(6) | curses.A_BOLD
 315:     if s in ("ISOLATED", "OFFLINE", "???"):
 316:         return curses.color_pair(3) | curses.A_BOLD
 317:     return curses.color_pair(5)
 318: 
 319: 
 320: def color_for_dirty(value):
 321:     if value is True or str(value).lower() == "true":
 322:         return curses.color_pair(3) | curses.A_BOLD
 323:     return curses.color_pair(1)
 324: 
 325: 
 326: def color_for_count(label, value):
 327:     try:
 328:         n = int(value)
 329:     except Exception:
 330:         n = 0
 331: 
 332:     if label == "executing" and n > 0:
 333:         return curses.color_pair(2) | curses.A_BOLD
 334:     if label == "created" and n > 0:
 335:         return curses.color_pair(6) | curses.A_BOLD
 336:     if label == "completed" and n > 0:
 337:         return curses.color_pair(1)
 338:     return curses.color_pair(5)
 339: 
 340: 
 341: def color_for_age(value, warn_s=1.5, stale_s=3.0):
 342:     if value is None:
 343:         return curses.color_pair(5)
 344:     try:
 345:         age = float(value)
 346:     except Exception:
 347:         return curses.color_pair(5)
 348:     if age >= stale_s:
 349:         return curses.color_pair(3) | curses.A_BOLD
 350:     if age >= warn_s:
 351:         return curses.color_pair(2) | curses.A_BOLD
 352:     return curses.color_pair(1)
 353: 
 354: 
 355: def color_for_busy(value):
 356:     if value is True:
 357:         return curses.color_pair(6) | curses.A_BOLD
 358:     if value is False:
 359:         return curses.color_pair(1)
 360:     return curses.color_pair(5)
 361: 
 362: 
 363: def color_for_progress_active(value):
 364:     if value is True:
 365:         return curses.color_pair(6) | curses.A_BOLD
 366:     return curses.color_pair(5)
 367: 
 368: 
 369: def color_for_progress_stalled(value):
 370:     if value is True:
 371:         return curses.color_pair(3) | curses.A_BOLD
 372:     return curses.color_pair(1)
 373: 
 374: 
 375: def color_for_progress_stage(stage):
 376:     if not stage:
 377:         return curses.color_pair(5)
 378:     return curses.color_pair(4)
 379: 
