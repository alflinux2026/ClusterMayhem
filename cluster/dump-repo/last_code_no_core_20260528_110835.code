 820:         for leader, count in sorted(stats["leaders_seen"].items()):
 821:             print(f"  {leader:15} -> {count}")
 822: 
 823:         print()
 824:         print("NODE SUCCESS")
 825:         for node, count in sorted(stats["per_node_ok"].items()):
 826:             print(f"  {node:30} -> {count}")
 827: 
 828:         print()
