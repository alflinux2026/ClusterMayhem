 365: def kill_node(node, seconds=None):
 366:     stat_inc("kill_attempts")
 367:     try:
 368:         resp = requests.post(f"{node}/sleep", timeout=2)
 369:         try:
 370:             payload = resp.json()
 371:         except Exception:
 372:             payload = {"raw_text": resp.text}
 373:         if resp.status_code == 200 and payload.get("ok") is True:
 374:             with dead_lock:
 375:                 dead_nodes.add(node)
 376:             stat_inc("kills")
 377:             stat_kill_event(node=node, action="sleep", ok=True, payload=payload, seconds=seconds)
 378:             print(f"[CHAOS] SLEEP {node}")
 379:             return True
 380:         stat_inc("kill_failures")
 381:         stat_kill_event(node=node, action="sleep", ok=False, payload=payload, seconds=seconds)
 382:         print(f"[CHAOS FAIL SLEEP] {node} -> status={resp.status_code} payload={payload}")
 383:         return False
 384:     except Exception as e:
 385:         stat_inc("kill_failures")
 386:         stat_kill_event(node=node, action="sleep", ok=False, error=str(e), seconds=seconds)
 387:         print(f"[CHAOS FAIL SLEEP] {node} -> {e}")
 388:         return False
 389: 
 390: 
 391: def revive_node(node):
 392:     try:
 393:         resp = requests.post(f"{node}/revive", timeout=2)
 394:         try:
 395:             payload = resp.json()
 396:         except Exception:
 397:             payload = {"raw_text": resp.text}
 398:         if resp.status_code == 200 and payload.get("ok") is True:
 399:             with dead_lock:
 400:                 dead_nodes.discard(node)
 401:             stat_inc("revives")
 402:             stat_kill_event(node=node, action="revive", ok=True, payload=payload)
 403:             print(f"[CHAOS] REVIVE {node}")
 404:             return True
 405:         stat_inc("revive_failures")
 406:         stat_kill_event(node=node, action="revive", ok=False, payload=payload)
 407:         print(f"[CHAOS FAIL REVIVE] {node} -> status={resp.status_code} payload={payload}")
 408:         return False
 409:     except Exception as e:
 410:         stat_inc("revive_failures")
 411:         stat_kill_event(node=node, action="revive", ok=False, error=str(e))
 412:         print(f"[CHAOS FAIL REVIVE] {node} -> {e}")
 413:         return False
 414: 
 415: 
 416: def kill_cycle(node, seconds):
 417:     try:
 418:         ok = kill_node(node, seconds=seconds)
 419:         if ok:
 420:             print(f"[CHAOS] DEAD {node} for {seconds:.2f}s")
 421:             time.sleep(seconds)
 422:     finally:
 423:         revive_node(node)
 424: 
 425: 
 426: def process_pending_event(pending: PendingEvent):
 427:     i = pending.event_index
 428:     event = pending.event
 429:     attempt_number = pending.retries_done + 1
 430:     available = [n for n in NODES if n not in pending.tried_nodes]
 431:     if not available:
 432:         pending.tried_nodes.clear()
 433:         available = list(NODES)
 434:     node = random.choice(available)
 435:     pending.tried_nodes.add(node)
 436:     start = time.time()
 437:     try:
 438:         r = requests.post(f"{node}/event", json=event, timeout=REQUEST_TIMEOUT)
 439:         elapsed_ms = (time.time() - start) * 1000
 440:         stat_latency(elapsed_ms)
 441:         payload = {}
 442:         try:
 443:             payload = r.json()
 444:         except Exception:
 445:             payload = {"raw_text": r.text}
 446:         leader = extract_leader(payload)
 447:         if leader:
 448:             stat_leader(leader)
 449:         if elapsed_ms >= SLOW_EVENT_THRESHOLD_MS:
 450:             stat_slow_event(event_index=i, attempt=attempt_number, node=node, latency_ms=elapsed_ms, leader=leader, payload=payload)
 451:         if r.status_code == 200:
 452:             stat_inc("submit_http_200")
 453:         result = classify_submit_response(r.status_code, payload)
 454:         if result == "submit_ok":
 455:             stat_inc("events_ok")
 456:             stat_inc("submit_semantic_ok")
 457:             stat_node_ok(node)
 458:             print(f"[TORTURE] {i:03} OK attempt={attempt_number} node={node} leader={leader} latency={elapsed_ms:.1f}ms")
 459:             return True
 460:         if result == "retryable_error" or r.status_code >= 500:
 461:             stat_inc("events_retried")
 462:             if isinstance(payload, dict) and payload.get("error") == "no leader":
 463:                 stat_inc("events_no_leader")
 464:             result_payload = payload.get("result") if isinstance(payload.get("result"), dict) else None
 465:             if isinstance(result_payload, dict) and result_payload.get("error") == "no leader":
 466:                 stat_inc("events_no_leader")
 467:             print(f"[RETRY] {i:03} attempt={attempt_number} node={node} status={r.status_code} payload={payload}")
 468:             if pending.retries_done + 1 >= MAX_RETRIES:
 469:                 stat_inc("events_failed")
 470:                 stat_unexpected_failure(event_index=i, attempt=attempt_number, node=node, status_code=r.status_code, payload=payload, reason="dropped_after_retries_retryable_response")
 471:                 print(f"[DROP] {i:03} event dropped after retries")
 472:                 return False
 473:             pending.retries_done += 1
 474:             stat_inc("queue_requeues")
 475:             enqueue_pending(pending, compute_retry_backoff(pending.retries_done))
 476:             return False
 477:         stat_inc("events_failed")
 478:         stat_inc("submit_hard_fail")
 479:         stat_node_fail(node)
 480:         stat_unexpected_failure(event_index=i, attempt=attempt_number, node=node, status_code=r.status_code, payload=payload, reason="hard_fail_non_retryable_response")
 481:         print(f"[FAIL] {i:03} attempt={attempt_number} node={node} status={r.status_code} payload={payload}")
 482:         return False
 483:     except requests.Timeout as e:
 484:         stat_inc("events_timeout")
 485:         stat_inc("events_retried")
 486:         print(f"[TIMEOUT] {i:03} attempt={attempt_number} {node} -> {e}")
 487:     except requests.ConnectionError as e:
 488:         stat_inc("events_connection_error")
 489:         stat_inc("events_retried")
 490:         print(f"[CONNECTION] {i:03} attempt={attempt_number} {node} -> {e}")
 491:     except Exception as e:
 492:         stat_inc("events_forward_error")
 493:         stat_inc("events_retried")
 494:         stat_unexpected_failure(event_index=i, attempt=attempt_number, node=node, reason=f"exception:{type(e).__name__}", payload={"exception": str(e)})
 495:         print(f"[ERROR] {i:03} attempt={attempt_number} {node} -> {e}")
 496:     if pending.retries_done + 1 >= MAX_RETRIES:
 497:         stat_inc("events_failed")
 498:         stat_unexpected_failure(event_index=i, attempt=attempt_number, node=node, reason="dropped_after_retries_exception", payload={"tried_nodes": list(pending.tried_nodes)})
 499:         print(f"[DROP] {i:03} event dropped after retries")
 500:         return False
 501:     pending.retries_done += 1
 502:     stat_inc("queue_requeues")
 503:     enqueue_pending(pending, compute_retry_backoff(pending.retries_done))
 504:     return False
 505: 
 506: 
 507: def sender_worker(worker_id):
 508:     while True:
 509:         try:
 510:             run_at, _, pending = pending_queue.get(timeout=0.5)
 511:         except queue.Empty:
 512:             if is_producer_done() and pending_queue.empty():
 513:                 return
 514:             continue
 515:         now = time.time()
 516:         if run_at > now:
 517:             pending_queue.put((run_at, next_enqueue_seq(), pending))
 518:             pending_queue.task_done()
 519:             time.sleep(min(run_at - now, 0.2))
 520:             continue
 521:         try:
 522:             process_pending_event(pending)
 523:         finally:
 524:             pending_queue.task_done()
 525: 
 526: 
 527: def chaos_loop():
 528:     for i in range(EVENTS):
 529:         if random.random() < KILL_PROBABILITY:
 530:             node = SLEEP_ONLY_NODE if SLEEP_ONLY_NODE else random.choice(NODES)
 531:             seconds = random.uniform(*DEATH_TIME_RANGE)
 532:             t = threading.Thread(target=kill_cycle, args=(node, seconds), daemon=True)
 533:             t.start()
 534:             kill_threads.append(t)
 535:         stat_inc("events_total")
 536:         pending = PendingEvent(event_index=i, event=build_event(i))
 537:         enqueue_pending(pending, delay_seconds=0.0)
 538:         time.sleep(random.uniform(*EVENT_DELAY_RANGE))
 539:     mark_producer_done()
 540: 
 541: 
 542: def revive_everything():
 543:     print("
 544: [MAIN] REVIVING ALL NODES
 545: ")
 546:     unique_nodes = sorted(set(NODES))
 547:     for node in unique_nodes:
 548:         try:
 549:             requests.post(f"{node}/revive", timeout=2)
 550:             print(f"[FORCE REVIVE] {node}")
 551:         except Exception as e:
 552:             print(f"[FORCE REVIVE FAIL] {node} -> {e}")
 553: 
 554: 
 555: def wait_kills():
 556:     print("
 557: [MAIN] waiting active kill cycles...
 558: ")
 559:     for t in kill_threads:
 560:         t.join(timeout=30)
 561: 
 562: 
 563: def wait_queue_drain():
 564:     deadline = time.time() + DRAIN_TIMEOUT
 565:     while time.time() < deadline:
 566:         if pending_queue.empty():
 567:             time.sleep(0.5)
 568:             if pending_queue.empty():
 569:                 return True
 570:         time.sleep(0.2)
 571:     return False
 572: 
 573: 
