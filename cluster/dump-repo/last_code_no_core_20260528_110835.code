 120: kill_threads = []
 121: dead_nodes = set()
 122: dead_lock = threading.Lock()
 123: stats_lock = threading.Lock()
 124: producer_done_lock = threading.Lock()
 125: enqueue_seq_lock = threading.Lock()
 126: pending_queue = queue.PriorityQueue()
 127: producer_done = False
 128: enqueue_seq = 0
 129: worker_sessions = {}
 130: worker_sessions_lock = threading.Lock()
 131: results_lock = threading.Lock()
 132: results = []
