   1: from __future__ import annotations
   2: 
   3: from dataclasses import dataclass, field
   4: from enum import Enum
   5: from typing import Any, Optional
   6: from uuid import uuid4
   7: import time
   8: 
   9: 
  10: class EventStatus(str, Enum):
  11:     CREATED = "created"
  12:     EXECUTING = "executing"
  13:     COMPLETED = "completed"
  14:     FAILED = "failed"
  15: 
  16: 
  17: class NodeState(str, Enum):
  18:     BOOT = "BOOT"
  19:     DISCOVERING = "DISCOVERING"
  20:     STANDBY = "STAND-BY"
  21:     ACTIVE = "ACTIVE"
  22:     DRAINING = "DRAINING"
  23:     SEGMENTATION = "SEGMENTATION"
  24:     ISOLATED = "ISOLATED"
  25:     OFFLINE = "OFFLINE"
  26: 
  27: 
  28: @dataclass(frozen=True, slots=True)
  29: class StreamKey:
  30:     tenant_id: str
  31:     app_id: str
  32:     data_type: str
  33:     schema_version: str = "v1"
  34: 
  35:     def stream_id(self) -> str:
  36:         return f"{self.tenant_id}.{self.app_id}.{self.data_type}.{self.schema_version}"
  37: 
  38:     def path_parts(self) -> list[str]:
  39:         return [self.tenant_id, self.app_id, self.data_type, self.schema_version]
  40: 
  41: 
  42: @dataclass(slots=True)
  43: class EventEnvelope:
  44:     stream: StreamKey
  45:     event_type: str
  46:     payload: dict[str, Any] = field(default_factory=dict)
  47:     event_id: str = field(default_factory=lambda: str(uuid4()))
  48:     trace_id: str = field(default_factory=lambda: str(uuid4()))
  49:     status: EventStatus = EventStatus.CREATED
  50:     route_hops: list[str] = field(default_factory=list)
  51:     source_node: Optional[str] = None
  52:     target_node: Optional[str] = None
  53:     execution_key: Optional[str] = None
  54:     created_at: float = field(default_factory=time.time)
  55:     updated_at: float = field(default_factory=time.time)
  56:     received_at: Optional[float] = None
  57:     attempt: int = 0
  58: 
  59:     def add_hop(self, hop: str) -> None:
  60:         self.route_hops.append(hop)
  61:         self.updated_at = time.time()
  62: 
  63:     def mark_status(self, status: EventStatus) -> None:
  64:         self.status = status
  65:         self.updated_at = time.time()
  66: 
  67:     def mark_received(self) -> None:
  68:         self.received_at = time.time()
  69:         self.updated_at = self.received_at
  70: 
  71: 
  72: @dataclass(slots=True)
  73: class SegmentMeta:
  74:     stream: StreamKey
  75:     segment_id: str
  76:     created_at: float = field(default_factory=time.time)
  77:     sealed_at: Optional[float] = None
  78:     first_event_id: Optional[str] = None
  79:     last_event_id: Optional[str] = None
  80:     min_seq: Optional[int] = None
  81:     max_seq: Optional[int] = None
  82:     event_count: int = 0
  83:     size_bytes: int = 0
  84:     sha256: Optional[str] = None
  85:     sealed: bool = False
  86:     dirty: bool = True
  87:     node_id: Optional[str] = None
  88:     file_name: Optional[str] = None
  89: 
  90:     def seal(self, sha256: str, size_bytes: int) -> None:
  91:         self.sealed = True
  92:         self.dirty = False
  93:         self.sealed_at = time.time()
  94:         self.sha256 = sha256
  95:         self.size_bytes = size_bytes
  96: 
  97: 
  98: @dataclass(slots=True)
  99: class NodeRuntimeState:
 100:     node_id: str
 101:     state: NodeState
 102:     priority: int
 103:     last_seen: float = field(default_factory=time.time)
 104:     log_meta: dict[str, Any] = field(default_factory=dict)
 105:     cluster_integrity: dict[str, Any] = field(default_factory=dict)
 106:     active_streams: dict[str, dict[str, Any]] = field(default_factory=dict)
 107: 
 108:     def touch(self) -> None:
 109:         self.last_seen = time.time()
 110: 
 111: 
 112: @dataclass(slots=True)
 113: class HeartbeatState:
 114:     node_id: str
 115:     state: str
 116:     priority: int
 117:     ts: float = field(default_factory=time.time)
 118:     log_meta: dict[str, Any] = field(default_factory=dict)
 119:     cluster_integrity: dict[str, Any] = field(default_factory=dict)
 120:     streams: dict[str, dict[str, Any]] = field(default_factory=dict)
 121: 
 122:     def to_record(self) -> dict[str, Any]:
 123:         return {
 124:             "node_id": self.node_id,
 125:             "state": self.state,
 126:             "priority": self.priority,
 127:             "ts": self.ts,
 128:             "log_meta": self.log_meta,
 129:             "cluster_integrity": self.cluster_integrity,
 130:             "streams": self.streams,
 131:         }



===== ./runtime/reconciler/reconciler_loop.py =====
   1: import logging
   2: import time
   3: from collections import defaultdict
   4: 
   5: from cluster.utils.log_print import log_state
   6: 
   7: from cluster.runtime.event_log import load_events, append_event
   8: from cluster.runtime.events.cluster_event import ClusterEvent
   9: from cluster.runtime.events.event_state import EventStatus
  10: 
  11: logger = logging.getLogger(__name__)
  12: EXECUTION_TIMEOUT = 10.0
  13: 
  14: 
  15: def _event_ts(e):
  16:     return e.get("updated_at") or e.get("created_at") or 0
  17: 
  18: 
  19: def reconcile_tick(node_runtime):
  20:     events = load_events() or []
  21:     now = time.time()
  22: 
  23:     by_id = defaultdict(list)
  24:     for e in events:
  25:         eid = e.get("event_id")
  26:         if not eid:
  27:             continue
  28:         by_id[eid].append(e)
  29: 
  30:     dirty_ids = []
  31:     for eid, history in by_id.items():
  32:         history.sort(key=_event_ts)
  33:         latest = history[-1]
  34:         if latest.get("status") not in (EventStatus.COMPLETED.value, EventStatus.FAILED.value):
  35:             dirty_ids.append(eid)
  36: 
  37:     if not dirty_ids:
  38:         return
  39: 
  40:     logger.debug("RECONCILER dirty_ids=%s", dirty_ids)
  41: 
  42:     for eid in dirty_ids:
  43:         history = by_id[eid]
  44:         latest = history[-1]
  45:         latest_status = latest.get("status")
  46: 
  47:         logger.debug("EVENT_ID=%s latest=%s len=%s", eid, latest_status, len(history))
  48: 
  49:         if latest_status == EventStatus.EXECUTING.value:
  50:             last_update = latest.get("updated_at") or latest.get("created_at") or 0
  51:             if now - last_update > EXECUTION_TIMEOUT:
  52:                 msg = latest.get("payload", {}).get("msg", "")
  53:                 logger.warning("RECOVERY EXECUTING STUCK -> CREATED event_id=%s", eid)
  54:                 log_state("yellow", "(EVENT)", f"{msg:12} -> RE-CREATED", 3)
  55:                 recovered = dict(latest)
  56:                 recovered["status"] = EventStatus.CREATED.value
  57:                 recovered["updated_at"] = now
  58:                 recovered["target_node"] = None
  59:                 recovered["execution_key"] = None
  60:                 recovered["attempt"] = 0
  61:                 recovered["route_hops"] = []
  62:                 recovered.pop("owner", None)
  63:                 append_event(ClusterEvent(**recovered))



===== ./runtime/replication.py =====
   1: import logging
   2: import os
   3: import time
   4: from pathlib import Path
   5: 
   6: import requests
   7: 
   8: from cluster.runtime import context as ctx
   9: from cluster.runtime.cluster_store import cluster_state
  10: from cluster.runtime.registry import CLUSTER_REGISTRY
  11: from cluster.runtime.event_log import (
  12:     DATA_DIR,
  13:     ensure_dir,
  14:     get_replica_log_path,
  15:     write_text_atomic,
  16:     clear_events_dirty_state,
  17: )
  18: from cluster.utils.log_print import log_state
  19: 
  20: logging.getLogger("urllib3").setLevel(logging.ERROR)
  21: logging.getLogger("requests").setLevel(logging.ERROR)
  22: 
  23: PEERALIVETTLSEC = 3.0
  24: 
  25: 
  26: def read_log_file(path: str) -> str:
  27:     p = Path(path)
  28:     if not p.exists():
  29:         return ""
  30:     return p.read_text(encoding="utf-8")
  31: 
  32: 
  33: def basename(path_or_name: str) -> str:
  34:     return os.path.basename(path_or_name)
  35: 
  36: 
  37: def base_prefix(local_filename: str) -> str:
  38:     name = basename(local_filename)
  39:     if name.endswith(".local.000.jsonl"):
  40:         return name[: -len(".local.000.jsonl")]
  41:     if name.endswith(".000.jsonl"):
  42:         return name[: -len(".000.jsonl")]
  43:     return name
  44: 
  45: 
  46: def replica_name(base: str, node_id: str) -> str:
  47:     return f"{base}.{node_id}.000.jsonl"
  48: 
  49: 
  50: def canonical_replica_node_id() -> str:
  51:     return ctx.node_id
  52: 
  53: 
  54: def alive_peer_ids():
  55:     out = []
  56:     now = time.time()
  57:     for node_id, data in cluster_state.items():
  58:         if node_id == ctx.node_id:
  59:             continue
  60:         if now - data.get("last_seen", 0) > PEERALIVETTLSEC:
  61:             continue
  62:         out.append(node_id)
  63:     return sorted(set(out))
  64: 
  65: 
  66: def configured_peer_ids():
  67:     out = []
  68: 
  69:     for peer in getattr(ctx, "peers", []) or []:
  70:         peer_id = peer.get("node_id")
  71:         if peer_id and peer_id != ctx.node_id:
  72:             out.append(peer_id)
  73: 
  74:     for node_id in CLUSTER_REGISTRY.keys():
  75:         if node_id != ctx.node_id:
  76:             out.append(node_id)
  77: 
  78:     return sorted(set(out))
  79: 
  80: 
  81: def target_peer_ids():
  82:     alive = alive_peer_ids()
  83:     configured = configured_peer_ids()
  84:     return sorted(set(alive) | set(configured))
  85: 
  86: 
  87: def replicate_file(local_filename: str, node_id: str) -> bool:
  88: 
  89:     source_path = str(DATA_DIR / local_filename)
  90:     content = read_log_file(source_path)
  91:     if not content.strip():
  92:         log_state("yellow", "REPL SKIP", f"file={local_filename} empty content", 3)
  93:         return False
  94: 
  95:     base = base_prefix(local_filename)
  96:     replica_filename = replica_name(base, node_id)
  97:     ensure_dir()
  98:     write_text_atomic(get_replica_log_path(node_id), content) if base == "event_log" else write_text_atomic(str(DATA_DIR / replica_filename), content)
  99:     log_state("cyan", "REPL SELF", f"{node_id} file={local_filename} bytes={len(content)}", 3)
 100: 
 101:     peers = target_peer_ids()
 102:     log_state("cyan", "REPL PEERS", f"file={local_filename} peers={peers}", 3)
 103: 
 104:     success = True
 105: 
 106:     for peer_id in peers:
 107:         node = CLUSTER_REGISTRY.get(peer_id)
 108:         if not node:
 109:             log_state("red", "LOG REPL FAIL", f"{peer_id} missing registry file={local_filename}", 3)
 110:             success = False
 111:             continue
 112: 
 113:         url = f"http://{node['host']}:{node['port']}/debug/events/replica/{node_id}"
 114:         log_state("cyan", "REPL POST", f"peer={peer_id} url={url} file={local_filename}", 3)
 115: 
 116:         try:
 117:             resp = requests.post(
 118:                 url,
 119:                 data=content.encode("utf-8"),
 120:                 headers={"Content-Type": "text/plain; charset=utf-8"},
 121:                 timeout=2,
 122:             )
 123: 
 124:             if resp.ok:
 125:                 log_state("cyan", "LOG REPL", f"{node_id} -> {peer_id}", 3)
 126:             else:
 127:                 success = False
 128:                 log_state("red", "LOG REPL FAIL", f"{peer_id} status={resp.status_code}", 3)
 129: 
 130:         except Exception as e:
 131:             success = False
 132:             log_state("red", "LOG REPL FAIL", f"{peer_id} err={e}", 3)
 133: 
 134:     if success:
 135:         clear_events_dirty_state()
 136:         log_state("cyan", "REPL CLEAR", "dirty=false", 3)



