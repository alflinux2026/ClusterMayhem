  14:     {"name": "lnx202pc", "host": "100.100.1.202", "user": "alftorres", "password": "alftorres", "port": 22, "api_port": 7000},
  15:     {"name": "lnx203hp", "host": "100.100.1.203", "user": "alftorres", "password": "alftorres", "port": 22, "api_port": 7000},
  16: ]
  17: 
  18: REMOTE_DIRS = {
  19:     "lnx200nas": "/home/alftorres/projects/mayhem-cluster/cluster/data",
  20:     "lnx202pc": "/home/alftorres/projects/mayhem-cluster/cluster/data",
  21:     "lnx203hp": "/home/alftorres/projects/Mayhem_runtime_oneshot/cluster/data",
  22: }
