 565: def write_csv_and_json():
 566:     with results_lock:
 567:         rows = list(results)
 568:     with open(EVENTS_CSV, "w", newline="", encoding="utf-8") as f:
 569:         writer = csv.DictWriter(f, fieldnames=["event_index", "attempt", "node", "status_code", "elapsed_ms", "leader", "result", "final"])
 570:         writer.writeheader()
 571:         for r in rows:
 572:             writer.writerow(r)
 573:     with stats_lock:
 574:         total = stats["events_total"]
 575:         ok = stats["events_ok"]
 576:         failed = stats["events_failed"]
 577:         success_rate = ((ok / total) * 100) if total else 0
 578:         avg_latency = (sum(stats["latency"]) / len(stats["latency"])) if stats["latency"] else 0
 579:         max_latency = max(stats["latency"]) if stats["latency"] else 0
 580:         min_latency = min(stats["latency"]) if stats["latency"] else 0
 581:         p50_latency = percentile(stats["latency"], 50)
 582:         p95_latency = percentile(stats["latency"], 95)
 583:         p99_latency = percentile(stats["latency"], 99)
 584:         report = {
 585:             "test_config": TEST_CONFIG,
 586:             "run_meta": {"started_at_epoch": TEST_STARTED_AT, "ended_at_epoch": time.time(), "started_at_iso": datetime.fromtimestamp(TEST_STARTED_AT).isoformat(), "ended_at_iso": datetime.now().isoformat(), "duration_seconds": round(time.time() - TEST_STARTED_AT, 3)},
 587:             "stats": {**stats, "success_rate": round(success_rate, 2), "latency_avg": round(avg_latency, 3), "latency_min": round(min_latency, 3), "latency_p50": round(p50_latency, 3), "latency_p95": round(p95_latency, 3), "latency_p99": round(p99_latency, 3), "latency_max": round(max_latency, 3), "per_node_ok": dict(stats["per_node_ok"]), "per_node_fail": dict(stats["per_node_fail"]), "leaders_seen": dict(stats["leaders_seen"]), "results_csv": str(EVENTS_CSV)},
 588:         }
 589:     with open(STATS_FILE, "w", encoding="utf-8") as f:
 590:         json.dump(report, f, indent=2, ensure_ascii=False)
 591: 
