  29: LINE_RE = re.compile(
  30:     r"^(?P<perm>\S+)\s+"
  31:     r"(?P<links>\d+)\s+"
  32:     r"(?P<owner>\S+)\s+"
  33:     r"(?P<group>\S+)\s+"
