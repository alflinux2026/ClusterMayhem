===== ./_lease/lease.py =====
   1: from dataclasses import dataclass
   2: import time
   3: 
   4: 
   5: @dataclass
   6: class Lease:
   7:     owner_id: str
   8:     ttl_seconds: float
   9:     granted_at: float
  10: 
  11:     def expires_at(self) -> float:
  12:         return self.granted_at + self.ttl_seconds
  13: 
  14:     def is_valid(self, now: float | None = None) -> bool:
  15:         now = now or time.time()
  16:         return now < self.expires_at()
  17: 
  18:     def renew(self):
  19:         self.granted_at = time.time()



===== ./_lease/lease_manager.py =====
   1: import time
   2: 
   3: 
   4: class Lease:
   5: 
   6:     def __init__(self, owner, ttl):
   7: 
   8:         self.owner = owner
   9:         self.ttl = ttl
  10:         self.created = time.time()
  11: 
  12:     def is_valid(self):
  13: 
  14:         return time.time() < self.created + self.ttl
  15: 
  16: 
  17: class LeaseManager:
  18: 
  19:     def __init__(self):
  20: 
  21:         self.leases = {}
  22: 
  23:     # -----------------------------------------------------
  24: 
  25:     def grant(self, node_id, ttl):
  26: 
  27:         self.leases[node_id] = Lease(node_id, ttl)
  28: 
  29:     # -----------------------------------------------------
  30: 
  31:     def is_valid(self, node_id):
  32: 
  33:         lease = self.leases.get(node_id)
  34: 
  35:         return lease.is_valid() if lease else False
  36: 
  37:     # -----------------------------------------------------
  38: 
  39:     def expire(self):
  40: 
  41:         expired = []
  42: 
  43:         for node_id, lease in list(self.leases.items()):
  44: 
  45:             if not lease.is_valid():
  46: 
  47:                 expired.append(node_id)
  48:                 del self.leases[node_id]
  49: 
  50:         return expired
  51: 
  52:     # -----------------------------------------------------
  53: 
  54:     def active_leader(self):
  55: 
  56:         for node_id, lease in self.leases.items():
  57: 
  58:             if lease.is_valid():
  59: 
  60:                 return node_id
  61: 
  62:         return None
  63: 
  64:     # -----------------------------------------------------
  65: 
  66:     def get_active_nodes(self):
  67: 
  68:         active = []
  69: 
  70:         for node_id, lease in self.leases.items():
  71: 
  72:             if lease.is_valid():
  73: 
  74:                 active.append(node_id)
  75: 
  76:         return active



