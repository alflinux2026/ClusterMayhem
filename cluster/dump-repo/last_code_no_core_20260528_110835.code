 521:         max_latency = max(stats["latency"]) if stats["latency"] else 0
 522:         min_latency = min(stats["latency"]) if stats["latency"] else 0
 523:         p50_latency = percentile(stats["latency"], 50)
 524:         p95_latency = percentile(stats["latency"], 95)
 525:         p99_latency = percentile(stats["latency"], 99)
