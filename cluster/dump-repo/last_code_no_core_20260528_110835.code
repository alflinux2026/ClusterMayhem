 624: def main():
 625:     print("[MAIN] starting UNIVERSAL chaos torture final")
 626:     print_test_config()
 627:     workers = []
 628:     for idx in range(SEND_WORKERS):
 629:         t = threading.Thread(target=sender_worker, args=(idx,), daemon=True)
 630:         t.start()
 631:         workers.append(t)
 632:     drained = False
 633:     try:
 634:         chaos_loop()
 635:         drained = wait_queue_drain()
 636:         pending_queue.join()
 637:         for t in workers:
 638:             t.join(timeout=5)
 639:     finally:
 640:         wait_kills()
 641:         revive_everything()
 642:         if not drained:
 643:             print(f"
 644: [MAIN WARN] queue drain timeout reached after {DRAIN_TIMEOUT:.1f}s
 645: ")
 646:         write_csv_and_json()
 647:         print_stats()
 648:         print("
 649: [MAIN] cluster restored
 650: ")
 651: 
