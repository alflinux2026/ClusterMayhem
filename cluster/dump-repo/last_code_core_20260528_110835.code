  21: def _update_node_events_cache(event: ClusterEvent, status: str):
  22:     node_id = getattr(event, "source_node", None) or getattr(event, "target_node", None)
  23:     if not node_id:
  24:         return
  25: 
  26:     node = cluster_state.get(node_id, {}) or {}
  27:     streams = dict(node.get("streams", {}) or {})
  28: 
  29:     local_summary = streams.get("events_summary_local", {}) or {}
  30:     local_summary["last_event_id"] = event.event_id
  31:     local_summary["counts"] = dict(local_summary.get("counts", {}) or {})
  32:     local_summary["total_events"] = int(local_summary.get("total_events", 0)) + 1
  33:     local_summary["counts"][status] = int(local_summary["counts"].get(status, 0)) + 1
  34: 
  35:     streams["events_summary_local"] = local_summary
  36:     node["streams"] = streams
  37:     cluster_state[node_id] = node
  38: 
  39: def get_integrity_canonical() -> dict:
  40:     state = read_state()
  41:     return {
  42:         "log_size": os.path.getsize(LOCAL_LOG_PATH) if LOCAL_LOG_PATH.exists() else 0,
  43:         "file_size": os.path.getsize(LOCAL_LOG_PATH) if LOCAL_LOG_PATH.exists() else 0,
  44:         "last_append_event_id": state.get("last_append_event_id"),
  45:         "last_append_created_at": state.get("last_append_created_at"),
  46:     }
  47: 
  48: 
  49: def ensure_dir():
  50:     DATA_DIR.mkdir(parents=True, exist_ok=True)
  51: 
  52: 
  53: def ensure_initial_files():
  54:     ensure_dir()
  55: 
  56:     if not STATE_PATH.exists():
  57:         write_state({
  58:             "dirty": True,
  59:             "events_dirty": True,
  60:             "last_append_event_id": None,
  61:             "last_append_created_at": None,
  62:             "last_append_updated_at": None,
  63:             "last_completed_event_id": None,
  64:             "last_completed_created_at": None,
  65:             "last_completed_updated_at": None,
  66:         })
  67: 
  68:     if not LOCAL_LOG_PATH.exists():
  69:         LOCAL_LOG_PATH.touch()
  70: 
  71:     if not COMPLETED_LOG_PATH.exists():
  72:         COMPLETED_LOG_PATH.touch()
