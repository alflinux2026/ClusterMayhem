 155: def _read_jsonl(path: str) -> list[dict]:
 156:     if not os.path.exists(path):
 157:         return []
 158:     out: list[dict] = []
 159:     with open(path, "r", encoding="utf-8") as f:
 160:         for line in f:
 161:             line = line.strip()
 162:             if not line:
 163:                 continue
 164:             try:
 165:                 out.append(json.loads(line))
 166:             except Exception:
 167:                 continue
 168:     return out
 169: 
 170: 
 171: def _summarize_events(events: list[dict]) -> dict:
 172:     latest_by_event_id: dict[str, dict] = {}
 173:     last_event_id = None
 174:     for event in events:
 175:         event_id = event.get("event_id")
 176:         if not event_id:
 177:             continue
 178:         latest_by_event_id[event_id] = event
 179:         last_event_id = event_id
 180:     counts = Counter()
 181:     for event in latest_by_event_id.values():
 182:         status = str(event.get("status", "unknown")).lower()
 183:         counts[status] += 1
 184:     return {
 185:         "total_events": len(latest_by_event_id),
 186:         "counts": {
 187:             "created": counts.get("created", 0),
 188:             "executing": counts.get("executing", 0),
 189:             "completed": counts.get("completed", 0),
 190:             "unknown": counts.get("unknown", 0),
 191:         },
 192:         "last_event_id": last_event_id,
 193:     }
 194: 
 195: 
 196: def _next_rotation_index(base_dir, stem, suffix=".jsonl"):
 197:     base_dir = Path(base_dir)
 198:     idx = 1
 199:     while True:
 200:         candidate = base_dir / f"{stem}.{idx:03d}{suffix}"
 201:         if not candidate.exists():
 202:             return idx
 203:         idx += 1
 204: 
 205: 
 206: def rotate_segment_files(target_group: str, segment: str = "000", files=None, force: bool = False):
 207:     files = files or ["events", "event_log"]
 208:     base_dir = Path(get_local_log_path(None)).resolve().parent
 209:     result = {}
 210: 
 211:     for kind in files:
 212:         src = base_dir / f"{kind}.local.{segment}.jsonl"
 213:         if not src.exists():
 214:             if force:
 215:                 result[kind] = {"before": str(src), "after": None, "index": None, "forced": True}
 216:                 continue
 217:             raise FileNotFoundError(str(src))
 218: 
 219:         idx = _next_rotation_index(base_dir, f"{kind}.{target_group}")
 220:         dst = base_dir / f"{kind}.{target_group}.{idx:03d}.jsonl"
 221:         os.replace(str(src), str(dst))
 222:         result[kind] = {"before": str(src), "after": str(dst), "index": idx, "forced": False}
 223: 
 224:     return result
 225: 
 226: 
 227: def cleanup_local_segment_files(target_group: str, segment: str = "000", files=None):
 228:     files = files or ["events", "event_log"]
 229:     base_dir = Path(get_local_log_path(None)).resolve().parent
 230:     removed = []
 231:     already_gone = []
 232: 
 233:     for kind in files:
 234:         p = base_dir / f"{kind}.local.{segment}.jsonl"
 235:         if p.exists():
 236:             p.unlink()
 237:             removed.append(str(p))
 238:         else:
 239:             already_gone.append(str(p))
 240: 
 241:     return {"target_group": target_group, "segment": segment, "removed": removed, "already_gone": already_gone}
