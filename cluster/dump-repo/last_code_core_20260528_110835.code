  36: def _node_id(node):
  37:     if isinstance(node, dict):
  38:         return node.get("node_id", "?")
  39:     return getattr(node, "node_id", "?")
  40: 
  41: 
  42: def rebuild_node_event_cache(node_id: str):
  43:     if not isinstance(node_id, str):
  44:         node_id = getattr(node_id, "node_id", None)
  45: 
  46:     if not node_id:
  47:         log_state("red", "CACHE_BOOTSTRAP", "invalid node_id for event cache bootstrap", 3)
  48:         return
  49: 
  50:     node = cluster_state.get(node_id, {}) or {}
  51:     if not isinstance(node, dict):
  52:         node = {}
  53: 
  54:     streams = dict(node.get("streams", {}) or {})
  55: 
  56:     local_events = load_events() or []
  57:     completed_events = []
  58:     try:
  59:         completed_events = load_completed_events() or []
  60:     except Exception as e:
  61:         log_state("red", "CACHE_BOOTSTRAP", f"{node_id} completed_load_failed={e}", 3)
  62: 
  63:     created_events = [e for e in local_events if e.get("status") == EventStatus.CREATED.value]
  64:     executing_events = [e for e in local_events if e.get("status") == EventStatus.EXECUTING.value]
  65: 
  66:     streams["events_summary_local"] = _summarize_events(local_events)
  67:     streams["events_summary_created"] = _summarize_events(created_events)
  68:     streams["events_summary_executing"] = _summarize_events(executing_events)
  69:     streams["events_summary_completed"] = _summarize_events(completed_events)
  70: 
  71:     node["node_id"] = node_id
  72:     node["streams"] = streams
  73:     cluster_state[node_id] = node
  74: 
  75: #    compute_leader()
  76: 
  77:     log_state("blue", "NODE STATE a", f"{_node_id(node)} local={len(local_events)} created={len(created_events)} executing={len(executing_events)} completed={len(completed_events)}", 3)
  78: 
  79: 
  80: def _node_streams(node):
  81:     if isinstance(node, dict):
  82:         return node.get("streams", {}) or {}
  83:     return getattr(node, "streams", {}) or {}
  84: 
  85: 
  86: def _node_event_counters(node) -> tuple[int, int, int, int]:
  87:     cache = _node_cache(node)
  88:     streams = cache.get("streams", {}) or {}
  89:     summary = streams.get("events_summary_local", {}) or {}
  90:     counts = summary.get("counts", {}) or {}
  91:     created = int(counts.get("created", 0))
  92:     executing = int(counts.get("executing", 0))
  93:     completed = int(counts.get("completed", 0))
  94:     total = int(summary.get("total_events", created + executing + completed))
  95:     return created, executing, completed, total
  96: 
  97: 
  98: def _can_segment(node) -> bool:
  99:     created, executing, completed, total = _node_event_counters(node)
 100:     cache = _node_cache(node)
 101:     dirty = bool(cache.get("dirty", False))
 102:     #log_state("yellow", "_can_segment", f"{created} --- {executing} --- {dirty} = {created == 0 and executing == 0 and not dirty}")
 103:     return created == 0 and executing == 0 and not dirty
 104: 
 105: 
 106: def _should_enter_DRAINING(node) -> bool:
 107:     created, executing, completed, total = _node_event_counters(node)
 108:     #log_state("yellow", "_should_enter_DRAINING", f"{total} > {MAX_SEGMENT_COUNT}")
 109:     return total > MAX_SEGMENT_COUNT
 110: 
 111: 
 112: def _should_enter_segmentation(node) -> bool:
 113:     created, executing, completed, total = _node_event_counters(node)
 114: 
 115: #    return total > MAX_SEGMENT_COUNT and _can_segment(node)
 116:     can_segment = _can_segment(node)
 117:     #log_state("yellow", "_should_enter_segmentation", f"{total} > {MAX_SEGMENT_COUNT} --- {can_segment}")
 118:     return _can_segment(node)
 119: 
