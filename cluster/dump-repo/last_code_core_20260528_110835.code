 503: @app.get("/dashboard/compact")
 504: def dashboard_compact():
 505:     now = time.time()
 506:     leader = compute_leader()
 507:     local_events = events_summary()
 508:     integrity = local_integrity_api()
 509:     local_node = cluster_state.get(ctx.node_id, {}) or {}
 510: 
 511:     try:
 512:         from cluster.runtime.progress_watchdog import (
 513:             get_progress_age_s,
 514:             get_progress_duration_s,
 515:             get_progress_pct,
 516:             refresh_progress_stalled_flag,
 517:         )
 518:     except Exception:
 519:         get_progress_age_s = None
 520:         get_progress_duration_s = None
 521:         get_progress_pct = None
 522:         refresh_progress_stalled_flag = None
 523: 
 524:     nodes = []
 525:     for node_id, node in sorted(cluster_state.items(), key=lambda kv: str(kv[0])):
 526:         log_meta = node.get("log_meta", {}) or {}
 527:         counts = (((node.get("streams") or {}).get("events_summary_local") or {}).get("counts") or {})
 528:         progress_age_s = None
 529:         progress_duration_s = None
 530:         progress_pct = None
 531:         progress_stalled = bool(node.get("progress_stalled", False))
 532: 
 533:         if refresh_progress_stalled_flag is not None:
 534:             try:
 535:                 progress_stalled = bool(refresh_progress_stalled_flag(node_id=node_id, now=now))
 536:                 node = cluster_state.get(node_id, node) or node
 537:             except Exception:
 538:                 progress_stalled = bool(node.get("progress_stalled", False))
 539: 
 540:         if get_progress_age_s is not None:
 541:             try:
 542:                 progress_age_s = get_progress_age_s(node=node, now=now)
 543:             except Exception:
 544:                 progress_age_s = None
 545: 
 546:         if get_progress_duration_s is not None:
 547:             try:
 548:                 progress_duration_s = get_progress_duration_s(node=node, now=now)
 549:             except Exception:
 550:                 progress_duration_s = None
 551: 
 552:         if get_progress_pct is not None:
 553:             try:
 554:                 progress_pct = get_progress_pct(node=node)
 555:             except Exception:
 556:                 progress_pct = None
 557:         else:
 558:             try:
 559:                 current = node.get("progress_current")
 560:                 total = node.get("progress_total")
 561:                 if current is not None and total not in (None, 0):
 562:                     progress_pct = round((float(current) / float(total)) * 100.0, 1)
 563:             except Exception:
 564:                 progress_pct = None
 565: 
 566:         item = {
 567:             "node_id": node_id,
 568:             "state": node.get("state"),
 569:             "state_since": node.get("state_since"),
 570:             "state_age_s": round(_state_age_s(node, now) or 0.0, 1),
 571:             "prev_state": node.get("prev_state"),
 572:             "state_reason": node.get("state_reason"),
 573:             "priority": node.get("priority"),
 574:             "last_seen": node.get("last_seen"),
 575:             "seen_age_s": round(_seen_age_s(node, now) or 0.0, 1),
 576:             "last_watchdog": node.get("last_watchdog"),
 577:             "watchdog_age_s": round(_watchdog_age_s(node, now) or 0.0, 1) if node.get("last_watchdog") is not None else None,
 578:             "watchdog_busy": node.get("watchdog_busy"),
 579:             "presence_age_s": round(_presence_age_s(node, now) or 0.0, 1),
 580:             "health": _presence_health(node, now, stale_after_s=3.0),
 581:             "local_size": log_meta.get("size", 0),
 582:             "local_events": ((node.get("streams") or {}).get("events_summary_local") or {}).get("total_events", 0),
 583:             "created": counts.get("created", 0),
 584:             "executing": counts.get("executing", 0),
 585:             "completed": counts.get("completed", 0),
 586:             "dirty": ((node.get("cluster_integrity") or {}).get("last_append_meta") or {}).get("dirty"),
 587:             "progress_active": bool(node.get("progress_active", False)),
 588:             "progress_stage": node.get("progress_stage"),
 589:             "progress_started_at": node.get("progress_started_at"),
 590:             "progress_touched_at": node.get("progress_touched_at"),
 591:             "progress_age_s": round(progress_age_s, 1) if progress_age_s is not None else None,
 592:             "progress_duration_s": round(progress_duration_s, 1) if progress_duration_s is not None else None,
 593:             "progress_current": node.get("progress_current"),
 594:             "progress_total": node.get("progress_total"),
 595:             "progress_pct": progress_pct,
 596:             "progress_stalled": progress_stalled,
 597:             "progress_meta": node.get("progress_meta", {}) or {},
 598:         }
 599:         nodes.append(item)
 600: 
 601:     local_progress = {
 602:         "progress_active": bool(local_node.get("progress_active", False)),
 603:         "progress_stage": local_node.get("progress_stage"),
 604:         "progress_started_at": local_node.get("progress_started_at"),
 605:         "progress_touched_at": local_node.get("progress_touched_at"),
 606:         "progress_age_s": None,
 607:         "progress_duration_s": None,
 608:         "progress_current": local_node.get("progress_current"),
 609:         "progress_total": local_node.get("progress_total"),
 610:         "progress_pct": None,
 611:         "progress_stalled": bool(local_node.get("progress_stalled", False)),
 612:         "progress_meta": local_node.get("progress_meta", {}) or {},
 613:     }
 614: 
 615:     return {
 616:         "cluster": {
 617:             "node_id": ctx.node_id,
 618:             "leader": leader,
 619:             "generated_at": now,
 620:             "integrity_ok": bool(integrity.get("integrity_ok", True)),
 621:             "local_state": ctx.node.state.value,
 622:             "local_state_since": getattr(ctx.node, "state_since", None),
 623:             "local_state_age_s": round(_state_age_s({"state_since": getattr(ctx.node, "state_since", None)}, now) or 0.0, 1),
 624:         },
 625:         "local": {
 626:             "events_summary": local_events,
 627:             "integrity": integrity,
 628:             "progress": local_progress,
 629:         },
 630:         "nodes": nodes,
 631:     }
