 473: @app.post("/watchdog")
 474: def watchdog(wd: Watchdog):
 475:     if ctx.node.state == NodeState.ISOLATED:
 476:         return {"error": "node isolated"}
 477:     existing = cluster_state.get(wd.node_id, {})
 478:     ts = wd.emitted_at if wd.emitted_at is not None else time.time()
 479:     cluster_state[wd.node_id] = {**existing, "last_watchdog": ts, "watchdog_busy": bool(wd.busy)}
 480:     return {"ok": True, "node_id": wd.node_id, "last_watchdog": ts, "watchdog_busy": bool(wd.busy)}
 481: 
