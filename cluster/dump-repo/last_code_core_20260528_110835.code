  27: #def file_sha256(path: str | Path, block_size: int = 65536) -> str | None:
  28: #    path = str(path)
  29: #    if not os.path.exists(path):
  30: #        return None
  31: #    h = hashlib.sha256()
  32: #    with open(path, "rb") as f:
  33: #        while True:
  34: #            chunk = f.read(block_size)
  35: #            if not chunk:
  36: #                break
  37: #            h.update(chunk)
  38: #    return h.hexdigest()
  39: 
  40: 
  41: def canonicalize(obj: Any, ignored_keys: set[str] | None = None) -> Any:
  42:     ignored_keys = ignored_keys or set()
  43:     if isinstance(obj, dict):
  44:         return {
  45:             k: canonicalize(v, ignored_keys)
  46:             for k, v in sorted(obj.items())
  47:             if k not in ignored_keys
  48:         }
  49:     if isinstance(obj, list):
  50:         return [canonicalize(v, ignored_keys) for v in obj]
  51:     return obj
  52: 
  53: 
  54: def compare_views(a: dict, b: dict) -> bool:
  55:     return canonicalize(a, IGNORED_NODE_KEYS) == canonicalize(b, IGNORED_NODE_KEYS)
  56: 
  57: 
  58: #def log_meta_ok(local_meta: dict, peer_meta: dict) -> bool:
  59: #    return all(local_meta.get(k) == peer_meta.get(k) for k in INTEGRITY_KEYS)
  60: 
  61: 
  62: def _compact_view(view: dict) -> dict:
  63:     if not isinstance(view, dict):
  64:         return {}
  65:     return {
  66:         "state": view.get("state"),
  67:         "state_since": view.get("state_since"),
  68:         "prev_state": view.get("prev_state"),
  69:         "state_reason": view.get("state_reason"),
  70:         "priority": view.get("priority"),
  71:         "log_meta": view.get("log_meta", {}),
  72:         "streams": view.get("streams", {}),
  73:     }
  74: 
  75: 
  76: def local_integrity_api() -> dict:
  77:     #path = get_local_log_path()
  78:     alive = compute_alive(include_self=True)
  79: 
  80:     canonical = get_integrity_canonical()
  81:     integrity_hash = hashlib.sha256(
  82:         json.dumps(canonical, sort_keys=True).encode("utf-8")
  83:     ).hexdigest()
  84: 
  85:     peer_status = {}
  86:     self_view = canonicalize(cluster_state.get(ctx.node_id, {}), IGNORED_NODE_KEYS)
  87:     self_meta = self_view.get("log_meta", {}) if isinstance(self_view, dict) else {}
  88: 
  89:     for node_id, data in alive.items():
  90:         view = canonicalize(data, IGNORED_NODE_KEYS)
  91:         meta = view.get("log_meta", {}) if isinstance(view, dict) else {}
  92:         peer_status[node_id] = {
  93:             "view": _compact_view(view),
  94:             "view_ok": view == canonicalize(cluster_state.get(node_id, {}), IGNORED_NODE_KEYS),
  95:             #"log_meta_ok": log_meta_ok(self_meta, meta) if node_id == ctx.node_id else True,
  96:         }
  97: 
  98:     return {
  99:         "node_id": ctx.node_id,
 100:         "alive_nodes": sorted(alive.keys()),
 101:         "self_view": _compact_view(self_view),
 102:         "peer_status": peer_status,
 103:         "integrity_canonical": canonical,
 104:         "integrity_hash": integrity_hash,
 105:         "integrity_ok": all(v["view_ok"] for v in peer_status.values()),
 106:     }
 107: 
 108: 
 109: def cluster_integrity_report() -> dict:
 110:     alive = compute_alive(include_self=True)
 111:     reference = canonicalize(cluster_state, IGNORED_NODE_KEYS)
 112:     per_peer = {}
 113: 
 114:     for node_id, data in alive.items():
 115:         view = canonicalize(data, IGNORED_NODE_KEYS)
 116:         meta = view.get("log_meta", {}) if isinstance(view, dict) else {}
 117:         ref_view = reference.get(node_id, {})
 118:         ref_meta = ref_view.get("log_meta", {}) if isinstance(ref_view, dict) else {}
 119: 
 120:         per_peer[node_id] = {
 121:             "matches_reference": view == ref_view,
 122:             "matches_log_meta": meta == ref_meta,
 123:             "state": view.get("state"),
 124:             "state_since": view.get("state_since"),
 125:             "prev_state": view.get("prev_state"),
 126:             "state_reason": view.get("state_reason"),
 127:             "priority": view.get("priority"),
 128:             "streams": view.get("streams", {}),
 129:         }
 130: 
 131:     return {
 132:         "node_id": ctx.node_id,
 133:         "alive_nodes": sorted(alive.keys()),
 134:         "reference": {k: _compact_view(v) for k, v in reference.items()} if isinstance(reference, dict) else {},
 135:         "per_peer": per_peer,
 136:         "integrity_ok": all(v["matches_reference"] and v["matches_log_meta"] for v in per_peer.values()),
 137:     }



===== ./runtime/leader.py =====
   1: import time
   2: 
   3: from cluster.runtime.cluster_store import cluster_state
   4: from cluster.runtime import context as ctx
   5: 
   6: LEADER_ALIVE_TIMEOUT = 1.5
   7: 
   8: 
   9: def refresh_self_alive_entry(now=None):
  10:     now = now or time.time()
  11:     if not getattr(ctx, "node", None):
  12:         return
  13: 
  14:     existing = cluster_state.get(ctx.node_id, {})
  15: 
  16:     cluster_state[ctx.node_id] = {
  17:         **existing,
  18:         "state": ctx.node.state.value,
  19:         "priority": ctx.node.priority,
  20:         "last_seen": now,
  21:         "state_since": getattr(ctx.node, "state_since", None),
  22:         "prev_state": getattr(ctx.node, "prev_state", None),
  23:         "state_reason": getattr(ctx.node, "state_reason", None),
  24:     }
  25: 
  26: 
  27: def last_presence_ts(data: dict) -> float:
  28:     candidates = []
  29:     for key in ("last_seen", "last_watchdog"):
  30:         value = data.get(key, 0)
  31:         if value is None:
  32:             continue
  33:         try:
  34:             candidates.append(float(value))
  35:         except Exception:
  36:             continue
  37:     return max(candidates) if candidates else 0.0
  38: 
  39: 
  40: def is_alive(data, timeout=LEADER_ALIVE_TIMEOUT, now=None):
  41:     now = now or time.time()
  42:     last_presence = last_presence_ts(data)
  43:     return (now - last_presence) < timeout
  44: 
  45: 
  46: def compute_alive(timeout=LEADER_ALIVE_TIMEOUT, include_self=True):
  47:     now = time.time()
  48:     if include_self:
  49:         refresh_self_alive_entry(now)
  50: 
  51:     active_nodes = {}
  52:     for node_id, data in cluster_state.items():
  53:         if not is_alive(data, timeout=timeout, now=now):
  54:             continue
  55:         if data.get("state") not in ("ACTIVE", "STANDBY", "STAND-BY", "DRAINING"):
  56:             continue
  57:         active_nodes[node_id] = data
  58:     return active_nodes
  59: 
  60: 
  61: def compute_leader(debug_node_id=None, timeout=LEADER_ALIVE_TIMEOUT):
  62:     active_nodes = compute_alive(timeout=timeout, include_self=True)
  63:     if not active_nodes:
  64:         return None
  65:     return min(
  66:         active_nodes.items(),
  67:         key=lambda x: (x[1].get("priority", 9999), x[0]),
  68:     )[0]



