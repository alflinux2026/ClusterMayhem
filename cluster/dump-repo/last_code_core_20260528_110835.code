 394: @app.post("/event")
 395: def handle_event(event: ClusterEvent):
 396:     if ctx.node.state == NodeState.SEGMENTATION:
 397:         return {"error": "node SEGMENTATION"}
 398:     if ctx.node.state == NodeState.DRAINING:
 399:         return {"error": "node DRAINING"}
 400:     if ctx.node.state == NodeState.ISOLATED:
 401:         return {"error": "node ISOLATED"}
 402:     leader = compute_leader()
 403:     if not leader:
 404:         log_state("red", "(NO LEADER)", event.event_id, 3)
 405:         return {"error": "no leader"}
 406: 
 407:     if ctx.node.state == NodeState.STANDBY:
 408: 
 409:     #if leader != ctx.node_id:
 410:         msg = event.payload.get("msg", "<no-msg>")
 411:         log_state("cyan", "[EVENT FWD]", f"{msg:12} -> {leader}", 3)
 412:         node = CLUSTER_REGISTRY[leader]
 413:         url = f"http://{node['host']}:{node['port']}/event"
 414:         try:
 415:             resp = requests.post(url, json=event.model_dump(), timeout=2)
 416:             return resp.json()
 417:         except Exception as e:
 418:             return {"error": str(e)}
 419: 
 420:     result = ingest_event(event, ctx.node_id)
 421:     return {"status": "ok", "event_id": event.event_id, "result": result}
