  15: 
  16: IGNORED_NODE_KEYS = {"last_seen"}
  17: #INTEGRITY_KEYS = (
  18: #    "dirty",
  19: #    "last_append_event_id",
  20: #    "last_append_created_at",
  21: #    "log_size",
  22: #    "file_size",
