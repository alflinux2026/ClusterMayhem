 483: @app.post("/heartbeat")
 484: def heartbeat(hb: Heartbeat):
 485:     if ctx.node.state == NodeState.ISOLATED:
 486:         return {"error": "node isolated"}
 487:     existing = cluster_state.get(hb.node_id, {})
 488:     cluster_state[hb.node_id] = {
 489:         **existing,
 490:         "state": hb.state,
 491:         "priority": hb.priority,
 492:         "last_seen": time.time(),
 493:         "state_since": hb.state_since if hb.state_since is not None else existing.get("state_since"),
 494:         "prev_state": hb.prev_state if hb.prev_state is not None else existing.get("prev_state"),
 495:         "state_reason": hb.state_reason if hb.state_reason is not None else existing.get("state_reason"),
 496:         "log_meta": hb.log_meta or existing.get("log_meta", {}),
 497:         "cluster_integrity": hb.cluster_integrity or existing.get("cluster_integrity", {}),
 498:         "streams": hb.streams or existing.get("streams", {}),
 499:     }
 500:     return {"ok": True}
