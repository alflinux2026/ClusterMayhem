 113: def load_events_from_path(path: str) -> List[dict]:
 114:     if not os.path.exists(path):
 115:         return []
 116: 
 117:     events = []
 118:     with open(path, "r", encoding="utf-8") as f:
 119:         for line in f:
 120:             line = line.strip()
 121:             if not line:
 122:                 continue
 123:             try:
 124:                 events.append(json.loads(line))
 125:             except json.JSONDecodeError:
 126:                 continue
 127:     return events
