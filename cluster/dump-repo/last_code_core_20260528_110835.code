   1: 
   2: import time
   3: import requests
   4: 
   5: from cluster.runtime.state import NodeState, ensure_state_meta, transition_node_state
   6: from cluster.runtime.leader import compute_leader
   7: from cluster.utils.log_print import log_state
   8: 
   9: 
  10: class NodeRuntime:
  11:     def __init__(self, node_id, priority):
  12:         self.node_id = node_id
  13:         self.priority = priority
  14:         self.state = NodeState.BOOT
  15:         self.last_heartbeat = time.time()
  16: 
  17:         ensure_state_meta(self)
  18:         self.state_reason = "node_init"
  19: 
  20:     def transition(self, new_state, reason=None):
  21:         result = transition_node_state(self, new_state, reason=reason)
  22: 
  23:         if result["changed"]:
  24:             print(
  25:                 f"[{self.node_id}] "
  26:                 f"{result['old_state']} -> {result['new_state']} "
  27:                 f"(reason={result['state_reason']})"
  28:             )
  29: 
  30:         return result
  31: 
  32:     def tick(self):
  33: #        if self.state == NodeState.BOOT:
  34: #            self.transition(NodeState.STANDBY, reason="boot_complete")
  35: #            return
  36: 
  37:         #log_state("yellow", "[NodeRunTime tick]", f"[{self.node_id}] ticking ...", 3)
  38: 
  39:         leader = compute_leader()
  40: 
  41:         if leader == self.node_id:
  42:             if self.state == NodeState.STANDBY:
  43:                 log_state("yellow", "[CLUSTER]", f"[{self.node_id}] becoming ACTIVE", 3)
  44:                 self.transition(NodeState.ACTIVE, reason="leader_selected")
  45:         else:
  46:             if self.state == NodeState.ACTIVE:
  47:                 log_state("yellow", "[CLUSTER]", f"[{self.node_id}] becoming STANDBY", 3)
  48:                 self.transition(NodeState.STANDBY, reason="leader_lost")
  49: 
  50:     def emit_heartbeat(self, peers):
  51:         hb = {
  52:             "node_id": self.node_id,
  53:             "state": self.state.value,
  54:             "priority": self.priority,
  55:             "state_since": getattr(self, "state_since", None),
  56:             "prev_state": getattr(self, "prev_state", None),
  57:             "state_reason": getattr(self, "state_reason", None),
  58:         }
  59: 
  60:         for peer in peers:
  61:             url = f"http://{peer['host']}:{peer['port']}/heartbeat"
  62:             try:
  63:                 requests.post(url, json=hb, timeout=2)
  64:             except requests.exceptions.RequestException:
  65:                 pass



