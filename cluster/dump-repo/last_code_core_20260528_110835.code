===== ./runtime/state.py =====
   1: # state.py
   2: import time
   3: from enum import Enum
   4: 
   5: 
   6: class NodeState(str, Enum):
   7:     BOOT = "BOOT"
   8:     DISCOVERING = "DISCOVERING"
   9:     STANDBY = "STAND-BY"
  10:     ACTIVE = "ACTIVE"
  11:     SEGMENTATION = "SEGMENTATION"
  12:     DRAINING = "DRAINING"
  13:     ISOLATED = "ISOLATED"
  14:     OFFLINE = "OFFLINE"
  15: 
  16: 
  17: def _state_value(value):
  18:     return value.value if isinstance(value, Enum) else str(value)
  19: 
  20: 
  21: def ensure_state_meta(node, now=None):
  22:     now = now or time.time()
  23: 
  24:     if not hasattr(node, "state_since") or node.state_since is None:
  25:         node.state_since = now
  26: 
  27:     if not hasattr(node, "prev_state"):
  28:         node.prev_state = None
  29: 
  30:     if not hasattr(node, "state_reason"):
  31:         node.state_reason = None
  32: 
  33:     return node
  34: 
  35: 
  36: def transition_node_state(node, new_state, reason=None, now=None):
  37:     now = now or time.time()
  38:     ensure_state_meta(node, now=now)
  39: 
  40:     old_state = _state_value(node.state)
  41:     new_state_value = _state_value(new_state)
  42: 
  43:     changed = old_state != new_state_value
  44: 
  45:     if changed:
  46:         node.prev_state = old_state
  47:         node.state = new_state if isinstance(new_state, Enum) else NodeState(new_state_value)
  48:         node.state_since = now
  49:         node.state_reason = reason
  50:     else:
  51:         if reason is not None:
  52:             node.state_reason = reason
  53: 
  54:     return {
  55:         "changed": changed,
  56:         "old_state": old_state,
  57:         "new_state": _state_value(node.state),
  58:         "state_since": node.state_since,
  59:         "state_reason": node.state_reason,
  60:     }
  61: 
  62: 
  63: def get_state_age_s(node, now=None):
  64:     now = now or time.time()
  65:     ensure_state_meta(node, now=now)
  66:     return max(0.0, now - float(node.state_since))



===== ./runtime/watchdog.py =====
   1: 
   2: import os
   3: import time
   4: import logging
   5: import requests
   6: 
   7: from cluster.runtime import context as ctx
   8: from cluster.runtime.cluster_store import cluster_state
   9: from cluster.utils.log_print import log_state
  10: 
  11: logging.getLogger("urllib3").setLevel(logging.ERROR)
  12: logging.getLogger("requests").setLevel(logging.ERROR)
  13: 
  14: WATCHDOG_PERIODSEC = float(os.getenv("WATCHDOG_PERIODSEC", 0.5))
  15: WATCHDOG_TIMEOUTSEC = float(os.getenv("WATCHDOG_TIMEOUTSEC", 1.0))
  16: WATCHDOG_DEBUG = str(os.getenv("WATCHDOG_DEBUG", "0")).strip().lower() in ("1", "true", "yes", "on")
  17: 
  18: HTTP = requests.Session()
  19: _last_watchdog_emit_ts = 0.0
  20: 
  21: 
  22: def _iter_targets(peers):
  23:     if isinstance(peers, dict):
  24:         for peer_id, node in peers.items():
  25:             if isinstance(node, dict):
  26:                 yield peer_id, node
  27:         return
  28: 
  29:     if isinstance(peers, list):
  30:         for node in peers:
  31:             if not isinstance(node, dict):
  32:                 continue
  33:             peer_id = node.get("node_id") or node.get("name") or node.get("host")
  34:             if peer_id:
  35:                 yield peer_id, node
  36:         return
  37: 
  38: 
  39: def _mark_local_watchdog(emitted_at: float, busy: bool):
  40:     node_id = getattr(ctx, "node_id", None)
  41:     if not node_id:
  42:         return
  43: 
  44:     current = cluster_state.get(node_id, {})
  45:     cluster_state[node_id] = {
  46:         **current,
  47:         "last_watchdog": emitted_at,
  48:         "last_seen": emitted_at,
  49:         "watchdog_busy": bool(busy),
  50:     }
  51: 
  52:     try:
  53:         ctx.node.last_watchdog = emitted_at
  54:         ctx.node.watchdog_busy = bool(busy)
  55:     except Exception:
  56:         pass
  57: 
  58: 
  59: def emit_watchdog(peers, force=False, busy=True):
  60:     global _last_watchdog_emit_ts
  61: 
  62:     if not getattr(ctx, "node_id", None):
  63:         return False
  64: 
  65:     now = time.time()
  66:     if not force and (now - _last_watchdog_emit_ts) < WATCHDOG_PERIODSEC:
  67:         return False
  68: 
  69:     emitted_at = now
  70:     _mark_local_watchdog(emitted_at, busy)
  71: 
  72:     payload = {
  73:         "node_id": ctx.node_id,
  74:         "busy": bool(busy),
  75:         "emitted_at": emitted_at,
  76:     }
  77: 
  78:     sent = 0
  79:     attempted = 0
  80: 
  81:     for peer_id, node in _iter_targets(peers):
  82:         host = node.get("host")
  83:         port = node.get("port")
  84:         if not host or not port:
  85:             continue
  86: 
  87:         attempted += 1
  88:         url = f"http://{host}:{port}/watchdog"
  89:         try:
  90:             resp = requests.post(url, json=payload, timeout=WATCHDOG_TIMEOUTSEC)
  91:             if resp.ok:
  92:                 sent += 1
  93:             elif WATCHDOG_DEBUG:
  94:                 log_state("yellow", "WATCHDOG", f"peer={peer_id} status={resp.status_code}", 3)
  95:         except Exception as e:
  96:             if WATCHDOG_DEBUG:
  97:                 log_state("red", "WATCHDOG", f"peer={peer_id} err={e}", 3)
  98: 
  99:     _last_watchdog_emit_ts = emitted_at
 100: 
 101:     if WATCHDOG_DEBUG:
 102:         log_state(
 103:             "cyan",
 104:             "WATCHDOG",
 105:             f"node={ctx.node_id} sent={sent}/{attempted} busy={bool(busy)} ts={emitted_at:.3f}",
 106:             3,
 107:         )
 108: 
 109:     return True
 110: 
 111: 
 112: def emit_watchdog_if_due(peers, busy=True):
 113:     return emit_watchdog(peers=peers, force=False, busy=busy)
 114: 
 115: 
 116: def emit_watchdog_now(peers, busy=True):
 117:     return emit_watchdog(peers=peers, force=True, busy=busy)



===== ./utils/log_print.py =====
   1: 
   2: from datetime import datetime
   3: 
   4: modeGhost = False
   5: 
   6: def log_state(color, typ, msg, decimals=0):
   7: 
   8:     if modeGhost:
   9:         return
  10: 
  11:     colors = {
  12:         "red": "\033[91m",
  13:         "green": "\033[92m",
  14:         "yellow": "\033[93m",
  15:         "blue": "\033[94m",
  16:         "magenta": "\033[95m",
  17:         "cyan": "\033[96m",
  18:         "white": "\033[97m",
  19:         "reset": "\033[0m",
  20:     }
  21: 
  22:     c = colors.get(color.lower(), colors["white"])
  23:     reset = colors["reset"]
  24: 
  25:     decimals = max(0, min(6, int(decimals)))
  26: 
  27:     # -----------------------------------------
  28:     # fixed-width timestamp
  29:     # -----------------------------------------
  30: 
  31:     now = datetime.now()
  32: 
  33:     if decimals == 0:
  34: 
  35:         # reserva espacio para ".000"
  36:         ts = now.strftime("%H:%M:%S") + "    "
  37: 
  38:     else:
  39: 
  40:         micros = f"{now.microsecond:06d}"[:decimals]
  41:         ts = f"{now.strftime('%H:%M:%S')}.{micros}"
  42: 
  43:         # padding fijo hasta longitud 12
  44:         ts = f"{ts:<12}"
  45: 
  46:     # -----------------------------------------
  47:     # aligned tag
  48:     # -----------------------------------------
  49: 
  50:     tag = f"{typ:>14}"
  51: 
  52:     # -----------------------------------------
  53:     # print
  54:     # -----------------------------------------
  55: 
  56:     print(f"[{ts}] {c}{tag}{reset} {msg}")
  57: 
  58: 
