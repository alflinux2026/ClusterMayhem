 121: def leader_event_state_check_tick():
 122:     global lasteventstatecheckts
 123:     now = time.time()
 124:     if now - lasteventstatecheckts < EVENTSTATECHECKPERIODSEC:
 125:         return
 126:     lasteventstatecheckts = now
 127: 
 128:     raw_events = load_events() or []
 129:     state_index = rebuild_event_state_index()
 130: 
 131:     raw_created = 0
 132:     raw_executing = 0
 133:     raw_completed = 0
 134:     for e in raw_events:
 135:         status = e.get("status")
 136:         if hasattr(status, "value"):
 137:             status = status.value
 138:         status = str(status).strip().lower()
 139:         if status == EventStatus.CREATED.value:
 140:             raw_created += 1
 141:         elif status == EventStatus.EXECUTING.value:
 142:             raw_executing += 1
 143:         elif status == EventStatus.COMPLETED.value:
 144:             raw_completed += 1
 145: 
 146:     created = 0
 147:     executing = 0
 148:     completed = 0
 149:     for event in state_index.values():
 150:         status = event.get("status") if isinstance(event, dict) else getattr(event, "status", None)
 151:         if hasattr(status, "value"):
 152:             status = status.value
 153:         status = str(status).strip().lower()
 154:         if status == EventStatus.CREATED.value:
 155:             created += 1
 156:         elif status == EventStatus.EXECUTING.value:
 157:             executing += 1
 158:         elif status == EventStatus.COMPLETED.value:
 159:             completed += 1
 160: 
 161: 
 162: def cleanup_local_segment_files(node_id: str, segment: str = "000", files=None):
 163:     files = files or ["events", "event_log"]
 164:     base_dir = Path(get_local_log_path(None)).resolve().parent
 165:     removed = []
 166:     missing = []
 167: 
 168:     for kind in files:
 169:         p = base_dir / f"{kind}.local.{segment}.jsonl"
 170:         if p.exists():
 171:             p.unlink()
 172:             removed.append(str(p))
 173:         else:
 174:             missing.append(str(p))
 175: 
 176:     #log_state("green", "SEGMENTATION", f"{node_id} cleanup_local_segment_files removed={len(removed)} missing={len(missing)} segment={segment}", 3)
 177: 
 178:     return {
 179:         "node_id": node_id,
 180:         "segment": segment,
 181:         "removed": removed,
 182:         "missing": missing,
 183:     }
 184: 
 185: def log_state_runtime_debug(node):
 186:     global laststatedebugts
 187:     now = time.time()
 188:     if now - laststatedebugts < STATEDEBUGPERIODSEC:
 189:         return
 190:     laststatedebugts = now
 191: 
 192:     age_s = get_state_age_s(node, now=now)
 193:     rebuild_node_event_cache(node.node_id)
 194: 
 195:     log_state("blue", "NODE STATE b", f"{_node_id(node)} state={node.state.value} age={age_s:.1f}s prev={getattr(node, 'prev_state', None)} reason={getattr(node, 'state_reason', None)}", 3)
 196: 
 197: 
 198: def rotate_segment_files(target_group: str, segment: str = "000", files=None, force: bool = False):
 199:     files = files or ["events", "event_log"]
 200:     base_dir = Path(get_local_log_path(None)).resolve().parent
 201:     local_node_id = getattr(ctx, "node_id", None) or getattr(getattr(ctx, "node", None), "node_id", None)
 202: 
 203:     if not local_node_id:
 204:         raise RuntimeError("missing local node_id for segment rotation")
 205: 
 206:     result = {}
 207: 
 208:     for kind in files:
 209:         src = base_dir / f"{kind}.local.{segment}.jsonl"
 210:         if not src.exists():
 211:             if force:
 212:                 result[kind] = {"before": str(src), "after": None, "index": None, "forced": True}
 213:                 continue
 214:             raise FileNotFoundError(str(src))
 215: 
 216:         idx = _next_rotation_index(base_dir, f"{kind}.{local_node_id}")
 217:         dst = base_dir / f"{kind}.{local_node_id}.{idx:03d}.jsonl"
 218:         os.replace(str(src), str(dst))
 219:         result[kind] = {"before": str(src), "after": str(dst), "index": idx, "forced": False}
 220: 
 221:     return result
 222: 
 223: 
 224: def _next_rotation_index(base_dir, stem, suffix=".jsonl"):
 225:     base_dir = Path(base_dir)
 226:     idx = 1
 227:     while True:
 228:         candidate = base_dir / f"{stem}.{idx:03d}{suffix}"
 229:         if not candidate.exists():
 230:             return idx
 231:         idx += 1
 232: 
 233: 
 234: class NodeWorker:
 235:     def __init__(self, node, peers, interval=1.0):
 236:         self.node = node
 237:         self.peers = peers
 238:         self.interval = interval
 239:         self.running = False
 240: 
 241:     def start(self):
 242:         self.running = True
 243:         t = threading.Thread(target=self.loop, daemon=True)
 244:         t.start()
 245: 
 246:     def stop(self):
 247:         self.running = False
 248: 
 249:     def tick_boot(self):
 250: 
 251:         #log_state("yellow", "[tick_boot]", f"[{self.node.node_id}] ticking ...", 3)
 252: 
 253:         emit_watchdog_if_due(self.peers, busy=True)
 254:         rebuild_node_event_cache(self.node.node_id)
 255:         self.node.event_cache_ready = True
 256:         self.node.transition(NodeState.STANDBY, reason="boot_complete")
 257: 
 258:     def tick_discovering(self):
 259:         pass
 260: 
 261:     def tick_standby(self):
 262: 
 263:         #log_state("yellow", "[tick_standby]", f"[{self.node.node_id}] ticking ...", 3)
 264: 
 265:         self.node.emit_heartbeat(self.peers)
 266:         emit_watchdog_if_due(self.peers, busy=True)
 267: 
 268:         leader = compute_leader()
 269: 
 270:         #log_state("yellow", "[tick_standby]", f"Leader: [{leader}]", 3)
 271: 
 272: #        if leader == self.node.node_id:
 273: #            if self.node.state == NodeState.STANDBY:
 274: #                log_state("yellow", "[CLUSTER]", f"[{self.node.node_id}] becoming ACTIVE from STANDBY tick", 3)
 275: #                self.transition(NodeState.ACTIVE, reason="leader_selected")
 276: 
 277: #        dispatch_tick()
 278: #        reconcile_tick(self.node)
 279:         replicate_eventlog()
 280:         replicate_events()
 281:         leader_event_state_check_tick()
 282:         if _should_enter_DRAINING(self.node):
 283:             self.node.transition(NodeState.DRAINING, reason="segment_max_count")
 284: 
 285:     def tick_active(self):
 286: 
 287:         #log_state("yellow", "[tick_active]", f"[{self.node.node_id}] ticking ...", 3)
 288: 
 289:         self.node.emit_heartbeat(self.peers)
 290:         emit_watchdog_if_due(self.peers, busy=True)
 291: #        dispatch_tick()
 292: #        reconcile_tick(self.node)
 293:         replicate_eventlog()
 294:         replicate_events()
 295:         leader_event_state_check_tick()
 296:         if _should_enter_DRAINING(self.node):
 297:             self.node.transition(NodeState.DRAINING, reason="segment_max_count")
 298: 
 299:     def tick_segmentation(self):
 300:         #log_state("magenta", "SEGMENTATION", f"{self.node.node_id} enter state={self.node.state.value}", 3)
 301:         self.node.emit_heartbeat(self.peers)
 302:         emit_watchdog_if_due(self.peers, busy=True)
 303: 
 304:         can_seg = _can_segment(self.node)
 305:         should_seg = _should_enter_segmentation(self.node)
 306:         #log_state("magenta", "SEGMENTATION", f"{self.node.node_id} can_segment={can_seg} should_enter_segmentation={should_seg}", 3)
 307:         ##time.sleep(15)
 308: 
 309:         if not should_seg:
 310:             #log_state("magenta", "SEGMENTATION", f"{self.node.node_id} skip reason=not_ready", 3)
 311:             return False
 312: 
 313:         result = rotate_segment_files(self.node.node_id, segment="000", files=["events", "event_log"], force=False)
 314:         log_state("magenta", "SEGMENTATION", f"{self.node.node_id} rotate ok={bool(result)}", 3)
 315:         #time.sleep(15)
 316: 
 317: 
 318:         cleanup_local_segment_files(self.node.node_id, segment="000", files=["events", "event_log"])
 319:         rebuild_node_event_cache(self.node.node_id)
 320:         self.node.transition(NodeState.STANDBY, reason="segment_closed")
 321:         #log_state("magenta", "SEGMENTATION", f"{self.node.node_id} exit -> STANDBY", 3)
 322:         #time.sleep(30)
 323: 
 324: 
 325:         return True
 326: 
 327:     def tick_DRAINING(self):
 328: 
 329:         #log_state("yellow", "[tick_draining]", f"[{self.node.node_id}] ticking ...", 3)
 330: 
 331:         self.node.emit_heartbeat(self.peers)
 332:         emit_watchdog_if_due(self.peers, busy=True)
 333: #        dispatch_tick()
 334: #        reconcile_tick(self.node)
 335:         replicate_eventlog()
 336:         replicate_events()
 337:         rebuild_node_event_cache(self.node.node_id)
 338:         leader_event_state_check_tick()
 339:         if _should_enter_segmentation(self.node):
 340:             #time.sleep(15)
 341:             self.node.transition(NodeState.SEGMENTATION, reason="segment_ready")
 342: 
 343:     def tick_isolated(self):
 344:         pass
 345: 
 346:     def tick_offline(self):
 347:         pass
 348: 
 349:     def _tick_by_state(self):
 350:         state = self.node.state
 351:         if state == NodeState.BOOT:
 352:             self.tick_boot()
 353:         elif state == NodeState.DISCOVERING:
 354:             self.tick_discovering()
 355:         elif state == NodeState.STANDBY:
 356:             self.tick_standby()
 357:         elif state == NodeState.ACTIVE:
 358:             self.tick_active()
 359:         elif state == NodeState.SEGMENTATION:
 360:             self.tick_segmentation()
 361:         elif state == NodeState.DRAINING:
 362:             self.tick_DRAINING()
 363:         elif state == NodeState.ISOLATED:
 364:             self.tick_isolated()
 365:         elif state == NodeState.OFFLINE:
 366:             self.tick_offline()
 367: 
 368:     def loop(self):
 369:         while self.running:
 370:             self.node.tick()
 371:             log_state_runtime_debug(self.node)
 372:             if self.node.state == NodeState.ISOLATED:
 373:                 #time.sleep(self.interval)
 374:                 continue
 375:             self._tick_by_state()
 376:             #time.sleep(self.interval)



===== ./runtime/progress_watchdog.py =====
   1: 
   2: import os
   3: import time
   4: from typing import Any
   5: 
   6: from cluster.runtime import context as ctx
   7: from cluster.runtime.cluster_store import cluster_state
   8: 
   9: PROGRESS_STALL_TIMEOUTSEC = float(os.getenv("PROGRESS_STALL_TIMEOUTSEC", 3.0))
  10: 
  11: 
  12: def _now() -> float:
  13:     return time.time()
  14: 
  15: 
  16: def _node_id() -> str | None:
  17:     return getattr(ctx, "node_id", None)
  18: 
  19: 
  20: def _merge_node_state(node_id: str, fields: dict):
  21:     current = cluster_state.get(node_id, {})
  22:     cluster_state[node_id] = {**current, **fields}
  23: 
  24: 
  25: def _safe_meta(meta: dict[str, Any] | None) -> dict[str, Any]:
  26:     return meta if isinstance(meta, dict) else {}
  27: 
  28: 
  29: def _coerce_progress(value):
  30:     if value is None:
  31:         return None
  32:     try:
  33:         return int(value)
  34:     except Exception:
  35:         return None
  36: 
  37: 
  38: def progress_start(stage: str, meta: dict[str, Any] | None = None):
  39:     node_id = _node_id()
  40:     if not node_id:
  41:         return
  42: 
  43:     now = _now()
  44:     _merge_node_state(node_id, {
  45:         "progress_active": True,
  46:         "progress_stage": stage,
  47:         "progress_started_at": now,
  48:         "progress_touched_at": now,
  49:         "progress_current": None,
  50:         "progress_total": None,
  51:         "progress_meta": _safe_meta(meta),
  52:         "progress_stalled": False,
  53:         "last_watchdog": now,
  54:         "last_seen": now,
  55:         "watchdog_busy": True,
  56:     })
  57: 
  58:     try:
  59:         ctx.node.last_watchdog = now
  60:         ctx.node.watchdog_busy = True
  61:     except Exception:
  62:         pass
  63: 
  64: 
  65: def progress_touch(
  66:     stage: str | None = None,
  67:     current: int | None = None,
  68:     total: int | None = None,
  69:     meta: dict[str, Any] | None = None,
  70: ):
  71:     node_id = _node_id()
  72:     if not node_id:
  73:         return
  74: 
  75:     now = _now()
  76:     current_state = cluster_state.get(node_id, {})
  77: 
  78:     next_stage = stage or current_state.get("progress_stage")
  79:     next_started_at = current_state.get("progress_started_at") or now
  80:     next_current = _coerce_progress(current)
  81:     next_total = _coerce_progress(total)
  82: 
  83:     if next_current is None:
  84:         next_current = current_state.get("progress_current")
  85:     if next_total is None:
  86:         next_total = current_state.get("progress_total")
  87: 
  88:     next_meta = current_state.get("progress_meta", {})
  89:     if meta is not None:
  90:         next_meta = _safe_meta(meta)
  91: 
  92:     _merge_node_state(node_id, {
  93:         "progress_active": True,
  94:         "progress_stage": next_stage,
  95:         "progress_started_at": next_started_at,
  96:         "progress_touched_at": now,
  97:         "progress_current": next_current,
  98:         "progress_total": next_total,
  99:         "progress_meta": next_meta,
 100:         "progress_stalled": False,
 101:         "last_watchdog": now,
 102:         "last_seen": now,
 103:         "watchdog_busy": True,
 104:     })
 105: 
 106:     try:
 107:         ctx.node.last_watchdog = now
 108:         ctx.node.watchdog_busy = True
 109:     except Exception:
 110:         pass
 111: 
 112: 
 113: def progress_done(stage: str | None = None, meta: dict[str, Any] | None = None):
 114:     node_id = _node_id()
 115:     if not node_id:
 116:         return
 117: 
 118:     now = _now()
 119:     current_state = cluster_state.get(node_id, {})
 120: 
 121:     next_stage = stage or current_state.get("progress_stage")
 122:     next_meta = current_state.get("progress_meta", {})
 123:     if meta is not None:
 124:         next_meta = _safe_meta(meta)
 125: 
 126:     _merge_node_state(node_id, {
 127:         "progress_active": False,
 128:         "progress_stage": next_stage,
 129:         "progress_started_at": current_state.get("progress_started_at"),
 130:         "progress_touched_at": now,
 131:         "progress_current": current_state.get("progress_current"),
 132:         "progress_total": current_state.get("progress_total"),
 133:         "progress_meta": next_meta,
 134:         "progress_stalled": False,
 135:         "last_watchdog": now,
 136:         "last_seen": now,
 137:         "watchdog_busy": False,
 138:     })
 139: 
 140:     try:
 141:         ctx.node.last_watchdog = now
 142:         ctx.node.watchdog_busy = False
 143:     except Exception:
 144:         pass
 145: 
 146: 
 147: def progress_reset():
 148:     node_id = _node_id()
 149:     if not node_id:
 150:         return
 151: 
 152:     now = _now()
 153:     _merge_node_state(node_id, {
 154:         "progress_active": False,
 155:         "progress_stage": None,
 156:         "progress_started_at": None,
 157:         "progress_touched_at": None,
 158:         "progress_current": None,
 159:         "progress_total": None,
 160:         "progress_meta": {},
 161:         "progress_stalled": False,
 162:         "last_watchdog": now,
 163:         "last_seen": now,
 164:         "watchdog_busy": False,
 165:     })
 166: 
 167:     try:
 168:         ctx.node.last_watchdog = now
 169:         ctx.node.watchdog_busy = False
 170:     except Exception:
 171:         pass
 172: 
 173: 
 174: def get_progress_snapshot(node_id: str | None = None) -> dict:
 175:     node_id = node_id or _node_id()
 176:     if not node_id:
 177:         return {}
 178: 
 179:     state = cluster_state.get(node_id, {})
 180:     return {
 181:         "progress_active": state.get("progress_active", False),
 182:         "progress_stage": state.get("progress_stage"),
 183:         "progress_started_at": state.get("progress_started_at"),
 184:         "progress_touched_at": state.get("progress_touched_at"),
 185:         "progress_current": state.get("progress_current"),
 186:         "progress_total": state.get("progress_total"),
 187:         "progress_meta": state.get("progress_meta", {}),
 188:         "progress_stalled": state.get("progress_stalled", False),
 189:     }
 190: 
 191: 
 192: def get_progress_age_s(node: dict | None = None, now: float | None = None) -> float | None:
 193:     now = now or _now()
 194: 
 195:     if node is None:
 196:         node_id = _node_id()
 197:         if not node_id:
 198:             return None
 199:         node = cluster_state.get(node_id, {})
 200: 
 201:     touched = node.get("progress_touched_at")
 202:     if touched is None:
 203:         return None
 204: 
 205:     try:
 206:         return max(0.0, now - float(touched))
 207:     except Exception:
 208:         return None
 209: 
 210: 
 211: def get_progress_duration_s(node: dict | None = None, now: float | None = None) -> float | None:
 212:     now = now or _now()
 213: 
 214:     if node is None:
 215:         node_id = _node_id()
 216:         if not node_id:
 217:             return None
 218:         node = cluster_state.get(node_id, {})
 219: 
 220:     started = node.get("progress_started_at")
 221:     if started is None:
 222:         return None
 223: 
 224:     try:
 225:         return max(0.0, now - float(started))
 226:     except Exception:
 227:         return None
 228: 
 229: 
 230: def get_progress_pct(node: dict | None = None) -> float | None:
 231:     if node is None:
 232:         node_id = _node_id()
 233:         if not node_id:
 234:             return None
 235:         node = cluster_state.get(node_id, {})
 236: 
 237:     current = node.get("progress_current")
 238:     total = node.get("progress_total")
 239: 
 240:     try:
 241:         current = float(current)
 242:         total = float(total)
 243:         if total <= 0:
 244:             return None
 245:         pct = (current / total) * 100.0
 246:         if pct < 0:
 247:             return 0.0
 248:         if pct > 100:
 249:             return 100.0
 250:         return round(pct, 1)
 251:     except Exception:
 252:         return None
 253: 
 254: 
 255: def progress_is_stalled(node: dict | None = None, now: float | None = None, timeout_s: float | None = None) -> bool:
 256:     now = now or _now()
 257:     timeout_s = timeout_s or PROGRESS_STALL_TIMEOUTSEC
 258: 
 259:     if node is None:
 260:         node_id = _node_id()
 261:         if not node_id:
 262:             return False
 263:         node = cluster_state.get(node_id, {})
 264: 
 265:     if not node.get("progress_active"):
 266:         return False
 267: 
 268:     age = get_progress_age_s(node, now=now)
 269:     if age is None:
 270:         return False
 271: 
 272:     return age > timeout_s
 273: 
 274: 
 275: def refresh_progress_stalled_flag(node_id: str | None = None, now: float | None = None, timeout_s: float | None = None) -> bool:
 276:     node_id = node_id or _node_id()
 277:     if not node_id:
 278:         return False
 279: 
 280:     now = now or _now()
 281:     timeout_s = timeout_s or PROGRESS_STALL_TIMEOUTSEC
 282:     node = cluster_state.get(node_id, {})
 283: 
 284:     stalled = progress_is_stalled(node=node, now=now, timeout_s=timeout_s)
 285:     _merge_node_state(node_id, {"progress_stalled": stalled})
 286:     return stalled



