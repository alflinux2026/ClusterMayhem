 262: def _normalize_event(e: dict) -> dict:
 263:     e = dict(e)
 264:     e["schema_version"] = str(e.get("schema_version", "0.1"))
 265:     e.setdefault("received_at", None)
 266:     e.setdefault("attempt", 0)
 267:     e.setdefault("route_hops", [])
 268:     e.setdefault("execution_key", None)
 269:     return e
 270: 
 271: 
 272: def _latest_map(events: List[dict]) -> Dict[str, dict]:
 273:     latest: Dict[str, dict] = {}
 274:     for e in events:
 275:         e = _normalize_event(e)
 276:         latest[e["event_id"]] = e
 277:     return latest
 278: 
 279: 
 280: def rebuild_event_state_index() -> Dict[str, dict]:
 281:     return _latest_map(load_events())
 282: 
 283: 
 284: def get_latest_event(event_id: str) -> Optional[dict]:
 285:     events = load_events()
 286:     for e in reversed(events):
 287:         if e["event_id"] == event_id:
 288:             return _normalize_event(e)
 289:     return None
 290: 
 291: 
 292: def get_created_events():
 293:     latest = rebuild_event_state_index()
 294:     domain_events = [ClusterEvent(**e) for e in latest.values()]
 295:     return [e for e in domain_events if e.status == EventStatus.CREATED]
 296: 
 297: 
 298: def get_completed_event_ids():
 299:     latest = rebuild_event_state_index()
 300:     domain_events = [ClusterEvent(**e) for e in latest.values()]
 301:     return {e.event_id for e in domain_events if e.status == EventStatus.COMPLETED}
 302: 
 303: 
 304: def append_event(event: ClusterEvent):
 305:     ensure_initial_files()
 306: 
 307:     record = {
 308:         "event_id": event.event_id,
 309:         "event_type": event.event_type,
 310:         "schema_version": str(event.schema_version),
 311:         "created_at": event.created_at,
 312:         "updated_at": getattr(event, "updated_at", None),
 313:         "received_at": getattr(event, "received_at", None),
 314:         "trace_id": event.trace_id,
 315:         "target_node": event.target_node,
 316:         "source_node": getattr(event, "source_node", None),
 317:         "route_hops": list(getattr(event, "route_hops", []) or []),
 318:         "status": event.status.value if hasattr(event.status, "value") else event.status,
 319:         "attempt": event.attempt,
 320:         "execution_key": getattr(event, "execution_key", None),
 321:         "payload": event.payload,
 322:     }
 323: 
 324:     line = json.dumps(record) + "\n"
 325:     with open(LOCAL_LOG_PATH, "a", encoding="utf-8") as f:
 326:         f.write(line)
 327:         f.flush()
 328:         os.fsync(f.fileno())
 329: 
 330:     state = read_state()
 331:     state["dirty"] = True
 332:     state["last_append_event_id"] = event.event_id
 333:     state["last_append_created_at"] = event.created_at
 334:     state["last_append_updated_at"] = getattr(event, "updated_at", None)
 335: 
 336: 
 337: 
 338:     if record["status"] == EventStatus.CREATED.value:
 339:         with open(COMPLETED_LOG_PATH, "a", encoding="utf-8") as f:
 340:             f.write(line)
 341:             f.flush()
 342:             os.fsync(f.fileno())
 343: 
 344:         state["events_dirty"] = True
 345:         state["last_completed_event_id"] = event.event_id
 346:         state["last_completed_created_at"] = event.created_at
 347:         state["last_completed_updated_at"] = getattr(event, "updated_at", None)
 348: 
 349:     try:
 350:         write_state(state)
 351:         _update_node_events_cache(event, record["status"])
 352: 
 353:     except Exception as e:
 354:         print(f"[STATE WRITE FAIL] {event.event_id} -> {e}")
 355: 
 356: 
 357: def replay_events(handler, stream: str | None = None):
 358:     events = load_events()
 359:     for raw in events:
 360:         event = ClusterEvent(**_normalize_event(raw))
 361:         handler(event)
 362: 



