 130: def _write_json_atomic(target_path: Path, payload: dict):
 131:     ensure_dir()
 132:     with _STATE_LOCK:
 133:         fd, tmp_name = tempfile.mkstemp(
 134:             prefix=f"{target_path.name}.",
 135:             suffix=".tmp",
 136:             dir=str(target_path.parent),
 137:             text=True,
 138:         )
 139:         try:
 140:             with os.fdopen(fd, "w", encoding="utf-8") as f:
 141:                 json.dump(payload, f, ensure_ascii=False)
 142:                 f.flush()
 143:                 os.fsync(f.fileno())
 144:             os.replace(tmp_name, str(target_path))
 145:         except Exception:
 146:             try:
 147:                 os.remove(tmp_name)
 148:             except FileNotFoundError:
 149:                 pass
 150:             raise
 151: 
 152: 
 153: def write_text_atomic(path: str, content: str):
 154:     ensure_dir()
 155:     target_path = Path(path)
 156:     fd, tmp_name = tempfile.mkstemp(
 157:         prefix=f"{target_path.name}.",
 158:         suffix=".tmp",
 159:         dir=str(target_path.parent),
 160:         text=True,
 161:     )
 162:     try:
 163:         with os.fdopen(fd, "w", encoding="utf-8") as f:
 164:             f.write(content)
 165:             f.flush()
 166:             os.fsync(f.fileno())
 167:         os.replace(tmp_name, str(target_path))
 168:     except Exception:
 169:         try:
 170:             os.remove(tmp_name)
 171:         except FileNotFoundError:
 172:             pass
 173:         raise
 174: 
