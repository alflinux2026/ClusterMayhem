  57: class SegmentRotateRequest(BaseModel):
  58:     request_id: str
  59:     source_node: str
  60:     target_group: str
  61:     segment: str
  62:     files: list[str] = ["events", "event_log"]
  63:     action: str = "rotate"
  64:     force: bool = False
  65:     ts: float | None = None
  66: 
  67: 
  68: def _round_or_none(value: float | None, digits: int = 1) -> float | None:
  69:     if value is None:
  70:         return None
  71:     try:
  72:         return round(float(value), digits)
  73:     except Exception:
  74:         return None
  75: 
  76: 
  77: def _watchdog_age_s(node: dict, now: float | None = None) -> float | None:
  78:     now = now or time.time()
  79:     last_watchdog = node.get("last_watchdog")
  80:     if last_watchdog is None:
  81:         return None
  82:     try:
  83:         return max(0.0, now - float(last_watchdog))
  84:     except Exception:
  85:         return None
  86: 
  87: 
  88: def _state_age_s(node: dict, now: float | None = None) -> float | None:
  89:     now = now or time.time()
  90:     state_since = node.get("state_since")
  91:     if state_since is None:
  92:         return None
  93:     try:
  94:         return max(0.0, now - float(state_since))
  95:     except Exception:
  96:         return None
  97: 
  98: 
  99: def _seen_age_s(node: dict, now: float | None = None) -> float | None:
 100:     now = now or time.time()
 101:     last_seen = node.get("last_seen")
 102:     if last_seen is None:
 103:         return None
 104:     try:
 105:         return max(0.0, now - float(last_seen))
 106:     except Exception:
 107:         return None
 108: 
 109: 
 110: def _presence_age_s(node: dict, now: float | None = None) -> float | None:
 111:     now = now or time.time()
 112:     last_seen = node.get("last_seen")
 113:     last_watchdog = node.get("last_watchdog")
 114:     candidates = []
 115:     for value in (last_seen, last_watchdog):
 116:         if value is None:
 117:             continue
 118:         try:
 119:             candidates.append(float(value))
 120:         except Exception:
 121:             continue
 122:     if not candidates:
 123:         return None
 124:     return max(0.0, now - max(candidates))
 125: 
 126: 
 127: def _presence_health(node: dict, now: float | None = None, stale_after_s: float = 3.0) -> str:
 128:     age = _presence_age_s(node, now)
 129:     if age is None:
 130:         return "stale"
 131:     return "ok" if age < stale_after_s else "stale"
 132: 
 133: 
 134: def _compact_node(node: dict) -> dict:
 135:     now = time.time()
 136:     return {
 137:         "state": node.get("state"),
 138:         "priority": node.get("priority"),
 139:         "last_seen": node.get("last_seen"),
 140:         "seen_age_s": _round_or_none(_seen_age_s(node, now), 3),
 141:         "last_watchdog": node.get("last_watchdog"),
 142:         "watchdog_age_s": _round_or_none(_watchdog_age_s(node, now), 3),
 143:         "watchdog_busy": node.get("watchdog_busy"),
 144:         "presence_age_s": _round_or_none(_presence_age_s(node, now), 3),
 145:         "presence_health": _presence_health(node, now),
 146:         "state_since": node.get("state_since"),
 147:         "state_age_s": _round_or_none(_state_age_s(node, now), 3),
 148:         "prev_state": node.get("prev_state"),
 149:         "state_reason": node.get("state_reason"),
 150:         "log_meta": node.get("log_meta", {}),
 151:         "streams": node.get("streams", {}),
 152:     }
 153: 
