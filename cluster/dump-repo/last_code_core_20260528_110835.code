  37: def alive_peer_ids():
  38:     out = []
  39:     now = time.time()
  40:     for node_id, data in cluster_state.items():
  41:         if node_id == ctx.node_id:
  42:             continue
  43:         if now - data.get("last_seen", 0) > PEERALIVETTLSEC:
