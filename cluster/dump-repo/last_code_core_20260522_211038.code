   1: import os
   2: import time
   3: import requests
   4: 
   5: from cluster.runtime.state import NodeState
   6: from cluster.runtime.leader import compute_leader
   7: from cluster.runtime.event_log import get_last_append_meta, load_events
   8: from cluster.runtime.integrity import file_sha256, cluster_integrity_report
   9: 
  10: from cluster.utils.log_print import log_state
  11: 
  12: 
  13: class NodeRuntime:
  14:     def __init__(self, node_id, priority):
  15:         self.node_id = node_id
  16:         self.priority = priority
  17:         self.state = NodeState.BOOT
  18:         self.last_heartbeat = time.time()
  19: 
  20:     def transition(self, new_state):
  21:         if self.state == new_state:
  22:             return
  23:         print(f"[{self.node_id}] {self.state} -> {new_state}")
  24:         self.state = new_state
  25: 
  26:     def tick(self):
  27:         if self.state == NodeState.BOOT:
  28:             self.transition(NodeState.STANDBY)
  29:             return
  30: 
  31:         leader = compute_leader()
  32:         if leader == self.node_id:
  33:             if self.state == NodeState.STANDBY:
  34:                 log_state("yellow", "[CLUSTER]", f"[{self.node_id}] becoming ACTIVE", 3)
  35:                 self.transition(NodeState.ACTIVE)
  36:         else:
  37:             if self.state == NodeState.ACTIVE:
  38:                 log_state("yellow", "[CLUSTER]", f"[{self.node_id}] becoming STANDBY", 3)
  39:                 self.transition(NodeState.STANDBY)
  40: 
  41:     def _log_size(self):
  42:         try:
  43:             return len(load_events())
  44:         except Exception:
  45:             return 0
  46: 
  47:     def _file_size(self):
  48:         try:
  49:             return os.path.getsize("cluster/data/event_log.local.jsonl")
  50:         except OSError:
  51:             return 0
  52: 
  53:     def emit_heartbeat(self, peers):
  54:         cluster_int = cluster_integrity_report()
  55:         hb = {
  56:             "node_id": self.node_id,
  57:             "state": self.state.value,
  58:             "priority": self.priority,
  59:             "log_meta": {
  60:                 **get_last_append_meta(),
  61:                 "log_size": self._log_size(),
  62:                 "file_size": self._file_size(),
  63:                 "file_hash": file_sha256("cluster/data/event_log.local.jsonl"),
  64:             },
  65:             "cluster_integrity": {
  66:                 "integrity_ok": cluster_int.get("integrity_ok", False),
  67:                 "alive_nodes": cluster_int.get("alive_nodes", []),
  68:                 "per_peer": cluster_int.get("per_peer", {}),
  69:             },
  70:         }
  71:         for peer in peers:
  72:             url = f"http://{peer['host']}:{peer['port']}/heartbeat"
  73:             try:
  74:                 requests.post(url, json=hb, timeout=2)
  75:             except requests.exceptions.RequestException:
  76:                 pass



