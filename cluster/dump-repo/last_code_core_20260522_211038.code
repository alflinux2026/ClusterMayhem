===== ./runtime/bootstrap.py =====
   1: import socket
   2: import json
   3: import os
   4: import requests
   5: import hashlib
   6: 
   7: 
   8: # -------------------------------------------------
   9: # PRIORITY DETERMINISTIC (FIXA POR NODO)
  10: # -------------------------------------------------
  11: def deterministic_priority(node_id: str):
  12:     return int(hashlib.md5(node_id.encode()).hexdigest(), 16) % 1000
  13: 
  14: 
  15: # -------------------------------------------------
  16: # BASIC UTILS
  17: # -------------------------------------------------
  18: def get_hostname():
  19:     return socket.gethostname()
  20: 
  21: 
  22: def load_config(path="config/node.local.json"):
  23:     with open(path, "r") as f:
  24:         return json.load(f)
  25: 
  26: 
  27: # -------------------------------------------------
  28: # DISCOVERY (MERGED VIEW SAFE)
  29: # -------------------------------------------------
  30: def discover_seed(peers):
  31:     clusters = []
  32: 
  33:     for p in peers:
  34:         try:
  35:             r = requests.get(
  36:                 f"http://{p['host']}:{p['port']}/cluster",
  37:                 timeout=1
  38:             )
  39:             if r.status_code == 200:
  40:                 clusters.append(r.json())
  41:         except:
  42:             continue
  43: 
  44:     merged = {}
  45: 
  46:     for cluster in clusters:
  47:         for node_id, data in cluster.items():
  48: 
  49:             if node_id not in merged:
  50:                 merged[node_id] = data
  51:                 continue
  52: 
  53:             # keep most recent info
  54:             if data.get("last_seen", 0) > merged[node_id].get("last_seen", 0):
  55:                 merged[node_id] = data
  56: 
  57:     return merged
  58: 
  59: 
  60: # -------------------------------------------------
  61: # CONFIG GENERATION
  62: # -------------------------------------------------
  63: def generate_local_config(peers):
  64: 
  65:     state = discover_seed(peers)
  66: 
  67:     used_priorities = {
  68:         n.get("priority")
  69:         for n in state.values()
  70:         if n.get("priority") is not None
  71:     }
  72: 
  73:     hostname = get_hostname()
  74: 
  75:     priority = deterministic_priority(hostname)
  76: 
  77:     # resolve collisions deterministically (NO LOOP DRIFT)
  78:     while priority in used_priorities:
  79:         priority += 1000  # salt step to avoid clustering collisions
  80: 
  81:     config = {
  82:         "node_id": hostname,
  83:         "priority": priority,
  84:         "bind_host": "0.0.0.0",
  85:         "bind_port": 7000,
  86:         "peers": peers
  87:     }
  88: 
  89:     os.makedirs("config", exist_ok=True)
  90: 
  91:     with open("config/node.local.json", "w") as f:
  92:         json.dump(config, f, indent=2)
  93: 
  94:     return config
  95: 
  96: 
  97: # -------------------------------------------------
  98: # BOOTSTRAP OR LOAD
  99: # -------------------------------------------------
 100: def load_or_bootstrap_config():
 101:     try:
 102:         return load_config()
 103:     except FileNotFoundError:
 104: 
 105:         peers = [
 106:             {"host": "100.100.1.200", "port": 7000},
 107:             {"host": "100.100.1.202", "port": 7000},
 108:             {"host": "100.100.1.203", "port": 7000},
 109:         ]
 110: 
 111:         return generate_local_config(peers)



