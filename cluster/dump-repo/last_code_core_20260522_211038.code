   1: import time
   2: 
   3: cluster_state = {}
   4: NODE_TTL = 5.0
   5: 
   6: 
   7: def cleanup_cluster():
   8:     now = time.time()
   9:     to_delete = [node_id for node_id, data in list(cluster_state.items()) if (now - data.get("last_seen", 0)) > NODE_TTL]
  10:     for node_id in to_delete:
  11:         print(f"[GC] removing {node_id}")
  12:         del cluster_state[node_id]
  13: 
  14: 
  15: def get_active_cluster():
  16:     cleanup_cluster()
  17:     return cluster_state



