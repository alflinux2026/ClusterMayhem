===== ./runtime/integrity.py =====
   1: import os
   2: import hashlib
   3: from typing import Any
   4: 
   5: from cluster.runtime import context as ctx
   6: from cluster.runtime.cluster_store import cluster_state
   7: from cluster.runtime.event_log import get_local_log_path, get_last_append_meta
   8: from cluster.runtime.leader import compute_alive
   9: 
  10: IGNORED_NODE_KEYS = {"last_seen"}
  11: 
  12: 
  13: def file_sha256(path: str, block_size: int = 65536) -> str | None:
  14:     if not os.path.exists(path):
  15:         return None
  16:     h = hashlib.sha256()
  17:     with open(path, "rb") as f:
  18:         while True:
  19:             chunk = f.read(block_size)
  20:             if not chunk:
  21:                 break
  22:             h.update(chunk)
  23:     return h.hexdigest()
  24: 
  25: 
  26: def canonicalize(obj: Any, ignored_keys: set[str] | None = None) -> Any:
  27:     ignored_keys = ignored_keys or set()
  28:     if isinstance(obj, dict):
  29:         return {k: canonicalize(v, ignored_keys) for k, v in sorted(obj.items()) if k not in ignored_keys}
  30:     if isinstance(obj, list):
  31:         return [canonicalize(v, ignored_keys) for v in obj]
  32:     return obj
  33: 
  34: 
  35: def compare_views(a: dict, b: dict) -> bool:
  36:     return canonicalize(a, IGNORED_NODE_KEYS) == canonicalize(b, IGNORED_NODE_KEYS)
  37: 
  38: 
  39: def log_meta_ok(local_meta: dict, peer_meta: dict) -> bool:
  40:     keys = ("dirty", "last_append_event_id", "last_append_created_at", "log_size", "file_size", "file_hash")
  41:     return all(local_meta.get(k) == peer_meta.get(k) for k in keys)
  42: 
  43: 
  44: def local_integrity_api() -> dict:
  45:     path = get_local_log_path()
  46:     alive = compute_alive(include_self=True)
  47:     local_meta = {
  48:         "path": path,
  49:         "size": os.path.getsize(path) if os.path.exists(path) else 0,
  50:         "sha256": file_sha256(path),
  51:     }
  52:     peer_status = {}
  53:     self_view = canonicalize(cluster_state.get(ctx.node_id, {}), IGNORED_NODE_KEYS)
  54:     self_meta = self_view.get("log_meta", {}) if isinstance(self_view, dict) else {}
  55: 
  56:     for node_id, data in alive.items():
  57:         view = canonicalize(data, IGNORED_NODE_KEYS)
  58:         meta = view.get("log_meta", {}) if isinstance(view, dict) else {}
  59:         peer_status[node_id] = {
  60:             "view": view,
  61:             "view_ok": view == canonicalize(cluster_state.get(node_id, {}), IGNORED_NODE_KEYS),
  62:             "log_meta_ok": log_meta_ok(self_meta, meta) if node_id == ctx.node_id else True,
  63:         }
  64: 
  65:     return {
  66:         "node_id": ctx.node_id,
  67:         "alive_nodes": sorted(alive.keys()),
  68:         "self_view": self_view,
  69:         "cluster_view": canonicalize(cluster_state, IGNORED_NODE_KEYS),
  70:         "peer_status": peer_status,
  71:         "local_log_meta": local_meta,
  72:         "last_append_meta": get_last_append_meta(),
  73:         "integrity_ok": True,
  74:     }
  75: 
  76: 
  77: def cluster_integrity_report() -> dict:
  78:     alive = compute_alive(include_self=True)
  79:     reference = canonicalize(cluster_state, IGNORED_NODE_KEYS)
  80:     per_peer = {}
  81:     for node_id, data in alive.items():
  82:         view = canonicalize(data, IGNORED_NODE_KEYS)
  83:         meta = view.get("log_meta", {}) if isinstance(view, dict) else {}
  84:         ref_view = reference.get(node_id, {})
  85:         ref_meta = ref_view.get("log_meta", {}) if isinstance(ref_view, dict) else {}
  86:         per_peer[node_id] = {
  87:             "matches_reference": view == ref_view,
  88:             "matches_log_meta": meta == ref_meta,
  89:             "view": view,
  90:             "reference_view": ref_view,
  91:         }
  92: 
  93:     return {
  94:         "node_id": ctx.node_id,
  95:         "alive_nodes": sorted(alive.keys()),
  96:         "reference": reference,
  97:         "per_peer": per_peer,
  98:         "integrity_ok": all(v["matches_reference"] and v["matches_log_meta"] for v in per_peer.values()),
  99:     }



===== ./runtime/leader.py =====
   1: import time
   2: 
   3: from cluster.utils.log_print import log_state
   4: from cluster.runtime.cluster_store import cluster_state
   5: from cluster.runtime import context as ctx
   6: 
   7: LEADER_ALIVE_TIMEOUT = 1.5
   8: 
   9: 
  10: def refresh_self_alive_entry(now=None):
  11:     now = now or time.time()
  12: 
  13:     if not getattr(ctx, "node", None):
  14:         return
  15: 
  16:     existing = cluster_state.get(ctx.node_id, {})
  17:     cluster_state[ctx.node_id] = {
  18:         "state": ctx.node.state.value,
  19:         "priority": ctx.node.priority,
  20:         "last_seen": now,
  21:         "log_meta": existing.get("log_meta", {}),
  22:     }
  23: 
  24: 
  25: def is_alive(data, timeout=LEADER_ALIVE_TIMEOUT, now=None):
  26:     now = now or time.time()
  27:     return (now - data.get("last_seen", 0)) < timeout
  28: 
  29: 
  30: def compute_alive(timeout=LEADER_ALIVE_TIMEOUT, include_self=True):
  31:     now = time.time()
  32: 
  33:     if include_self:
  34:         refresh_self_alive_entry(now)
  35: 
  36:     active_nodes = {}
  37: 
  38:     for node_id, data in cluster_state.items():
  39:         alive = is_alive(data, timeout=timeout, now=now)
  40:         if alive:
  41:             active_nodes[node_id] = data
  42:         else:
  43:             data["state"] = "GONE"
  44: 
  45:     return active_nodes
  46: 
  47: 
  48: def compute_leader(debug_node_id=None, timeout=LEADER_ALIVE_TIMEOUT):
  49:     active_nodes = compute_alive(timeout=timeout, include_self=True)
  50: 
  51:     if not active_nodes:
  52:         return None
  53: 
  54:     leader = min(
  55:         active_nodes.items(),
  56:         key=lambda x: (x[1]["priority"], x[0])
  57:     )[0]
  58: 
  59:     return leader



===== ./runtime/log_replication.py =====
   1: import logging
   2: import time
   3: import requests
   4: 
   5: from cluster.runtime import context as ctx
   6: from cluster.runtime.cluster_store import cluster_state
   7: from cluster.runtime.registry import CLUSTER_REGISTRY
   8: from cluster.runtime.event_log import (
   9:     read_local_log_text,
  10:     write_replica_log,
  11:     read_state,
  12:     clear_state,
  13: )
  14: from cluster.utils.log_print import log_state
  15: 
  16: logging.getLogger("urllib3").setLevel(logging.ERROR)
  17: logging.getLogger("requests").setLevel(logging.ERROR)
  18: 
  19: PEERALIVETTLSEC = 3.0
  20: 
  21: 
  22: def canonical_replica_node_id() -> str:
  23:     return ctx.node_id
  24: 
  25: 
  26: def alive_peer_ids():
  27:     out = []
  28:     now = time.time()
  29:     for node_id, data in cluster_state.items():
  30:         if node_id == ctx.node_id:
  31:             continue
  32:         if now - data.get("last_seen", 0) > PEERALIVETTLSEC:
  33:             continue
  34:         out.append(node_id)
  35:     return out
  36: 
  37: 
  38: def replicate_local():
  39:     node_id = canonical_replica_node_id()
  40: 
  41:     log_state("cyan", "REPL TICK", f"node={node_id}", 3)
  42: 
  43:     allowed_states = {"ACTIVE", "STANDBY", "DEGRADED"}
  44:     node_state = getattr(getattr(ctx, "node", None), "state", None)
  45:     node_state_value = getattr(node_state, "value", None)
  46:     log_state("cyan", "REPL STATE", f"state={node_state_value} allowed={node_state_value in allowed_states}", 3)
  47:     if node_state_value not in allowed_states:
  48:         return
  49: 
  50:     state = read_state()
  51:     dirty = bool(state.get("dirty", False))
  52:     log_state("cyan", "REPL FLAG", f"dirty={dirty} state_exists={bool(state)}", 3)
  53:     if not dirty:
  54:         return
  55: 
  56:     content = read_local_log_text()
  57:     content_bytes = content.encode("utf-8") if content else b""
  58:     log_state("cyan", "REPL CONTENT", f"len={len(content_bytes)} empty={not content.strip()}", 3)
  59:     if not content.strip():
  60:         log_state("yellow", "REPL SKIP", "empty content", 3)
  61:         return
  62: 
  63:     write_replica_log(node_id, content)
  64:     local_written_bytes = len(content_bytes)
  65:     log_state("cyan", "REPL WRITE", f"bytes={local_written_bytes}", 3)
  66: 
  67:     peers = alive_peer_ids()
  68:     log_state("cyan", "REPL PEERS", f"peers={peers}", 3)
  69:     if not peers:
  70:         log_state("yellow", "REPL SKIP", "no peers", 3)
  71:         return
  72: 
  73:     success = True
  74:     for peer_id in peers:
  75:         node = CLUSTER_REGISTRY.get(peer_id)
  76:         if not node:
  77:             log_state("red", "LOG REPL FAIL", f"{peer_id} missing registry", 3)
  78:             success = False
  79:             continue
  80: 
  81:         url = f"http://{node['host']}:{node['port']}/debug/log/replica/{node_id}"
  82:         log_state("cyan", "REPL POST", f"peer={peer_id} url={url}", 3)
  83:         try:
  84:             resp = requests.post(
  85:                 url,
  86:                 data=content_bytes,
  87:                 headers={"Content-Type": "text/plain; charset=utf-8"},
  88:                 timeout=2,
  89:             )
  90:             if not resp.ok:
  91:                 success = False
  92:                 log_state("red", "LOG REPL FAIL", f"{peer_id} status={resp.status_code}", 3)
  93:                 continue
  94: 
  95:             data = resp.json()
  96:             ok = bool(data.get("ok"))
  97:             peer_written = data.get("written_bytes")
  98:             peer_path = data.get("path")
  99: 
 100:             if ok and peer_written == local_written_bytes:
 101:                 log_state("cyan", "LOG REPL", f"{node_id} -> {peer_id}", 3)
 102:             else:
 103:                 success = False
 104:                 log_state(
 105:                     "red",
 106:                     "LOG REPL FAIL",
 107:                     f"{peer_id} path={peer_path} bytes={peer_written} expected={local_written_bytes}",
 108:                     3,
 109:                 )
 110: 
 111:         except Exception as e:
 112:             success = False
 113:             log_state("red", "LOG REPL FAIL", f"{peer_id} err={e}", 3)
 114: 
 115:     if success:
 116:         clear_state()
 117:         log_state("cyan", "REPL CLEAR", "dirty=false", 3)



