  95: @app.post("/event")
  96: def handle_event(event: ClusterEvent):
  97:     if ctx.node.state == NodeState.ISOLATED:
  98:         return {"error": "node isolated"}
  99: 
 100:     leader = compute_leader()
 101:     if not leader:
 102:         log_state("red", "(NO LEADER)", event.event_id, 3)
 103:         return {"error": "no leader"}
 104: 
 105:     if leader != ctx.node_id:
 106:         msg = event.payload.get("msg", "<no-msg>")
 107:         log_state("cyan", "[EVENT FWD]", f"{msg:12} -> {leader}", 3)
 108:         node = CLUSTER_REGISTRY[leader]
 109:         url = f"http://{node['host']}:{node['port']}/event"
 110:         try:
 111:             resp = requests.post(url, json=event.model_dump(), timeout=2)
 112:             return resp.json()
 113:         except Exception as e:
 114:             return {"error": str(e)}
 115: 
 116:     result = ingest_event(event, ctx.node_id)
 117:     return {"status": "ok", "event_id": event.event_id, "result": result}
 118: 
