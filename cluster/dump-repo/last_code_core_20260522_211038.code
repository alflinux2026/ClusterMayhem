   1: import json
   2: import os
   3: from typing import Dict, List, Optional
   4: 
   5: from cluster.runtime.events.cluster_event import ClusterEvent
   6: from cluster.runtime.events.event_state import EventStatus
   7: 
   8: BASE_DIR = os.path.dirname(os.path.dirname(os.path.dirname(__file__)))
   9: DATA_DIR = os.path.join(BASE_DIR, "cluster", "data")
  10: LOCAL_LOG_PATH = os.path.join(DATA_DIR, "event_log.local.jsonl")
  11: STATE_PATH = os.path.join(DATA_DIR, "last_append.state.json")
  12: 
  13: 
  14: def ensure_dir():
  15:     os.makedirs(DATA_DIR, exist_ok=True)
  16: 
  17: 
  18: def get_local_log_path() -> str:
  19:     return LOCAL_LOG_PATH
  20: 
  21: 
  22: def get_state_path() -> str:
  23:     return STATE_PATH
  24: 
  25: 
  26: def get_replica_log_path(node_id: str) -> str:
  27:     return os.path.join(DATA_DIR, f"event_log.{node_id}.jsonl")
  28: 
  29: 
  30: def list_replica_log_paths() -> List[str]:
  31:     if not os.path.exists(DATA_DIR):
  32:         return []
  33:     out: List[str] = []
  34:     for name in sorted(os.listdir(DATA_DIR)):
  35:         if not name.startswith("event_log."):
  36:             continue
  37:         if not name.endswith(".jsonl"):
  38:             continue
  39:         if name == "event_log.local.jsonl":
  40:             continue
  41:         out.append(os.path.join(DATA_DIR, name))
  42:     return out
  43: 
  44: 
  45: def load_events_from_path(path: str) -> List[dict]:
  46:     if not os.path.exists(path):
  47:         return []
  48:     events = []
  49:     with open(path, "r", encoding="utf-8") as f:
  50:         for line in f:
  51:             line = line.strip()
  52:             if not line:
  53:                 continue
  54:             try:
  55:                 events.append(json.loads(line))
  56:             except json.JSONDecodeError:
  57:                 continue
  58:     return events
  59: 
  60: 
  61: def write_text_atomic(path: str, content: str):
  62:     ensure_dir()
  63:     tmp_path = path + ".tmp"
  64:     with open(tmp_path, "w", encoding="utf-8") as f:
  65:         f.write(content)
  66:         f.flush()
  67:         os.fsync(f.fileno())
  68:     os.replace(tmp_path, path)
  69: 
  70: 
  71: def read_local_log_text() -> str:
  72:     if not os.path.exists(LOCAL_LOG_PATH):
  73:         return ""
  74:     with open(LOCAL_LOG_PATH, "r", encoding="utf-8") as f:
  75:         return f.read()
  76: 
  77: 
  78: def write_replica_log(node_id: str, content: str):
  79:     write_text_atomic(get_replica_log_path(node_id), content)
  80: 
  81: 
  82: def read_state() -> dict:
  83:     if not os.path.exists(STATE_PATH):
  84:         return {}
  85:     try:
  86:         with open(STATE_PATH, "r", encoding="utf-8") as f:
  87:             data = json.load(f)
  88:             return data if isinstance(data, dict) else {}
  89:     except (OSError, json.JSONDecodeError):
  90:         return {}
  91: 
  92: 
  93: def write_state(state: dict):
  94:     ensure_dir()
  95:     with open(STATE_PATH, "w", encoding="utf-8") as f:
  96:         json.dump(state, f, ensure_ascii=False)
  97: 
  98: 
  99: def clear_state():
 100:     try:
 101:         os.remove(STATE_PATH)
 102:     except FileNotFoundError:
 103:         pass
 104: 
 105: 
 106: def load_events() -> List[dict]:
 107:     return load_events_from_path(LOCAL_LOG_PATH)
 108: 
 109: 
 110: def load_local_events() -> List[dict]:
 111:     return load_events_from_path(LOCAL_LOG_PATH)
 112: 
 113: 
 114: def load_replica_events(node_id: str) -> List[dict]:
 115:     return load_events_from_path(get_replica_log_path(node_id))
 116: 
 117: 
 118: def load_all_replica_events() -> List[dict]:
 119:     events: List[dict] = []
 120:     for path in list_replica_log_paths():
 121:         events.extend(load_events_from_path(path))
 122:     return events
 123: 
 124: 
 125: def load_cluster_events() -> List[dict]:
 126:     return load_all_replica_events()
 127: 
 128: 
 129: def get_last_append_meta() -> dict:
 130:     state = read_state()
 131:     return {
 132:         "dirty": bool(state.get("dirty", False)),
 133:         "last_append_event_id": state.get("last_append_event_id"),
 134:         "last_append_created_at": state.get("last_append_created_at"),
 135:     }
 136: 
 137: 
 138: def _normalize_event(e: dict) -> dict:
 139:     e = dict(e)
 140:     e["schema_version"] = str(e.get("schema_version", "0.1"))
 141:     e.setdefault("received_at", None)
 142:     e.setdefault("attempt", 0)
 143:     e.setdefault("route_hops", [])
 144:     e.setdefault("execution_key", None)
 145:     return e
 146: 
 147: 
 148: def _latest_map(events: List[dict]) -> Dict[str, dict]:
 149:     latest: Dict[str, dict] = {}
 150:     for e in events:
 151:         e = _normalize_event(e)
 152:         latest[e["event_id"]] = e
 153:     return latest
 154: 
 155: 
 156: def rebuild_event_state_index() -> Dict[str, dict]:
 157:     return _latest_map(load_events())
 158: 
 159: 
 160: def get_latest_event(event_id: str) -> Optional[dict]:
 161:     events = load_events()
 162:     for e in reversed(events):
 163:         if e["event_id"] == event_id:
 164:             return _normalize_event(e)
 165:     return None
 166: 
 167: 
 168: def get_created_events():
 169:     latest = rebuild_event_state_index()
 170:     domain_events = [ClusterEvent(**e) for e in latest.values()]
 171:     return [e for e in domain_events if e.status == EventStatus.CREATED]
 172: 
 173: 
 174: def get_completed_event_ids():
 175:     latest = rebuild_event_state_index()
 176:     domain_events = [ClusterEvent(**e) for e in latest.values()]
 177:     return {e.event_id for e in domain_events if e.status == EventStatus.COMPLETED}
 178: 
 179: 
 180: def append_event(event: ClusterEvent):
 181:     ensure_dir()
 182:     record = {
 183:         "event_id": event.event_id,
 184:         "event_type": event.event_type,
 185:         "schema_version": str(event.schema_version),
 186:         "created_at": event.created_at,
 187:         "received_at": getattr(event, "received_at", None),
 188:         "trace_id": event.trace_id,
 189:         "target_node": event.target_node,
 190:         "route_hops": event.route_hops,
 191:         "status": event.status.value if hasattr(event.status, "value") else event.status,
 192:         "attempt": event.attempt,
 193:         "payload": event.payload,
 194:     }
 195:     if record["status"] == EventStatus.COMPLETED.value:
 196:         existing = load_events()
 197:         if any(e.get("event_id") == event.event_id and e.get("status") == EventStatus.COMPLETED.value for e in existing):
 198:             return
 199:     with open(LOCAL_LOG_PATH, "a", encoding="utf-8") as f:
 200:         f.write(json.dumps(record) + "\\n")
 201:         f.flush()
 202:         os.fsync(f.fileno())
 203:     write_state({
 204:         "dirty": True,
 205:         "last_append_event_id": event.event_id,
 206:         "last_append_created_at": event.created_at,
 207:     })
 208: 
 209: 
 210: def replay_events(handler):
 211:     events = load_events()
 212:     for raw in events:
 213:         event = ClusterEvent(**_normalize_event(raw))
 214:         handler(event)



===== ./runtime/event_router.py =====
   1: import requests
   2: 
   3: from cluster.runtime.registry import CLUSTER_REGISTRY
   4: from cluster.utils.log_print import log_state
   5: from cluster.runtime.events.cluster_event import ClusterEvent
   6: from cluster.runtime.events.event_state import EventStatus
   7: 
   8: def forward_event(node_id: str, event: ClusterEvent):
   9:     node = CLUSTER_REGISTRY[node_id]
  10:     url = f"http://{node['host']}:{node['port']}/execute"
  11: 
  12:     event.add_hop(f"worker:{node_id}")
  13: 
  14:     msg = event.payload.get("msg", "<no-msg>")
  15: 
  16:     log_state(
  17:         "magenta",
  18:         "[WORKER SEND]",
  19:         f"{msg:12} -> {node_id}",
  20:         3
  21:     )
  22: 
  23:     try:
  24:         resp = requests.post(
  25:             url,
  26:             json=event.model_dump(),
  27:             timeout=2
  28:         )
  29:         worker_result = resp.json()
  30:     except Exception as e:
  31:         log_state(
  32:             "red",
  33:             "[WORKER SEND FAIL]",
  34:             f"{msg:12} -> {node_id} | {e}",
  35:             3
  36:         )
  37:         return {"error": "worker_send_failed"}
  38: 
  39:     if worker_result.get("status") == "completed":
  40:         from cluster.runtime.state_machine import transition_event
  41: 
  42:         transition_event(event.event_id, EventStatus.COMPLETED)
  43: 
  44:         log_state(
  45:             "yellow",
  46:             "(EVENT)",
  47:             f"{msg:12} -> COMPLETED",
  48:             3
  49:         )
  50: 
  51:     return {
  52:         "status": "forwarded",
  53:         "event_id": event.event_id,
  54:         "target": node_id
  55:     }



===== ./runtime/events/cluster_event.py =====
   1: from pydantic import BaseModel, Field
   2: from typing import Optional
   3: from uuid import uuid4
   4: import time
   5: 
   6: from cluster.runtime.events.event_state import EventStatus
   7: 
   8: 
   9: class ClusterEvent(BaseModel):
  10: 
  11:     event_id: str = Field(default_factory=lambda: str(uuid4()))
  12:     trace_id: str = Field(default_factory=lambda: str(uuid4()))
  13: 
  14:     schema_version: str = "0.1"   # 👈 FIJO: string ONLY
  15: 
  16:     event_type: str
  17: 
  18:     payload: dict = {}
  19: 
  20:     status: EventStatus = EventStatus.CREATED
  21: 
  22:     route_hops: list[str] = []
  23: 
  24:     target_node: Optional[str] = None
  25:     source_node: Optional[str] = None   # 👈 LO USA event_log
  26: 
  27:     created_at: float = 0.0
  28:     updated_at: float = 0.0
  29: 
