   1: # File: cluster/runtime/node_boot.py
   2: # Previous: none
   3: # Author: alftorres
   4: # Date: 2026-05-19T21:11:14+0200
   5: # Version: 0.0.0
   6: # Genealogy:
   7: #   cluster/runtime/node_boot.py 0.0.0 2026-05-19T21:11:14+0200
   8: #   God
   9: #
  10: # Purpose:
  11: # Notes:
  12: #
  13: # FRV-ID: 500641938cf30f1e
  14: # Header_End
  15: 
  16: """
  17: runtime.node_boot
  18: 
  19: Responsabilidad:
  20: - Punto de entrada del proceso de nodo.
  21: - Carga la configuración local, construye el runtime del nodo, inicializa
  22:   el contexto global compartido, arranca el worker de fondo y expone la API HTTP.
  23: 
  24: Rol en la arquitectura:
  25: - Este módulo actúa como ensamblador del nodo.
  26: - No contiene lógica de negocio HTTP ni definición de endpoints.
  27: - La lógica HTTP vive en runtime.api_app.
  28: - La lógica periódica de cluster vive en runtime.node_worker.
  29: 
  30: Entradas:
  31: - Configuración obtenida desde load_or_bootstrap_config().
  32: 
  33: Salidas / efectos laterales:
  34: - Inicializa ctx.node_id, ctx.priority y ctx.node.
  35: - Arranca un NodeWorker en background.
  36: - Lanza uvicorn para servir la API del nodo.
  37: 
  38: Límites:
  39: - No debe contener handlers HTTP.
  40: - No debe contener lógica de ingest, dispatch, reconcile o execute.
  41: - No debe mutar cluster_state directamente.
  42: 
  43: Notas de mantenimiento:
  44: - El orden de inicialización importa: ctx debe quedar listo antes de que
  45:   FastAPI procese requests, porque los endpoints dependen de ctx.node y ctx.node_id.
  46: - Si se cambia el orden de arranque, validar /health, /leader, /cluster y chaos test.
  47: """
  48: 
  49: import threading
  50: import uvicorn
  51: 
  52: from cluster.runtime.node_worker import NodeWorker
  53: from cluster.runtime.node_runtime import NodeRuntime
  54: from cluster.runtime.bootstrap import load_or_bootstrap_config
  55: from cluster.runtime import context as ctx
  56: from cluster.runtime.api_app import app
  57: from cluster.utils.log_print import log_state
  58: 
  59: 
  60: def run_node(config):
  61:     ctx.node_id = config["node_id"]
  62:     ctx.priority = config["priority"]
  63: 
  64:     node = NodeRuntime(
  65:         node_id=config["node_id"],
  66:         priority=config["priority"],
  67:     )
  68:     ctx.node = node
  69: 
  70:     log_state(
  71:         "cyan",
  72:         "[BOOT]",
  73:         (
  74:             f"node={config['node_id']} "
  75:             f"priority={config['priority']} "
  76:             f"bind={config.get('bind_host', '0.0.0.0')}:{config.get('bind_port', 7000)} "
  77:             f"peers={len(config.get('peers', []))}"
  78:         ),
  79:         3,
  80:     )
  81: 
  82:     worker = NodeWorker(
  83:         node=node,
  84:         peers=config["peers"],
  85:         interval=1.0,
  86:     )
  87: 
  88:     threading.Thread(
  89:         target=worker.start,
  90:         daemon=True,
  91:     ).start()
  92: 
  93:     log_state("green", "[WORKER]", f"background loop started for {config['node_id']}", 3)
  94:     log_state(
  95:         "green",
  96:         "[HTTP]",
  97:         f"serving app on {config.get('bind_host', '0.0.0.0')}:{config.get('bind_port', 7000)}",
  98:         3,
  99:     )
 100: 
 101:     uvicorn.run(
 102:         app,
 103:         host=config.get("bind_host", "0.0.0.0"),
 104:         port=config.get("bind_port", 7000),
 105:         log_level="warning",
 106:         access_log=False,
 107:     )
 108: 
 109: 
 110: if __name__ == "__main__":
 111:     config = load_or_bootstrap_config()
 112:     run_node(config)



