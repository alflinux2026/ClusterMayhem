===== ./runtime/state_machine.py =====
   1: from cluster.runtime.events.event_state import EventStatus, validate_transition
   2: from cluster.runtime.event_log import load_events, append_event
   3: from cluster.runtime.events.cluster_event import ClusterEvent
   4: 
   5: def transition_event(event_id: str, new_status):
   6:     events = load_events()
   7: 
   8:     latest_raw = None
   9:     for e in reversed(events):
  10:         if e["event_id"] == event_id:
  11:             latest_raw = e
  12:             break
  13: 
  14:     if not latest_raw:
  15:         return
  16: 
  17:     latest = ClusterEvent(**latest_raw)
  18:     old_status = latest.status
  19: 
  20:     validate_transition(old_status, new_status)
  21: 
  22:     latest.status = new_status
  23:     append_event(latest)



===== ./runtime/worker/event_worker.py =====
   1: # =========================
   2: # WORKER - IDEMPOTENT EXECUTOR
   3: # =========================
   4: 
   5: import time
   6: from cluster.utils.log_print import log_state
   7: 
   8: executed_keys = set()
   9: 
  10: def run_business_logic(payload: dict):
  11:     return {"ok": True, "payload": payload}
  12: 
  13: def execute_event(event):
  14:     event.execution_key = f"{event.event_id}:{event.attempt}"
  15: 
  16:     if event.execution_key in executed_keys:
  17:         log_state("red", "[CACHE HIT]", event.execution_key, 3)
  18:         return {
  19:             "status": "completed",
  20:             "cached": True,
  21:             "event_id": event.event_id,
  22:             "execution_key": event.execution_key
  23:         }
  24: 
  25:     result = run_business_logic(event.payload)
  26:     executed_keys.add(event.execution_key)
  27: 
  28:     msg = event.payload.get("msg", "<no-msg>")
  29:     log_state("green", "[EXECUTE]", f"{msg:12}", 3)
  30: 
  31:     return {
  32:         "status": "completed",
  33:         "event_id": event.event_id,
  34:         "execution_key": event.execution_key,
  35:         "result": result
  36:     }



===== ./utils/log_print.py =====
   1: 
   2: from datetime import datetime
   3: 
   4: modeGhost = False
   5: 
   6: def log_state(color, typ, msg, decimals=0):
   7: 
   8:     if modeGhost:
   9:         return
  10: 
  11:     colors = {
  12:         "red": "\033[91m",
  13:         "green": "\033[92m",
  14:         "yellow": "\033[93m",
  15:         "blue": "\033[94m",
  16:         "magenta": "\033[95m",
  17:         "cyan": "\033[96m",
  18:         "white": "\033[97m",
  19:         "reset": "\033[0m",
  20:     }
  21: 
  22:     c = colors.get(color.lower(), colors["white"])
  23:     reset = colors["reset"]
  24: 
  25:     decimals = max(0, min(6, int(decimals)))
  26: 
  27:     # -----------------------------------------
  28:     # fixed-width timestamp
  29:     # -----------------------------------------
  30: 
  31:     now = datetime.now()
  32: 
  33:     if decimals == 0:
  34: 
  35:         # reserva espacio para ".000"
  36:         ts = now.strftime("%H:%M:%S") + "    "
  37: 
  38:     else:
  39: 
  40:         micros = f"{now.microsecond:06d}"[:decimals]
  41:         ts = f"{now.strftime('%H:%M:%S')}.{micros}"
  42: 
  43:         # padding fijo hasta longitud 12
  44:         ts = f"{ts:<12}"
  45: 
  46:     # -----------------------------------------
  47:     # aligned tag
  48:     # -----------------------------------------
  49: 
  50:     tag = f"{typ:>14}"
  51: 
  52:     # -----------------------------------------
  53:     # print
  54:     # -----------------------------------------
  55: 
  56:     print(f"[{ts}] {c}{tag}{reset} {msg}")
  57: 
  58: 
