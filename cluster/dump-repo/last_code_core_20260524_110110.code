===== ./runtime/node_runtime.py =====
   1: import time
   2: import requests
   3: 
   4: from cluster.runtime.state import NodeState
   5: from cluster.runtime.leader import compute_leader
   6: from cluster.utils.log_print import log_state
   7: 
   8: 
   9: class NodeRuntime:
  10:     def __init__(self, node_id, priority):
  11:         self.node_id = node_id
  12:         self.priority = priority
  13:         self.state = NodeState.BOOT
  14:         self.last_heartbeat = time.time()
  15: 
  16:     def transition(self, new_state):
  17:         if self.state == new_state:
  18:             return
  19:         print(f"[{self.node_id}] {self.state} -> {new_state}")
  20:         self.state = new_state
  21: 
  22:     def tick(self):
  23:         if self.state == NodeState.BOOT:
  24:             self.transition(NodeState.STANDBY)
  25:             return
  26: 
  27:         leader = compute_leader()
  28: 
  29:         if leader == self.node_id:
  30:             if self.state == NodeState.STANDBY:
  31:                 log_state("yellow", "[CLUSTER]", f"[{self.node_id}] becoming ACTIVE", 3)
  32:                 self.transition(NodeState.ACTIVE)
  33:         else:
  34:             if self.state == NodeState.ACTIVE:
  35:                 log_state("yellow", "[CLUSTER]", f"[{self.node_id}] becoming STANDBY", 3)
  36:                 self.transition(NodeState.STANDBY)
  37: 
  38:     def emit_heartbeat(self, peers):
  39:         hb = {
  40:             "node_id": self.node_id,
  41:             "state": self.state.value,
  42:             "priority": self.priority,
  43:         }
  44:         for peer in peers:
  45:             url = f"http://{peer['host']}:{peer['port']}/heartbeat"
  46:             try:
  47:                 requests.post(url, json=hb, timeout=2)
  48:             except requests.exceptions.RequestException:
  49:                 pass



