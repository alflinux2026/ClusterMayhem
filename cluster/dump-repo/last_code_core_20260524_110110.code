   1: import json
   2: import os
   3: from typing import Dict, List, Optional
   4: 
   5: from cluster.runtime.events.cluster_event import ClusterEvent
   6: from cluster.runtime.events.event_state import EventStatus
   7: 
   8: BASE_DIR = os.path.dirname(os.path.dirname(os.path.dirname(__file__)))
   9: DATA_DIR = os.path.join(BASE_DIR, "cluster", "data")
  10: LOCAL_LOG_PATH = os.path.join(DATA_DIR, "event_log.local.jsonl")
  11: STATE_PATH = os.path.join(DATA_DIR, "last_append.state.json")
  12: 
  13: 
  14: def ensure_dir():
  15:     os.makedirs(DATA_DIR, exist_ok=True)
  16: 
  17: 
  18: def get_local_log_path(stream: str | None = None) -> str:
  19:     return LOCAL_LOG_PATH
  20: 
  21: 
  22: def get_state_path() -> str:
  23:     return STATE_PATH
  24: 
  25: 
  26: def get_replica_log_path(node_id: str) -> str:
  27:     return os.path.join(DATA_DIR, f"event_log.{node_id}.jsonl")
  28: 
  29: 
  30: def list_replica_log_paths() -> List[str]:
  31:     if not os.path.exists(DATA_DIR):
  32:         return []
  33: 
  34:     out: List[str] = []
  35:     for name in sorted(os.listdir(DATA_DIR)):
  36:         if not name.startswith("event_log."):
  37:             continue
  38:         if not name.endswith(".jsonl"):
  39:             continue
  40:         if name == "event_log.local.jsonl":
  41:             continue
  42:         out.append(os.path.join(DATA_DIR, name))
  43:     return out
  44: 
  45: 
  46: def load_events_from_path(path: str) -> List[dict]:
  47:     if not os.path.exists(path):
  48:         return []
  49: 
  50:     events = []
  51:     with open(path, "r", encoding="utf-8") as f:
  52:         for line in f:
  53:             line = line.strip()
  54:             if not line:
  55:                 continue
  56:             try:
  57:                 events.append(json.loads(line))
  58:             except json.JSONDecodeError:
  59:                 continue
  60:     return events
  61: 
  62: 
  63: def write_text_atomic(path: str, content: str):
  64:     ensure_dir()
  65:     tmp_path = path + ".tmp"
  66:     with open(tmp_path, "w", encoding="utf-8") as f:
  67:         f.write(content)
  68:         f.flush()
  69:         os.fsync(f.fileno())
  70:     os.replace(tmp_path, path)
  71: 
  72: 
  73: def read_local_log_text() -> str:
  74:     if not os.path.exists(LOCAL_LOG_PATH):
  75:         return ""
  76:     with open(LOCAL_LOG_PATH, "r", encoding="utf-8") as f:
  77:         return f.read()
  78: 
  79: 
  80: def write_replica_log(node_id: str, content: str):
  81:     ensure_dir()
  82:     write_text_atomic(get_replica_log_path(node_id), content)
  83: 
  84: 
  85: def read_state() -> dict:
  86:     if not os.path.exists(STATE_PATH):
  87:         return {}
  88:     try:
  89:         with open(STATE_PATH, "r", encoding="utf-8") as f:
  90:             data = json.load(f)
  91:             return data if isinstance(data, dict) else {}
  92:     except (OSError, json.JSONDecodeError):
  93:         return {}
  94: 
  95: 
  96: def get_last_append_meta() -> dict:
  97:     state = read_state()
  98:     return state if isinstance(state, dict) else {}
  99: 
 100: 
 101: def write_state(state: dict):
 102:     ensure_dir()
 103:     tmp_path = STATE_PATH + ".tmp"
 104:     with open(tmp_path, "w", encoding="utf-8") as f:
 105:         json.dump(state, f, ensure_ascii=False)
 106:         f.flush()
 107:         os.fsync(f.fileno())
 108:     os.replace(tmp_path, STATE_PATH)
 109: 
 110: 
 111: def clear_state():
 112:     try:
 113:         os.remove(STATE_PATH)
 114:     except FileNotFoundError:
 115:         pass
 116: 
 117: 
 118: def load_events() -> List[dict]:
 119:     return load_events_from_path(LOCAL_LOG_PATH)
 120: 
 121: 
 122: def load_local_events() -> List[dict]:
 123:     return load_events_from_path(LOCAL_LOG_PATH)
 124: 
 125: 
 126: def load_replica_events(node_id: str) -> List[dict]:
 127:     return load_events_from_path(get_replica_log_path(node_id))
 128: 
 129: 
 130: def load_all_replica_events() -> List[dict]:
 131:     events: List[dict] = []
 132:     for path in list_replica_log_paths():
 133:         events.extend(load_events_from_path(path))
 134:     return events
 135: 
 136: 
 137: def load_cluster_events() -> List[dict]:
 138:     return load_all_replica_events()
 139: 
 140: 
 141: def _normalize_event(e: dict) -> dict:
 142:     e = dict(e)
 143:     e["schema_version"] = str(e.get("schema_version", "0.1"))
 144:     e.setdefault("received_at", None)
 145:     e.setdefault("attempt", 0)
 146:     e.setdefault("route_hops", [])
 147:     e.setdefault("execution_key", None)
 148:     return e
 149: 
 150: 
 151: def _latest_map(events: List[dict]) -> Dict[str, dict]:
 152:     latest: Dict[str, dict] = {}
 153:     for e in events:
 154:         e = _normalize_event(e)
 155:         latest[e["event_id"]] = e
 156:     return latest
 157: 
 158: 
 159: def rebuild_event_state_index() -> Dict[str, dict]:
 160:     return _latest_map(load_events())
 161: 
 162: 
 163: def get_latest_event(event_id: str) -> Optional[dict]:
 164:     events = load_events()
 165:     for e in reversed(events):
 166:         if e.get("event_id") == event_id:
 167:             return _normalize_event(e)
 168:     return None
 169: 
 170: 
 171: def get_created_events():
 172:     latest = rebuild_event_state_index()
 173:     domain_events = [ClusterEvent(**e) for e in latest.values()]
 174:     return [e for e in domain_events if e.status == EventStatus.CREATED]
 175: 
 176: 
 177: def get_completed_event_ids():
 178:     latest = rebuild_event_state_index()
 179:     domain_events = [ClusterEvent(**e) for e in latest.values()]
 180:     return {e.event_id for e in domain_events if e.status == EventStatus.COMPLETED}
 181: 
 182: 
 183: def append_event(event: ClusterEvent):
 184:     ensure_dir()
 185: 
 186:     record = {
 187:         "event_id": event.event_id,
 188:         "event_type": event.event_type,
 189:         "schema_version": str(event.schema_version),
 190:         "created_at": event.created_at,
 191:         "updated_at": getattr(event, "updated_at", None),
 192:         "received_at": getattr(event, "received_at", None),
 193:         "trace_id": event.trace_id,
 194:         "target_node": event.target_node,
 195:         "source_node": getattr(event, "source_node", None),
 196:         "route_hops": list(getattr(event, "route_hops", []) or []),
 197:         "status": event.status.value if hasattr(event.status, "value") else event.status,
 198:         "attempt": event.attempt,
 199:         "execution_key": getattr(event, "execution_key", None),
 200:         "payload": event.payload,
 201:     }
 202: 
 203:     if record["status"] == EventStatus.COMPLETED.value:
 204:         existing = load_events()
 205:         if any(
 206:             e.get("event_id") == event.event_id and e.get("status") == EventStatus.COMPLETED.value
 207:             for e in existing
 208:         ):
 209:             return
 210: 
 211:     with open(LOCAL_LOG_PATH, "a", encoding="utf-8") as f:
 212:         f.write(json.dumps(record) + "\n")
 213:         f.flush()
 214:         os.fsync(f.fileno())
 215: 
 216:     try:
 217:         write_state({
 218:             "dirty": True,
 219:             "last_append_event_id": event.event_id,
 220:             "last_append_created_at": event.created_at,
 221:         })
 222:     except Exception as e:
 223:         print(f"[STATE WRITE FAIL] {event.event_id} -> {e}")
 224: 
 225: 
 226: def replay_events(handler, stream: str | None = None):
 227:     events = load_events()
 228:     for raw in events:
 229:         event = ClusterEvent(**_normalize_event(raw))
 230:         handler(event)



