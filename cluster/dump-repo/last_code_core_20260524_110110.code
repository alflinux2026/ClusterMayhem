  11:     trace_id: str = Field(default_factory=lambda: str(uuid4()))
  12: 
  13:     schema_version: str = "0.1"
  14:     event_type: str
  15: 
  16:     payload: dict = Field(default_factory=dict)
  17: 
  18:     status: EventStatus = EventStatus.CREATED
  19: 
  20:     route_hops: list[str] = Field(default_factory=list)
  21: 
  22:     target_node: Optional[str] = None
  23:     source_node: Optional[str] = None
  24: 
  25:     created_at: float = Field(default_factory=time.time)
  26:     updated_at: float = Field(default_factory=time.time)
  27: 
  28:     received_at: Optional[float] = None
  29: 
  30:     attempt: int = 0
  31:     execution_key: Optional[str] = None
  32: 
  33:     def add_hop(self, hop: str):
  34:         self.route_hops.append(hop)
  35:         self.updated_at = time.time()
  36: 
  37:     def mark_status(self, status: EventStatus):
  38:         self.status = status
  39:         self.updated_at = time.time()
  40: 
  41:     def mark_received(self):
  42:         self.received_at = time.time()
  43:         self.updated_at = self.received_at



===== ./runtime/events/event_state.py =====
   1: from enum import Enum
   2: 
   3: 
   4: class EventStatus(str, Enum):
   5:     CREATED = "created"
   6:     EXECUTING = "executing"
   7:     COMPLETED = "completed"
   8:     FAILED = "failed"
   9: 
  10: 
  11: VALID_TRANSITIONS = {
  12:     EventStatus.CREATED: [
  13:         EventStatus.EXECUTING,
  14:     ],
  15: 
  16:     EventStatus.EXECUTING: [
  17:         EventStatus.COMPLETED,
  18:         EventStatus.FAILED,
  19:         EventStatus.CREATED,  # retry
  20:     ],
  21: 
  22:     EventStatus.COMPLETED: [],
  23: 
  24:     EventStatus.FAILED: [],
  25: }
  26: 
  27: 
  28: def validate_transition(old_status, new_status):
  29: 
  30:     if old_status == new_status:
  31:         return  # IDEMPOTENTE NO-OP
  32: 
  33:     allowed = VALID_TRANSITIONS.get(old_status, [])
  34: 
  35:     if new_status not in allowed:
  36:         raise ValueError(
  37:             f"Invalid transition: {old_status} -> {new_status}"
  38:         )



