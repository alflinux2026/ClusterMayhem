===== ./runtime/integrity.py =====
   1: import os
   2: import hashlib
   3: from pathlib import Path
   4: from typing import Any
   5: 
   6: from cluster.runtime import context as ctx
   7: from cluster.runtime.cluster_store import cluster_state
   8: from cluster.runtime.event_log import get_local_log_path, get_last_append_meta
   9: from cluster.runtime.leader import compute_alive
  10: 
  11: IGNORED_NODE_KEYS = {"last_seen"}
  12: INTEGRITY_KEYS = ("dirty", "last_append_event_id", "last_append_created_at", "log_size", "file_size", "file_hash")
  13: 
  14: 
  15: def file_sha256(path: str | Path, block_size: int = 65536) -> str | None:
  16:     path = str(path)
  17:     if not os.path.exists(path):
  18:         return None
  19:     h = hashlib.sha256()
  20:     with open(path, "rb") as f:
  21:         while True:
  22:             chunk = f.read(block_size)
  23:             if not chunk:
  24:                 break
  25:             h.update(chunk)
  26:     return h.hexdigest()
  27: 
  28: 
  29: def canonicalize(obj: Any, ignored_keys: set[str] | None = None) -> Any:
  30:     ignored_keys = ignored_keys or set()
  31:     if isinstance(obj, dict):
  32:         return {k: canonicalize(v, ignored_keys) for k, v in sorted(obj.items()) if k not in ignored_keys}
  33:     if isinstance(obj, list):
  34:         return [canonicalize(v, ignored_keys) for v in obj]
  35:     return obj
  36: 
  37: 
  38: def compare_views(a: dict, b: dict) -> bool:
  39:     return canonicalize(a, IGNORED_NODE_KEYS) == canonicalize(b, IGNORED_NODE_KEYS)
  40: 
  41: 
  42: def log_meta_ok(local_meta: dict, peer_meta: dict) -> bool:
  43:     return all(local_meta.get(k) == peer_meta.get(k) for k in INTEGRITY_KEYS)
  44: 
  45: 
  46: def _compact_view(view: dict) -> dict:
  47:     if not isinstance(view, dict):
  48:         return {}
  49:     return {
  50:         "state": view.get("state"),
  51:         "priority": view.get("priority"),
  52:         "log_meta": view.get("log_meta", {}),
  53:         "streams": view.get("streams", {}),
  54:     }
  55: 
  56: 
  57: def local_integrity_api() -> dict:
  58:     path = get_local_log_path()
  59:     alive = compute_alive(include_self=True)
  60:     local_meta = {
  61:         "path": path,
  62:         "size": os.path.getsize(path) if os.path.exists(path) else 0,
  63:         "sha256": file_sha256(path),
  64:     }
  65:     peer_status = {}
  66:     self_view = canonicalize(cluster_state.get(ctx.node_id, {}), IGNORED_NODE_KEYS)
  67:     self_meta = self_view.get("log_meta", {}) if isinstance(self_view, dict) else {}
  68: 
  69:     for node_id, data in alive.items():
  70:         view = canonicalize(data, IGNORED_NODE_KEYS)
  71:         meta = view.get("log_meta", {}) if isinstance(view, dict) else {}
  72:         peer_status[node_id] = {
  73:             "view": _compact_view(view),
  74:             "view_ok": view == canonicalize(cluster_state.get(node_id, {}), IGNORED_NODE_KEYS),
  75:             "log_meta_ok": log_meta_ok(self_meta, meta) if node_id == ctx.node_id else True,
  76:         }
  77: 
  78:     return {
  79:         "node_id": ctx.node_id,
  80:         "alive_nodes": sorted(alive.keys()),
  81:         "self_view": _compact_view(self_view),
  82:         "peer_status": peer_status,
  83:         "local_log_meta": local_meta,
  84:         "last_append_meta": get_last_append_meta(),
  85:         "integrity_ok": all(v["view_ok"] and v["log_meta_ok"] for v in peer_status.values()),
  86:     }
  87: 
  88: 
  89: def cluster_integrity_report() -> dict:
  90:     alive = compute_alive(include_self=True)
  91:     reference = canonicalize(cluster_state, IGNORED_NODE_KEYS)
  92:     per_peer = {}
  93:     for node_id, data in alive.items():
  94:         view = canonicalize(data, IGNORED_NODE_KEYS)
  95:         meta = view.get("log_meta", {}) if isinstance(view, dict) else {}
  96:         ref_view = reference.get(node_id, {})
  97:         ref_meta = ref_view.get("log_meta", {}) if isinstance(ref_view, dict) else {}
  98:         per_peer[node_id] = {
  99:             "matches_reference": view == ref_view,
 100:             "matches_log_meta": meta == ref_meta,
 101:             "state": view.get("state"),
 102:             "priority": view.get("priority"),
 103:             "streams": view.get("streams", {}),
 104:         }
 105: 
 106:     return {
 107:         "node_id": ctx.node_id,
 108:         "alive_nodes": sorted(alive.keys()),
 109:         "reference": {k: _compact_view(v) for k, v in reference.items()} if isinstance(reference, dict) else {},
 110:         "per_peer": per_peer,
 111:         "integrity_ok": all(v["matches_reference"] and v["matches_log_meta"] for v in per_peer.values()),
 112:     }



===== ./runtime/leader.py =====
   1: import time
   2: 
   3: from cluster.runtime.cluster_store import cluster_state
   4: from cluster.runtime import context as ctx
   5: 
   6: LEADER_ALIVE_TIMEOUT = 1.5
   7: 
   8: 
   9: def refresh_self_alive_entry(now=None):
  10:     now = now or time.time()
  11:     if not getattr(ctx, "node", None):
  12:         return
  13:     cluster_state[ctx.node_id] = {
  14:         "state": ctx.node.state.value,
  15:         "priority": ctx.node.priority,
  16:         "last_seen": now,
  17:     }
  18: 
  19: 
  20: def is_alive(data, timeout=LEADER_ALIVE_TIMEOUT, now=None):
  21:     now = now or time.time()
  22:     return (now - data.get("last_seen", 0)) < timeout
  23: 
  24: 
  25: def compute_alive(timeout=LEADER_ALIVE_TIMEOUT, include_self=True):
  26:     now = time.time()
  27:     if include_self:
  28:         refresh_self_alive_entry(now)
  29:     active_nodes = {}
  30:     for node_id, data in cluster_state.items():
  31:         if is_alive(data, timeout=timeout, now=now):
  32:             active_nodes[node_id] = data
  33:     return active_nodes
  34: 
  35: 
  36: def compute_leader(debug_node_id=None, timeout=LEADER_ALIVE_TIMEOUT):
  37:     active_nodes = compute_alive(timeout=timeout, include_self=True)
  38:     if not active_nodes:
  39:         return None
  40:     return min(active_nodes.items(), key=lambda x: (x[1].get("priority", 9999), x[0]))[0]



===== ./runtime/log_replication.py =====
   1: 
   2: import logging
   3: import time
   4: 
   5: import requests
   6: 
   7: from cluster.runtime import context as ctx
   8: from cluster.runtime.cluster_store import cluster_state
   9: from cluster.runtime.registry import CLUSTER_REGISTRY
  10: from cluster.runtime.event_log import read_local_log_text, write_replica_log, get_replica_log_path, read_state, write_state, clear_state
  11: from cluster.utils.log_print import log_state
  12: 
  13: logging.getLogger("urllib3").setLevel(logging.ERROR)
  14: logging.getLogger("requests").setLevel(logging.ERROR)
  15: 
  16: PEERALIVETTLSEC = 3.0
  17: 
  18: 
  19: def canonical_replica_node_id() -> str:
  20:     return ctx.node_id
  21: 
  22: 
  23: def alive_peer_ids():
  24:     out = []
  25:     now = time.time()
  26:     for node_id, data in cluster_state.items():
  27:         if node_id == ctx.node_id:
  28:             continue
  29:         if now - data.get("last_seen", 0) > PEERALIVETTLSEC:
  30:             continue
  31:         out.append(node_id)
  32:     return out
  33: 
  34: 
  35: def replicate_local():
  36:     node_id = canonical_replica_node_id()
  37: 
  38:     log_state("cyan", "REPL TICK", f"node={node_id}", 3)
  39: 
  40:     allowed_states = {"ACTIVE", "STANDBY", "DEGRADED"}
  41:     node_state = getattr(getattr(ctx, "node", None), "state", None)
  42:     node_state_value = getattr(node_state, "value", None)
  43:     log_state("cyan", "REPL STATE", f"state={node_state_value} allowed={node_state_value in allowed_states}", 3)
  44:     if node_state_value not in allowed_states:
  45:         return
  46: 
  47:     state = read_state()
  48:     dirty = bool(state.get("dirty", False))
  49:     log_state("cyan", "REPL FLAG", f"dirty={dirty} state_exists={bool(state)}", 3)
  50:     if not dirty:
  51:         return
  52: 
  53:     content = read_local_log_text()
  54:     log_state("cyan", "REPL CONTENT", f"len={len(content)} empty={not content.strip()}", 3)
  55:     if not content.strip():
  56:         log_state("yellow", "REPL SKIP", "empty content", 3)
  57:         return
  58: 
  59:     write_replica_log(node_id, content)
  60:     log_state("cyan", "REPL WRITE", f"bytes={len(content)}", 3)
  61: 
  62:     peers = alive_peer_ids()
  63:     log_state("cyan", "REPL PEERS", f"peers={peers}", 3)
  64:     if not peers:
  65:         log_state("yellow", "REPL SKIP", "no peers", 3)
  66:         return
  67: 
  68:     success = True
  69:     for peer_id in peers:
  70:         node = CLUSTER_REGISTRY.get(peer_id)
  71:         if not node:
  72:             log_state("red", "LOG REPL FAIL", f"{peer_id} missing registry", 3)
  73:             success = False
  74:             continue
  75: 
  76:         url = f"http://{node['host']}:{node['port']}/debug/log/replica/{node_id}"
  77:         log_state("cyan", "REPL POST", f"peer={peer_id} url={url}", 3)
  78:         try:
  79:             resp = requests.post(
  80:                 url,
  81:                 data=content.encode("utf-8"),
  82:                 headers={"Content-Type": "text/plain; charset=utf-8"},
  83:                 timeout=2,
  84:             )
  85:             if resp.ok:
  86:                 log_state("cyan", "LOG REPL", f"{node_id} -> {peer_id}", 3)
  87:             else:
  88:                 success = False
  89:                 log_state("red", "LOG REPL FAIL", f"{peer_id} status={resp.status_code}", 3)
  90:         except Exception as e:
  91:             success = False
  92:             log_state("red", "LOG REPL FAIL", f"{peer_id} err={e}", 3)
  93: 
  94:     if success:
  95:         clear_state()
  96:         log_state("cyan", "REPL CLEAR", "dirty=false", 3)



