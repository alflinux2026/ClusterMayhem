  63:             "(EVENT)",
  64:             f"{msg:12} -> COMPLETED",
  65:             3
  66:         )
  67: 
  68:     return {
  69:         "status": "forwarded",
  70:         "event_id": event.event_id,
  71:         "target": node_id,
