   4: def send_heartbeat(peer_host, peer_port, payload, timeout=1.0):
   5: 
   6:     url = f"http://{peer_host}:{peer_port}/heartbeat"
   7: 
   8:     try:
   9:         r = requests.post(
  10:             url,
  11:             json=payload,
  12:             timeout=timeout,
  13:         )
  14: 
  15:         return r.json()
  16: 
  17:     except Exception as e:
  18: 
  19:         print(f"[CLIENT ERROR] {url} -> {e}")
  20: 
  21:         return None
  22: 
  23: def broadcast_heartbeat(peers, payload):
  24: 
  25:     for peer in peers:
  26: 
  27:         send_heartbeat(
  28:             peer["host"],
  29:             peer["port"],
  30:             payload,
  31:         )



