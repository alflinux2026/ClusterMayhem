  11: from cluster.runtime.serialization import event_to_record, record_to_event, segment_meta_to_record, record_to_segment_meta
  12: 
  13: BASE_DIR = Path(__file__).resolve().parents[2]
  14: DATA_DIR = BASE_DIR / "cluster" / "data"
  15: STATE_SUFFIX = ".state.json"
  16: 
  17: 
  18: def ensure_dir() -> None:
  19:     DATA_DIR.mkdir(parents=True, exist_ok=True)
  20: 
  21: 
  22: def stream_dir(stream: StreamKey) -> Path:
  23:     return DATA_DIR / stream.tenant_id / stream.app_id / stream.data_type / stream.schema_version
  24: 
  25: 
  26: def current_log_path(stream: StreamKey) -> Path:
  27:     return stream_dir(stream) / "current.jsonl"
  28: 
  29: 
  30: def segments_dir(stream: StreamKey) -> Path:
  31:     return stream_dir(stream) / "segments"
  32: 
  33: 
  34: def segment_log_path(stream: StreamKey, segment_id: str) -> Path:
  35:     return segments_dir(stream) / f"{segment_id}.jsonl"
  36: 
  37: 
  38: def segment_meta_path(stream: StreamKey, segment_id: str) -> Path:
  39:     return segments_dir(stream) / f"{segment_id}.meta.json"
  40: 
  41: 
  42: def state_path(stream: StreamKey) -> Path:
  43:     return stream_dir(stream) / f"current{STATE_SUFFIX}"
  44: 
  45: 
  46: def get_local_log_path(stream: StreamKey | None = None) -> str:
  47:     if stream is None:
  48:         return str(DATA_DIR / "event_log.local.jsonl")
  49:     return str(current_log_path(stream))
  50: 
  51: 
  52: def get_replica_log_path(node_id: str) -> str:
  53:     return str(DATA_DIR / f"event_log.{node_id}.jsonl")
  54: 
  55: 
  56: def list_replica_log_paths() -> List[str]:
  57:     if not DATA_DIR.exists():
  58:         return []
  59:     out: List[str] = []
  60:     for path in sorted(DATA_DIR.iterdir()):
  61:         if path.is_file() and path.name.startswith("event_log.") and path.name.endswith(".jsonl") and path.name != "event_log.local.jsonl":
  62:             out.append(str(path))
  63:     return out
  64: 
  65: 
  66: def load_events_from_path(path: str) -> List[dict]:
  67:     if not os.path.exists(path):
  68:         return []
  69:     events = []
  70:     with open(path, "r", encoding="utf-8") as f:
  71:         for line in f:
  72:             line = line.strip()
  73:             if not line:
  74:                 continue
  75:             try:
  76:                 events.append(json.loads(line))
  77:             except json.JSONDecodeError:
  78:                 continue
  79:     return events
  80: 
  81: 
  82: def write_text_atomic(path: str, content: str) -> None:
  83:     ensure_dir()
  84:     p = Path(path)
  85:     p.parent.mkdir(parents=True, exist_ok=True)
  86:     tmp_path = p.with_suffix(p.suffix + ".tmp")
  87:     with open(tmp_path, "w", encoding="utf-8") as f:
  88:         f.write(content)
  89:         f.flush()
  90:         os.fsync(f.fileno())
  91:     os.replace(tmp_path, p)
  92: 
  93: 
  94: def read_local_log_text(stream: StreamKey | None = None) -> str:
  95:     path = get_local_log_path(stream)
  96:     if not os.path.exists(path):
  97:         return ""
  98:     with open(path, "r", encoding="utf-8") as f:
  99:         return f.read()
 100: 
 101: 
 102: def write_replica_log(node_id: str, content: str) -> None:
 103:     write_text_atomic(get_replica_log_path(node_id), content)
 104: 
 105: 
 106: def read_state(stream: StreamKey) -> dict:
 107:     p = state_path(stream)
 108:     if not p.exists():
 109:         return {}
 110:     try:
 111:         with open(p, "r", encoding="utf-8") as f:
 112:             data = json.load(f)
 113:             return data if isinstance(data, dict) else {}
 114:     except (OSError, json.JSONDecodeError):
 115:         return {}
 116: 
 117: 
 118: def write_state(stream: StreamKey, state: dict) -> None:
 119:     ensure_dir()
 120:     p = state_path(stream)
 121:     p.parent.mkdir(parents=True, exist_ok=True)
 122:     with open(p, "w", encoding="utf-8") as f:
 123:         json.dump(state, f, ensure_ascii=False)
 124: 
 125: 
 126: def clear_state(stream: StreamKey) -> None:
 127:     try:
 128:         os.remove(state_path(stream))
 129:     except FileNotFoundError:
 130:         pass
 131: 
 132: 
 133: def append_event(event: ClusterEvent | EventEnvelope) -> None:
 134:     ensure_dir()
 135:     if isinstance(event, EventEnvelope):
 136:         envelope = event
 137:     else:
 138:         envelope = EventEnvelope.from_cluster_event(event)
 139:     record = event_to_record(envelope)
 140:     stream = StreamKey(**record["stream"])
 141:     path = current_log_path(stream)
 142:     path.parent.mkdir(parents=True, exist_ok=True)
 143:     with open(path, "a", encoding="utf-8") as f:
 144:         f.write(json.dumps(record, ensure_ascii=False) + "\n")
 145:         f.flush()
 146:         os.fsync(f.fileno())
 147:     write_state(stream, {
 148:         "dirty": True,
 149:         "last_append_event_id": record["event_id"],
 150:         "last_append_created_at": record.get("created_at"),
 151:         "stream_id": record["stream"]["stream_id"],
 152:     })
 153: 
 154: 
 155: def load_events(stream: StreamKey | None = None) -> List[dict]:
 156:     if stream is None:
 157:         return load_events_from_path(str(DATA_DIR / "event_log.local.jsonl"))
 158:     return load_events_from_path(str(current_log_path(stream)))
 159: 
 160: 
 161: def load_local_events(stream: StreamKey | None = None) -> List[dict]:
 162:     return load_events(stream)
 163: 
 164: 
 165: def load_replica_events(node_id: str) -> List[dict]:
 166:     return load_events_from_path(get_replica_log_path(node_id))
 167: 
 168: 
 169: def load_all_replica_events() -> List[dict]:
 170:     events: List[dict] = []
 171:     for path in list_replica_log_paths():
 172:         events.extend(load_events_from_path(path))
 173:     return events
 174: 
 175: 
 176: def load_cluster_events() -> List[dict]:
 177:     return load_all_replica_events()
 178: 
 179: 
 180: def get_last_append_meta(stream: StreamKey | None = None) -> dict:
 181:     if stream is None:
 182:         return {}
 183:     state = read_state(stream)
 184:     return {
 185:         "dirty": bool(state.get("dirty", False)),
 186:         "last_append_event_id": state.get("last_append_event_id"),
 187:         "last_append_created_at": state.get("last_append_created_at"),
 188:         "stream_id": state.get("stream_id", stream.stream_id()),
 189:     }
 190: 
 191: 
 192: def _normalize_event(e: dict) -> dict:
 193:     e = dict(e)
 194:     e["schema_version"] = str(e.get("schema_version", "0.1"))
 195:     e.setdefault("received_at", None)
 196:     e.setdefault("attempt", 0)
 197:     e.setdefault("route_hops", [])
 198:     e.setdefault("execution_key", None)
 199:     return e
 200: 
 201: 
 202: def rebuild_event_state_index(stream: StreamKey | None = None) -> Dict[str, dict]:
 203:     latest: Dict[str, dict] = {}
 204:     for e in load_events(stream):
 205:         e = _normalize_event(e)
 206:         latest[e["event_id"]] = e
 207:     return latest
 208: 
 209: 
 210: def get_latest_event(event_id: str, stream: StreamKey | None = None) -> Optional[dict]:
 211:     events = load_events(stream)
 212:     for e in reversed(events):
 213:         if e["event_id"] == event_id:
 214:             return _normalize_event(e)
 215:     return None
 216: 
 217: 
 218: def get_created_events(stream: StreamKey | None = None):
 219:     latest = rebuild_event_state_index(stream)
 220:     domain_events = [record_to_event(e) for e in latest.values()]
 221:     return [e for e in domain_events if e.status == EventStatus.CREATED]
 222: 
 223: 
 224: def get_completed_event_ids(stream: StreamKey | None = None):
 225:     latest = rebuild_event_state_index(stream)
 226:     domain_events = [record_to_event(e) for e in latest.values()]
 227:     return {e.event_id for e in domain_events if e.status == EventStatus.COMPLETED}
 228: 
 229: 
 230: def replay_events(handler, stream: StreamKey | None = None):
 231:     for raw in load_events(stream):
 232:         handler(record_to_event(_normalize_event(raw)))
 233: 
 234: 
 235: def seal_segment(meta: SegmentMeta) -> None:
 236:     ensure_dir()
 237:     p = segment_meta_path(meta.stream, meta.segment_id)
 238:     p.parent.mkdir(parents=True, exist_ok=True)
 239:     with open(p, "w", encoding="utf-8") as f:
 240:         json.dump(segment_meta_to_record(meta), f, ensure_ascii=False, indent=2)
 241: 
 242: 
 243: def load_segment_meta(stream: StreamKey, segment_id: str) -> SegmentMeta | None:
 244:     p = segment_meta_path(stream, segment_id)
 245:     if not p.exists():
 246:         return None
 247:     try:
 248:         with open(p, "r", encoding="utf-8") as f:
 249:             raw = json.load(f)
 250:         return record_to_segment_meta(raw)
 251:     except (OSError, json.JSONDecodeError):
 252:         return None



===== ./runtime/event_router.py =====
   1: import requests
   2: 
   3: from cluster.runtime.registry import CLUSTER_REGISTRY
   4: from cluster.utils.log_print import log_state
   5: from cluster.runtime.events.cluster_event import ClusterEvent
   6: from cluster.runtime.event_log import append_event
   7: from cluster.runtime.events.event_state import EventStatus
   8: 
   9: 
  10: def forward_event(node_id: str, event: ClusterEvent, stream=None):
  11:     node = CLUSTER_REGISTRY[node_id]
  12:     url = f"http://{node['host']}:{node['port']}/execute"
  13: 
  14:     event.add_hop(f"worker:{node_id}")
  15: 
  16:     msg = event.payload.get("msg", "<no-msg>")
  17: 
  18:     log_state("magenta", "[WORKER SEND]", f"{msg:12} -> {node_id}", 3)
  19: 
  20:     try:
  21:         resp = requests.post(
  22:             url,
  23:             json=event.model_dump(),
  24:             timeout=2,
  25:         )
  26:         worker_result = resp.json()
  27:     except Exception as e:
  28:         log_state("red", "[WORKER SEND FAIL]", f"{msg:12} -> {node_id} | {e}", 3)
  29:         return {"error": "worker_send_failed"}
  30: 
  31:     if worker_result.get("status") == "completed":
  32:         event.mark_status(EventStatus.COMPLETED)
  33:         append_event(event)
  34:         log_state("yellow", "(EVENT)", f"{msg:12} -> COMPLETED", 3)
  35: 
  36:     return {
  37:         "status": "forwarded",
  38:         "event_id": event.event_id,
  39:         "target": node_id,
  40:     }
  41: 



