   1: import os
   2: import hashlib
   3: from pathlib import Path
   4: from typing import Any
   5: 
   6: from cluster.runtime import context as ctx
   7: from cluster.runtime.cluster_store import cluster_state
   8: from cluster.runtime.event_log import get_local_log_path, get_last_append_meta
   9: from cluster.runtime.leader import compute_alive
  10: 
  11: IGNORED_NODE_KEYS = {"last_seen"}
  12: 
  13: 
  14: def file_sha256(path: str | Path, block_size: int = 65536) -> str | None:
  15:     path = str(path)
  16:     if not os.path.exists(path):
  17:         return None
  18:     h = hashlib.sha256()
  19:     with open(path, "rb") as f:
  20:         while True:
  21:             chunk = f.read(block_size)
  22:             if not chunk:
  23:                 break
  24:             h.update(chunk)
  25:     return h.hexdigest()
  26: 
  27: 
  28: def canonicalize(obj: Any, ignored_keys: set[str] | None = None) -> Any:
  29:     ignored_keys = ignored_keys or set()
  30:     if isinstance(obj, dict):
  31:         return {k: canonicalize(v, ignored_keys) for k, v in sorted(obj.items()) if k not in ignored_keys}
  32:     if isinstance(obj, list):
  33:         return [canonicalize(v, ignored_keys) for v in obj]
  34:     return obj
  35: 
  36: 
  37: def compare_views(a: dict, b: dict) -> bool:
  38:     return canonicalize(a, IGNORED_NODE_KEYS) == canonicalize(b, IGNORED_NODE_KEYS)
  39: 
  40: 
  41: def log_meta_ok(local_meta: dict, peer_meta: dict) -> bool:
  42:     keys = ("dirty", "last_append_event_id", "last_append_created_at", "log_size", "file_size", "file_hash")
  43:     return all(local_meta.get(k) == peer_meta.get(k) for k in keys)
  44: 
  45: 
  46: def local_integrity_api() -> dict:
  47:     path = get_local_log_path()
  48:     alive = compute_alive(include_self=True)
  49:     local_meta = {
  50:         "path": path,
  51:         "size": os.path.getsize(path) if os.path.exists(path) else 0,
  52:         "sha256": file_sha256(path),
  53:     }
  54:     peer_status = {}
  55:     self_view = canonicalize(cluster_state.get(ctx.node_id, {}), IGNORED_NODE_KEYS)
  56:     self_meta = self_view.get("log_meta", {}) if isinstance(self_view, dict) else {}
  57: 
  58:     for node_id, data in alive.items():
  59:         view = canonicalize(data, IGNORED_NODE_KEYS)
  60:         meta = view.get("log_meta", {}) if isinstance(view, dict) else {}
  61:         peer_status[node_id] = {
  62:             "view": view,
  63:             "view_ok": view == canonicalize(cluster_state.get(node_id, {}), IGNORED_NODE_KEYS),
  64:             "log_meta_ok": log_meta_ok(self_meta, meta) if node_id == ctx.node_id else True,
  65:         }
  66: 
  67:     return {
  68:         "node_id": ctx.node_id,
  69:         "alive_nodes": sorted(alive.keys()),
  70:         "self_view": self_view,
  71:         "cluster_view": canonicalize(cluster_state, IGNORED_NODE_KEYS),
  72:         "peer_status": peer_status,
  73:         "local_log_meta": local_meta,
  74:         "last_append_meta": get_last_append_meta(),
  75:         "integrity_ok": True,
  76:     }
  77: 
  78: 
  79: def cluster_integrity_report() -> dict:
  80:     alive = compute_alive(include_self=True)
  81:     reference = canonicalize(cluster_state, IGNORED_NODE_KEYS)
  82:     per_peer = {}
  83:     for node_id, data in alive.items():
  84:         view = canonicalize(data, IGNORED_NODE_KEYS)
  85:         meta = view.get("log_meta", {}) if isinstance(view, dict) else {}
  86:         ref_view = reference.get(node_id, {})
  87:         ref_meta = ref_view.get("log_meta", {}) if isinstance(ref_view, dict) else {}
  88:         per_peer[node_id] = {
  89:             "matches_reference": view == ref_view,
  90:             "matches_log_meta": meta == ref_meta,
  91:             "view": view,
  92:             "reference_view": ref_view,
  93:         }
  94: 
  95:     return {
  96:         "node_id": ctx.node_id,
  97:         "alive_nodes": sorted(alive.keys()),
  98:         "reference": reference,
  99:         "per_peer": per_peer,
 100:         "integrity_ok": all(v["matches_reference"] and v["matches_log_meta"] for v in per_peer.values()),
 101:     }



===== ./runtime/leader.py =====
   1: import time
   2: 
   3: from cluster.runtime.cluster_store import cluster_state
   4: from cluster.runtime import context as ctx
   5: 
   6: LEADER_ALIVE_TIMEOUT = 1.5
   7: 
   8: 
   9: def refresh_self_alive_entry(now=None):
  10:     now = now or time.time()
  11:     if not getattr(ctx, "node", None):
  12:         return
  13:     cluster_state[ctx.node_id] = {
  14:         "state": ctx.node.state.value,
  15:         "priority": ctx.node.priority,
  16:         "last_seen": now,
  17:     }
  18: 
  19: 
  20: def is_alive(data, timeout=LEADER_ALIVE_TIMEOUT, now=None):
  21:     now = now or time.time()
  22:     return (now - data.get("last_seen", 0)) < timeout
  23: 
  24: 
  25: def compute_alive(timeout=LEADER_ALIVE_TIMEOUT, include_self=True):
  26:     now = time.time()
  27:     if include_self:
  28:         refresh_self_alive_entry(now)
  29:     active_nodes = {}
  30:     for node_id, data in cluster_state.items():
  31:         if is_alive(data, timeout=timeout, now=now):
  32:             active_nodes[node_id] = data
  33:     return active_nodes
  34: 
  35: 
  36: def compute_leader(debug_node_id=None, timeout=LEADER_ALIVE_TIMEOUT):
  37:     active_nodes = compute_alive(timeout=timeout, include_self=True)
  38:     if not active_nodes:
  39:         return None
  40:     return min(active_nodes.items(), key=lambda x: (x[1].get("priority", 9999), x[0]))[0]



