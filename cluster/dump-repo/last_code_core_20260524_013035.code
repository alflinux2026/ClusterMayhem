   1: import logging
   2: import time
   3: import requests
   4: 
   5: from cluster.runtime import context as ctx
   6: from cluster.runtime.cluster_store import cluster_state
   7: from cluster.runtime.registry import CLUSTER_REGISTRY
   8: from cluster.runtime.event_log import (
   9:     get_local_log_path,
  10:     load_replica_events,
  11:     load_all_replica_events,
  12:     load_cluster_events,
  13:     list_replica_log_paths,
  14:     load_events_from_path,
  15:     get_last_append_meta,
  16: )
  17: from cluster.utils.log_print import log_state
  18: 
  19: 
  20: def replicate_local():
  21:     local_path = get_local_log_path()
  22:     if not local_path:
  23:         return
  24:     for node_id, node in CLUSTER_REGISTRY.items():
  25:         try:
  26:             url = f"http://{node['host']}:{node['port']}/debug/log/replica/{ctx.node_id}"
  27:             with open(local_path, 'r', encoding='utf-8') as f:
  28:                 content = f.read()
  29:             requests.post(url, data=content.encode('utf-8'), timeout=2)
  30:         except Exception as e:
  31:             logging.debug(f"replicate_local failed for {node_id}: {e}")
  32: 
  33: 
  34: def replicate_from_peer(node_id: str):
  35:     node = CLUSTER_REGISTRY.get(node_id)
  36:     if not node:
  37:         return
  38:     try:
  39:         url = f"http://{node['host']}:{node['port']}/debug/log/replica/{ctx.node_id}"
  40:         resp = requests.get(url, timeout=2)
  41:         if resp.status_code == 200:
  42:             return resp.text
  43:     except Exception as e:
  44:         logging.debug(f"replicate_from_peer failed for {node_id}: {e}")
  45:     return None
  46: 
  47: 
  48: def sync_replica_state():
  49:     events = load_cluster_events()
  50:     return {
  51:         "replica_paths": list_replica_log_paths(),
  52:         "replica_count": len(events),
  53:         "last_append_meta": get_last_append_meta(),
  54:     }
  55: 



