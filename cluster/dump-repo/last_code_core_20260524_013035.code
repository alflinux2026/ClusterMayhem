 125: def sleep():
 126:     log_state("red", "- SLEEP -", f"{ctx.node_id} -> SLEEP", 3)
 127:     ctx.node.transition(NodeState.ISOLATED)
 128:     return {"ok": True, "node": ctx.node_id, "state": ctx.node.state.value}
 129: 
 130: 
 131: @app.post("/revive")
 132: def revive():
 133:     log_state("red", "- WAKEUP -", f"{ctx.node_id} -> WAKEUP", 3)
 134:     ctx.node.transition(NodeState.STANDBY)
 135:     return {"ok": True, "node": ctx.node_id, "state": ctx.node.state.value}
 136: 
 137: 
 138: @app.get("/health")
