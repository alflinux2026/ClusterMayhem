 160:         "state": hb.state,
 161:         "priority": hb.priority,
 162:         "last_seen": time.time(),
 163:         "log_meta": hb.log_meta or {},
 164:         "cluster_integrity": hb.cluster_integrity or existing.get("cluster_integrity", {}),
 165:         "streams": hb.streams or existing.get("streams", {}),
 166:     }
 167: 
