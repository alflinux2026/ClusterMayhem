  20:     if os.path.exists(path):
  21:         try:
  22:             with open(path, "r", encoding="utf-8") as f:
  23:                 data = json.load(f)
  24:             if isinstance(data, dict) and data:
  25:                 return data
  26:         except (json.JSONDecodeError, OSError):
  27:             pass
  28: 
  29:     node_id = socket.gethostname()
  30:     cfg = {
  31:         "node_id": node_id,
  32:         "priority": int(os.getenv("NODE_PRIORITY", "100")),
  33:         "port": int(os.getenv("NODE_PORT", "8000")),
  34:         "tenant_id": os.getenv("TENANT_ID", "default"),
  35:         "app_id": os.getenv("APP_ID", "mayhem"),
  36:         "data_type": os.getenv("DATA_TYPE", "event"),
  37:         "schema_version": os.getenv("SCHEMA_VERSION", "0.1"),
  38:         "peers": [],
  39:     }
  40:     _write_json_atomic(path, cfg)
  41:     return cfg



