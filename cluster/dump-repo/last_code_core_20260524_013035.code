   7: #   cluster/runtime/node_boot.py 0.0.0 2026-05-19T21:11:14+0200
   8: #   God
   9: #
  10: # Purpose:
  11: # Notes:
  12: #
  13: # FRV-ID: 500641938cf30f1e
  14: # Header_End
  15: 
  16: """
  17: runtime.node_boot
  18: 
  19: Responsabilidad:
  20: - Punto de entrada del proceso de nodo.
  21: - Carga la configuración local, construye el runtime del nodo, inicializa
  22:   el contexto global compartido, arranca el worker de fondo y expone la API HTTP.
  23: 
  24: Rol en la arquitectura:
  25: - Este módulo actúa como ensamblador del nodo.
  26: - No contiene lógica de negocio HTTP ni definición de endpoints.
  27: - La lógica HTTP vive en runtime.api_app.
  28: - La lógica periódica de cluster vive en runtime.node_worker.
  29: 
  30: Entradas:
  31: - Configuración obtenida desde load_or_bootstrap_config().
  32: 
  33: Salidas / efectos laterales:
  34: - Inicializa ctx.node_id, ctx.priority y ctx.node.
  35: - Arranca un NodeWorker en background.
  36: - Lanza uvicorn para servir la API del nodo.
  37: 
  38: Límites:
  39: - No debe contener handlers HTTP.
  40: - No debe contener lógica de ingest, dispatch, reconcile o execute.
  41: - No debe mutar cluster_state directamente.
  42: 
  43: Notas de mantenimiento:
  44: - El orden de inicialización importa: ctx debe quedar listo antes de que
  45:   FastAPI procese requests, porque los endpoints dependen de ctx.node y ctx.node_id.
  46: - Si se cambia el orden de arranque, validar /health, /leader, /cluster y chaos test.
  47: """
  48: 
  49: import threading
  50: 
  51: import uvicorn
  52: 
  53: from cluster.runtime import context as ctx
  54: from cluster.runtime.api_app import app
  55: from cluster.runtime.bootstrap import load_or_bootstrap_config
  56: from cluster.runtime.models import StreamKey
  57: from cluster.runtime.node_runtime import NodeRuntime
  58: from cluster.runtime.node_worker import NodeWorker
  59: from cluster.utils.log_print import log_state
  60: 
  61: 
  62: def build_stream_key(cfg) -> StreamKey:
  63:     return StreamKey(
  64:         tenant_id=str(cfg.get("tenant_id", "default")),
  65:         app_id=str(cfg.get("app_id", "mayhem")),
  66:         data_type=str(cfg.get("data_type", "event")),
  67:         schema_version=str(cfg.get("schema_version", "0.1")),
  68:     )
  69: 
  70: 
  71: def main():
  72:     cfg = load_or_bootstrap_config()
  73:     ctx.stream = build_stream_key(cfg)
  74:     ctx.node = NodeRuntime(cfg["node_id"], cfg["priority"], stream=ctx.stream)
  75:     ctx.node_stream = ctx.stream
  76:     ctx.nodeid = cfg["node_id"]
  77:     ctx.node_id = cfg["node_id"]
  78:     ctx.peers = cfg.get("peers", [])
  79: 
  80:     log_state("cyan", "[BOOT]", f"node={ctx.nodeid} stream={ctx.stream.stream_id()}", 3)
  81: 
  82:     worker = NodeWorker(ctx.node, ctx.peers)
  83:     t = threading.Thread(target=worker.start, daemon=True)
  84:     t.start()
  85: 
  86:     uvicorn.run(app, host="0.0.0.0", port=int(cfg["port"]))
  87: 
  88: 
  89: if __name__ == "__main__":
  90:     main()



===== ./runtime/node_runtime.py =====
   1: from dataclasses import dataclass, field
   2: from pathlib import Path
   3: import os
   4: import time
   5: import requests
   6: 
   7: from cluster.runtime.state import NodeState
   8: from cluster.runtime.leader import compute_leader
   9: from cluster.runtime.event_log import get_last_append_meta, load_events
  10: from cluster.runtime.integrity import file_sha256, cluster_integrity_report
  11: from cluster.utils.log_print import log_state
  12: from cluster.runtime.models import StreamKey
  13: 
  14: 
  15: @dataclass(slots=True)
  16: class NodeRuntimeState:
  17:     node_id: str
  18:     state: NodeState
  19:     priority: int
  20:     stream: StreamKey | None = None
  21:     last_seen: float = field(default_factory=time.time)
  22:     log_meta: dict = field(default_factory=dict)
  23:     cluster_integrity: dict = field(default_factory=dict)
  24:     active_streams: dict = field(default_factory=dict)
  25: 
  26:     def touch(self):
  27:         self.last_seen = time.time()
  28: 
  29: 
  30: class NodeRuntime:
  31:     def __init__(self, node_id, priority, stream: StreamKey | None = None):
  32:         self.runtime_state = NodeRuntimeState(node_id=node_id, state=NodeState.BOOT, priority=priority, stream=stream)
  33:         self.last_heartbeat = time.time()
  34: 
  35:     @property
  36:     def node_id(self):
  37:         return self.runtime_state.node_id
  38: 
  39:     @property
  40:     def priority(self):
  41:         return self.runtime_state.priority
  42: 
  43:     @property
  44:     def state(self):
  45:         return self.runtime_state.state
  46: 
  47:     @state.setter
  48:     def state(self, new_state):
  49:         self.runtime_state.state = new_state
  50:         self.runtime_state.touch()
  51: 
  52:     @property
  53:     def stream(self):
  54:         return self.runtime_state.stream
  55: 
  56:     def transition(self, new_state):
  57:         if self.runtime_state.state == new_state:
  58:             return
  59:         print(f"[{self.node_id}] {self.runtime_state.state} -> {new_state}")
  60:         self.state = new_state
  61: 
  62:     def tick(self):
  63:         if self.state == NodeState.BOOT:
  64:             self.transition(NodeState.STANDBY)
  65:             return
  66: 
  67:         leader = compute_leader()
  68:         if leader == self.node_id:
  69:             if self.state == NodeState.STANDBY:
  70:                 log_state("yellow", "[CLUSTER]", f"[{self.node_id}] becoming ACTIVE", 3)
  71:                 self.transition(NodeState.ACTIVE)
  72:         else:
  73:             if self.state == NodeState.ACTIVE:
  74:                 log_state("yellow", "[CLUSTER]", f"[{self.node_id}] becoming STANDBY", 3)
  75:                 self.transition(NodeState.STANDBY)
  76: 
  77:     def _log_size(self):
  78:         try:
  79:             return len(load_events(self.stream)) if self.stream else len(load_events())
  80:         except Exception:
  81:             return 0
  82: 
  83:     def _file_size(self):
  84:         try:
  85:             if self.stream:
  86:                 path = Path("cluster/data") / self.stream.tenant_id / self.stream.app_id / self.stream.data_type / self.stream.schema_version / "current.jsonl"
  87:                 return os.path.getsize(path)
  88:             return os.path.getsize("cluster/data/event_log.local.jsonl")
  89:         except OSError:
  90:             return 0
  91: 
  92:     def emit_heartbeat(self, peers):
  93:         cluster_int = cluster_integrity_report()
  94:         if self.stream:
  95:             path = Path("cluster/data") / self.stream.tenant_id / self.stream.app_id / self.stream.data_type / self.stream.schema_version / "current.jsonl"
  96:             file_hash = file_sha256(path)
  97:         else:
  98:             file_hash = file_sha256("cluster/data/event_log.local.jsonl")
  99:         log_meta = {
 100:             **get_last_append_meta(self.stream),
 101:             "log_size": self._log_size(),
 102:             "file_size": self._file_size(),
 103:             "file_hash": file_hash,
 104:         }
 105:         self.runtime_state.log_meta = log_meta
 106:         self.runtime_state.cluster_integrity = cluster_int
 107:         hb = {
 108:             "node_id": self.node_id,
 109:             "state": self.state.value,
 110:             "priority": self.priority,
 111:             "log_meta": log_meta,
 112:             "cluster_integrity": {
 113:                 "integrity_ok": cluster_int.get("integrity_ok", False),
 114:                 "alive_nodes": cluster_int.get("alive_nodes", []),
 115:                 "per_peer": cluster_int.get("per_peer", {}),
 116:             },
 117:             "streams": self.runtime_state.active_streams,
 118:         }
 119:         for peer in peers:
 120:             url = f"http://{peer['host']}:{peer['port']}/heartbeat"
 121:             try:
 122:                 requests.post(url, json=hb, timeout=2)
 123:             except requests.exceptions.RequestException:
 124:                 pass
 125: 



