 279: def get_session(worker_id):
 280:     with worker_sessions_lock:
 281:         if worker_id not in worker_sessions:
 282:             s = requests.Session()
 283:             adapter = requests.adapters.HTTPAdapter(pool_connections=16, pool_maxsize=16, max_retries=0)
 284:             s.mount("http://", adapter)
 285:             s.mount("https://", adapter)
 286:             worker_sessions[worker_id] = s
 287:         return worker_sessions[worker_id]
 288: 
 289: 
 290: def kill_node(node, seconds=None):
 291:     stat_inc("kill_attempts")
 292:     try:
 293:         resp = requests.post(f"{node}/sleep", timeout=2)
 294:         try:
 295:             payload = resp.json()
 296:         except Exception:
 297:             payload = {"raw_text": resp.text}
 298:         if resp.status_code == 200 and payload.get("ok") is True:
 299:             with dead_lock:
 300:                 dead_nodes.add(node)
 301:             stat_inc("kills")
 302:             stat_kill_event(node=node, action="sleep", ok=True, payload=payload, seconds=seconds)
 303:             print(f"[CHAOS] SLEEP {node}")
 304:             return True
 305:         stat_inc("kill_failures")
 306:         stat_kill_event(node=node, action="sleep", ok=False, payload=payload, seconds=seconds)
 307:         print(f"[CHAOS FAIL SLEEP] {node} -> status={resp.status_code} payload={payload}")
 308:         return False
 309:     except Exception as e:
 310:         stat_inc("kill_failures")
 311:         stat_kill_event(node=node, action="sleep", ok=False, error=str(e), seconds=seconds)
 312:         print(f"[CHAOS FAIL SLEEP] {node} -> {e}")
 313:         return False
 314: 
 315: 
 316: def revive_node(node):
 317:     try:
 318:         resp = requests.post(f"{node}/revive", timeout=2)
 319:         try:
 320:             payload = resp.json()
 321:         except Exception:
 322:             payload = {"raw_text": resp.text}
 323:         if resp.status_code == 200 and payload.get("ok") is True:
 324:             with dead_lock:
 325:                 dead_nodes.discard(node)
 326:             stat_inc("revives")
 327:             stat_kill_event(node=node, action="revive", ok=True, payload=payload)
 328:             print(f"[CHAOS] REVIVE {node}")
 329:             return True
 330:         stat_inc("revive_failures")
 331:         stat_kill_event(node=node, action="revive", ok=False, payload=payload)
 332:         print(f"[CHAOS FAIL REVIVE] {node} -> status={resp.status_code} payload={payload}")
 333:         return False
 334:     except Exception as e:
 335:         stat_inc("revive_failures")
 336:         stat_kill_event(node=node, action="revive", ok=False, error=str(e))
 337:         print(f"[CHAOS FAIL REVIVE] {node} -> {e}")
 338:         return False
 339: 
 340: 
 341: def kill_cycle(node, seconds):
 342:     try:
 343:         if kill_node(node, seconds=seconds):
 344:             print(f"[CHAOS] DEAD {node} for {seconds:.2f}s")
 345:             time.sleep(seconds)
 346:     finally:
 347:         revive_node(node)
 348: 
 349: 
 350: def process_pending_event(pending: PendingEvent, worker_id: int):
 351:     i = pending.event_index
 352:     event = pending.event
 353:     attempt_number = pending.retries_done + 1
 354:     available = [n for n in NODES if n not in pending.tried_nodes]
 355:     if not available:
 356:         pending.tried_nodes.clear()
 357:         available = list(NODES)
 358:     node = random.choice(available)
 359:     pending.tried_nodes.add(node)
 360:     start = time.time()
 361:     session = get_session(worker_id)
 362:     try:
 363:         r = session.post(f"{node}/event", json=event, timeout=REQUEST_TIMEOUT)
 364:         elapsed_ms = (time.time() - start) * 1000
 365:         stat_latency(elapsed_ms)
 366:         try:
 367:             payload = r.json()
 368:         except Exception:
 369:             payload = {"raw_text": r.text}
 370:         leader = extract_leader(payload)
 371:         if leader:
 372:             stat_leader(leader)
 373:         if elapsed_ms >= SLOW_EVENT_THRESHOLD_MS:
 374:             stat_slow_event(i, attempt_number, node, elapsed_ms, leader, payload)
 375:         if r.status_code == 200:
 376:             stat_inc("submit_http_200")
 377:         result = classify_submit_response(r.status_code, payload)
 378:         row = {"event_index": i, "attempt": attempt_number, "node": node, "status_code": r.status_code, "elapsed_ms": round(elapsed_ms, 3), "leader": leader, "result": result, "final": None}
 379:         if result == "submit_ok":
 380:             stat_inc("events_ok")
 381:             stat_inc("submit_semantic_ok")
 382:             stat_node_ok(node)
 383:             row["final"] = "ok"
 384:             with results_lock:
 385:                 results.append(row)
 386:             print(f"[TORTURE] {i:03} OK attempt={attempt_number} node={node} leader={leader} latency={elapsed_ms:.1f}ms")
 387:             return True
 388:         if result == "retryable_error" or r.status_code >= 500:
 389:             stat_inc("events_retried")
 390:             if isinstance(payload, dict) and payload.get("error") == "no leader":
 391:                 stat_inc("events_no_leader")
 392:             result_payload = payload.get("result") if isinstance(payload.get("result"), dict) else None
 393:             if isinstance(result_payload, dict) and result_payload.get("error") == "no leader":
 394:                 stat_inc("events_no_leader")
 395:             row["final"] = "retry"
 396:             with results_lock:
 397:                 results.append(row)
 398:             print(f"[RETRY] {i:03} attempt={attempt_number} node={node} status={r.status_code} payload={payload}")
 399:             if pending.retries_done + 1 >= MAX_RETRIES:
 400:                 stat_inc("events_failed")
 401:                 stat_unexpected_failure(i, attempt_number, node, r.status_code, payload, "dropped_after_retries_retryable_response")
 402:                 print(f"[DROP] {i:03} event dropped after retries")
 403:                 return False
 404:             pending.retries_done += 1
 405:             stat_inc("queue_requeues")
 406:             enqueue_pending(pending, compute_retry_backoff(pending.retries_done))
 407:             return False
 408:         stat_inc("events_failed")
 409:         stat_inc("submit_hard_fail")
 410:         stat_node_fail(node)
 411:         stat_unexpected_failure(i, attempt_number, node, r.status_code, payload, "hard_fail_non_retryable_response")
 412:         row["final"] = "hard_fail"
 413:         with results_lock:
 414:             results.append(row)
 415:         print(f"[FAIL] {i:03} attempt={attempt_number} node={node} status={r.status_code} payload={payload}")
 416:         return False
 417:     except requests.Timeout as e:
 418:         stat_inc("events_timeout")
 419:         stat_inc("events_retried")
 420:         print(f"[TIMEOUT] {i:03} attempt={attempt_number} {node} -> {e}")
 421:     except requests.ConnectionError as e:
 422:         stat_inc("events_connection_error")
 423:         stat_inc("events_retried")
 424:         print(f"[CONNECTION] {i:03} attempt={attempt_number} {node} -> {e}")
 425:     except Exception as e:
 426:         stat_inc("events_forward_error")
 427:         stat_inc("events_retried")
 428:         stat_unexpected_failure(i, attempt_number, node, reason=f"exception:{type(e).__name__}", payload={"exception": str(e)})
 429:         print(f"[ERROR] {i:03} attempt={attempt_number} {node} -> {e}")
 430:     if pending.retries_done + 1 >= MAX_RETRIES:
 431:         stat_inc("events_failed")
 432:         stat_unexpected_failure(i, attempt_number, node, reason="dropped_after_retries_exception", payload={"tried_nodes": list(pending.tried_nodes)})
 433:         print(f"[DROP] {i:03} event dropped after retries")
 434:         return False
 435:     pending.retries_done += 1
 436:     stat_inc("queue_requeues")
 437:     enqueue_pending(pending, compute_retry_backoff(pending.retries_done))
 438:     return False
 439: 
 440: 
 441: def sender_worker(worker_id):
 442:     while True:
 443:         try:
 444:             run_at, _, pending = pending_queue.get(timeout=0.5)
 445:         except queue.Empty:
 446:             if is_producer_done() and pending_queue.empty():
 447:                 return
 448:             continue
 449:         now = time.time()
 450:         if run_at > now:
 451:             pending_queue.put((run_at, next_enqueue_seq(), pending))
 452:             pending_queue.task_done()
 453:             time.sleep(min(run_at - now, 0.2))
 454:             continue
 455:         try:
 456:             process_pending_event(pending, worker_id)
 457:         finally:
 458:             pending_queue.task_done()
 459: 
 460: 
 461: def chaos_loop():
 462:     for i in range(EVENTS):
 463:         if random.random() < KILL_PROBABILITY:
 464:             node = SLEEP_ONLY_NODE if SLEEP_ONLY_NODE else random.choice(NODES)
 465:             seconds = random.uniform(*DEATH_TIME_RANGE)
 466:             t = threading.Thread(target=kill_cycle, args=(node, seconds), daemon=True)
 467:             t.start()
 468:             kill_threads.append(t)
 469:         stat_inc("events_total")
 470:         enqueue_pending(PendingEvent(event_index=i, event=build_event(i)), delay_seconds=0.0)
 471:         time.sleep(random.uniform(*EVENT_DELAY_RANGE))
 472:     mark_producer_done()
 473: 
 474: 
 475: def revive_everything():
 476:     print("\\n[MAIN] REVIVING ALL NODES\\n")
 477:     for node in sorted(set(NODES)):
 478:         try:
 479:             requests.post(f"{node}/revive", timeout=2)
 480:             print(f"[FORCE REVIVE] {node}")
 481:         except Exception as e:
 482:             print(f"[FORCE REVIVE FAIL] {node} -> {e}")
 483: 
 484: 
 485: def wait_kills():
 486:     print("\\n[MAIN] waiting active kill cycles...\\n")
 487:     for t in kill_threads:
 488:         t.join(timeout=30)
 489: 
 490: 
 491: def wait_queue_drain():
 492:     deadline = time.time() + DRAIN_TIMEOUT
 493:     while time.time() < deadline:
 494:         if pending_queue.empty():
 495:             time.sleep(0.5)
 496:             if pending_queue.empty():
 497:                 return True
 498:         time.sleep(0.2)
 499:     return False
 500: 
 501: 
 502: def write_csv_and_json():
 503:     with results_lock:
 504:         rows = list(results)
 505:     with open(EVENTS_CSV, "w", newline="", encoding="utf-8") as f:
 506:         writer = csv.DictWriter(f, fieldnames=["event_index", "attempt", "node", "status_code", "elapsed_ms", "leader", "result", "final"])
 507:         writer.writeheader()
 508:         writer.writerows(rows)
 509:     with stats_lock:
 510:         total = stats["events_total"]
 511:         ok = stats["events_ok"]
 512:         failed = stats["events_failed"]
 513:         success_rate = ((ok / total) * 100) if total else 0
 514:         avg_latency = (sum(stats["latency"]) / len(stats["latency"])) if stats["latency"] else 0
 515:         max_latency = max(stats["latency"]) if stats["latency"] else 0
 516:         min_latency = min(stats["latency"]) if stats["latency"] else 0
 517:         p50_latency = percentile(stats["latency"], 50)
 518:         p95_latency = percentile(stats["latency"], 95)
 519:         p99_latency = percentile(stats["latency"], 99)
 520:         report = {"test_config": TEST_CONFIG, "run_meta": {"started_at_epoch": TEST_STARTED_AT, "ended_at_epoch": time.time(), "started_at_iso": datetime.fromtimestamp(TEST_STARTED_AT).isoformat(), "ended_at_iso": datetime.now().isoformat(), "duration_seconds": round(time.time() - TEST_STARTED_AT, 3)}, "stats": {**stats, "success_rate": round(success_rate, 2), "latency_avg": round(avg_latency, 3), "latency_min": round(min_latency, 3), "latency_p50": round(p50_latency, 3), "latency_p95": round(p95_latency, 3), "latency_p99": round(p99_latency, 3), "latency_max": round(max_latency, 3), "per_node_ok": dict(stats["per_node_ok"]), "per_node_fail": dict(stats["per_node_fail"]), "leaders_seen": dict(stats["leaders_seen"]), "results_csv": str(EVENTS_CSV)}}
 521:     with open(STATS_FILE, "w", encoding="utf-8") as f:
 522:         json.dump(report, f, indent=2, ensure_ascii=False)
 523: 
