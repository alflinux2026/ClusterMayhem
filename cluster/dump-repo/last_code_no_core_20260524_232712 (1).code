===== ./core/transitions.py =====
   1: from cluster.core.state import NodeState
   2: 
   3: ALLOWED_TRANSITIONS = {
   4:     NodeState.BOOT: {
   5:         NodeState.DISCOVERING,
   6:     },
   7:     NodeState.DISCOVERING: {
   8:         NodeState.STANDBY,
   9:         NodeState.ACTIVE,
  10:         NodeState.ISOLATED,
  11:     },
  12:     NodeState.STANDBY: {
  13:         NodeState.ACTIVE,
  14:         NodeState.DEGRADED,
  15:         NodeState.OFFLINE,
  16:         NodeState.ISOLATED,
  17:     },
  18:     NodeState.ACTIVE: {
  19:         NodeState.STANDBY,
  20:         NodeState.DEGRADED,
  21:         NodeState.OFFLINE,
  22:     },
  23:     NodeState.DEGRADED: {
  24:         NodeState.STANDBY,
  25:         NodeState.OFFLINE,
  26:     },
  27:     NodeState.ISOLATED: {
  28:         NodeState.DISCOVERING,
  29:         NodeState.OFFLINE,
  30:     },
  31: }
  32: 
  33: def can_transition(from_state: NodeState, to_state: NodeState) -> bool:
  34:     return to_state in ALLOWED_TRANSITIONS.get(from_state, set())



