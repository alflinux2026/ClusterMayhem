 290: def render_file_inventory(groups):
 291:     source_order = ["lnx200nas", "lnx202pc", "lnx203hp"]
 292:     NODE_WIDTH = 16
 293:     FILE_WIDTH = 30
 294:     SIZE_WIDTH = 10
 295:     MTIME_WIDTH = 30
 296:     lines = []
 297: 
 298:     for source in source_order:
 299:         if source not in groups:
 300:             continue
 301:         entries = groups[source]
 302:         lines.append(f"### log de {source}:")
 303:         lines.append("")
 304: 
 305:         local = next((e for e in entries if e["node"] == source and "local" in e["file"]), None)
 306:         local_replica = next(
 307:             (e for e in entries if e["node"] == source and e["file"] == f"event_log.{source}.jsonl"),
 308:             None,
 309:         )
 310:         remotes = [
 311:             e for e in entries if e["file"] == f"event_log.{source}.jsonl" and e["node"] != source
 312:         ]
 313:         remotes.sort(key=lambda x: x["node"])
 314: 
 315:         for e in [local, local_replica, *remotes]:
 316:             if not e:
 317:                 continue
 318:             node = (e["node"] + " " * NODE_WIDTH)[:NODE_WIDTH]
 319:             file = (e["file"] + " " * FILE_WIDTH)[:FILE_WIDTH]
 320:             size = (f"{e['size']}" + " " * SIZE_WIDTH)[:SIZE_WIDTH]
 321:             mtime = (e["mtime_date"] + "T" + e["mtime_time"] + e["mtime_tz"] + " " * MTIME_WIDTH)[:MTIME_WIDTH]
 322:             lines.append(f"- {node}  {file}  {size}  {mtime}")
 323: 
 324:         lines.append("")
 325: 
 326:     return lines
 327: 
 328: 
 329: def render_api_detail(api_snapshots):
 330:     source_order = ["lnx200nas", "lnx202pc", "lnx203hp"]
 331:     lines = []
 332:     lines.append("### detalle API por nodo")
 333:     lines.append("")
 334: 
 335:     for node_name in source_order:
 336:         snap = api_snapshots.get(node_name, {})
 337:         lines.append(f"#### {node_name}")
 338:         lines.append("")
 339:         lines.append(f"- health: {json.dumps(snap.get('health', {}), ensure_ascii=False)}")
 340:         lines.append(f"- leader: {json.dumps(snap.get('leader', {}), ensure_ascii=False)}")
 341:         lines.append(f"- integrity: {json.dumps(snap.get('integrity', {}), ensure_ascii=False)}")
 342:         lines.append(f"- events_summary_local: {json.dumps(snap.get('events_summary_local', {}), ensure_ascii=False)}")
 343:         lines.append("- events_summary_replica:")
 344:         for replica_of in source_order:
 345:             replica = snap.get("events_summary_replica", {}).get(replica_of, {})
 346:             lines.append(f"  - {replica_of}: {json.dumps(replica, ensure_ascii=False)}")
 347:         lines.append("")
 348: 
 349:     return lines
 350: 
 351: 
 352: def render_markdown(groups, api_snapshots):
 353:     lines = []
 354:     lines.extend(render_top_summary_1(api_snapshots, groups))
 355:     lines.extend(render_file_inventory(groups))
 356:     #lines.extend(render_top_summary_2(api_snapshots, groups))
 357: #    lines.extend(render_api_detail(api_snapshots))
 358:     return "\n".join(lines).strip() + "\n"
 359: 
