  26: 
  27: @dataclass(frozen=True, slots=True)
  28: class StreamKey:
  29:     tenant_id: str
  30:     app_id: str
  31:     data_type: str
  32:     schema_version: str = "v1"
  33: 
  34:     def stream_id(self) -> str:
  35:         return f"{self.tenant_id}.{self.app_id}.{self.data_type}.{self.schema_version}"
  36: 
  37:     def path_parts(self) -> list[str]:
  38:         return [self.tenant_id, self.app_id, self.data_type, self.schema_version]
  39: 
  40: 
  41: @dataclass(slots=True)
  42: class EventEnvelope:
  43:     stream: StreamKey
  44:     event_type: str
  45:     payload: dict[str, Any] = field(default_factory=dict)
  46:     event_id: str = field(default_factory=lambda: str(uuid4()))
  47:     trace_id: str = field(default_factory=lambda: str(uuid4()))
  48:     status: EventStatus = EventStatus.CREATED
  49:     route_hops: list[str] = field(default_factory=list)
  50:     source_node: Optional[str] = None
  51:     target_node: Optional[str] = None
  52:     execution_key: Optional[str] = None
  53:     created_at: float = field(default_factory=time.time)
  54:     updated_at: float = field(default_factory=time.time)
  55:     received_at: Optional[float] = None
  56:     attempt: int = 0
  57: 
  58:     def add_hop(self, hop: str) -> None:
  59:         self.route_hops.append(hop)
  60:         self.updated_at = time.time()
  61: 
  62:     def mark_status(self, status: EventStatus) -> None:
  63:         self.status = status
  64:         self.updated_at = time.time()
  65: 
  66:     def mark_received(self) -> None:
  67:         self.received_at = time.time()
  68:         self.updated_at = self.received_at
  69: 
  70: 
  71: @dataclass(slots=True)
  72: class SegmentMeta:
  73:     stream: StreamKey
  74:     segment_id: str
  75:     created_at: float = field(default_factory=time.time)
  76:     sealed_at: Optional[float] = None
  77:     first_event_id: Optional[str] = None
  78:     last_event_id: Optional[str] = None
  79:     min_seq: Optional[int] = None
  80:     max_seq: Optional[int] = None
  81:     event_count: int = 0
  82:     size_bytes: int = 0
  83:     sha256: Optional[str] = None
  84:     sealed: bool = False
  85:     dirty: bool = True
  86:     node_id: Optional[str] = None
  87:     file_name: Optional[str] = None
  88: 
  89:     def seal(self, sha256: str, size_bytes: int) -> None:
  90:         self.sealed = True
  91:         self.dirty = False
  92:         self.sealed_at = time.time()
  93:         self.sha256 = sha256
  94:         self.size_bytes = size_bytes
  95: 
  96: 
  97: @dataclass(slots=True)
  98: class NodeRuntimeState:
  99:     node_id: str
 100:     state: NodeState
 101:     priority: int
 102:     last_seen: float = field(default_factory=time.time)
 103:     log_meta: dict[str, Any] = field(default_factory=dict)
 104:     cluster_integrity: dict[str, Any] = field(default_factory=dict)
 105:     active_streams: dict[str, dict[str, Any]] = field(default_factory=dict)
 106: 
 107:     def touch(self) -> None:
 108:         self.last_seen = time.time()
 109: 
 110: 
 111: @dataclass(slots=True)
 112: class HeartbeatState:
 113:     node_id: str
 114:     state: str
 115:     priority: int
 116:     ts: float = field(default_factory=time.time)
 117:     log_meta: dict[str, Any] = field(default_factory=dict)
 118:     cluster_integrity: dict[str, Any] = field(default_factory=dict)
 119:     streams: dict[str, dict[str, Any]] = field(default_factory=dict)
 120: 
 121:     def to_record(self) -> dict[str, Any]:
 122:         return {
 123:             "node_id": self.node_id,
 124:             "state": self.state,
 125:             "priority": self.priority,
 126:             "ts": self.ts,
 127:             "log_meta": self.log_meta,
 128:             "cluster_integrity": self.cluster_integrity,
 129:             "streams": self.streams,
