 112: def fetch_api_snapshot(node):
 113:     base = f"http://{node['host']}:{node['api_port']}"
 114:     dashboard = fetch_json(f"{base}/dashboard/compact")
 115:     health = fetch_json(f"{base}/health")
 116:     integrity = fetch_json(f"{base}/integrity")
 117:     events_summary_local = fetch_json(f"{base}/debug/events/summary")
 118: 
 119:     return {
 120:         "node": node["name"],
 121:         "host": node["host"],
 122:         "health": health,
 123:         "dashboard": dashboard,
 124:         "integrity": integrity,
 125:         "events_summary_local": events_summary_local,
 126:     }
 127: 
 128: 
 129: def build_groups(rows):
 130:     groups = {}
 131:     for row in rows:
 132:         groups.setdefault(row["source"], []).append(row)
 133:     return groups
 134: 
 135: 
 136: def check_consistency(groups):
 137:     for source, entries in groups.items():
 138:         for file_name in set(e["file"] for e in entries):
 139:             entries_file = [e for e in entries if e["file"] == file_name]
 140:             sizes = {e["node"]: e["size"] for e in entries_file}
 141:             mtimes = {e["node"]: (e["mtime_date"], e["mtime_time"]) for e in entries_file}
 142:             size_ok = len(set(sizes.values())) == 1
 143:             mtime_ok = len(set(mtimes.values())) <= 2
 144:             print(
 145:                 f"[INFO] {source}/{file_name}: size={'OK' if size_ok else 'MISMATCH'} "
 146:                 f"mtime={'OK' if mtime_ok else 'MISMATCH'}"
 147:             )
