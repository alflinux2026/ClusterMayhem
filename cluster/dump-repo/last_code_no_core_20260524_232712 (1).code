 355: def draw_top_summary_curses(stdscr, start_y, api_snapshots, width):
 356:     source_order = ["lnx200nas", "lnx202pc", "lnx203hp"]
 357: 
 358:     NODE_W = 12
 359:     HEALTH_W = 8
 360:     STATE_W = 12
 361:     TSTATE_W = 8
 362:     PRES_W = 7
 363:     WDOG_W = 7
 364:     BUSY_W = 5
 365:     SIZE_W = 10
 366:     EVENTS_W = 12
 367:     COUNT_W = 9
 368:     DIRTY_W = 7
 369: 
 370:     def cut(value, width):
 371:         s = "-" if value is None else str(value)
 372:         return s if len(s) <= width else s[: max(0, width - 1)] + "…"
 373: 
 374:     def fmt_age(value):
 375:         if value is None:
 376:             return "-"
 377:         try:
 378:             value = float(value)
 379:         except Exception:
 380:             return "-"
 381:         if value < 60:
 382:             return f"{value:.0f}s"
 383:         if value < 3600:
 384:             return f"{value / 60:.1f}m"
 385:         return f"{value / 3600:.1f}h"
 386: 
 387:     def fmt_busy(value):
 388:         if value is True:
 389:             return "Y"
 390:         if value is False:
 391:             return "-"
 392:         return "?"
 393: 
 394:     def put(y, x, text, attr=0):
 395:         if y < 0 or x >= width - 1:
 396:             return
 397:         stdscr.addnstr(y, x, text, max(1, width - 1 - x), attr)
 398: 
 399:     y = start_y
 400: 
 401:     put(y, 0, "### resumen cluster", curses.color_pair(4) | curses.A_BOLD)
 402:     y += 2
 403:     put(
 404:         y,
 405:         0,
 406:         "- leader esperado: "
 407:         + ", ".join(
 408:             f"{node}: {api_snapshots.get(node, {}).get('dashboard', {}).get('cluster', {}).get('leader', '?')}"
 409:             for node in source_order
 410:         ),
 411:         curses.color_pair(4),
 412:     )
 413:     y += 2
 414: 
 415:     header = (
 416:         f"- {'nodo':<{NODE_W}}  {'health':<{HEALTH_W}}  {'state':<{STATE_W}}  {'t_state':>{TSTATE_W}}  "
 417:         f"{'pres':>{PRES_W}}  {'wdog':>{WDOG_W}}  {'busy':<{BUSY_W}}  "
 418:         f"{'local_size':>{SIZE_W}}  {'local_events':>{EVENTS_W}}  "
 419:         f"{'created':>{COUNT_W}}  {'executing':>{COUNT_W}}  {'completed':>{COUNT_W}}  {'dirty':<{DIRTY_W}}"
 420:     )
 421:     put(y, 0, header, curses.color_pair(4) | curses.A_BOLD)
 422:     y += 1
 423: 
 424:     for node_name in source_order:
 425:         view = _node_runtime_view(api_snapshots, node_name)
 426:         health_value = cut(view["health"], HEALTH_W)
 427:         state_value = cut(view["state"], STATE_W)
 428:         stale_state = str(health_value).lower() == "stale"
 429: 
 430:         cols = [
 431:             (f"- {node_name:<{NODE_W}}  ", curses.color_pair(5)),
 432:             (f"{health_value:<{HEALTH_W}}  ", color_for_health(health_value)),
 433:             (f"{state_value:<{STATE_W}}  ", color_for_state(state_value, stale=stale_state)),
 434:             (f"{fmt_age(view['state_age_s']):>{TSTATE_W}}  ", curses.color_pair(5)),
 435:             (f"{fmt_age(view['presence_age_s']):>{PRES_W}}  ", color_for_age(view["presence_age_s"], warn_s=1.5, stale_s=3.0)),
 436:             (f"{fmt_age(view['watchdog_age_s']):>{WDOG_W}}  ", color_for_age(view["watchdog_age_s"], warn_s=1.5, stale_s=3.0)),
 437:             (f"{fmt_busy(view['watchdog_busy']):<{BUSY_W}}  ", color_for_busy(view["watchdog_busy"])),
 438:             (f"{view['local_size']:>{SIZE_W}}  ", curses.color_pair(5)),
 439:             (f"{view['local_events']:>{EVENTS_W}}  ", curses.color_pair(5)),
 440:             (f"{view['created']:>{COUNT_W}}  ", color_for_count("created", view["created"])),
 441:             (f"{view['executing']:>{COUNT_W}}  ", color_for_count("executing", view["executing"])),
 442:             (f"{view['completed']:>{COUNT_W}}  ", color_for_count("completed", view["completed"])),
 443:             (f"{cut(view['dirty'], DIRTY_W):<{DIRTY_W}}", color_for_dirty(view["dirty"])),
 444:         ]
 445: 
 446:         x = 0
 447:         for text, attr in cols:
 448:             put(y, x, text, attr)
 449:             x += len(text)
 450: 
 451:         y += 1
 452: 
 453:     return y + 1
 454: 
 455: 
 456: def render_file_inventory(groups):
 457:     source_order = ["lnx200nas", "lnx202pc", "lnx203hp"]
 458:     NODE_WIDTH = 16
 459:     FILE_WIDTH = 30
 460:     SIZE_WIDTH = 10
 461:     MTIME_WIDTH = 30
 462:     lines = []
 463: 
 464:     for source in source_order:
 465:         if source not in groups:
 466:             continue
 467:         entries = groups[source]
 468:         lines.append(f"### log de {source}:")
 469:         lines.append("")
 470: 
 471:         local = next((e for e in entries if e["node"] == source and "local" in e["file"]), None)
 472:         local_replica = next(
 473:             (e for e in entries if e["node"] == source and e["file"] == f"event_log.{source}.jsonl"),
 474:             None,
 475:         )
 476:         remotes = [
 477:             e for e in entries if e["file"] == f"event_log.{source}.jsonl" and e["node"] != source
 478:         ]
 479:         remotes.sort(key=lambda x: x["node"])
 480: 
 481:         for e in [local, local_replica, *remotes]:
 482:             if not e:
 483:                 continue
 484:             node = (e["node"] + " " * NODE_WIDTH)[:NODE_WIDTH]
 485:             file = (e["file"] + " " * FILE_WIDTH)[:FILE_WIDTH]
 486:             size = (f"{e['size']}" + " " * SIZE_WIDTH)[:SIZE_WIDTH]
 487:             mtime = (e["mtime_date"] + "T" + e["mtime_time"] + e["mtime_tz"] + " " * MTIME_WIDTH)[:MTIME_WIDTH]
 488:             lines.append(f"- {node}  {file}  {size}  {mtime}")
 489: 
 490:         lines.append("")
 491: 
 492:     return lines
 493: 
 494: 
 495: def render_markdown(groups, api_snapshots):
 496:     lines = []
 497:     lines.extend(render_top_summary_1(api_snapshots, groups))
 498:     lines.extend(render_file_inventory(groups))
 499:     return "\n".join(lines).strip() + "\n"
 500: 
 501: 
 502: def collect_snapshot():
 503:     all_rows = []
 504:     api_snapshots = {}
 505:     errors = []
 506: 
 507:     for node in NODES:
 508:         try:
 509:             text = ssh_ls(node)
 510:             rows = parse_ls_output(node["name"], text)
 511:             all_rows.extend(rows)
 512:         except Exception as e:
 513:             errors.append(f"SSH {node['name']}: {e}")
 514: 
 515:         try:
 516:             api_snapshots[node["name"]] = fetch_api_snapshot(node)
 517:         except Exception as e:
 518:             errors.append(f"API {node['name']}: {e}")
 519:             api_snapshots[node["name"]] = {"node": node["name"], "error": str(e)}
 520: 
 521:     groups = build_groups(all_rows)
 522:     return groups, api_snapshots, errors
 523: 
 524: 
 525: def write_outputs(groups, api_snapshots):
 526:     all_rows = []
 527:     for entries in groups.values():
 528:         all_rows.extend(entries)
 529: 
 530:     md = render_markdown(groups, api_snapshots)
 531:     OUT_MD.write_text(md, encoding="utf-8")
 532: 
 533:     with OUT_CSV.open("w", newline="", encoding="utf-8") as f:
 534:         writer = csv.DictWriter(
 535:             f,
 536:             fieldnames=["node", "file", "source", "mtime_date", "mtime_time", "mtime_tz", "size"],
 537:         )
 538:         writer.writeheader()
 539:         writer.writerows(all_rows)
 540: 
 541:     OUT_API_JSON.write_text(json.dumps(api_snapshots, ensure_ascii=False, indent=2), encoding="utf-8")
 542: 
 543: 
 544: def save_snapshot(lines, groups, api_snapshots, errors, started_at, refresh_seconds):
 545:     OUT_SNAPSHOT_DIR.mkdir(parents=True, exist_ok=True)
 546:     ts_file = datetime.now().strftime("%Y%m%d_%H%M%S")
 547: 
 548:     md_path = OUT_SNAPSHOT_DIR / f"cluster_live_snapshot_{ts_file}.md"
 549:     json_path = OUT_SNAPSHOT_DIR / f"cluster_live_snapshot_{ts_file}.json"
 550: 
 551:     md_content = "\n".join(lines).strip() + "\n"
 552:     md_path.write_text(md_content, encoding="utf-8")
 553: 
 554:     snapshot_payload = {
 555:         "captured_at": datetime.now().isoformat(),
 556:         "refresh_seconds": refresh_seconds,
 557:         "monitor_uptime_s": round(time.time() - started_at, 3),
 558:         "errors": errors,
 559:         "groups": groups,
 560:         "api_snapshots": api_snapshots,
 561:         "rendered_lines": lines,
 562:     }
 563:     json_path.write_text(json.dumps(snapshot_payload, ensure_ascii=False, indent=2), encoding="utf-8")
 564: 
 565:     return md_path, json_path
 566: 
 567: 
 568: def build_screen_lines(groups, api_snapshots, errors, started_at, refresh_seconds):
 569:     ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
 570:     lines = []
 571:     lines.append(
 572:         f"cluster_live.py  actualizado: {ts}  refresh={refresh_seconds:.1f}s  "
 573:         f"[s]=snapshot md+json  [q]=salir"
 574:     )
 575:     lines.append("")
 576:     if errors:
 577:         lines.append("errores:")
 578:         for err in errors:
 579:             lines.append(f"- {err}")
 580:         lines.append("")
 581:     lines.extend(render_top_summary_1(api_snapshots, groups))
 582:     lines.extend(render_file_inventory(groups))
 583:     lines.append(f"uptime monitor: {time.time() - started_at:.1f}s")
 584:     if LAST_STATUS_LINE:
 585:         lines.append("")
 586:         lines.append(LAST_STATUS_LINE)
 587:     return lines
 588: 
 589: 
 590: def ui_loop(stdscr, refresh_seconds=1.5):
 591:     global LAST_STATUS_LINE
 592: 
 593:     curses.curs_set(0)
 594:     curses.noecho()
 595:     curses.cbreak()
 596:     stdscr.nodelay(True)
 597:     stdscr.keypad(True)
 598:     setup_colors()
 599:     started_at = time.time()
 600: 
 601:     while True:
 602:         cycle_start = time.time()
 603:         groups, api_snapshots, errors = collect_snapshot()
 604:         write_outputs(groups, api_snapshots)
 605:         lines = build_screen_lines(groups, api_snapshots, errors, started_at, refresh_seconds)
 606: 
 607:         stdscr.erase()
 608:         height, width = stdscr.getmaxyx()
 609:         usable_height = max(1, height - 1)
 610: 
 611:         stdscr.addnstr(
 612:             0,
 613:             0,
 614:             f"cluster_live.py  actualizado: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}  refresh={refresh_seconds:.1f}s  [s]=snapshot md+json  [q]=salir",
 615:             max(1, width - 1),
 616:             curses.color_pair(4) | curses.A_BOLD,
 617:         )
 618: 
 619:         y = 2
 620: 
 621:         if errors:
 622:             stdscr.addnstr(y, 0, "errores:", max(1, width - 1), curses.color_pair(3) | curses.A_BOLD)
 623:             y += 1
 624:             for err in errors:
 625:                 if y >= usable_height:
 626:                     break
 627:                 stdscr.addnstr(y, 0, f"- {err}", max(1, width - 1), curses.color_pair(3))
 628:                 y += 1
 629:             y += 1
 630: 
 631:         if y < usable_height:
 632:             y = draw_top_summary_curses(stdscr, y, api_snapshots, width)
 633: 
 634:         plain_lines = render_file_inventory(groups)
 635:         plain_lines.append(f"uptime monitor: {time.time() - started_at:.1f}s")
 636:         if LAST_STATUS_LINE:
 637:             plain_lines.append("")
 638:             plain_lines.append(LAST_STATUS_LINE)
 639: 
 640:         for line in plain_lines:
 641:             if y >= usable_height:
 642:                 break
 643:             stdscr.addnstr(y, 0, line, max(1, width - 1))
 644:             y += 1
 645: 
 646:         stdscr.refresh()
 647: 
 648:         while True:
 649:             key = stdscr.getch()
 650: 
 651:             if key in (ord("q"), ord("Q")):
 652:                 return
 653: 
 654:             if key in (ord("s"), ord("S")):
 655:                 try:
 656:                     md_path, json_path = save_snapshot(
 657:                         lines=lines,
 658:                         groups=groups,
 659:                         api_snapshots=api_snapshots,
 660:                         errors=errors,
 661:                         started_at=started_at,
 662:                         refresh_seconds=refresh_seconds,
 663:                     )
 664:                     LAST_STATUS_LINE = f"[snapshot] guardado md={md_path} json={json_path}"
 665:                 except Exception as e:
 666:                     LAST_STATUS_LINE = f"[snapshot] error: {e}"
 667:                 break
 668: 
 669:             if key == -1:
 670:                 pass
 671:             else:
 672:                 continue
 673: 
 674:             if time.time() - cycle_start >= refresh_seconds:
 675:                 break
 676: 
 677:             time.sleep(0.05)
 678: 
 679: 
 680: def run_live_monitor(refresh_seconds=1.5):
 681:     curses.wrapper(lambda stdscr: ui_loop(stdscr, refresh_seconds=refresh_seconds))
 682: 
 683: 
 684: def run_once():
 685:     all_rows = []
 686:     api_snapshots = {}
 687: 
 688:     for node in NODES:
 689:         print(f"[INFO] Consultando SSH {node['name']} ({node['host']})...")
 690:         try:
 691:             text = ssh_ls(node)
 692:             rows = parse_ls_output(node["name"], text)
 693:             all_rows.extend(rows)
 694:         except Exception as e:
 695:             print(f"[ERROR] SSH {node['name']}: {e}")
 696: 
 697:         print(f"[INFO] Consultando API {node['name']} ({node['host']})...")
 698:         api_snapshots[node["name"]] = fetch_api_snapshot(node)
 699: 
 700:     groups = build_groups(all_rows)
 701:     check_consistency(groups)
 702:     write_outputs(groups, api_snapshots)
 703: 
 704:     print(f"[OK] Markdown: {OUT_MD}")
 705:     print(f"[OK] CSV: {OUT_CSV}")
 706:     print(f"[OK] API JSON: {OUT_API_JSON}")
 707: 
 708: 
 709: if __name__ == "__main__":
 710:     run_live_monitor()



