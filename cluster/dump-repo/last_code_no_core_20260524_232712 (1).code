 361: def main():
 362:     all_rows = []
 363:     api_snapshots = {}
 364: 
 365:     for node in NODES:
 366:         print(f"[INFO] Consultando SSH {node['name']} ({node['host']})...")
 367:         try:
 368:             text = ssh_ls(node)
 369:             rows = parse_ls_output(node["name"], text)
 370:             all_rows.extend(rows)
 371:         except Exception as e:
 372:             print(f"[ERROR] SSH {node['name']}: {e}")
 373: 
 374:         print(f"[INFO] Consultando API {node['name']} ({node['host']})...")
 375:         api_snapshots[node["name"]] = fetch_api_snapshot(node)
 376: 
 377:     groups = build_groups(all_rows)
 378:     check_consistency(groups)
 379: 
 380:     md = render_markdown(groups, api_snapshots)
 381:     OUT_MD.write_text(md, encoding="utf-8")
 382: 
 383:     with OUT_CSV.open("w", newline="", encoding="utf-8") as f:
 384:         writer = csv.DictWriter(
 385:             f,
 386:             fieldnames=["node", "file", "source", "mtime_date", "mtime_time", "mtime_tz", "size"],
 387:         )
 388:         writer.writeheader()
 389:         writer.writerows(all_rows)
 390: 
 391:     OUT_API_JSON.write_text(json.dumps(api_snapshots, ensure_ascii=False, indent=2), encoding="utf-8")
 392: 
 393:     print(f"[OK] Markdown: {OUT_MD}")
 394:     print(f"[OK] CSV: {OUT_CSV}")
 395:     print(f"[OK] API JSON: {OUT_API_JSON}")
 396: 
 397: 
 398: if __name__ == "__main__":
 399:     main()



