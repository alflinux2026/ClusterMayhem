 563: def wait_queue_drain():
 564:     deadline = time.time() + DRAIN_TIMEOUT
 565:     while time.time() < deadline:
 566:         if pending_queue.empty():
 567:             time.sleep(0.5)
 568:             if pending_queue.empty():
 569:                 return True
 570:         time.sleep(0.2)
 571:     return False
 572: 
