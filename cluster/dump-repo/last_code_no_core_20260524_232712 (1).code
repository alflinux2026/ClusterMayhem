  23: DEFAULT_EVENT_DELAY_MIN = 0.05
  24: DEFAULT_EVENT_DELAY_MAX = 0.2
  25: DEFAULT_KILL_PROBABILITY = 0.1
  26: DEFAULT_DEATH_TIME_MIN = 5.0
  27: DEFAULT_DEATH_TIME_MAX = 10.0
  28: DEFAULT_REQUEST_TIMEOUT = 5.0
  29: DEFAULT_MAX_RETRIES = 10
  30: DEFAULT_SLOW_EVENT_THRESHOLD_MS = 500.0
  31: DEFAULT_SLEEP_ONLY_NODE = None
