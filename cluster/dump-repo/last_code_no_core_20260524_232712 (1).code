 555: def main():
 556:     print(f"[MAIN] starting UNIVERSAL chaos torture final v2 ({ARGS.mode})")
 557:     print_test_config()
 558:     workers = []
 559:     for idx in range(SEND_WORKERS):
 560:         t = threading.Thread(target=sender_worker, args=(idx,), daemon=True)
 561:         t.start()
 562:         workers.append(t)
 563:     drained = False
 564:     try:
 565:         chaos_loop()
 566:         drained = wait_queue_drain()
 567:         pending_queue.join()
 568:         for t in workers:
 569:             t.join(timeout=5)
 570:     finally:
 571:         wait_kills()
 572:         revive_everything()
 573:         if not drained:
 574:             print(f"\\n[MAIN WARN] queue drain timeout reached after {DRAIN_TIMEOUT:.1f}s\\n")
 575:         write_csv_and_json()
 576:         print_stats()
 577:         print("\\n[MAIN] cluster restored\\n")
 578: 
 579: 
 580: if __name__ == "__main__":
 581:     main()



