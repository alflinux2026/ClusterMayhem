 275: def render_top_summary_1(api_snapshots, groups):
 276:     source_order = ["lnx200nas", "lnx202pc", "lnx203hp"]
 277:     lines = []
 278: 
 279:     NODE_W = 12
 280:     HEALTH_W = 8
 281:     STATE_W = 12
 282:     TSTATE_W = 8
 283:     PRES_W = 7
 284:     WDOG_W = 7
 285:     BUSY_W = 5
 286:     SIZE_W = 10
 287:     EVENTS_W = 12
 288:     COUNT_W = 9
 289:     DIRTY_W = 7
 290: 
 291:     def cut(value, width):
 292:         s = "-" if value is None else str(value)
 293:         return s if len(s) <= width else s[: max(0, width - 1)] + "…"
 294: 
 295:     def fmt_age(value):
 296:         if value is None:
 297:             return "-"
 298:         try:
 299:             value = float(value)
 300:         except Exception:
 301:             return "-"
 302:         if value < 60:
 303:             return f"{value:.0f}s"
 304:         if value < 3600:
 305:             return f"{value / 60:.1f}m"
 306:         return f"{value / 3600:.1f}h"
 307: 
 308:     def fmt_busy(value):
 309:         if value is True:
 310:             return "Y"
 311:         if value is False:
 312:             return "-"
 313:         return "?"
 314: 
 315:     lines.append("### resumen cluster")
 316:     lines.append("")
 317:     lines.append(
 318:         "- leader esperado: "
 319:         + ", ".join(
 320:             f"{node}: {api_snapshots.get(node, {}).get('dashboard', {}).get('cluster', {}).get('leader', '?')}"
 321:             for node in source_order
 322:         )
 323:     )
 324:     lines.append("")
 325:     lines.append(
 326:         f"- {'nodo':<{NODE_W}}  {'health':<{HEALTH_W}}  {'state':<{STATE_W}}  {'t_state':>{TSTATE_W}}  "
 327:         f"{'pres':>{PRES_W}}  {'wdog':>{WDOG_W}}  {'busy':<{BUSY_W}}  "
 328:         f"{'local_size':>{SIZE_W}}  {'local_events':>{EVENTS_W}}  "
 329:         f"{'created':>{COUNT_W}}  {'executing':>{COUNT_W}}  {'completed':>{COUNT_W}}  "
 330:         f"{'dirty':<{DIRTY_W}}"
 331:     )
 332: 
 333:     for node_name in source_order:
 334:         view = _node_runtime_view(api_snapshots, node_name)
 335:         lines.append(
 336:             f"- {node_name:<{NODE_W}}  "
 337:             f"{cut(view['health'], HEALTH_W):<{HEALTH_W}}  "
 338:             f"{cut(view['state'], STATE_W):<{STATE_W}}  "
 339:             f"{fmt_age(view['state_age_s']):>{TSTATE_W}}  "
 340:             f"{fmt_age(view['presence_age_s']):>{PRES_W}}  "
 341:             f"{fmt_age(view['watchdog_age_s']):>{WDOG_W}}  "
 342:             f"{fmt_busy(view['watchdog_busy']):<{BUSY_W}}  "
 343:             f"{view['local_size']:>{SIZE_W}}  "
 344:             f"{view['local_events']:>{EVENTS_W}}  "
 345:             f"{view['created']:>{COUNT_W}}  "
 346:             f"{view['executing']:>{COUNT_W}}  "
 347:             f"{view['completed']:>{COUNT_W}}  "
 348:             f"{cut(view['dirty'], DIRTY_W):<{DIRTY_W}}"
 349:         )
 350: 
 351:     lines.append("")
 352:     return lines
 353: 
