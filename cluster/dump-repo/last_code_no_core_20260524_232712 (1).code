  12: def load_config():
  13: 
  14:     with open("cluster/config/nodes.json") as f:
  15:         return json.load(f)
  16: 
  17: 
  18: def build_peers(config, self_id):
  19: 
  20:     return [
  21:         n for n in config["nodes"]
  22:         if n["node_id"] != self_id
  23:     ]
  24: 
  25: 
  26: def main(node_id, priority):
  27: 
