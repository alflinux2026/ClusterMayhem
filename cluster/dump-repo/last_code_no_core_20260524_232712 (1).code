 374: def revive_node(node):
 375:     try:
 376:         resp = requests.post(f"{node}/revive", timeout=2)
 377:         try:
 378:             payload = resp.json()
 379:         except Exception:
 380:             payload = {"raw_text": resp.text}
 381:         if resp.status_code == 200 and payload.get("ok") is True:
 382:             with dead_lock:
 383:                 dead_nodes.discard(node)
 384:             stat_inc("revives")
 385:             stat_kill_event(node=node, action="revive", ok=True, payload=payload)
 386:             print(f"[CHAOS] REVIVE {node}")
 387:             return True
 388:         stat_inc("revive_failures")
 389:         stat_kill_event(node=node, action="revive", ok=False, payload=payload)
 390:         print(f"[CHAOS FAIL REVIVE] {node} -> status={resp.status_code} payload={payload}")
 391:         return False
 392:     except Exception as e:
 393:         stat_inc("revive_failures")
 394:         stat_kill_event(node=node, action="revive", ok=False, error=str(e))
 395:         print(f"[CHAOS FAIL REVIVE] {node} -> {e}")
 396:         return False
