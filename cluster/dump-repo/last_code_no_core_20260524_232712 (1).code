 554: def wait_queue_drain():
 555:     deadline = time.time() + DRAIN_TIMEOUT
 556:     while time.time() < deadline:
 557:         if pending_queue.empty():
 558:             time.sleep(0.5)
 559:             if pending_queue.empty():
 560:                 return True
 561:         time.sleep(0.2)
 562:     return False
