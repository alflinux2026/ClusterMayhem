 525: def print_stats():
 526:     with stats_lock:
 527:         total = stats["events_total"]
 528:         ok = stats["events_ok"]
 529:         failed = stats["events_failed"]
 530:         success_rate = ((ok / total) * 100) if total else 0
 531:         avg_latency = (sum(stats["latency"]) / len(stats["latency"])) if stats["latency"] else 0
 532:         max_latency = max(stats["latency"]) if stats["latency"] else 0
 533:         min_latency = min(stats["latency"]) if stats["latency"] else 0
 534:         p50_latency = percentile(stats["latency"], 50)
 535:         p95_latency = percentile(stats["latency"], 95)
 536:         p99_latency = percentile(stats["latency"], 99)
 537:     print("\\n" + "=" * 56)
 538:     print("FINAL CHAOS STATS")
 539:     print("=" * 56)
 540:     print(f"events_total........: {total}")
 541:     print(f"events_ok...........: {ok}")
 542:     print(f"events_failed.......: {failed}")
 543:     print(f"success_rate........: {success_rate:.2f}%")
 544:     print(f"latency_avg.........: {avg_latency:.1f} ms")
 545:     print(f"latency_min.........: {min_latency:.1f} ms")
 546:     print(f"latency_p50.........: {p50_latency:.1f} ms")
 547:     print(f"latency_p95.........: {p95_latency:.1f} ms")
 548:     print(f"latency_p99.........: {p99_latency:.1f} ms")
 549:     print(f"latency_max.........: {max_latency:.1f} ms")
 550:     print(f"stats_file..........: {STATS_FILE}")
 551:     print(f"events_csv..........: {EVENTS_CSV}")
 552:     print("=" * 56)
