  10: def event_to_record(event: EventEnvelope) -> dict[str, Any]:
  11:     return {
  12:         "event_id": event.event_id,
  13:         "trace_id": event.trace_id,
  14:         "stream": {
  15:             "tenant_id": event.stream.tenant_id,
  16:             "app_id": event.stream.app_id,
  17:             "data_type": event.stream.data_type,
  18:             "schema_version": event.stream.schema_version,
  19:             "stream_id": event.stream.stream_id(),
  20:         },
  21:         "stream_id": event.stream.stream_id(),
  22:         "tenant_id": event.stream.tenant_id,
  23:         "app_id": event.stream.app_id,
  24:         "data_type": event.stream.data_type,
  25:         "schema_version": event.stream.schema_version,
  26:         "event_type": event.event_type,
  27:         "payload": event.payload,
  28:         "status": event.status.value,
  29:         "route_hops": event.route_hops,
  30:         "source_node": event.source_node,
  31:         "target_node": event.target_node,
  32:         "execution_key": event.execution_key,
  33:         "created_at": event.created_at,
  34:         "updated_at": event.updated_at,
  35:         "received_at": event.received_at,
  36:         "attempt": event.attempt,
  37:     }
  38: 
  39: 
  40: def record_to_event(record: dict[str, Any]) -> EventEnvelope:
  41:     stream_data = record.get("stream")
  42:     if isinstance(stream_data, dict):
  43:         stream = StreamKey(
  44:             tenant_id=stream_data.get("tenant_id", record.get("tenant_id", "default")),
  45:             app_id=stream_data.get("app_id", record.get("app_id", "default")),
  46:             data_type=stream_data.get("data_type", record.get("data_type", "event")),
  47:             schema_version=stream_data.get("schema_version", record.get("schema_version", "v1")),
  48:         )
  49:     else:
  50:         stream = StreamKey(
  51:             tenant_id=record.get("tenant_id", "default"),
  52:             app_id=record.get("app_id", "default"),
  53:             data_type=record.get("data_type", "event"),
  54:             schema_version=record.get("schema_version", "v1"),
  55:         )
  56:     event = EventEnvelope(
  57:         stream=stream,
  58:         event_type=record.get("event_type", ""),
  59:         payload=record.get("payload", {}),
  60:         event_id=record.get("event_id"),
  61:         trace_id=record.get("trace_id"),
  62:         status=EventStatus(record.get("status", EventStatus.CREATED.value)),
  63:         route_hops=record.get("route_hops", []),
  64:         source_node=record.get("source_node"),
  65:         target_node=record.get("target_node"),
  66:         execution_key=record.get("execution_key"),
  67:         created_at=record.get("created_at", 0.0),
  68:         updated_at=record.get("updated_at", 0.0),
  69:         received_at=record.get("received_at"),
  70:         attempt=record.get("attempt", 0),
  71:     )
  72:     return event
  73: 
  74: 
  75: def segment_meta_to_record(meta: SegmentMeta) -> dict[str, Any]:
  76:     data = asdict(meta)
  77:     data["stream"] = {
  78:         "tenant_id": meta.stream.tenant_id,
  79:         "app_id": meta.stream.app_id,
  80:         "data_type": meta.stream.data_type,
  81:         "schema_version": meta.stream.schema_version,
  82:         "stream_id": meta.stream.stream_id(),
  83:     }
  84:     data["stream_id"] = meta.stream.stream_id()
  85:     data["tenant_id"] = meta.stream.tenant_id
  86:     data["app_id"] = meta.stream.app_id
  87:     data["data_type"] = meta.stream.data_type
  88:     data["schema_version"] = meta.stream.schema_version
  89:     return data
  90: 
  91: 
  92: def record_to_segment_meta(record: dict[str, Any]) -> SegmentMeta:
  93:     stream_data = record.get("stream")
  94:     if isinstance(stream_data, dict):
  95:         stream = StreamKey(
  96:             tenant_id=stream_data.get("tenant_id", record.get("tenant_id", "default")),
  97:             app_id=stream_data.get("app_id", record.get("app_id", "default")),
  98:             data_type=stream_data.get("data_type", record.get("data_type", "event")),
  99:             schema_version=stream_data.get("schema_version", record.get("schema_version", "v1")),
 100:         )
 101:     else:
 102:         stream = StreamKey(
 103:             tenant_id=record.get("tenant_id", "default"),
 104:             app_id=record.get("app_id", "default"),
 105:             data_type=record.get("data_type", "event"),
 106:             schema_version=record.get("schema_version", "v1"),
 107:         )
 108:     return SegmentMeta(
 109:         stream=stream,
 110:         segment_id=record.get("segment_id", ""),
 111:         start_event_id=record.get("start_event_id"),
 112:         end_event_id=record.get("end_event_id"),
 113:         event_count=record.get("event_count", 0),
 114:         created_at=record.get("created_at", 0.0),
 115:         closed_at=record.get("closed_at"),
 116:         file_size=record.get("file_size", 0),
 117:         file_hash=record.get("file_hash"),
 118:         dirty=record.get("dirty", False),
 119:     )
