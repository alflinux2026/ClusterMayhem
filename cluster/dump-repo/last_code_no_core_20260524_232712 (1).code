  92: RETRY_BACKOFF_BASE = ARGS.retry_backoff_base
  93: RETRY_BACKOFF_MAX = ARGS.retry_backoff_max
  94: DRAIN_TIMEOUT = ARGS.drain_timeout if ARGS.drain_timeout != 60.0 else preset["drain_timeout"]
  95: STREAM_KEY = StreamKey(tenant_id=ARGS.tenant_id, app_id=ARGS.app_id, data_type=ARGS.data_type, schema_version=ARGS.schema_version)
  96: 
  97: TEST_STARTED_AT = time.time()
  98: RUN_ID = datetime.now().strftime("%Y%m%d_%H%M%S")
  99: OUT_DIR = Path(ARGS.output) if ARGS.output else Path(f"chaos_out_{RUN_ID}")
 100: OUT_DIR.mkdir(parents=True, exist_ok=True)
 101: STATS_FILE = OUT_DIR / "stats.json"
 102: EVENTS_CSV = OUT_DIR / "events.csv"
 103: 
 104: TEST_CONFIG = {
 105:     "mode": ARGS.mode,
 106:     "nodes": NODES,
 107:     "events": EVENTS,
 108:     "event_delay_range": EVENT_DELAY_RANGE,
 109:     "kill_probability": KILL_PROBABILITY,
 110:     "death_time_range": DEATH_TIME_RANGE,
 111:     "request_timeout": REQUEST_TIMEOUT,
 112:     "max_retries": MAX_RETRIES,
 113:     "sleep_only_node": SLEEP_ONLY_NODE,
 114:     "slow_event_threshold_ms": SLOW_EVENT_THRESHOLD_MS,
 115:     "seed": ARGS.seed,
 116:     "run_id": RUN_ID,
 117:     "stats_file": str(STATS_FILE),
 118:     "events_csv": str(EVENTS_CSV),
 119:     "send_workers": SEND_WORKERS,
 120:     "retry_backoff_base": RETRY_BACKOFF_BASE,
 121:     "retry_backoff_max": RETRY_BACKOFF_MAX,
 122:     "drain_timeout": DRAIN_TIMEOUT,
 123:     "stream": {"tenant_id": STREAM_KEY.tenant_id, "app_id": STREAM_KEY.app_id, "data_type": STREAM_KEY.data_type, "schema_version": STREAM_KEY.schema_version, "stream_id": STREAM_KEY.stream_id()},
 124: }
 125: 
 126: kill_threads = []
 127: dead_nodes = set()
 128: dead_lock = threading.Lock()
 129: stats_lock = threading.Lock()
 130: producer_done_lock = threading.Lock()
 131: enqueue_seq_lock = threading.Lock()
 132: pending_queue = queue.PriorityQueue()
 133: producer_done = False
 134: enqueue_seq = 0
 135: worker_sessions = {}
 136: worker_sessions_lock = threading.Lock()
 137: results_lock = threading.Lock()
 138: results = []
 139: stats = {"events_total": 0, "events_ok": 0, "events_failed": 0, "events_retried": 0, "events_no_leader": 0, "events_timeout": 0, "events_connection_error": 0, "events_forward_error": 0, "events_unexpected_fail": 0, "events_slow": 0, "kills": 0, "revives": 0, "kill_attempts": 0, "kill_failures": 0, "revive_failures": 0, "per_node_ok": defaultdict(int), "per_node_fail": defaultdict(int), "leaders_seen": defaultdict(int), "latency": [], "unexpected_failures": [], "slow_events": [], "kill_events": [], "submit_http_200": 0, "submit_semantic_ok": 0, "submit_hard_fail": 0, "queue_requeues": 0, "queue_max_depth": 0}
 140: 
 141: 
 142: @dataclass
 143: class PendingEvent:
 144:     event_index: int
 145:     event: dict
 146:     retries_done: int = 0
 147:     tried_nodes: set = field(default_factory=set)
 148:     first_enqueued_at: float = field(default_factory=time.time)
 149: 
 150: 
 151: def build_event(i):
 152:     return {"event_id": str(uuid.uuid4()), "trace_id": str(uuid.uuid4()), "event_type": "chaos.test", "payload": {"msg": f"msg-203: {i}", "seq": i, "source": "chaos_203", "run_id": RUN_ID, "stream_id": STREAM_KEY.stream_id()}, "stream": {"tenant_id": STREAM_KEY.tenant_id, "app_id": STREAM_KEY.app_id, "data_type": STREAM_KEY.data_type, "schema_version": STREAM_KEY.schema_version, "stream_id": STREAM_KEY.stream_id()}, "stream_id": STREAM_KEY.stream_id(), "tenant_id": STREAM_KEY.tenant_id, "app_id": STREAM_KEY.app_id, "data_type": STREAM_KEY.data_type, "schema_version": STREAM_KEY.schema_version, "status": "created", "route_hops": [], "source_node": None, "target_node": None, "execution_key": None, "created_at": time.time(), "updated_at": time.time(), "received_at": None, "attempt": 0}
 153: 
 154: 
 155: def stat_inc(key, amount=1):
 156:     with stats_lock:
 157:         stats[key] += amount
 158: 
 159: 
 160: def stat_node_ok(node):
 161:     with stats_lock:
 162:         stats["per_node_ok"][node] += 1
 163: 
 164: 
 165: def stat_node_fail(node):
 166:     with stats_lock:
 167:         stats["per_node_fail"][node] += 1
 168: 
 169: 
 170: def stat_leader(name):
 171:     with stats_lock:
 172:         stats["leaders_seen"][name] += 1
 173: 
 174: 
 175: def stat_latency(ms):
 176:     with stats_lock:
 177:         stats["latency"].append(ms)
 178: 
 179: 
 180: def stat_unexpected_failure(event_index, attempt, node, status_code=None, payload=None, reason=None):
 181:     with stats_lock:
 182:         stats["events_unexpected_fail"] += 1
 183:         stats["unexpected_failures"].append({"event_index": event_index, "attempt": attempt, "node": node, "status_code": status_code, "payload": payload, "reason": reason, "timestamp": datetime.now().isoformat()})
 184: 
 185: 
 186: def stat_slow_event(event_index, attempt, node, latency_ms, leader=None, payload=None):
 187:     with stats_lock:
 188:         stats["events_slow"] += 1
 189:         stats["slow_events"].append({"event_index": event_index, "attempt": attempt, "node": node, "latency_ms": round(latency_ms, 3), "leader": leader, "payload": payload, "timestamp": datetime.now().isoformat()})
 190: 
 191: 
 192: def stat_kill_event(node, action, ok, payload=None, error=None, seconds=None):
 193:     with stats_lock:
 194:         stats["kill_events"].append({"action": action, "node": node, "ok": ok, "seconds": seconds, "payload": payload, "error": error, "timestamp": datetime.now().isoformat()})
 195: 
 196: 
 197: def percentile(data, p):
 198:     if not data:
 199:         return 0.0
 200:     values = sorted(data)
 201:     if len(values) == 1:
 202:         return float(values[0])
 203:     rank = (len(values) - 1) * (p / 100.0)
 204:     low = int(rank)
 205:     high = min(low + 1, len(values) - 1)
 206:     return float(values[low] + (values[high] - values[low]) * (rank - low))
 207: 
 208: 
 209: def is_retryable_response(payload):
 210:     if not isinstance(payload, dict):
 211:         return False
 212:     if payload.get("error") in {"no leader", "node isolated"}:
 213:         return True
 214:     return any(p in str(payload.get("error", "")).lower() for p in ["timeout", "connection", "refused", "temporarily unavailable", "isolated", "no leader"])
 215: 
 216: 
 217: def extract_leader(payload):
 218:     if not isinstance(payload, dict):
 219:         return None
 220:     if "result" in payload and isinstance(payload["result"], dict):
 221:         return payload["result"].get("leader")
 222:     return payload.get("leader")
 223: 
 224: 
 225: def classify_submit_response(status_code, payload):
 226:     if status_code != 200:
 227:         return "http_not_ok"
 228:     if not isinstance(payload, dict):
 229:         return "submit_ok"
 230:     if payload.get("error"):
 231:         return "retryable_error" if is_retryable_response(payload) else "hard_fail"
 232:     result = payload.get("result")
 233:     if isinstance(result, dict) and result.get("error"):
 234:         return "retryable_error" if is_retryable_response(result) else "hard_fail"
 235:     return "submit_ok"
 236: 
 237: 
 238: def next_enqueue_seq():
 239:     global enqueue_seq
 240:     with enqueue_seq_lock:
 241:         enqueue_seq += 1
 242:         return enqueue_seq
 243: 
 244: 
 245: def enqueue_pending(pending, delay_seconds=0.0):
 246:     run_at = time.time() + max(0.0, delay_seconds)
 247:     pending_queue.put((run_at, next_enqueue_seq(), pending))
 248:     with stats_lock:
 249:         stats["queue_max_depth"] = max(stats["queue_max_depth"], pending_queue.qsize())
 250: 
 251: 
 252: def mark_producer_done():
 253:     global producer_done
 254:     with producer_done_lock:
 255:         producer_done = True
 256: 
 257: 
 258: def is_producer_done():
 259:     with producer_done_lock:
 260:         return producer_done
 261: 
 262: 
 263: def compute_retry_backoff(retries_done):
 264:     return min(RETRY_BACKOFF_BASE * (2 ** max(0, retries_done - 1)), RETRY_BACKOFF_MAX)
 265: 
 266: 
 267: def print_test_config():
 268:     print("\\n" + "=" * 56)
 269:     print(f"CHAOS TEST CONFIG [{ARGS.mode}]")
 270:     print("=" * 56)
 271:     for k, v in TEST_CONFIG.items():
 272:         if k == "stream":
 273:             print(f"{k}: {v['stream_id']}")
 274:         else:
 275:             print(f"{k}: {v}")
 276:     print("=" * 56 + "\\n")
 277: 
