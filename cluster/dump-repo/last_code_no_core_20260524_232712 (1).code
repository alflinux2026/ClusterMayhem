 241: def stat_kill_event(node, action, ok, payload=None, error=None, seconds=None):
 242:     with stats_lock:
 243:         stats["kill_events"].append({
 244:             "action": action,
 245:             "node": node,
 246:             "ok": ok,
 247:             "seconds": seconds,
 248:             "payload": payload,
 249:             "error": error,
 250:             "timestamp": datetime.now().isoformat(),
 251:         })
