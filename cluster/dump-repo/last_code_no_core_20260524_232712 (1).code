===== ./cluster_data_remote_inventory_with_api.py =====
   1: import csv
   2: import json
   3: import re
   4: from pathlib import Path
   5: 
   6: import paramiko
   7: import requests
   8: 
   9: NODES = [
  10:     {"name": "lnx200nas", "host": "100.100.1.200", "user": "alftorres", "password": "alftorres", "port": 22, "api_port": 7000},
  11:     {"name": "lnx202pc", "host": "100.100.1.202", "user": "alftorres", "password": "alftorres", "port": 22, "api_port": 7000},
  12:     {"name": "lnx203hp", "host": "100.100.1.203", "user": "alftorres", "password": "alftorres", "port": 22, "api_port": 7000},
  13: ]
  14: 
  15: REMOTE_DIRS = {
  16:     "lnx200nas": "/home/alftorres/projects/mayhem-cluster/cluster/data",
  17:     "lnx202pc": "/home/alftorres/projects/mayhem-cluster/cluster/data",
  18:     "lnx203hp": "/home/alftorres/projects/Mayhem_runtime_oneshot/cluster/data",
  19: }
  20: 
  21: OUT_MD = Path("cluster_data_remote_inventory.md")
  22: OUT_CSV = Path("cluster_data_remote_inventory.csv")
  23: OUT_API_JSON = Path("cluster_data_remote_api_snapshot.json")
  24: 
  25: LINE_RE = re.compile(
  26:     r"^(?P<perm>\S+)\s+"
  27:     r"(?P<links>\d+)\s+"
  28:     r"(?P<owner>\S+)\s+"
  29:     r"(?P<group>\S+)\s+"
  30:     r"(?P<size>\d+)\s+"
  31:     r"(?P<date>\d{4}-\d{2}-\d{2})\s+"
  32:     r"(?P<time>\d{2}:\d{2}:\d{2}\.\d+)\s+"
  33:     r"(?P<tz>[+-]\d{4})\s+"
  34:     r"(?P<name>.+)$"
  35: )
  36: 
  37: 
  38: def ssh_ls(node):
  39:     remote_dir = REMOTE_DIRS[node["name"]]
  40:     client = paramiko.SSHClient()
  41:     client.set_missing_host_key_policy(paramiko.AutoAddPolicy())
  42:     client.connect(
  43:         hostname=node["host"],
  44:         port=node["port"],
  45:         username=node["user"],
  46:         password=node["password"],
  47:         timeout=5,
  48:         look_for_keys=False,
  49:         allow_agent=False,
  50:     )
  51:     cmd = f'ls -lb --full-time "{remote_dir}"'
  52:     stdin, stdout, stderr = client.exec_command(cmd)
  53:     out = stdout.read().decode("utf-8", errors="replace")
  54:     err = stderr.read().decode("utf-8", errors="replace")
  55:     client.close()
  56: 
  57:     if err.strip() and not out.strip():
  58:         raise RuntimeError(f"{node['name']}: {err.strip()}")
  59: 
  60:     return out
  61: 
  62: 
  63: def parse_ls_output(node_name, text):
  64:     rows = []
  65:     for line in text.splitlines():
  66:         line = line.rstrip()
  67:         if not line or line.startswith("total "):
  68:             continue
  69:         m = LINE_RE.match(line)
  70:         if not m:
  71:             continue
  72:         d = m.groupdict()
  73:         file_name = d["name"]
  74:         m_source = re.match(r"^event_log\.(.+)\.jsonl$", file_name)
  75:         if not m_source and file_name != "event_log.local.jsonl":
  76:             continue
  77: 
  78:         source = m_source.group(1) if m_source else None
  79:         if file_name == "event_log.local.jsonl":
  80:             source = node_name
  81: 
  82:         rows.append(
  83:             {
  84:                 "node": node_name,
  85:                 "file": file_name,
  86:                 "source": source,
  87:                 "mtime_date": d["date"],
  88:                 "mtime_time": d["time"],
  89:                 "mtime_tz": d["tz"],
  90:                 "size": int(d["size"]),
  91:             }
  92:         )
  93:     return rows
  94: 
  95: 
  96: def fetch_json(url, timeout=4):
  97:     try:
  98:         resp = requests.get(url, timeout=timeout)
  99:         resp.raise_for_status()
 100:         return resp.json()
 101:     except Exception as e:
 102:         return {"error": str(e), "url": url}
 103: 
 104: 
 105: def fetch_api_snapshot(node):
 106:     base = f"http://{node['host']}:{node['api_port']}"
 107:     snapshot = {
 108:         "node": node["name"],
 109:         "host": node["host"],
 110:         "health": fetch_json(f"{base}/health"),
 111:         "leader": fetch_json(f"{base}/leader"),
 112:         "integrity": fetch_json(f"{base}/integrity"),
 113:         "events_summary_local": fetch_json(f"{base}/debug/events/summary"),
 114:         "events_summary_replica": {},
 115:     }
 116:     for replica_of in [n["name"] for n in NODES]:
 117:         snapshot["events_summary_replica"][replica_of] = fetch_json(
 118:             f"{base}/debug/events/summary/replica/{replica_of}"
 119:         )
 120:     return snapshot
 121: 
 122: 
 123: def build_groups(rows):
 124:     groups = {}
 125:     for row in rows:
 126:         groups.setdefault(row["source"], []).append(row)
 127:     return groups
 128: 
 129: 
 130: def check_consistency(groups):
 131:     for source, entries in groups.items():
 132:         for file_name in set(e["file"] for e in entries):
 133:             entries_file = [e for e in entries if e["file"] == file_name]
 134:             sizes = {e["node"]: e["size"] for e in entries_file}
 135:             mtimes = {e["node"]: (e["mtime_date"], e["mtime_time"]) for e in entries_file}
 136:             size_ok = len(set(sizes.values())) == 1
 137:             mtime_ok = len(set(mtimes.values())) <= 2
 138:             print(
 139:                 f"[INFO] {source}/{file_name}: size={'OK' if size_ok else 'MISMATCH'} "
 140:                 f"mtime={'OK' if mtime_ok else 'MISMATCH'}"
 141:             )
 142: 
 143: 
 144: def render_markdown(groups, api_snapshots):
 145:     source_order = ["lnx200nas", "lnx202pc", "lnx203hp"]
 146:     NODE_WIDTH = 16
 147:     FILE_WIDTH = 30
 148:     SIZE_WIDTH = 10
 149:     MTIME_WIDTH = 30
 150: 
 151:     lines = []
 152:     for source in source_order:
 153:         if source not in groups:
 154:             continue
 155:         entries = groups[source]
 156:         lines.append(f"### log de {source}:")
 157:         lines.append("")
 158: 
 159:         local = next((e for e in entries if e["node"] == source and "local" in e["file"]), None)
 160:         local_replica = next(
 161:             (e for e in entries if e["node"] == source and e["file"] == f"event_log.{source}.jsonl"),
 162:             None,
 163:         )
 164:         remotes = [
 165:             e for e in entries if e["file"] == f"event_log.{source}.jsonl" and e["node"] != source
 166:         ]
 167:         remotes.sort(key=lambda x: x["node"])
 168: 
 169:         for e in [local, local_replica, *remotes]:
 170:             if not e:
 171:                 continue
 172:             node = (e["node"] + " " * NODE_WIDTH)[:NODE_WIDTH]
 173:             file = (e["file"] + " " * FILE_WIDTH)[:FILE_WIDTH]
 174:             size = (f"{e['size']}" + " " * SIZE_WIDTH)[:SIZE_WIDTH]
 175:             mtime = (e["mtime_date"] + "T" + e["mtime_time"] + e["mtime_tz"] + " " * MTIME_WIDTH)[:MTIME_WIDTH]
 176:             lines.append(f"- {node}  {file}  {size}  {mtime}")
 177: 
 178:         lines.append("")
 179: 
 180:     lines.append("### events_summary_local API por nodo:")
 181:     lines.append("")
 182:     for node_name in source_order:
 183:         snap = api_snapshots.get(node_name, {})
 184:         local = snap.get("events_summary_local", {})
 185:         lines.append(f"#### {node_name}")
 186:         lines.append("")
 187:         lines.append(f"- events_summary_local: {json.dumps(local, ensure_ascii=False)}")
 188:         lines.append("")
 189:     lines.append("### foto API por nodo:")
 190:     lines.append("")
 191: 
 192:     for node_name in source_order:
 193:         snap = api_snapshots.get(node_name, {})
 194:         health = snap.get("health", {})
 195:         leader = snap.get("leader", {})
 196:         integrity = snap.get("integrity", {})
 197:         local = snap.get("events_summary_local", {})
 198:         lines.append(f"#### {node_name}")
 199:         lines.append("")
 200:         lines.append(f"- health: {json.dumps(health, ensure_ascii=False)}")
 201:         lines.append(f"- leader: {json.dumps(leader, ensure_ascii=False)}")
 202:         lines.append(f"- integrity: {json.dumps(integrity, ensure_ascii=False)}")
 203:         lines.append(f"- events_summary_local: {json.dumps(local, ensure_ascii=False)}")
 204:         lines.append("- events_summary_replica:")
 205:         for replica_of in source_order:
 206:             replica = snap.get("events_summary_replica", {}).get(replica_of, {})
 207:             lines.append(f"  - {replica_of}: {json.dumps(replica, ensure_ascii=False)}")
 208:         lines.append("")
 209: 
 210:     return "\n".join(lines).strip() + "\n"
 211: 
 212: 
 213: def main():
 214:     all_rows = []
 215:     api_snapshots = {}
 216: 
 217:     for node in NODES:
 218:         print(f"[INFO] Consultando SSH {node['name']} ({node['host']})...")
 219:         try:
 220:             text = ssh_ls(node)
 221:             rows = parse_ls_output(node["name"], text)
 222:             all_rows.extend(rows)
 223:         except Exception as e:
 224:             print(f"[ERROR] SSH {node['name']}: {e}")
 225: 
 226:         print(f"[INFO] Consultando API {node['name']} ({node['host']})...")
 227:         api_snapshots[node["name"]] = fetch_api_snapshot(node)
 228: 
 229:     groups = build_groups(all_rows)
 230:     check_consistency(groups)
 231: 
 232:     md = render_markdown(groups, api_snapshots)
 233:     OUT_MD.write_text(md, encoding="utf-8")
 234: 
 235:     with OUT_CSV.open("w", newline="", encoding="utf-8") as f:
 236:         writer = csv.DictWriter(
 237:             f,
 238:             fieldnames=["node", "file", "source", "mtime_date", "mtime_time", "mtime_tz", "size"],
 239:         )
 240:         writer.writeheader()
 241:         writer.writerows(all_rows)
 242: 
 243:     OUT_API_JSON.write_text(json.dumps(api_snapshots, ensure_ascii=False, indent=2), encoding="utf-8")
 244: 
 245:     print(f"[OK] Markdown: {OUT_MD}")
 246:     print(f"[OK] CSV: {OUT_CSV}")
 247:     print(f"[OK] API JSON: {OUT_API_JSON}")
 248: 
 249: 
 250: if __name__ == "__main__":
 251:     main()



