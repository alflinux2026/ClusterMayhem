 544: [MAIN] REVIVING ALL NODES
 545: ")
 546:     unique_nodes = sorted(set(NODES))
 547:     for node in unique_nodes:
 548:         try:
 549:             requests.post(f"{node}/revive", timeout=2)
 550:             print(f"[FORCE REVIVE] {node}")
 551:         except Exception as e:
 552:             print(f"[FORCE REVIVE FAIL] {node} -> {e}")
 553: 
