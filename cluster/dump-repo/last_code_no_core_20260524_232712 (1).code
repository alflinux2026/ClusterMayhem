   1: 
   2: import re
   3: import csv
   4: import paramiko
   5: from pathlib import Path
   6: 
   7: NODES = [
   8:     {"name": "lnx200nas", "host": "100.100.1.200", "user": "alftorres", "password": "alftorres", "port": 22},
   9:     {"name": "lnx202pc", "host": "100.100.1.202", "user": "alftorres", "password": "alftorres", "port": 22},
  10:     {"name": "lnx203hp", "host": "100.100.1.203", "user": "alftorres", "password": "alftorres", "port": 22},
  11: ]
  12: 
  13: # Ruta distinta por nodo
  14: REMOTE_DIRS = {
  15:     "lnx200nas":  "/home/alftorres/projects/mayhem-cluster/cluster/data",
  16:     "lnx202pc":  "/home/alftorres/projects/mayhem-cluster/cluster/data",
  17:     "lnx203hp":  "/home/alftorres/projects/Mayhem_runtime_oneshot/cluster/data",
  18: }
  19: 
  20: OUT_MD = Path("cluster_data_remote_inventory.md")
  21: OUT_CSV = Path("cluster_data_remote_inventory.csv")
  22: 
  23: LINE_RE = re.compile(
  24:     r"^(?P<perm>\S+)\s+"
  25:     r"(?P<links>\d+)\s+"
  26:     r"(?P<owner>\S+)\s+"
  27:     r"(?P<group>\S+)\s+"
  28:     r"(?P<size>\d+)\s+"
  29:     r"(?P<date>\d{4}-\d{2}-\d{2})\s+"
  30:     r"(?P<time>\d{2}:\d{2}:\d{2}\.\d+)\s+"
  31:     r"(?P<tz>[+-]\d{4})\s+"
  32:     r"(?P<name>.+)$"
  33: )
  34: 
  35: def ssh_ls(node):
  36:     remote_dir = REMOTE_DIRS[node["name"]]
  37:     client = paramiko.SSHClient()
  38:     client.set_missing_host_key_policy(paramiko.AutoAddPolicy())
  39:     client.connect(
  40:         hostname=node["host"],
  41:         port=node["port"],
  42:         username=node["user"],
  43:         password=node["password"],
  44:         timeout=5,
  45:         look_for_keys=False,
  46:         allow_agent=False,
  47:     )
  48:     cmd = f'ls -lb --full-time "{remote_dir}"'
  49:     stdin, stdout, stderr = client.exec_command(cmd)
  50:     out = stdout.read().decode("utf-8", errors="replace")
  51:     err = stderr.read().decode("utf-8", errors="replace")
  52:     client.close()
  53: 
  54:     if err.strip() and not out.strip():
  55:         raise RuntimeError(f"{node['name']}: {err.strip()}")
  56: 
  57:     return out
  58: 
  59: def parse_ls_output(node_name, text):
  60:     rows = []
  61:     for line in text.splitlines():
  62:         line = line.rstrip()
  63:         if not line or line.startswith("total "):
  64:             continue
  65:         m = LINE_RE.match(line)
  66:         if not m:
  67:             continue
  68:         d = m.groupdict()
  69:         file_name = d["name"]
  70:         m_source = re.match(r"^event_log\.(.+)\.jsonl$", file_name)
  71:         if not m_source:
  72:             continue
  73:         source = m_source.group(1)
  74: 
  75:         # también capturamos .local como si fuera lnx200nas
  76:         if file_name == "event_log.local.jsonl" and node_name == "lnx200nas":
  77:             source = "lnx200nas"
  78:         if file_name == "event_log.local.jsonl" and node_name == "lnx202pc":
  79:             source = "lnx202pc"
  80:         if file_name == "event_log.local.jsonl" and node_name == "lnx203hp":
  81:             source = "lnx203hp"
  82: 
  83:         rows.append({
  84:             "node": node_name,
  85:             "file": file_name,
  86:             "source": source,
  87:             "mtime_date": d["date"],
  88:             "mtime_time": d["time"],
  89:             "mtime_tz": d["tz"],
  90:             "size": int(d["size"]),
  91:         })
  92:     return rows
  93: 
  94: def build_groups(rows):
  95:     groups = {}
  96:     for row in rows:
  97:         groups.setdefault(row["source"], []).append(row)
  98:     return groups
  99: 
 100: def check_consistency(groups):
 101:     for source, entries in groups.items():
 102:         for file_name in set(e["file"] for e in entries):
 103:             entries_file = [e for e in entries if e["file"] == file_name]
 104:             sizes = {e["node"]: e["size"] for e in entries_file}
 105:             mtimes = {e["node"]: (e["mtime_date"], e["mtime_time"]) for e in entries_file}
 106:             size_ok = len(set(sizes.values())) == 1
 107:             mtime_ok = len(set(mtimes.values())) <= 2
 108: 
 109:             print(
 110:                 f"[INFO] {source}/{file_name}: "
 111:                 f"size={'OK' if size_ok else 'MISMATCH'} "
 112:                 f"mtime={'OK' if mtime_ok else 'MISMATCH'}"
 113:             )
 114: 
 115: def render_markdown(groups):
 116:     source_order = ["lnx200nas", "lnx202pc", "lnx203hp"]
 117: 
 118:     # Anchuras de columna
 119:     NODE_WIDTH  = 16
 120:     FILE_WIDTH  = 30
 121:     SIZE_WIDTH  = 10
 122:     MTIME_WIDTH = 25
 123: 
 124:     lines = []
 125: 
 126:     for source in source_order:
 127:         if source not in groups:
 128:             continue
 129:         entries = groups[source]
 130: 
 131:         lines.append(f"### log de {source}:")
 132:         lines.append("")
 133: 
 134:         # 1. fila: .local en el nodo source
 135:         local = next(
 136:             (e for e in entries if e["node"] == source and "local" in e["file"]),
 137:             None
 138:         )
 139: 
 140:         # 2. fila: copia local (event_log.<source>.jsonl) en el mismo nodo source
 141:         local_replica = next(
 142:             (e for e in entries
 143:              if e["node"] == source and e["file"] == f"event_log.{source}.jsonl"),
 144:             None
 145:         )
 146: 
 147:         # 3. resto: event_log.<source>.jsonl en otros nodos
 148:         remotes = [
 149:             e for e in entries
 150:             if e["file"] == f"event_log.{source}.jsonl" and e["node"] != source
 151:         ]
 152:         remotes.sort(key=lambda x: x["node"])
 153: 
 154:         # Escribe .local primero
 155:         if local:
 156:             node  = (local["node"] + " " * NODE_WIDTH)[:NODE_WIDTH]
 157:             file  = (local["file"] + " " * FILE_WIDTH)[:FILE_WIDTH]
 158:             size  = (f"{local['size']}" + " " * SIZE_WIDTH)[:SIZE_WIDTH]
 159:             mtime = (
 160:                 local["mtime_date"] + "T" + local["mtime_time"] + local["mtime_tz"] + " " * MTIME_WIDTH
 161:             )[:MTIME_WIDTH]
 162:             lines.append(f"- {node}  {file}  {size}  {mtime}")
 163: 
 164:         # luego copia local en el mismo nodo
 165:         if local_replica:
 166:             node  = (local_replica["node"] + " " * NODE_WIDTH)[:NODE_WIDTH]
 167:             file  = (local_replica["file"] + " " * FILE_WIDTH)[:FILE_WIDTH]
 168:             size  = (f"{local_replica['size']}" + " " * SIZE_WIDTH)[:SIZE_WIDTH]
 169:             mtime = (
 170:                 local_replica["mtime_date"] + "T" + local_replica["mtime_time"] + local_replica["mtime_tz"] + " " * MTIME_WIDTH
 171:             )[:MTIME_WIDTH]
 172:             lines.append(f"- {node}  {file}  {size}  {mtime}")
 173: 
 174:         # finalmente remotos
 175:         for e in remotes:
 176:             node  = (e["node"] + " " * NODE_WIDTH)[:NODE_WIDTH]
 177:             file  = (e["file"] + " " * FILE_WIDTH)[:FILE_WIDTH]
 178:             size  = (f"{e['size']}" + " " * SIZE_WIDTH)[:SIZE_WIDTH]
 179:             mtime = (
 180:                 e["mtime_date"] + "T" + e["mtime_time"] + e["mtime_tz"] + " " * MTIME_WIDTH
 181:             )[:MTIME_WIDTH]
 182:             lines.append(f"- {node}  {file}  {size}  {mtime}")
 183: 
 184:         lines.append("")
 185: 
 186:     return "\n".join(lines).strip() + "\n"
 187: 
 188: 
 189: def main():
 190:     all_rows = []
 191:     for node in NODES:
 192:         print(f"[INFO] Consultando {node['name']} ({node['host']})...")
 193:         try:
 194:             text = ssh_ls(node)
 195:             rows = parse_ls_output(node["name"], text)
 196:             all_rows.extend(rows)
 197:         except Exception as e:
 198:             print(f"[ERROR] {node['name']}: {e}")
 199: 
 200:     groups = build_groups(all_rows)
 201:     check_consistency(groups)
 202: 
 203:     md = render_markdown(groups)
 204:     OUT_MD.write_text(md, encoding="utf-8")
 205: 
 206:     with OUT_CSV.open("w", newline="", encoding="utf-8") as f:
 207:         writer = csv.DictWriter(
 208:             f,
 209:             fieldnames=["node", "file", "source", "mtime_date", "mtime_time", "mtime_tz", "size"],
 210:         )
 211:         writer.writeheader()
 212:         writer.writerows(all_rows)
 213: 
 214:     print(f"[OK] Markdown: {OUT_MD}")
 215:     print(f"[OK] CSV: {OUT_CSV}")
 216: 
 217: if __name__ == "__main__":
 218:     main()



