 160: # =====================================================
 161: # DATA MODEL
 162: # =====================================================
 163: 
 164: @dataclass
 165: class PendingEvent:
 166:     event_index: int
 167:     event: dict
 168:     retries_done: int = 0
 169:     tried_nodes: set = field(default_factory=set)
 170:     first_enqueued_at: float = field(default_factory=time.time)
 171: 
 172: 
 173: # =====================================================
 174: # HELPERS
 175: # =====================================================
 176: 
 177: def build_event(i):
 178:     return {
 179:         "event_id": str(uuid.uuid4()),
 180:         "event_type": "chaos.test",
 181:         "schema_version": "1",
 182:         "created_at": time.time(),
 183:         "received_at": None,
 184:         "trace_id": str(uuid.uuid4()),
 185:         "parent_event_id": None,
 186:         "source_node": None,
 187:         "target_node": None,
 188:         "route_hops": [],
 189:         "status": "created",
 190:         "attempt": 0,
 191:         "payload": {
 192:             "msg": f"msg-203: {i}",
 193:             "seq": i,
 194:             "source": "chaos_203"
 195:         }
 196:     }
 197: 
 198: 
 199: def stat_inc(key, amount=1):
 200:     with stats_lock:
 201:         stats[key] += amount
 202: 
 203: 
 204: def stat_node_ok(node):
 205:     with stats_lock:
 206:         stats["per_node_ok"][node] += 1
 207: 
 208: 
 209: def stat_node_fail(node):
 210:     with stats_lock:
 211:         stats["per_node_fail"][node] += 1
 212: 
 213: 
 214: def stat_leader(name):
 215:     with stats_lock:
 216:         stats["leaders_seen"][name] += 1
 217: 
 218: 
 219: def stat_latency(ms):
 220:     with stats_lock:
 221:         stats["latency"].append(ms)
 222: 
 223: 
 224: def stat_unexpected_failure(event_index, attempt, node, status_code=None, payload=None, reason=None):
 225:     with stats_lock:
 226:         stats["events_unexpected_fail"] += 1
 227:         stats["unexpected_failures"].append({
 228:             "event_index": event_index,
 229:             "attempt": attempt,
 230:             "node": node,
 231:             "status_code": status_code,
 232:             "payload": payload,
 233:             "reason": reason,
 234:             "timestamp": datetime.now().isoformat(),
 235:         })
 236: 
 237: 
 238: def stat_slow_event(event_index, attempt, node, latency_ms, leader=None, payload=None):
 239:     with stats_lock:
 240:         stats["events_slow"] += 1
 241:         stats["slow_events"].append({
 242:             "event_index": event_index,
 243:             "attempt": attempt,
 244:             "node": node,
 245:             "latency_ms": round(latency_ms, 3),
 246:             "leader": leader,
 247:             "payload": payload,
 248:             "timestamp": datetime.now().isoformat(),
 249:         })
 250: 
 251: 
 252: def stat_kill_event(node, action, ok, payload=None, error=None, seconds=None):
 253:     with stats_lock:
 254:         stats["kill_events"].append({
 255:             "action": action,
 256:             "node": node,
 257:             "ok": ok,
 258:             "seconds": seconds,
 259:             "payload": payload,
 260:             "error": error,
 261:             "timestamp": datetime.now().isoformat(),
 262:         })
 263: 
 264: 
 265: def percentile(data, p):
 266:     if not data:
 267:         return 0.0
 268:     values = sorted(data)
 269:     if len(values) == 1:
 270:         return float(values[0])
 271:     rank = (len(values) - 1) * (p / 100.0)
 272:     low = int(rank)
 273:     high = min(low + 1, len(values) - 1)
 274:     fraction = rank - low
 275:     return float(values[low] + (values[high] - values[low]) * fraction)
 276: 
 277: 
 278: def is_retryable_response(payload):
 279:     if not isinstance(payload, dict):
 280:         return False
 281: 
 282:     if payload.get("error") in {"no leader", "node isolated"}:
 283:         return True
 284: 
 285:     error = str(payload.get("error", "")).lower()
 286: 
 287:     retry_patterns = [
 288:         "timeout",
 289:         "connection",
 290:         "refused",
 291:         "temporarily unavailable",
 292:         "isolated",
 293:         "no leader",
 294:     ]
 295: 
 296:     return any(p in error for p in retry_patterns)
 297: 
 298: 
 299: def extract_leader(payload):
 300:     if not isinstance(payload, dict):
 301:         return None
 302: 
 303:     if "result" in payload and isinstance(payload["result"], dict):
 304:         return payload["result"].get("leader")
 305: 
 306:     return payload.get("leader")
 307: 
 308: 
 309: def classify_submit_response(status_code, payload):
 310:     if status_code != 200:
 311:         return "http_not_ok"
 312: 
 313:     if not isinstance(payload, dict):
 314:         return "submit_ok"
 315: 
 316:     if payload.get("error"):
 317:         if is_retryable_response(payload):
 318:             return "retryable_error"
 319:         return "hard_fail"
 320: 
 321:     result = payload.get("result")
 322:     if isinstance(result, dict) and result.get("error"):
 323:         if is_retryable_response(result):
 324:             return "retryable_error"
 325:         return "hard_fail"
 326: 
 327:     return "submit_ok"
 328: 
 329: 
 330: def next_enqueue_seq():
 331:     global enqueue_seq
 332:     with enqueue_seq_lock:
 333:         enqueue_seq += 1
 334:         return enqueue_seq
 335: 
 336: 
 337: def enqueue_pending(pending, delay_seconds=0.0):
 338:     run_at = time.time() + max(0.0, delay_seconds)
 339:     pending_queue.put((run_at, next_enqueue_seq(), pending))
 340:     with stats_lock:
 341:         depth = pending_queue.qsize()
 342:         if depth > stats["queue_max_depth"]:
 343:             stats["queue_max_depth"] = depth
 344: 
 345: 
 346: def mark_producer_done():
 347:     global producer_done
 348:     with producer_done_lock:
 349:         producer_done = True
 350: 
 351: 
 352: def is_producer_done():
 353:     with producer_done_lock:
 354:         return producer_done
 355: 
 356: 
 357: def compute_retry_backoff(retries_done):
 358:     backoff = RETRY_BACKOFF_BASE * (2 ** max(0, retries_done - 1))
 359:     return min(backoff, RETRY_BACKOFF_MAX)
 360: 
 361: 
 362: def print_test_config():
 363:     print("\n" + "=" * 56)
 364:     print("CHAOS TEST CONFIG v3")
 365:     print("=" * 56)
 366:     print(f"run_id..............: {RUN_ID}")
 367:     print(f"stats_file..........: {STATS_FILE}")
 368:     print(f"started_at..........: {datetime.fromtimestamp(TEST_STARTED_AT).isoformat()}")
 369:     print(f"nodes...............: {NODES}")
 370:     print(f"events..............: {EVENTS}")
 371:     print(f"event_delay_range...: {EVENT_DELAY_RANGE}")
 372:     print(f"kill_probability....: {KILL_PROBABILITY}")
 373:     print(f"death_time_range....: {DEATH_TIME_RANGE}")
 374:     print(f"request_timeout.....: {REQUEST_TIMEOUT}")
 375:     print(f"max_retries.........: {MAX_RETRIES}")
 376:     print(f"sleep_only_node.....: {SLEEP_ONLY_NODE}")
 377:     print(f"slow_threshold_ms...: {SLOW_EVENT_THRESHOLD_MS}")
 378:     print(f"send_workers........: {SEND_WORKERS}")
 379:     print(f"retry_backoff_base..: {RETRY_BACKOFF_BASE}")
 380:     print(f"retry_backoff_max...: {RETRY_BACKOFF_MAX}")
 381:     print(f"drain_timeout.......: {DRAIN_TIMEOUT}")
 382:     print(f"seed................: {ARGS.seed}")
 383:     print("=" * 56 + "\n")
 384: 
 385: 
 386: # =====================================================
 387: # KILL / REVIVE
 388: # =====================================================
 389: 
 390: def kill_node(node, seconds=None):
 391:     stat_inc("kill_attempts")
 392: 
 393:     try:
 394:         resp = requests.post(f"{node}/sleep", timeout=2)
 395:         payload = {}
 396: 
 397:         try:
 398:             payload = resp.json()
 399:         except Exception:
 400:             payload = {"raw_text": resp.text}
 401: 
 402:         if resp.status_code == 200 and payload.get("ok") is True:
 403:             with dead_lock:
 404:                 dead_nodes.add(node)
 405: 
 406:             stat_inc("kills")
 407:             stat_kill_event(node=node, action="sleep", ok=True, payload=payload, seconds=seconds)
 408:             print(f"[CHAOS] SLEEP {node}")
 409:             return True
 410: 
 411:         stat_inc("kill_failures")
 412:         stat_kill_event(node=node, action="sleep", ok=False, payload=payload, seconds=seconds)
 413:         print(f"[CHAOS FAIL SLEEP] {node} -> status={resp.status_code} payload={payload}")
 414:         return False
 415: 
 416:     except Exception as e:
 417:         stat_inc("kill_failures")
 418:         stat_kill_event(node=node, action="sleep", ok=False, error=str(e), seconds=seconds)
 419:         print(f"[CHAOS FAIL SLEEP] {node} -> {e}")
 420:         return False
 421: 
 422: 
 423: def revive_node(node):
 424:     try:
 425:         resp = requests.post(f"{node}/revive", timeout=2)
 426:         payload = {}
 427: 
 428:         try:
 429:             payload = resp.json()
 430:         except Exception:
 431:             payload = {"raw_text": resp.text}
 432: 
 433:         if resp.status_code == 200 and payload.get("ok") is True:
 434:             with dead_lock:
 435:                 dead_nodes.discard(node)
 436: 
 437:             stat_inc("revives")
 438:             stat_kill_event(node=node, action="revive", ok=True, payload=payload)
 439:             print(f"[CHAOS] REVIVE {node}")
 440:             return True
 441: 
 442:         stat_inc("revive_failures")
 443:         stat_kill_event(node=node, action="revive", ok=False, payload=payload)
 444:         print(f"[CHAOS FAIL REVIVE] {node} -> status={resp.status_code} payload={payload}")
 445:         return False
 446: 
 447:     except Exception as e:
 448:         stat_inc("revive_failures")
 449:         stat_kill_event(node=node, action="revive", ok=False, error=str(e))
 450:         print(f"[CHAOS FAIL REVIVE] {node} -> {e}")
 451:         return False
 452: 
 453: 
 454: def kill_cycle(node, seconds):
 455:     try:
 456:         ok = kill_node(node, seconds=seconds)
 457:         if ok:
 458:             print(f"[CHAOS] DEAD {node} for {seconds:.2f}s")
 459:             time.sleep(seconds)
 460:     finally:
 461:         revive_node(node)
 462: 
 463: 
 464: # =====================================================
 465: # EVENT PROCESSING
 466: # =====================================================
 467: 
 468: def process_pending_event(pending: PendingEvent):
 469:     i = pending.event_index
 470:     event = pending.event
 471:     attempt_number = pending.retries_done + 1
 472: 
 473:     available = [n for n in NODES if n not in pending.tried_nodes]
 474: 
 475:     if not available:
 476:         pending.tried_nodes.clear()
 477:         available = list(NODES)
 478: 
 479:     node = random.choice(available)
 480:     pending.tried_nodes.add(node)
 481:     start = time.time()
 482: 
 483:     try:
 484:         r = requests.post(
 485:             f"{node}/event",
 486:             json=event,
 487:             timeout=REQUEST_TIMEOUT
 488:         )
 489: 
 490:         elapsed_ms = (time.time() - start) * 1000
 491:         stat_latency(elapsed_ms)
 492: 
 493:         payload = {}
 494:         try:
 495:             payload = r.json()
 496:         except Exception:
 497:             payload = {"raw_text": r.text}
 498: 
 499:         leader = extract_leader(payload)
 500:         if leader:
 501:             stat_leader(leader)
 502: 
 503:         if elapsed_ms >= SLOW_EVENT_THRESHOLD_MS:
 504:             stat_slow_event(
 505:                 event_index=i,
 506:                 attempt=attempt_number,
 507:                 node=node,
 508:                 latency_ms=elapsed_ms,
 509:                 leader=leader,
 510:                 payload=payload,
 511:             )
 512: 
 513:         if r.status_code == 200:
 514:             stat_inc("submit_http_200")
 515: 
 516:         result = classify_submit_response(r.status_code, payload)
 517: 
 518:         if result == "submit_ok":
 519:             stat_inc("events_ok")
 520:             stat_inc("submit_semantic_ok")
 521:             stat_node_ok(node)
 522: 
 523:             print(
 524:                 f"[TORTURE] "
 525:                 f"{i:03} "
 526:                 f"OK "
 527:                 f"attempt={attempt_number} "
 528:                 f"node={node} "
 529:                 f"leader={leader} "
 530:                 f"latency={elapsed_ms:.1f}ms"
 531:             )
 532:             return True
 533: 
 534:         if result == "retryable_error" or r.status_code >= 500:
 535:             stat_inc("events_retried")
 536: 
 537:             if isinstance(payload, dict) and payload.get("error") == "no leader":
 538:                 stat_inc("events_no_leader")
 539: 
 540:             result_payload = payload.get("result") if isinstance(payload.get("result"), dict) else None
 541:             if isinstance(result_payload, dict) and result_payload.get("error") == "no leader":
 542:                 stat_inc("events_no_leader")
 543: 
 544:             print(
 545:                 f"[RETRY] "
 546:                 f"{i:03} "
 547:                 f"attempt={attempt_number} "
 548:                 f"node={node} "
 549:                 f"status={r.status_code} "
 550:                 f"payload={payload}"
 551:             )
 552: 
 553:             if pending.retries_done + 1 >= MAX_RETRIES:
 554:                 stat_inc("events_failed")
 555:                 stat_unexpected_failure(
 556:                     event_index=i,
 557:                     attempt=attempt_number,
 558:                     node=node,
 559:                     status_code=r.status_code,
 560:                     payload=payload,
 561:                     reason="dropped_after_retries_retryable_response",
 562:                 )
 563:                 print(f"[DROP] {i:03} event dropped after retries")
 564:                 return False
 565: 
 566:             pending.retries_done += 1
 567:             stat_inc("queue_requeues")
 568:             enqueue_pending(pending, compute_retry_backoff(pending.retries_done))
 569:             return False
 570: 
 571:         stat_inc("events_failed")
 572:         stat_inc("submit_hard_fail")
 573:         stat_node_fail(node)
 574:         stat_unexpected_failure(
 575:             event_index=i,
 576:             attempt=attempt_number,
 577:             node=node,
 578:             status_code=r.status_code,
 579:             payload=payload,
 580:             reason="hard_fail_non_retryable_response",
 581:         )
 582: 
 583:         print(
 584:             f"[FAIL] "
 585:             f"{i:03} "
 586:             f"attempt={attempt_number} "
 587:             f"node={node} "
 588:             f"status={r.status_code} "
 589:             f"payload={payload}"
 590:         )
 591:         return False
 592: 
 593:     except requests.Timeout as e:
 594:         stat_inc("events_timeout")
 595:         stat_inc("events_retried")
 596: 
 597:         print(
 598:             f"[TIMEOUT] "
 599:             f"{i:03} "
 600:             f"attempt={attempt_number} "
 601:             f"{node} -> {e}"
 602:         )
 603: 
 604:     except requests.ConnectionError as e:
 605:         stat_inc("events_connection_error")
 606:         stat_inc("events_retried")
 607: 
 608:         print(
 609:             f"[CONNECTION] "
 610:             f"{i:03} "
 611:             f"attempt={attempt_number} "
 612:             f"{node} -> {e}"
 613:         )
 614: 
 615:     except Exception as e:
 616:         stat_inc("events_forward_error")
 617:         stat_inc("events_retried")
 618:         stat_unexpected_failure(
 619:             event_index=i,
 620:             attempt=attempt_number,
 621:             node=node,
 622:             reason=f"exception:{type(e).__name__}",
 623:             payload={"exception": str(e)},
 624:         )
 625: 
 626:         print(
 627:             f"[ERROR] "
 628:             f"{i:03} "
 629:             f"attempt={attempt_number} "
 630:             f"{node} -> {e}"
 631:         )
 632: 
 633:     if pending.retries_done + 1 >= MAX_RETRIES:
 634:         stat_inc("events_failed")
 635:         stat_unexpected_failure(
 636:             event_index=i,
 637:             attempt=attempt_number,
 638:             node=node,
 639:             reason="dropped_after_retries_exception",
 640:             payload={"tried_nodes": list(pending.tried_nodes)},
 641:         )
 642:         print(f"[DROP] {i:03} event dropped after retries")
 643:         return False
 644: 
 645:     pending.retries_done += 1
 646:     stat_inc("queue_requeues")
 647:     enqueue_pending(pending, compute_retry_backoff(pending.retries_done))
 648:     return False
 649: 
 650: 
 651: def sender_worker(worker_id):
 652:     while True:
 653:         try:
 654:             run_at, _, pending = pending_queue.get(timeout=0.5)
 655:         except queue.Empty:
 656:             if is_producer_done() and pending_queue.empty():
 657:                 return
 658:             continue
 659: 
 660:         now = time.time()
 661:         if run_at > now:
 662:             pending_queue.put((run_at, next_enqueue_seq(), pending))
 663:             pending_queue.task_done()
 664:             time.sleep(min(run_at - now, 0.2))
 665:             continue
 666: 
 667:         try:
 668:             process_pending_event(pending)
 669:         finally:
 670:             pending_queue.task_done()
 671: 
 672: 
 673: # =====================================================
 674: # MAIN LOOP
 675: # =====================================================
 676: 
 677: def chaos_loop():
 678:     for i in range(EVENTS):
 679:         if random.random() < KILL_PROBABILITY:
 680:             if SLEEP_ONLY_NODE:
 681:                 node = SLEEP_ONLY_NODE
 682:             else:
 683:                 node = random.choice(NODES)
 684: 
 685:             seconds = random.uniform(*DEATH_TIME_RANGE)
 686: 
 687:             t = threading.Thread(
 688:                 target=kill_cycle,
 689:                 args=(node, seconds),
 690:                 daemon=True
 691:             )
 692:             t.start()
 693:             kill_threads.append(t)
 694: 
 695:         stat_inc("events_total")
 696:         pending = PendingEvent(
 697:             event_index=i,
 698:             event=build_event(i),
 699:         )
 700:         enqueue_pending(pending, delay_seconds=0.0)
 701: 
 702:         time.sleep(random.uniform(*EVENT_DELAY_RANGE))
 703: 
 704:     mark_producer_done()
 705: 
 706: 
 707: # =====================================================
 708: # FORCE REVIVE ALL
 709: # =====================================================
 710: 
 711: def revive_everything():
 712:     print("\n[MAIN] REVIVING ALL NODES\n")
 713: 
 714:     unique_nodes = sorted(set(NODES))
 715: 
 716:     for node in unique_nodes:
 717:         try:
 718:             requests.post(f"{node}/revive", timeout=2)
 719:             print(f"[FORCE REVIVE] {node}")
 720:         except Exception as e:
 721:             print(f"[FORCE REVIVE FAIL] {node} -> {e}")
 722: 
 723: 
 724: # =====================================================
 725: # WAIT ALL KILL THREADS
 726: # =====================================================
 727: 
 728: def wait_kills():
 729:     print("\n[MAIN] waiting active kill cycles...\n")
 730: 
 731:     for t in kill_threads:
 732:         t.join(timeout=30)
 733: 
 734: 
 735: # =====================================================
 736: # WAIT QUEUE DRAIN
 737: # =====================================================
 738: 
 739: def wait_queue_drain():
 740:     deadline = time.time() + DRAIN_TIMEOUT
 741: 
 742:     while time.time() < deadline:
 743:         if pending_queue.empty():
 744:             time.sleep(0.5)
 745:             if pending_queue.empty():
 746:                 return True
 747:         time.sleep(0.2)
 748: 
 749:     return False
 750: 
