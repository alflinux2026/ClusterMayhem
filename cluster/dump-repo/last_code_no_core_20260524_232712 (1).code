   1: import json
   2: import os
   3: from typing import Dict, List, Optional
   4: 
   5: from cluster.runtime.events.cluster_event import ClusterEvent
   6: from cluster.runtime.events.event_state import EventStatus
   7: 
   8: BASE_DIR = os.path.dirname(os.path.dirname(os.path.dirname(__file__)))
   9: DATA_DIR = os.path.join(BASE_DIR, "cluster", "data")
  10: LOCAL_LOG_PATH = os.path.join(DATA_DIR, "event_log.local.jsonl")
  11: STATE_PATH = os.path.join(DATA_DIR, "last_append.state.json")
  12: 
  13: 
  14: def ensure_dir():
  15:     os.makedirs(DATA_DIR, exist_ok=True)
  16: 
  17: 
  18: def get_local_log_path() -> str:
  19:     return LOCAL_LOG_PATH
  20: 
  21: 
  22: def get_state_path() -> str:
  23:     return STATE_PATH
  24: 
  25: 
  26: def get_replica_log_path(node_id: str) -> str:
  27:     return os.path.join(DATA_DIR, f"event_log.{node_id}.jsonl")
  28: 
  29: 
  30: def list_replica_log_paths() -> List[str]:
  31:     if not os.path.exists(DATA_DIR):
  32:         return []
  33:     out: List[str] = []
  34:     for name in sorted(os.listdir(DATA_DIR)):
  35:         if not name.startswith("event_log."):
  36:             continue
  37:         if not name.endswith(".jsonl"):
  38:             continue
  39:         if name == "event_log.local.jsonl":
  40:             continue
  41:         out.append(os.path.join(DATA_DIR, name))
  42:     return out
  43: 
  44: 
  45: def load_events_from_path(path: str) -> List[dict]:
  46:     if not os.path.exists(path):
  47:         return []
  48:     events = []
  49:     with open(path, "r", encoding="utf-8") as f:
  50:         for line in f:
  51:             line = line.strip()
  52:             if not line:
  53:                 continue
  54:             try:
  55:                 events.append(json.loads(line))
  56:             except json.JSONDecodeError:
  57:                 continue
  58:     return events
  59: 
  60: 
  61: def write_text_atomic(path: str, content: str):
  62:     ensure_dir()
  63:     tmp_path = path + ".tmp"
  64:     with open(tmp_path, "w", encoding="utf-8") as f:
  65:         f.write(content)
  66:     os.replace(tmp_path, path)
  67: 
  68: 
  69: def read_local_log_text() -> str:
  70:     if not os.path.exists(LOCAL_LOG_PATH):
  71:         return ""
  72:     with open(LOCAL_LOG_PATH, "r", encoding="utf-8") as f:
  73:         return f.read()
  74: 
  75: 
  76: def write_replica_log(node_id: str, content: str):
  77:     write_text_atomic(get_replica_log_path(node_id), content)
  78: 
  79: 
  80: def read_state() -> dict:
  81:     if not os.path.exists(STATE_PATH):
  82:         return {}
  83:     try:
  84:         with open(STATE_PATH, "r", encoding="utf-8") as f:
  85:             data = json.load(f)
  86:             return data if isinstance(data, dict) else {}
  87:     except (OSError, json.JSONDecodeError):
  88:         return {}
  89: 
  90: 
  91: def write_state(state: dict):
  92:     write_text_atomic(STATE_PATH, json.dumps(state))
  93: 
  94: 
  95: def clear_state():
  96:     try:
  97:         os.remove(STATE_PATH)
  98:     except FileNotFoundError:
  99:         pass
 100: 
 101: 
 102: def load_events() -> List[dict]:
 103:     return load_events_from_path(LOCAL_LOG_PATH)
 104: 
 105: 
 106: def load_local_events() -> List[dict]:
 107:     return load_events_from_path(LOCAL_LOG_PATH)
 108: 
 109: 
 110: def load_replica_events(node_id: str) -> List[dict]:
 111:     return load_events_from_path(get_replica_log_path(node_id))
 112: 
 113: 
 114: def load_all_replica_events() -> List[dict]:
 115:     events: List[dict] = []
 116:     for path in list_replica_log_paths():
 117:         events.extend(load_events_from_path(path))
 118:     return events
 119: 
 120: 
 121: def load_cluster_events() -> List[dict]:
 122:     return load_all_replica_events()
 123: 
 124: 
 125: def _normalize_event(e: dict) -> dict:
 126:     e = dict(e)
 127:     e["schema_version"] = str(e.get("schema_version", "0.1"))
 128:     e.setdefault("received_at", None)
 129:     e.setdefault("attempt", 0)
 130:     e.setdefault("route_hops", [])
 131:     e.setdefault("execution_key", None)
 132:     return e
 133: 
 134: 
 135: def _latest_map(events: List[dict]) -> Dict[str, dict]:
 136:     latest: Dict[str, dict] = {}
 137:     for e in events:
 138:         e = _normalize_event(e)
 139:         latest[e["event_id"]] = e
 140:     return latest
 141: 
 142: 
 143: def rebuild_event_state_index() -> Dict[str, dict]:
 144:     return _latest_map(load_events())
 145: 
 146: 
 147: def get_latest_event(event_id: str) -> Optional[dict]:
 148:     events = load_events()
 149:     for e in reversed(events):
 150:         if e["event_id"] == event_id:
 151:             return _normalize_event(e)
 152:     return None
 153: 
 154: 
 155: def get_created_events():
 156:     latest = rebuild_event_state_index()
 157:     domain_events = [ClusterEvent(**e) for e in latest.values()]
 158:     return [e for e in domain_events if e.status == EventStatus.CREATED]
 159: 
 160: 
 161: def get_completed_event_ids():
 162:     latest = rebuild_event_state_index()
 163:     domain_events = [ClusterEvent(**e) for e in latest.values()]
 164:     return {e.event_id for e in domain_events if e.status == EventStatus.COMPLETED}
 165: 
 166: 
 167: def append_event(event: ClusterEvent):
 168:     ensure_dir()
 169:     record = {
 170:         "event_id": event.event_id,
 171:         "event_type": event.event_type,
 172:         "schema_version": str(event.schema_version),
 173:         "created_at": event.created_at,
 174:         "received_at": getattr(event, "received_at", None),
 175:         "trace_id": event.trace_id,
 176:         "target_node": event.target_node,
 177:         "route_hops": event.route_hops,
 178:         "status": event.status.value if hasattr(event.status, "value") else event.status,
 179:         "attempt": event.attempt,
 180:         "payload": event.payload,
 181:     }
 182:     if record["status"] == EventStatus.COMPLETED.value:
 183:         existing = load_events()
 184:         if any(e.get("event_id") == event.event_id and e.get("status") == EventStatus.COMPLETED.value for e in existing):
 185:             return
 186:     with open(LOCAL_LOG_PATH, "a", encoding="utf-8") as f:
 187:         f.write(json.dumps(record) + "\n")
 188:     write_state({
 189:         "dirty": True,
 190:         "last_append_event_id": event.event_id,
 191:         "last_append_created_at": event.created_at,
 192:     })
 193: 
 194: 
 195: def replay_events(handler):
 196:     events = load_events()
 197:     for raw in events:
 198:         event = ClusterEvent(**_normalize_event(raw))
 199:         handler(event)



