 150: def _node_runtime_view(api_snapshots, node_name):
 151:     snap = api_snapshots.get(node_name, {}) or {}
 152:     dashboard = snap.get("dashboard", {}) or {}
 153:     health = snap.get("health", {}) or {}
 154:     integrity = snap.get("integrity", {}) or {}
 155:     local_summary = snap.get("events_summary_local", {}) or {}
 156: 
 157:     row = {}
 158:     for r in dashboard.get("nodes", []) or []:
 159:         if r.get("node_id") == node_name:
 160:             row = r
 161:             break
 162: 
 163:     counts = local_summary.get("counts", {}) if isinstance(local_summary, dict) else {}
 164:     local_meta = integrity.get("local_log_meta", {}) if isinstance(integrity, dict) else {}
 165:     last_append = integrity.get("last_append_meta", {}) if isinstance(integrity, dict) else {}
 166: 
 167:     def fallback(*values):
 168:         for value in values:
 169:             if value is not None:
 170:                 return value
 171:         return None
 172: 
 173:     state_raw = row.get("state") or health.get("state")
 174:     state_value = state_raw if state_raw in ("ACTIVE", "STAND-BY", "STANDBY", "DEGRADED", "ISOLATED", "OFFLINE") else "???"
 175: 
 176:     return {
 177:         "health": fallback(row.get("health"), health.get("status"), "?"),
 178:         "state": state_value,
 179:         "state_age_s": fallback(row.get("state_age_s"), health.get("state_age_s")),
 180:         "presence_age_s": fallback(row.get("presence_age_s"), health.get("presence_age_s")),
 181:         "watchdog_age_s": fallback(row.get("watchdog_age_s"), health.get("watchdog_age_s")),
 182:         "watchdog_busy": fallback(row.get("watchdog_busy"), health.get("watchdog_busy")),
 183:         "local_size": int(local_meta.get("size", 0) or 0),
 184:         "local_events": int(local_summary.get("total_events", 0) or 0),
 185:         "created": int(counts.get("created", 0) or 0),
 186:         "executing": int(counts.get("executing", 0) or 0),
 187:         "completed": int(counts.get("completed", 0) or 0),
 188:         "dirty": last_append.get("dirty", "-"),
 189:     }
 190: 
 191: def setup_colors():
 192:     if not curses.has_colors():
 193:         return False
 194: 
 195:     curses.start_color()
 196:     curses.use_default_colors()
 197: 
 198:     curses.init_pair(1, curses.COLOR_GREEN, -1)
 199:     curses.init_pair(2, curses.COLOR_YELLOW, -1)
 200:     curses.init_pair(3, curses.COLOR_RED, -1)
 201:     curses.init_pair(4, curses.COLOR_CYAN, -1)
 202:     curses.init_pair(5, curses.COLOR_WHITE, -1)
 203:     curses.init_pair(6, curses.COLOR_MAGENTA, -1)
 204:     return True
 205: 
 206: 
 207: def color_for_health(value):
 208:     v = str(value or "").lower()
 209:     if v == "ok":
 210:         return curses.color_pair(1) | curses.A_BOLD
 211:     if v == "stale":
 212:         return curses.color_pair(3) | curses.A_BOLD
 213:     return curses.color_pair(2) | curses.A_BOLD
 214: 
 215: 
 216: def color_for_state(state, stale=False):
 217:     if stale:
 218:         return curses.color_pair(3) | curses.A_BOLD
 219: 
 220:     s = str(state or "").upper()
 221:     if s == "ACTIVE":
 222:         return curses.color_pair(1) | curses.A_BOLD
 223:     if s in ("STAND-BY", "STANDBY"):
 224:         return curses.color_pair(2) | curses.A_BOLD
 225:     if s == "DEGRADED":
 226:         return curses.color_pair(6) | curses.A_BOLD
 227:     if s in ("ISOLATED", "OFFLINE", "???"):
 228:         return curses.color_pair(3) | curses.A_BOLD
 229:     return curses.color_pair(5)
 230: 
 231: 
 232: def color_for_dirty(value):
 233:     if value is True or str(value).lower() == "true":
 234:         return curses.color_pair(3) | curses.A_BOLD
 235:     return curses.color_pair(1)
 236: 
 237: 
 238: def color_for_count(label, value):
 239:     try:
 240:         n = int(value)
 241:     except Exception:
 242:         n = 0
 243: 
 244:     if label == "executing" and n > 0:
 245:         return curses.color_pair(2) | curses.A_BOLD
 246:     if label == "created" and n > 0:
 247:         return curses.color_pair(6) | curses.A_BOLD
 248:     if label == "completed" and n > 0:
 249:         return curses.color_pair(1)
 250:     return curses.color_pair(5)
 251: 
 252: 
 253: def color_for_age(value, warn_s=1.5, stale_s=3.0):
 254:     if value is None:
 255:         return curses.color_pair(5)
 256:     try:
 257:         age = float(value)
 258:     except Exception:
 259:         return curses.color_pair(5)
 260:     if age >= stale_s:
 261:         return curses.color_pair(3) | curses.A_BOLD
 262:     if age >= warn_s:
 263:         return curses.color_pair(2) | curses.A_BOLD
 264:     return curses.color_pair(1)
 265: 
 266: 
 267: def color_for_busy(value):
 268:     if value is True:
 269:         return curses.color_pair(6) | curses.A_BOLD
 270:     if value is False:
 271:         return curses.color_pair(1)
 272:     return curses.color_pair(5)
 273: 
