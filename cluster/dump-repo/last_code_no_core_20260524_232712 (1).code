  96: # =====================================================
  97: # GLOBALS
  98: # =====================================================
  99: 
 100: kill_threads = []
 101: dead_nodes = set()
 102: 
 103: dead_lock = threading.Lock()
 104: stats_lock = threading.Lock()
 105: 
 106: stats = {
 107:     "events_total": 0,
 108:     "events_ok": 0,
 109:     "events_failed": 0,
 110:     "events_retried": 0,
 111:     "events_no_leader": 0,
 112:     "events_timeout": 0,
 113:     "events_connection_error": 0,
 114:     "events_forward_error": 0,
 115:     "events_unexpected_fail": 0,
 116:     "events_slow": 0,
 117:     "kills": 0,
 118:     "revives": 0,
 119:     "kill_attempts": 0,
 120:     "kill_failures": 0,
 121:     "revive_failures": 0,
 122:     "per_node_ok": defaultdict(int),
 123:     "per_node_fail": defaultdict(int),
 124:     "leaders_seen": defaultdict(int),
 125:     "latency": [],
 126:     "unexpected_failures": [],
 127:     "slow_events": [],
 128:     "kill_events": [],
 129: }
 130: 
 131: 
 132: # =====================================================
 133: # HELPERS
 134: # =====================================================
 135: 
 136: def build_event(i):
 137:     return {
 138:         "event_id": str(uuid.uuid4()),
 139:         "event_type": "chaos.test",
 140:         "schema_version": "1",
 141:         "created_at": time.time(),
 142:         "received_at": None,
 143:         "trace_id": str(uuid.uuid4()),
 144:         "parent_event_id": None,
 145:         "source_node": None,
 146:         "target_node": None,
 147:         "route_hops": [],
 148:         "status": "created",
 149:         "attempt": 0,
 150:         "payload": {
 151:             "msg": f"msg-203: {i}",
 152:             "seq": i,
 153:             "source": "chaos_203"
 154:         }
 155:     }
 156: 
 157: 
 158: def stat_inc(key, amount=1):
 159:     with stats_lock:
 160:         stats[key] += amount
 161: 
 162: 
 163: def stat_node_ok(node):
 164:     with stats_lock:
 165:         stats["per_node_ok"][node] += 1
 166: 
 167: 
 168: def stat_node_fail(node):
 169:     with stats_lock:
 170:         stats["per_node_fail"][node] += 1
 171: 
 172: 
 173: def stat_leader(name):
 174:     with stats_lock:
 175:         stats["leaders_seen"][name] += 1
 176: 
 177: 
 178: def stat_latency(ms):
 179:     with stats_lock:
 180:         stats["latency"].append(ms)
 181: 
 182: 
 183: def stat_unexpected_failure(event_index, attempt, node, status_code=None, payload=None, reason=None):
 184:     with stats_lock:
 185:         stats["events_unexpected_fail"] += 1
 186:         stats["unexpected_failures"].append({
 187:             "event_index": event_index,
 188:             "attempt": attempt,
 189:             "node": node,
 190:             "status_code": status_code,
 191:             "payload": payload,
 192:             "reason": reason,
 193:             "timestamp": datetime.now().isoformat(),
 194:         })
 195: 
 196: 
 197: def stat_slow_event(event_index, attempt, node, latency_ms, leader=None, payload=None):
 198:     with stats_lock:
 199:         stats["events_slow"] += 1
 200:         stats["slow_events"].append({
 201:             "event_index": event_index,
 202:             "attempt": attempt,
 203:             "node": node,
 204:             "latency_ms": round(latency_ms, 3),
 205:             "leader": leader,
 206:             "payload": payload,
 207:             "timestamp": datetime.now().isoformat(),
 208:         })
 209: 
 210: 
 211: def stat_kill_event(node, action, ok, payload=None, error=None, seconds=None):
 212:     with stats_lock:
 213:         stats["kill_events"].append({
 214:             "action": action,
 215:             "node": node,
 216:             "ok": ok,
 217:             "seconds": seconds,
 218:             "payload": payload,
 219:             "error": error,
 220:             "timestamp": datetime.now().isoformat(),
 221:         })
 222: 
 223: 
 224: def percentile(data, p):
 225:     if not data:
 226:         return 0.0
 227:     values = sorted(data)
 228:     if len(values) == 1:
 229:         return float(values[0])
 230:     rank = (len(values) - 1) * (p / 100.0)
 231:     low = int(rank)
 232:     high = min(low + 1, len(values) - 1)
 233:     fraction = rank - low
 234:     return float(values[low] + (values[high] - values[low]) * fraction)
 235: 
 236: 
 237: def is_event_submit_ok(status_code, payload):
 238:     if status_code != 200:
 239:         return False
 240: 
 241:     if not isinstance(payload, dict):
 242:         return False
 243: 
 244:     if payload.get("ok") is True:
 245:         return True
 246: 
 247:     result = payload.get("result")
 248:     if isinstance(result, dict) and result.get("ok") is True:
 249:         return True
 250: 
 251:     return False
 252: 
 253: 
 254: def is_retryable_response(payload):
 255:     if not isinstance(payload, dict):
 256:         return False
 257: 
 258:     if payload.get("error") in {"no leader", "node isolated"}:
 259:         return True
 260: 
 261:     error = str(payload.get("error", "")).lower()
 262: 
 263:     retry_patterns = [
 264:         "timeout",
 265:         "connection",
 266:         "refused",
 267:         "temporarily unavailable",
 268:         "isolated",
 269:     ]
 270: 
 271:     return any(p in error for p in retry_patterns)
 272: 
 273: 
