 152: def render_top_summary_1(api_snapshots, groups):
 153:     source_order = ["lnx200nas", "lnx202pc", "lnx203hp"]
 154:     lines = []
 155: 
 156:     NODE_W = 12
 157:     HEALTH_W = 8
 158:     STATE_W = 10
 159:     LEADER_W = 12
 160:     SIZE_W = 10
 161:     EVENTS_W = 12
 162:     COUNT_W = 9
 163:     DIRTY_W = 7
 164: 
 165:     def cut(value, width):
 166:         s = "-" if value is None else str(value)
 167:         return s if len(s) <= width else s[: max(0, width - 1)] + "…"
 168: 
 169:     lines.append("### resumen cluster")
 170:     lines.append("")
 171:     lines.append(
 172:         "- leader esperado: "
 173:         + ", ".join(
 174:             f"{node}: {api_snapshots.get(node, {}).get('leader', {}).get('leader', '?')}"
 175:             for node in source_order
 176:         )
 177:     )
 178:     lines.append("")
 179:     lines.append(
 180:         f"- {'nodo':<{NODE_W}}  {'health':<{HEALTH_W}}  {'state':<{STATE_W}}  "
 181:         f"{'leader':<{LEADER_W}}  {'local_size':>{SIZE_W}}  {'local_events':>{EVENTS_W}}  "
 182:         f"{'created':>{COUNT_W}}  {'executing':>{COUNT_W}}  {'completed':>{COUNT_W}}  "
 183:         f"{'dirty':<{DIRTY_W}}"
 184:     )
 185: 
 186:     for node_name in source_order:
 187:         snap = api_snapshots.get(node_name, {})
 188:         health = snap.get("health", {})
 189:         leader = snap.get("leader", {}).get("leader", "?")
 190:         integrity = snap.get("integrity", {})
 191:         self_view = integrity.get("self_view", {}) if isinstance(integrity, dict) else {}
 192:         local_meta = integrity.get("local_log_meta", {}) if isinstance(integrity, dict) else {}
 193:         last_append = integrity.get("last_append_meta", {}) if isinstance(integrity, dict) else {}
 194:         local_summary = snap.get("events_summary_local", {}) if isinstance(snap, dict) else {}
 195:         counts = local_summary.get("counts", {}) if isinstance(local_summary, dict) else {}
 196: 
 197:         lines.append(
 198:             f"- {node_name:<{NODE_W}}  "
 199:             f"{cut(health.get('status', '?'), HEALTH_W):<{HEALTH_W}}  "
 200:             f"{cut(self_view.get('state', '?'), STATE_W):<{STATE_W}}  "
 201:             f"{cut(leader, LEADER_W):<{LEADER_W}}  "
 202:             f"{local_meta.get('size', 0):>{SIZE_W}}  "
 203:             f"{local_summary.get('total_events', 0):>{EVENTS_W}}  "
 204:             f"{counts.get('created', 0):>{COUNT_W}}  "
 205:             f"{counts.get('executing', 0):>{COUNT_W}}  "
 206:             f"{counts.get('completed', 0):>{COUNT_W}}  "
 207:             f"{str(last_append.get('dirty', '?')):<{DIRTY_W}}"
 208:         )
 209: 
 210:     lines.append("")
 211:     return lines
 212: 
 213: def render_top_summary_2(api_snapshots, groups):
 214:     source_order = ["lnx200nas", "lnx202pc", "lnx203hp"]
 215:     lines = []
 216: 
