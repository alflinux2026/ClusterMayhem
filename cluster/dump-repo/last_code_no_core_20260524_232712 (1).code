  10: class EventStatus(str, Enum):
  11:     CREATED = "created"
  12:     EXECUTING = "executing"
  13:     COMPLETED = "completed"
  14:     FAILED = "failed"
  15: 
  16: 
  17: class NodeState(str, Enum):
  18:     BOOT = "BOOT"
  19:     DISCOVERING = "DISCOVERING"
  20:     STANDBY = "STAND-BY"
  21:     ACTIVE = "ACTIVE"
  22:     DEGRADED = "DEGRADED"
  23:     ISOLATED = "ISOLATED"
  24:     OFFLINE = "OFFLINE"
