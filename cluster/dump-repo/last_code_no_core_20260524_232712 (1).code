 174: def build_event(i):
 175:     event = ClusterEvent(
 176:         event_type="chaos.test",
 177:         payload={
 178:             "msg": f"msg-203: {i}",
 179:             "seq": i,
 180:             "source": "chaos_v4",
 181:             "run_id": RUN_ID,
 182:             "stream_id": STREAM_KEY.stream_id(),
 183:         },
 184:     )
 185:     return event.model_dump()
