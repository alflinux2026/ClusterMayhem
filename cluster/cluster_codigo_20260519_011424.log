        print()
        print("UNEXPECTED FAILURES")
        if stats["unexpected_failures"]:
            for idx, item in enumerate(stats["unexpected_failures"], start=1):
                print(
                    f"  #{idx:02} "
                    f"event={item.get('event_index')} "
                    f"attempt={item.get('attempt')} "
